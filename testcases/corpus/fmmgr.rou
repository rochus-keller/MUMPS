	S %A=$S(IOT'="TRM":IOPAR,IOST?1"C".E:"("_IOM_":""C"")",IOST?1"PK".E:"("_IOM_":""P"")",1:IOM),%A=""""_IO_""""_$E(":",%A]"")_%A C:IOT="MT" IO O @%A I $D(^%ZIS(2,IOST(0),2))=1 S %Y=^(2) D 2
	I $D(^%ZIS(2,IOST(0),102)) S %Y=^(102) D 2 E  G IOPC:$D(IOP) W *7,"NOT ON LINE" G IC
	I IOT="MT",'$D(IOP) R "  REWIND? NO// ",%X:$S($D(DTIME):DTIME,1:60) S:'$T %X=U Q:%X=U  I %X?1"Y".E!(%X?1"y".E) U IO W *5 U IO(0)
R	W:'$D(IOP) ! G KIL:IO=IO(0) S ^DISV(IO(0),"^%ZIS(1,")=%E G KIL:'%B!(IOST'["K"&(IOST["SINGLE")),F^%ZIS2
	;
IOPC	C:%B IO
N	S %X=IO(0) K IO S IO(0)=%X,POP=1,IOF="#",(IO,IOT,IOM,ION,IOST,IOSL,IOBS,IOPAR)=""
KIL	K %ZIS,%IS,%A,%B,%H,%E,%X,%Y,%Z,%Z9,IOP Q
	;
2	Q:%Y=""  I %IS'[0 O IO(0)::0
	S %X=$T U IO X %Y Q:'%X  U IO(0) Q
	;
ST	S IOST(0)=%A,IOST=$S($D(^%ZIS(2,%A,0)):$P(^(0),"^",1),1:"") Q
	;
STP	I '$D(^(1)) S IOF="#",IOSL=66,IOBS="*8",IOM=132 Q
	S %A=^(1),IOM=+%A,IOF=$P(%A,"^",2),IOSL=$P(%A,"^",3),IOBS=$P(%A,"^",4)
	Q
SUB	I $D(^%ZIS(2,"B",%A))>9 S %A=+$O(^%ZIS(2,"B",%A,0)) Q
	S %XX=%A D 2^%ZIS4 S %A=+%YY Q
	Q

ZIS1VXD
%ZIS1	;MVB ; 16 Dec 87  3:32 PM ;DEVICE SELECTOR FOR VAX-DSM V3;6/22/88  6:27 PM
	;;5.976;
	I '$D(^%ZIS(1,%A,0)) K IOS S:$D(IOP)&(%IS["T") IO="" G N^%ZIS2:$D(IOP),A^%ZIS
	I $D(IO("Q")),IO("Q")=1,$F("_VT^_LT^_RT^_NV",$E($P(^%ZIS(1,%A,0),"^",2),1,3))>1,$D(^("TYPE")),^("TYPE")="VTRM" W:'$D(IOP) *7,"  YOU CAN NOT QUEUE TO A VIRTUAL TERMINAL!" G N^%ZIS2:$D(IOP),A^%ZIS
	I '$D(IOVTH),$D(IOVTS) W:'$D(IOP) *7,"YOU CAN NOT DIRECT OUTPUT TO A VIRTUAL TERMINAL!" G N^%ZIS2:$D(IOP),A^%ZIS
	I $D(IOVTS),IO(0)'=%X W:'$D(IOP) *7,"YOU CAN NOT SELECT A VIRTUAL TERMINAL!" G N^%ZIS2:$D(IOP),A^%ZIS
	I $D(^("TYPE")),^("TYPE")="VTRM" S IOVTS=1
	I $D(IOVTH),$D(IOVTS),IO(0)'[$P(^(0),"^",2) W:$D(IOP) *7,"YOU CAN NOT SELECT ANOTHER VIRTUAL TERMINAL!" G N^%ZIS2:$D(IOP),A^%ZIS
	S %E=%A I '$D(IOP),$P(^(0),"^",2)'=$I,$D(^(1)) W "  ",$P(^(1),"^",1)
1	K IOCPU S %Z=^%ZIS(1,%E,0),IO=$S('$D(IOVTS):$P(%Z,"^",2),1:$I),IOS=%E S:IO=0 IO=$I,IO("S")=%H
	S ION=$P(%Z,"^",1),IOT=$S($D(^("TYPE")):^("TYPE"),1:""),IOPAR=$S($D(^("IOPAR")):^("IOPAR"),1:""),IOUPAR=$S($D(^("IOUPAR")):^("IOUPAR"),1:""),%A=$S($D(^("SUBTYPE")):^("SUBTYPE"),1:0),IOHG=$P(%Z,"^",10)
	S IOTO=$S($D(^("TIME")):$S($P(^("TIME"),"^",2)]"":+$P(^("TIME"),"^",2),1:1),1:1) I $D(%IS("T")) S IOTO=$S(%IS("T")<11:+%IS("T"),1:10)
	I $D(IO("S")) S IO=$S(%IS["S":$P($S($D(^%ZIS(1,+$P(%Z,"^",8),0)):^(0),1:""),"^",2),1:IO) I %IS["S",IO]"" S %H=+$P(%Z,"^",8),IO("S")=%H,IO(0)=IO
	I %E=%H,IOT["TRM",$D(^XUTL("XQ",$J,"IOST(0)")) S %A=+^("IOST(0)")
	I '$T,$D(^%ZIS(1,%E,91)) S %Z9=^(91),IOM=+%Z9,IOF=$P(%Z9,"^",2),IOSL=$P(%Z9,"^",3),IOBS=$P(%Z9,"^",4) I IOM]"",IOSL,IOF]"",IOBS]""
	D ST^%ZIS2,STP^%ZIS2:'$T S:%IS["U" USIO=IOM_"^"_IOF_"^"_IOSL_"^"_IOBS
	G TRY:$S(%ZISV]"":$S(%ZISV=$P(%Z,"^",9):1,$P(%Z,"^",9)="":1,1:0),1:1) S %A=$P(%Z,"^",9) S IOCPU=%A I %IS'["Q" G OPEN:%ZISB&(IOT="TRM"&($P(%Z,"^",10)]"")),N^%ZIS2:$D(IOP) W *7,"  DEVICE IS ON ANOTHER CPU ('",%A,"')",! G I
	S IO("Q")=1,%ZISB=0
TRY	I $D(^%ZIS(1,%E,90)),$D(DT)#2,^(90),^(90)'>DT G:$D(IOP) N^%ZIS2:%ZISB,OPEN W *7,"  OUT OF SERVICE" G I:%ZISB R " ..OK? NO// ",%X:5 G I:%X'?1"Y".E
OPEN	G L^%ZIS2:IOT="SPL"!(IOT="SDP")!'%ZISB I '$D(IOCPU) O IO::IOTO
	G L^%ZIS2:$T D:($S(IOHG]"":$S($D(^%ZIS(1,"AH",IOHG,%E))#2:1,1:0),1:0)) HUNT G N^%ZIS2:'$D(ZISHP)&($D(IOP))
	D:'$T&($S(IOHG]"":$S($D(^%ZIS(1,"AH",IOHG,%E))#2:1,1:0),1:0)) HUNT
	I $D(ZISHP),'$D(ZISHIO) W:'$D(IOP) *7," All devices in hunt group "_IOHG_" are busy!" K ZISHP G N^%ZIS2:$D(IOP),A^%ZIS
	I $D(ZISHP),$D(ZISHIO) W:'$D(IOP)&(ZISHP'=%E) !,*7," Routing to device "_$P(^%ZIS(1,ZISHP,0),"^",1)_$S($D(^(1)):" "_$P(^(1),"^",1)_" ",1:"") S %E=ZISHP K ZISHP,ZISHIO G 1
	W:'$T *7,"  [BUSY]" W "  ...  WAIT? " R %X:5 G OPEN:%X?1"Y".E
I	G A^%ZIS
HUNT	;
	S ZISHP=%E F ZISHGL=0:0 S ZISHP=+$O(^%ZIS(1,"AH",IOHG,ZISHP)) I ZISHP>0 Q:ZISHP=%E  I $D(^%ZIS(1,+ZISHP,0))#2,$P(^(0),"^",9)=%ZISV!($P(^(0),"^",9)="") S ZISHIO=$P(^(0),"^",2) O ZISHIO:"":1 Q:$T
	K ZISHGL Q:ZISHP'=%E  K ZISHIO I '$D(IOCPU) O IO::0 S:$T ZISHIO=IO Q
	Q
	;
VIRTUAL	;VIRTUAL TERMINAL
	F ZISI=0:0 Q:ZISVT=""  D VTLKUP Q:%E>0  S ZISVT=$E(ZISVT,1,($L(ZISVT)-1))
	K %ZISX Q
VTLKUP	;
	F %ZISX=%ZISV,"" S %E=$S(%ZISV]"":$S($O(^%ZIS(1,"G","SYS."_%ZISX_"."_ZISVT,0))>0:+$O(^(0)),1:+$O(^%ZIS(1,"CPU",%ZISX_"."_ZISVT,0))),1:"") Q:%E
	Q

ZIS2
%ZIS2	;SFISC/AC,RWF -- DEVICE HANDLER (CHECKS) ;5/23/89  15:20 ;3/30/89  10:02 AM
	;;6.0;
LOOP	;
	I $D(DTOUT)!$D(DUOUT) K %ZISHP,%ZISHPOP Q
	S POP=0 D CHECK I POP,%ZISHG]"",%IS'["D",'$D(%ZISHPOP) D HUNT G LOOP
	I POP D HGBSY:$D(%ZISHPOP),TMPVAR^%ZIS6:%IS["T" S:%IS'["T" IO="" Q
	D TMPVAR^%ZIS6
	D TRM^%ZIS3:%ZTYPE["TRM",SPL^%ZIS3:%ZTYPE="SPL",MT^%ZIS3:%ZTYPE="MT",SDP^%ZIS3:%ZTYPE="SDP",HFS^%ZIS3:%ZTYPE="HFS",OTH^%ZIS3:%ZTYPE="OTH"!(%ZTYPE="BAR")
	I $D(%ZISHPOP),'$D(IO(1,IO)) D HGBSY Q
	I POP S:%IS'["T" IO="" I %ZISHG]"",%IS'["D",'$D(%ZISHPOP) D HUNT G LOOP
	Q
HGBSY	;
	S:%IS'["T" IO="" K %ZISHP,%ZISHPOP Q:$D(IOP)
	W:$X>38 !,?5 W *7," All devices in hunt group "_%ZISHG_" are busy!" Q
CHECK	;
	K %ZISCPU S %Z=^%ZIS(1,%E,0),IO=$P(%Z,"^",2),%ZISHG=$P(%Z,"^",10)
	S %Z90=$S($D(^(90)):^(90),1:""),%Z95=$S($D(^(95)):^(95),1:""),%ZTIME=$S($D(^("TIME")):^("TIME"),1:""),%ZTYPE=$S($D(^("TYPE")):^("TYPE"),1:"")
VTRM	;Virtual Terminal Check
	I %ZTYPE="VTRM",'('$D(IO("Q"))&(%A=%H)) W:'$D(IOP)&'$D(%ZISHP) *7,"  [YOU CAN NOT SELECT A VIRTUAL TERMINAL]" S POP=1 Q
	S:%ZTYPE="VTRM"&'$D(IO("Q"))&(%A=%H) IO=$I
OCPU	;Other Cpu Check
	I $P(%Z,"^",9)=%ZISV!($P(%Z,"^",9)="") G OOS
	S %ZISCPU=$P(%Z,"^",9)
	I %IS["Q" S IO("Q")=1,%ZISB=0
	E  I %ZISB&(%ZTYPE="TRM"&($P(%Z,"^",10)]""&(%IS'["D"))) S POP=1
	E  S POP=1 I '$D(IOP) W *7,"  [DEVICE IS ON ANOTHER CPU ('",%ZISCPU,"')]",!
	Q:POP
OOS	;Out Of Service Check
	I %Z90,$D(DT)#2,%Z90'>DT S:%ZISB POP=1
	I $T,'$D(IOP),'$D(%ZISHP) W *7,"  [OUT OF SERVICE]" I 'POP W " ..OK" N DTIME S %=2,U="^",DTIME=5 D YN^%ZIS1 G:%=0 OOS S:%'=1 POP=1
	Q:POP!(IO=$I)!(IO=0)
	;
PTIME	;Prohibitted Time Check
	I %ZISB,%ZTIME]"" S %A=$P(%ZTIME,"^",1),%X=$P($H,",",2),%=%X\60#60+(%X\3600*100),%X=$P(%A,"-",2) I %X'<%A&(%'>%X&(%'<%A))!(%X<%A&(%'<%A!(%'>%X))) S POP=1 I '$D(IOP),'$D(%ZISHP) W *7,"  [ACCESS PROHIBITED AT THIS TIME]"
	Q:POP
DUZ	;Security Check
	I %Z95]"" S %X=$S($D(DUZ(0)):DUZ(0),1:"") I %X'="@" S POP=1 F %A=1:1:$L(%X) S:%Z95[$E(%X,%A) POP=0 Q:'POP
	I POP,'$D(IOP),'$D(%ZISHP) W *7,"  [ACCESS PROHIBITED]"
	Q
HUNT	;
	I '$D(%ZISHP) S %ZISHP=%E,%E=0
	F %ZISHGL=0:0 S %E=+$O(^%ZIS(1,"AH",%ZISHG,%E)) Q:%E'>0  I $D(^%ZIS(1,%E,0))#2,$P(^(0),"^",9)=%ZISV!($P(^(0),"^",9)="") Q
	I %E'>0 S %ZISHPOP=1,%E=%ZISHP Q
	Q
	;

ZIS2DSM
%ZIS2	;GFT/SF ; 1AUG1986 2:11 PM;
	;;5.01
	W:$D(^%ZOSF("VOL")) !?4,"Volume set: ",^%ZOSF("VOL")
	W !?4,"ENTER '0' " I $S($D(%IS("B")):%IS("B")="",1:1) W "OR NOTHING "
	W "TO GET OUTPUT ON THIS DEVICE," E  W !?4,"ENTER NOTHING TO GET OUTPUT ON ",%A,","
	W:$D(^%ZIS(1,%E,99)) !?4,"ENTER 'P' FOR OUTPUT TO THE PRINTER,"
	I %IS["Q",$D(^%ZTSCH("RUN")) W !?4,"ENTER 'Q' TO QUEUE OUTPUT TO RUN LATER,"
	W !?4,"OR JUST ENTER A DEVICE NUMBER (1, 47, 64, 65, ETC.)",!,"WANT A LIST OF DEVICES? (YES/NO/PRINTERS) NO// " D SBR^%ZIS
	W ! S %X=$F("PpYy",%X)\2 G N^%ZIS1:$D(DTOUT)!$D(DFOUT),RD^%ZIS:'%X S %E=0,%Y=0
L	S %E=$N(^%ZIS(1,"B",%E)),%A=$N(^(%E,0)) G ^%ZIS:'$D(^%ZIS(1,%A,0)),L:$P(^(0),"^",2)=46,L:$P(^(0),"^",2)=63
	I %X=1 G L:'$D(^("SUBTYPE")),L:'$D(^%ZIS(2,+^("SUBTYPE"),0)),L:^(0)'?1"P".E
	W $J($P(^%ZIS(1,%A,0),"^",1),9) W:$D(^(1)) " ",$P(^(1),"^",1) I $D(^(90)),^(90) W " ** OUT OF SERVICE"
	W ?39 I $X>40 W ! S %Y=%Y+1 I %Y>20 R "'^' TO STOP: ",%Y:$S($D(DTIME):DTIME,1:60),! G ^%ZIS:%Y?1P S %Y=0
	G L
	;
SPOOL	N DIC,X,Y
R	S DIC=3.51,U="^",DIC("DR")="" I $D(IOP) S X=$P(%Y,";",1),DIC(0)="XMLZ"
	E  S DIC(0)="AEQMZL"
	S Y=-1 D DIC:$D(DUZ)=11 G ^%ZIS:Y<0
	S %A=$P($H,",",2),%A=$S($D(DT)#2:DT_(%A#3600\60/100+(%A\3600)/100),1:"") I '$P(Y,"^",3) S %X=$P(Y(0),"^",2) I %X O 2:%X+512 S:%A&'$D(IOP) $P(^(0),"^",4)=%A G DOC
	F %X=1:1 I '$D(^ZISPLDSM("C",%X))!$D(^(%X,+Y)) Q:%X<256  W:'$D(IOP) *7,"  DELETE SOME OTHER DOCUMENT!" G ^%ZIS
	S ^(+Y)="" O 2:%X
	S ^ZISPLDSM(+Y,0)=$P(Y(0),"^",1)_U_%X_U_DUZ(0)_U_%A_U_DUZ
DOC	S IO("DOC")=$P(Y(0),"^",1)
K	K %ZIS,%IS,%A,%B,%E,%X,%Y Q
	;
DIC	N (Y,DIC,X,DUZ,DT) S:DUZ(0)'="@" DIC("S")="I 1 F %=1:1:$L($P(^(0),""^"",3)) I DUZ(0)[$E($P(^(0),""^"",3),%) Q" S DLAYGO=3 D ^DIC K DIC Q
	;
F	S %A="Y" R:'$D(IOP) "DO YOU WANT TO FREE UP THIS TERMINAL? NO// ",%A:$S($D(DTIME):DTIME,1:60) S:%A?1"y".E!(%A?1"Y".E) IO("C")=1 K:$D(DUZ)#2 ^XMB(3.7,DUZ,100,IO(0))
	G K

ZIS2DTM
ZIS2DTM	;HGL,GFT/SF,HGL::B-FmSys.Rsave;11:31 AM  Oct 8, 1987;02:15 PM  Apr 1, 1986;DATATREE ; 05 Nov 87  1:49 PM
	;;5.976;
	W !?4,"ENTER '0' " I $S($D(%IS("B")):%IS("B")="",1:1) W "OR NOTHING "
	W "TO GET OUTPUT ON THIS DEVICE," E  W !?4,"ENTER NOTHING TO GET OUTPUT ON ",%A,","
	W:$D(^%ZIS(1,%E,99)) !?4,"ENTER 'P' FOR OUTPUT TO THE PRINTER,"
	I %IS["Q",$D(^%ZTSCH("RUN")) W !?4,"ENTER 'Q' TO QUEUE OUTPUT TO RUN LATER,"
	W !?4,"OR JUST ENTER A DEVICE NUMBER (1, 47, 64, 65, ETC.)",!,"WANT A LIST OF DEVICES? (YES/NO/PRINTERS) NO// " D SBR^%ZIS
	W ! S %X=$F("PpYy",%X)\2 G N^%ZIS1:$D(DTOUT)!$D(DFOUT),RD^%ZIS:'%X S %E=0,%Y=0
L	S %E=$N(^%ZIS(1,"B",%E)),%A=$N(^(%E,0)) G ^%ZIS:'$D(^%ZIS(1,%A,0)),L:$P(^(0),"^",2)=46,L:$P(^(0),"^",2)=63
	I %X=1 G L:'$D(^("SUBTYPE")),L:'$D(^%ZIS(2,+^("SUBTYPE"),0)),L:^(0)'?1"P".E
	W $J($P(^%ZIS(1,%A,0),"^",1),9) W:$D(^(1)) " ",^(1) I $D(^(90)),^(90) W " ** OUT OF SERVICE"
	W:$X<30 ?30 I $X>30 W ! S %Y=%Y+1 I %Y>20 R "'^' TO STOP: ",%Y,! G ^%ZIS:%Y?1P S %Y=0
	G L
	;
DOSFILE	;ENTRY POINT FOR HANDLING "F" TYPE DEVICE
	S IO="",ION="F",IOT="SDP",%Y=$$gfile() I %Y=-1 G K
	S IO=+%Y,(IOPAR,IO("DOC"))=$P(%Y,$C(22),2) I $D(IO("Q")) C IO
	S IOM=$P(%Y,$C(22),3),IOSL=$P(%Y,$C(22),4),IOST="P-DEC"
K	K %ZIS,%IS,%A,%B,%E,%X,%Y Q
	;
	;
F	S %A="Y" R:'$D(IOP) "DO YOU WANT TO FREE UP THIS TERMINAL? NO// ",%A S:%A?1"y".E!(%A?1"Y".E) IO("C")=1
	G K
	;
	;
gfile	;
	s file="",mode="w",dm=$c(22) d file i $d(err) q -1
	q io_$c(22)_file_$c(22)_rmar_$c(22)_plen
	;
file	k err,io
	w:$zx ! w "File name: "
	s xi=$$^%mxread(file,1) i xi s err="No file" q
	s file=$p(xi,dm,2) i file="" s err="No file" q
	d iofree i $d(err) d ^%errwindow(err) q
	d fopen
	i mode="" d amode
	i mode="" s err="No file access specified" q
	i $$open^%mf(io,mode,file,0) d rmar q
	d ^%errwindow("Can't access file") g file
	;
rmar	r !,"Right margin: 80//",rmar i rmar="" s rmar=80
	i rmar'?1n.n w " ?? must be numeric" g rmar
plen	r !,"Page length: 66//",plen i plen="" s plen=66
	i plen'?1n.n w " ?? must be numeric" g plen
	q
	;
fopen	s fstatus=0 zerr foperr o io:("r":file) c io s fstatus=1 q
foperr	q
	;
amode	i 'fstatus s mode="W" q
	w !,"File exists - Select access mode: "
	s mode=$p($$^%moption("W:Write,A:Append","C"),dm,2)
	q
	;
cancel	s cancel=$$^%yesnowindow("","Cancel output request","no")="Y"
	i cancel zerr
	s restart=$$^%yesnowindow("","Restart device selection","no")="Y"
	i restart zerr
	k cancel,restart
	q
	;
errtrap	i $d(cancel),cancel s err=1 d errclose q
	i $d(restart),restart k cancel,restart d errclose q
	zerr
	;
errclose	;
	i $d(io),io>0,io'=$i c io
	q
	;
iofree	s io=$$freedev i io=-1 s err="No free I/O channel"
	q
	;
freedev	;
	f p=$v(4,38,-3):0  s l=$v(0,p,-2) q:'l  q:'$v(0,p+4,-2)&($v(0,p+6,-1)=6)  s p=p+l
	i l q $v(0,p+2,-2)
	q -1

ZIS2M11
%ZIS2	;GFT/SF  ; 1AUG1986 2:12 PM;
	;;5.01
	W:$D(^%ZOSF("VOL")) !?4,"Volume set: ",^%ZOSF("VOL")
	W !?4,"ENTER '0' " I $S($D(%IS("B")):%IS("B")="",1:1) W "OR NOTHING "
	W "TO GET OUTPUT ON THIS DEVICE," E  W !?4,"ENTER NOTHING TO GET OUTPUT ON ",%A,","
	W:$D(^%ZIS(1,%E,99)) !?4,"ENTER 'P' FOR OUTPUT TO THE PRINTER,"
	I %IS["Q",$D(^%ZTSCH("RUN")) W !?4,"ENTER 'Q' TO QUEUE OUTPUT TO RUN LATER,"
	W !?4,"OR JUST ENTER A DEVICE NUMBER (1, 47, 64, 65, ETC.)",!,"WANT A LIST OF DEVICES? (YES/NO/PRINTERS) NO// " D SBR^%ZIS
	W ! S %X=$F("PpYy",%X)\2 G N^%ZIS1:$D(DTOUT)!$D(DFOUT),RD^%ZIS:'%X S %E=0,%Y=0
L	S %E=$N(^%ZIS(1,"B",%E)),%A=$N(^(%E,0)) G ^%ZIS:'$D(^%ZIS(1,%A,0)),L:$P(^(0),"^",2)=46,L:$P(^(0),"^",2)=63
	I %X=1 G L:'$D(^("SUBTYPE")),L:'$D(^%ZIS(2,+^("SUBTYPE"),0)),L:^(0)'?1"P".E
	W $J($P(^%ZIS(1,%A,0),"^",1),9) W:$D(^(1)) " ",$P(^(1),"^",1) I $D(^(90)),^(90) W " ** OUT OF SERVICE"
	W ?39 I $X>40 W ! S %Y=%Y+1 I %Y>20 R "'^' TO STOP: ",%Y:$S($D(DTIME):DTIME,1:60),! G ^%ZIS:%Y?1P S %Y=0
	G L
	;
HANG	H 60
SPOOL	I IOPAR?1"(".E1")" S IOPAR=$E(IOPAR,2,$L(IOPAR)-1)
	I $D(IOP) S %E=$P(%Y,";",1) I %E?1ANP.ANP S %A=$N(^SPOOL(0,%E,0)) I %A>0 G HANG:'$D(^SPOOL(%A,16777215)) O IO:(%A:$P(^(16777215),"{",3)+1) K ^(16777215) S IODOC=%E G G
	I $P(IOPAR,":",1)]"" S IODOC=$P(IOPAR,":",1)
	I $P(IOPAR,":",2)]"" S IOPGM=$P(IOPAR,":",2)
	I '$D(IODES) S IODES=""
	C 2 D ^%ISSPL I POP S POP=0 G ^%ZIS
G	S IO("DOC")=IODOC K IODOC,IODES,IOPGM,IOSPL G F:%IS["F"
K	K %ZIS,%IS,%A,%B,%E,%X,%Y Q
	;
P	;
	W "  ADDRESS/PARAMETERS: " W:IOPAR]"" IOPAR,"// " D SBR^%ZIS G N^%ZIS1:$D(DTOUT)!$D(DFOUT) S:%X]"" IOPAR=%X S:$P(IOPAR,"(",1)]"" IOPAR="("_IOPAR_")" G O^%ZIS1
	;
F	S %A="Y" R:'$D(IOP) "DO YOU WANT TO FREE UP THIS TERMINAL? NO// ",%A:$S($D(DTIME):DTIME,1:60) S:%A?1"y".E!(%A?1"Y".E) IO("C")=1 K:$D(DUZ)#2 ^XMB(3.7,DUZ,100,IO(0)) G K

ZIS2M11P
%ZIS2	;GFT/SF  ; 1AUG1986 2:13 PM; FOR M/11+!!
	;;5.01
	W:$D(^%ZOSF("VOL")) !?4,"Volume set: ",^%ZOSF("VOL")
	W !?4,"ENTER '0' " I $S($D(%IS("B")):%IS("B")="",1:1) W "OR NOTHING "
	W "TO GET OUTPUT ON THIS DEVICE," E  W !?4,"ENTER NOTHING TO GET OUTPUT ON ",%A,","
	W:$D(^%ZIS(1,%E,99)) !?4,"ENTER 'P' FOR OUTPUT TO THE PRINTER,"
	I %IS["Q",$D(^%ZTSCH("RUN")) W !?4,"ENTER 'Q' TO QUEUE OUTPUT TO RUN LATER,"
	W !?4,"OR JUST ENTER A DEVICE NUMBER (1, 47, 64, 65, ETC.)",!,"WANT A LIST OF DEVICES? (YES/NO/PRINTERS) NO// " D SBR^%ZIS
	W ! S %X=$F("PpYy",%X)\2 G N^%ZIS1:$D(DTOUT)!$D(DFOUT),RD^%ZIS:'%X S %E=0,%Y=0
L	S %E=$N(^%ZIS(1,"B",%E)),%A=$N(^(%E,0)) G ^%ZIS:'$D(^%ZIS(1,%A,0)),L:$P(^(0),"^",2)=46,L:$P(^(0),"^",2)=63
	I %X=1 G L:'$D(^("SUBTYPE")),L:'$D(^%ZIS(2,+^("SUBTYPE"),0)),L:^(0)'?1"P".E
	W $J($P(^%ZIS(1,%A,0),"^",1),9) W:$D(^(1)) " ",$P(^(1),"^",1) I $D(^(90)),^(90) W " ** OUT OF SERVICE"
	W ?39 I $X>40 W ! S %Y=%Y+1 I %Y>20 R "'^' TO STOP: ",%Y:$S($D(DTIME):DTIME,1:60),! G ^%ZIS:%Y?1P S %Y=0
	G L
	;
HANG	H 60
SPOOL	I IOPAR?1"(".E1")" S IOPAR=$E(IOPAR,2,$L(IOPAR)-1)
	I $D(IOP) S %E=$P(%Y,";",1) I %E?1ANP.ANP S %A=$N(^SPOOL(0,%E,0)) I %A>0 G HANG:'$D(^SPOOL(%A,2147483647)) O IO:(%A:$P(^(2147483647),"{",3)+1) K ^(2147483647) S IODOC=%E G G
	I $P(IOPAR,":",1)]"" S IODOC=$P(IOPAR,":",1)
	I $P(IOPAR,":",2)]"" S IOPGM=$P(IOPAR,":",2)
	I '$D(IODES) S IODES=""
	C 2 D ^%ISSPL I POP S POP=0 G ^%ZIS
G	S IO("DOC")=IODOC K IODOC,IODES,IOPGM,IOSPL G F:%IS["F"
K	K %ZIS,%IS,%A,%B,%E,%X,%Y Q
	;
P	;
	W "  ADDRESS/PARAMETERS: " W:IOPAR]"" IOPAR,"// " D SBR^%ZIS G N^%ZIS1:$D(DTOUT)!$D(DFOUT) S:%X]"" IOPAR=%X S:$P(IOPAR,"(",1)]"" IOPAR="("_IOPAR_")" G O^%ZIS1
	;
F	S %A="Y" R:'$D(IOP) "DO YOU WANT TO FREE UP THIS TERMINAL? NO// ",%A:$S($D(DTIME):DTIME,1:60) S:%A?1"y".E!(%A?1"Y".E) IO("C")=1 K:$D(DUZ)#2 ^XMB(3.7,DUZ,100,IO(0)) G K

ZIS2MVX
%ZIS2	;GFT/SF  ; 85/12/18  3:21 PM ;
	;;5.01
	W:$D(^%ZOSF("VOL")) !?4,"Volume set: ",^%ZOSF("VOL")
	W !?4,"ENTER '0' " I $S($D(%IS("B")):%IS("B")="",1:1) W "OR NOTHING "
	W "TO GET OUTPUT ON THIS DEVICE," E  W !?4,"ENTER NOTHING TO GET OUTPUT ON ",%A,","
	W:$D(^%ZIS(1,%E,99)) !?4,"ENTER 'P' FOR OUTPUT TO THE PRINTER,"
	I %IS["Q",$D(^%ZTSCH("RUN")) W !?4,"ENTER 'Q' TO QUEUE OUTPUT TO RUN LATER,"
	W !?4,"OR JUST ENTER A DEVICE NUMBER (1, 47, 64, 65, ETC.)",!,"WANT A LIST OF DEVICES? (YES/NO/PRINTERS) NO// " D SBR^%ZIS
	W ! S %X=$F("PpYy",%X)\2 G N^%ZIS1:$D(DTOUT)!$D(DFOUT),RD^%ZIS:'%X S %E=0,%Y=0
L	S %E=$N(^%ZIS(1,"B",%E)),%A=$N(^(%E,0)) G ^%ZIS:'$D(^%ZIS(1,%A,0)),L:$P(^(0),"^",2)=46,L:$P(^(0),"^",2)=63
	I %X=1 G L:'$D(^("SUBTYPE")),L:'$D(^%ZIS(2,+^("SUBTYPE"),0)),L:^(0)'?1"P".E
	W $J($P(^%ZIS(1,%A,0),"^",1),9) W:$D(^(1)) " ",$P(^(1),"^",1) I $D(^(90)),^(90) W " ** OUT OF SERVICE"
	W ?39 I $X>40 W ! S %Y=%Y+1 I %Y>20 R "'^' TO STOP: ",%Y:$S($D(DTIME):DTIME,1:60),! G ^%ZIS:%Y?1P S %Y=0
	G L
	;
HANG	H 60
SPOOL	I IOPAR?1"(".E1")" S IOPAR=$E(IOPAR,2,$L(IOPAR)-1)
	I $D(IOP) S %E=$P(%Y,";",1) I %E?1ANP.ANP S %A=$N(^SPOOL(0,%E,0)) I %A>0 G HANG:'$D(^SPOOL(%A,2147483647)) O IO:(%A:$P(^(2147483647),"{",3)+1) K ^(2147483647) S IODOC=%E G G
	I $P(IOPAR,":",1)]"" S IODOC=$P(IOPAR,":",1)
	I $P(IOPAR,":",2)]"" S IOPGM=$P(IOPAR,":",2)
	I '$D(IODES) S IODES=""
	C 2 D ^%ISSPL I POP S POP=0 G ^%ZIS
G	S IO("DOC")=IODOC K IODOC,IODES,IOPGM,IOSPL G F:%IS["F"
K	K %ZIS,%IS,%A,%B,%E,%H,%X,%Y,%Z,%Z9 Q
	;
F	I %IS["Q" S %A=0 R:'$D(IOP) !,"Do you want to free up this terminal? NO// ",%A:$S($D(DTIME):DTIME,1:60) I %A?1"Y".E!(%A?1"y".E) C IO S IO("Q")=1
	G K

ZIS2VXD
%ZIS2	;GFT,MVB ; 16 Dec 87  3:33 PM ;DEVICE SELECTOR FOR VAX-DSM V3;6/1/88  3:30 PM
	;;5.976;
IC	C:%ZISB IO G A^%ZIS
	;
L	G M:IO=$I I %ZISB,$D(^%ZIS(1,%E,"TIME")) S %A=$P(^("TIME"),"^",1),%X=$P($H,",",2),%=%X\60#60+(%X\3600*100),%X=$P(%A,"-",2) G:%X'<%A X:%'>%X&(%'<%A),DUZ G X:%>%A!(%<%X)
DUZ	G M:'$D(^(95)),M:^(95)="" S %X=$S($D(DUZ(0)):DUZ(0),1:"") F %A=1:1:$L(%X) G M:%X="@",M:^(95)[$E(%X,%A)
X	G IOPC:$D(IOP) W *7,"  [ACCESS PROHIBITED]" G IC
M	S %A=$P(%Y,";",1) I %A?1A.ANP D SUB I $D(^%ZIS(2,%A,1)) D ST,STP S %Y=$P(%Y,";",2,3) G M
	S:$P(%Y,";",2) IOSL=+$P(%Y,";",2) I %A>3 S IOM=+%A G S
	I %IS["M",'$D(IOP),IOT["TRM",$S(%E=%H:+$P(%Z,"^",3),1:1),$P(%Z,"^",4)
	I $T W "    RIGHT MARGIN: " W:IOM]"" IOM,"// " D SBR^%ZIS G N:$D(DTOUT)!$D(DFOUT)!$D(DUOUT) S:%X=""&IOM %X=IOM G M:%X'?1N.N S IOM=$S(%X<256:%X,1:0)
S	G:IOT="SPL" R:%IS["T",SPOOL^%ZIS3 I $D(%IS("IOPAR")) S IOPAR=%IS("IOPAR")
	D HFS^%ZIS3:IOT="HFS"
	I '$D(IOP),IOT'["TRM",$P(^%ZIS(1,%E,0),"^",4) W "  ADDRESS/PARAMETERS: " W:IOPAR]"" IOPAR_"// " D SBR^%ZIS G N:$D(DTOUT)!$D(DFOUT)!$D(DUOUT) S:%X]"" IOPAR=%X S:IOPAR]""&($A(IOPAR)-40) IOPAR="("_IOPAR_")"
S1	I '$D(IOP),IOT="HFS",'$P(^%ZIS(1,%E,0),"^",4),IOPAR="",$D(^%ZIS(1,%E,1)),$P(^(1),"^",6) W ?45,"INPUT/OUTPUT OPERATION: " D SBR^%ZIS G N:$D(DTOUT)!$D(DFOUT)!$D(DUOUT) D HOPT:%X="?"!($F("?^R^N^RW",%X)'>1) G S1:%X="?"!($F("?^R^N^RW",%X)'>1) I 1
	I  S IOPAR=$S(%X="R":"READONLY",%X="N":"NEWVERSION",1:"")
	G:%IS["T" R
O	D:$D(IOS) ZISLPC^%ZIS3 G R:'%ZISB I $D(IO("S")) S IO("S")=$S($D(^%ZIS(1,%H,"SUBTYPE")):^("SUBTYPE"),1:0) I $D(^%ZIS(2,IO("S"),10)),^(10)]"" U IO(0) D X10^ZISX
	;S %A=$S(IOT="TRM":$S($L(IOM):"WIDTH="_IOM,1:""),1:IOPAR),%A=""""_IO_""""_$E(":",%A]"")_%A C:IOT="MT" IO O IO U @%A,IO(0) I $D(^%ZIS(2,IOST(0),2))=1 S %Y=^(2) D 2
	S %A=$S(IOPAR]"":IOPAR,1:""),%A=""""_IO_""""_$S(%A]"":":"_%A,1:"") C:IOT="MT" IO O @%A S IOUPAR=$S($D(%IS("IOUPAR")):%IS("IOUPAR"),IOUPAR]"":IOUPAR,1:"") I IOT["TRM" U IO:(WIDTH=IOM)
	S %A1=""""_IO_""""_$S(IOUPAR]"":":"_IOUPAR,1:"") U @%A1,IO(0) I $D(^%ZIS(2,IOST(0),2))=1 S %Y=^(2) D 2
	I $D(^%ZIS(2,IOST(0),102)) S %Y=^(102) D 2 E  G IOPC:$D(IOP) W *7,"NOT ON LINE" G IC
	I IOT="MT",'$D(IOP) R "  REWIND? NO// ",%X:$S($D(DTIME):DTIME,1:60) S:'$T %X=U Q:%X=U  I %X?1"Y".E!(%X?1"y".E) U IO:REWIND,IO(0)
R	W:'$D(IOP) ! G KIL:IO=IO(0) S:$D(DUZ)#2 ^DISV(+DUZ,"^%ZIS(1,")=%E G KIL:%IS["T"!'%ZISB!(IOST'["K"&(IOST["SINGLE")),F^%ZIS3
	;
IOPC	C:%ZISB IO
N	K IO("L"),IO("C") S POP=1 S:%IS'["T"!(%IS["T"&($D(DTOUT)!$D(DFOUT)!$D(DUOUT))) IO=""
	I %IS'["T" S ION=$P(IO(1),";"),IOM=+$P(IO(1),";",2),IOF=$P(IO(1),";",3),IOSL=$P(IO(1),";",4),IOBS=$P(IO(1),";",5) K IO(1) S:IOF="" IOF="#"
	I $T S IOST(0)=+IO(2),IOST=$P(IO(2),";",2),IOPAR=$P(IO(2),";",3),IOUPAR=$P(IO(2),";",4) K IO(2)
	I $T S IOS=$P(IO(3),";",1) S:$P(IO(3),";",2)]"" IOCPU=$P(IO(3),";",2) K IO(3)
KIL	S:%IS["T" IO("T")=1 K %ZIS,%ZISV,%IS,%A,%ZISB,%H,%E,%X,%Y,%Z,%Z9,IOP,IOTO,IO(1),IO(2),IO(3) Q
	;
2	Q:%Y=""  I %IS'[0 O IO(0)::0
	S %X=$T U IO D %Y^ZISX Q:'%X  U IO(0) Q
	;
ST	S IOST(0)=%A,IOST=$S($D(^%ZIS(2,%A,0)):$P(^(0),"^",1),1:"") Q
	;
STP	S:'$D(%Z9) (IOF,IOSL,IOBS,IOM)="" S %A=$S('$D(^(1)):"132^#^66^*8",1:^(1))
	S:IOM="" IOM=+%A S:IOF="" IOF=$P(%A,"^",2) S:'IOSL IOSL=$P(%A,"^",3) S:IOBS="" IOBS=$P(%A,"^",4)
	Q
SUB	I $D(^%ZIS(2,"B",%A))>9 S %A=+$O(^%ZIS(2,"B",%A,0)) Q
	S %XX=%A D 2^%ZIS4 S %A=+%YY Q
	Q
	;
HOPT	W !,"Enter one of the following host file input/ouput operation:"
	W !,?16,"R = READONLY",!,?16,"N = NEWVERSION",!,?15,"RW = READ/WRITE",! Q

ZIS3
%ZIS3	;SFISC/AC,RWF -- DEVICE HANDLER(DEVICE TYPES & PARAMETERS);5/25/89  11:01 ;5/26/89  10:01
	;;6.0;
TRM	;Terminal type
	D OPEN^%ZIS4:'POP&(%ZISB),MARGN:'POP,SETPAR:'POP
	I 'POP,%IS'["T",%ZISB=1,'$D(IOP),IO'=IO(0),'$D(IO("Q")),%IS["Q" D AQUE
	W:'$D(IOP) ! I '$D(IO("Q")) D O^%ZIS4:'POP&(%ZISB&(%IS'["T"))
	Q
SPL	;Spool type
	N %E,%Z D MARGN W:'$D(IOP) ! D SPOOL^%ZIS4:%IS'["T" Q
MT	;Magtape type
	D MARGN,ASKPAR,AMTREW:'POP&'$D(IOP) W:'$D(IOP) ! D O^%ZIS4:'POP&(%ZISB&(%IS'["T")) Q
SDP	;Sequential disk processor type
	D MARGN,ASKPAR W:'$D(IOP) ! D O^%ZIS4:'POP&(%ZISB&(%IS'["T")) Q
HFS	;Host File Server type
	D MARGN,HFS^%ZIS4 W:'$D(IOP) ! D O^%ZIS4:'POP&(%ZISB&(%IS'["T")) Q
OTH	;Other Device type
	D OPEN^%ZIS4:'POP&(%ZISB),MARGN:'POP,ASKPAR:'POP W:'$D(IOP) ! D O^%ZIS4:'POP&(%ZISB&(%IS'["T")) Q
	;
MARGN	S %A=$P(%Y,";",1) I %A?1A.ANP D SUB I $D(^%ZIS(2,%A,1)) S %ZISTP=0 K %Z91 D ST S %Y=$P(%Y,";",2,3) G MARGN
	S:$P(%Y,";",2) $P(%Z91,"^",3)=+$P(%Y,";",2) I %A>3 S $P(%Z91,"^")=+%A Q
	Q:%ZTYPE'["TRM"
ASKMAR	I %IS["M",'$D(IOP),$S(%E=%H:+$P(%Z,"^",3),1:1),$P(%Z,"^",4) W "    RIGHT MARGIN: " W:$P(%Z91,"^")]"" +%Z91,"// "
	E  Q
	D SBR^%ZIS1 I '$D(DTOUT)&'$D(DUOUT) S:%X=""&($P(%Z91,"^")]"") %X=+%Z91 G ASKMAR:%X'?1.N S $P(%Z91,"^")=$S(%X<256:%X,1:0) Q
	S POP=1 I %ZISB&(%ZTYPE["TRM")&(IO'=IO(0)) C IO K IO(1,IO) Q
	Q
	;
ASKPAR	I '$D(IOP),$P(^%ZIS(1,%E,0),"^",4) W "  ADDRESS/PARAMETERS: " W:%ZISOPAR]"" %ZISOPAR_"// " D SBR^%ZIS1 D MSG1:%X="?" G ASKPAR:%X="?" S:%X]"" %ZISOPAR=%X I $D(DTOUT)!$D(DUOUT) S POP=1
	I POP,%ZISB&(%ZTYPE["TRM") C IO K IO(1,IO) Q
	Q:POP
	;
SETPAR	S:%ZISOPAR]""&($A(%ZISOPAR)-40) %ZISOPAR="("_%ZISOPAR_")" Q
	;
AQUE	S %=$S($D(IO("Q")):1,1:2),U="^",%ZISDTIM=60
	I $D(IO("Q")) W !,"PREVIOUSLY, YOU HAVE SELECTED QUEUEING."
	W !,"DO YOU "_$S($D(IO("Q")):"STILL ",1:"")_"WANT YOUR OUTPUT QUEUED"
	D YN^%ZIS1 K %ZISDTIM G AQUE:%=0 Q:$D(IO("Q"))
	I %=-1 S POP=1 C IO K IO(1,IO) Q
	I %=1 S IO("Q")=1 C IO K IO(1,IO) Q
	Q
AMTREW	I %ZISB,%ZTYPE="MT",'$D(IOP) W "  REWIND" S %=2,U="^",%ZISDTIM=60 D YN^%ZIS1 K %ZISDTIM G AMTREW:%=0 I %=-1 S POP=1 Q
	S:%=1 %ZISMTR=1 Q
	;
ST	S %ZISIOST(0)=%A,%ZISIOST=$S($D(^%ZIS(2,%A,0)):$P(^(0),"^",1),1:"") Q:%ZISTP
STP	S:'$D(%Z91) %Z91="" S %A=$S('$D(^(1)):"132^#^66^*8",1:^(1))
	S:$P(%Z91,"^")="" $P(%Z91,"^")=+%A S:$P(%Z91,"^",2)="" $P(%Z91,"^",2)=$P(%A,"^",2) S:'$P(%Z91,"^",3) $P(%Z91,"^",3)=$P(%A,"^",3) S:$P(%Z91,"^",4)="" $P(%Z91,"^",4)=$P(%A,"^",4) S $P(%Z91,"^",5)=$P(%A,"^",5) Q
	;
SUB	I $D(^%ZIS(2,"B",%A))>9 S %A=+$O(^%ZIS(2,"B",%A,0)) Q
	S %XX=%A D 2^%ZIS5 S %A=+%YY Q
	Q
MSG1	W !?5,"Enter the desired parameters needed to open the selected device.",!?25 Q
	;

ZIS3DSM
%ZIS3	;GFT/SF ; 10/6/88  14:08 ;4/7/88  6:46 PM
	;;5.976;
	;
	;O 2:1 Should start a new output to document 1; O 2:513 Should re-open at start.
	;C 2   Should end document; C 2:256 close and erase
SPOOL	;%ZDA=pointer to ^XMB(3.51, %ZFN=spool file num.
	I '$D(^XMB(3.51,0)) W:'$D(IOP) !?5,"The spooler files are not setup in this account." G N
	I $D(ZISDA) W:'$D(IOP) !?5,*7,"You may not Spool the printing of a Spool document" G N
R	S %ZY=-1 D NEWDOC^ZISPL1:$D(DUZ)'[0 G N:%ZY'>0 S %ZDA=+%ZY,%ZFN=$P(%ZY(0),"^",2),IO("DOC")=$P(%ZY(0),"^",1) G OK:$D(IO("Q"))
	G:'%ZISB OK I '$P(%ZY,"^",3),%ZFN D SPL3 G N:%ZFN<0,DOC
	S %ZFN=-1 D SPL2 G:%ZFN<0 N S $P(^XMB(3.51,%ZDA,0),"^",2)=%ZFN,^XMB(3.51,"C",%ZFN,%ZDA)=""
DOC	S IO("SPOOL")=%ZDA,^XUTL("XQ",$J,"SPOOL")=%ZDA,IOF="#"
OK	K %ZDA,%ZFN G KIL^%ZIS2 ;OK return
N	K %ZDA,%ZFN,IO("DOC") S:$D(IOP) IOP="^" G A^%ZIS ;Error return
	;
SPL2	O 2:1 G:$ZA<0 SPL4 S %ZFN=$ZA#256 Q
SPL3	O 2:%ZFN+256 G:$ZA<0 SPL4 Q
SPL4	W:'$D(IOP) !?5,*7,"Couldn't open the spool file." S %ZFN=-1 Q
	;
CLOSE	C 2 D MAIL^ZISPL1 Q:%ZDA'>0
	S %ZFN=$P(%ZS,"^",2) D SPL3 Q:%ZFN'>0  U 2 S %ZCR=$C(13),%Y=""
	F %=0:0 R %X:5 Q:$ZA<0  F %1=0:0 S %1=$L(%Y),%Y=%Y_$E(%X,1,255-%1),%X=$E(%X,256-%1,999),%1=$F(%Y,%ZCR) Q:%1'>0  S %2=$E(%Y,$A(%Y)=10+1,%1-2),%Y=$E(%Y,%1,999) D CL2
	C 2:256 D CLOSE^ZISPL1 K %Y,%X,%1
	Q
CL2	S %1=$F(%2,$C(12)) I %1>0 S %=%+1,^XMB(3.9,XMZ,2,%,0)="|TOP|",%2=$E(%2,1,%1-2)_$E(%2,%1,999)
	S %=%+1,^XMB(3.9,XMZ,2,%,0)=%2 Q
	;
F	S %A="Y" R:'$D(IOP) "DO YOU WANT TO FREE UP THIS TERMINAL? NO// ",%A:$S($D(DTIME):DTIME,1:60) S:%A?1"y".E!(%A?1"Y".E) IO("C")=1 K:$D(DUZ)#2 ^XMB(3.7,+DUZ,100,IO(0))
	G OK
ZISLPC	I $D(IO("Q")) Q:IO("Q")=1
	S ZISLL=$N(^%ZIS("Z",106,"B",IOS,0)) G:ZISLL<0 ZISLPCQ
	G:%ZISV="" ZISLPCQ
	S %ZISI=0,ZISLP="" I $O(^%ZIS(1,"CPU",0))'="" G ZISLMDF
	F %ZISR=1:1 S I=$O(^%ZIS(1,"C",IO,%ZISI)) Q:%ZISI=""  S ZISLP=$O(^%ZIS("Z",106,"B",%ZISI,0)) I ZISLP'="" S ZISLP=$P(^%ZIS("Z",106,ZISLP,0),"^",2) Q:ZISLP'=""
	G ZISLPC1
ZISLMDF	F %ZISR=1:1 S %ZISI=$O(^%ZIS(1,"CPU",%ZISV_"."_IO,%ZISI)) Q:%ZISI=""  S ZISLP=$O(^%ZIS("Z",106,"B",%ZISI,0)) I ZISLP'="" S ZISLP=$P(^%ZIS("Z",106,ZISLP,0),"^",2) Q:ZISLP'=""
ZISLPC1	G:ZISLP="" ZISLPCQ S ZISLL=^%ZIS("Z",106,ZISLL,0),ZISLL=$P(ZISLL,"^",4) G:ZISLL="" ZISLPCQ G:ZISLL=ZISLP ZISLPCQ D ^%ZISLPC C:POP IO Q
ZISLPCQ	K ZISLL,ZISLP Q

ZIS3MVX
%ZIS3	;GFT/SF  ; 10/6/88  14:10 ;2/11/88  5:14 PM
	;;5.976;
	;
HANG	H 60
SPOOL	;%ZDA=pointer to ^XMB(3.51, %ZFN=spool file num.
	I '$D(^XMB(3.51,0)) W:'$D(IOP) !?5,"The spooler files are not setup in this account." G N
	I $D(ZISDA) W:'$D(IOP) !?5,*7,"You may not Spool the printing of a Spool document" G N
R	S %ZY=-1 D NEWDOC^ZISPL1:$D(DUZ)=11 G N:%ZY'>0 S %ZDA=+%ZY,%ZFN=$P(%ZY(0),U,2),IO("DOC")=$P(%ZY(0),U,1) G OK:$D(IO("Q"))
	G:'%ZISB OK I '$P(Y,"^",3),%ZFN D SPL3 G N:%ZFN<0,DOC
	F %ZFN=1:1 I '$D(^XMB(3.51,"C",%ZFN))!$D(^(%ZFN,%ZDA)) Q:%ZFN<256  W:'$D(IOP) *7,"  DELETE SOME OTHER DOCUMENT!" G N
	D SPL2 S $P(^XMB(3.51,%ZDA,0),U,2)=%ZFN,^XMB(3.51,"C",%ZFN,%ZDA)=""
DOC	S IO("SPOOL")=%ZDA,^XUTL("XQ",$J,"SPOOL")=%ZDA
OK	K %ZDA,%ZFN G KIL^%ZIS2 ;OK return
N	K %ZDA,%ZFN,IO("DOC") S:$D(IOP) IOP="^" G A^%ZIS ;Error return
	;
SPL2	O IO:(%ZFN:0) S ^SPOOL(0,IO("DOC"),%ZFN)="",^SPOOL(%ZFN,0)=IO("DOC")_"{"_$H Q
SPL3	G SPL4:'$D(^SPOOL(%ZFN,2147483647)) O IO:(%ZFN:$P(^(2147483647),"{",3)) K ^(2147483647) Q
SPL4	W:'$D(IOP) !,"Spool file already open" S %ZFN=-1 Q
	;
CLOSE	C:IO=IO(0) IO D MAIL^ZISPL1 Q:%ZDA'>0
	S %ZFN=$P(%ZS,"^",2),%ZCR=$C(13),%Y="",%=0,%3=$P(^SPOOL(%ZFN,2147483647),"{",3)-1
	F %2=1:1:%3 S %X=^SPOOL(%ZFN,%2),%=%+1,^XMB(3.9,XMZ,2,%,0)=$S($C(13,10)[%X:"",%X[$C(12):"|TOP|",1:$P(%X,$C(13),1))
	K ^SPOOL(%ZFN),^SPOOL(0,$P(%ZS,U,1)),%Y,%X,%1,%2,%3 D CLOSE^ZISPL1
	Q
F	I %IS["Q" S %A=0 R:'$D(IOP) !,"Do you want to free up this terminal? NO// ",%A:$S($D(DTIME):DTIME,1:60) I %A?1"Y".E!(%A?1"y".E) C IO S IO("Q")=1
	G OK
ZISLPC	I $D(IO("Q")) Q:IO("Q")=1
	S ZISLL=$N(^%ZIS("Z",106,"B",IOS,0)) G:ZISLL<0 ZISLPCQ
	G:%ZISV="" ZISLPCQ
	S %ZISI=0,ZISLP="" I $O(^%ZIS(1,"CPU",0))'="" G ZISLMDF
	F %ZISR=1:1 S %ZISI=$O(^%ZIS(1,"C",IO,%ZISI)) Q:%ZISI=""  S ZISLP=$O(^%ZIS("Z",106,"B",%ZISI,0)) I ZISLP'="" S ZISLP=$P(^%ZIS("Z",106,ZISLP,0),"^",2) Q:ZISLP'=""
	G ZISLPC1
ZISLMDF	F %ZISR=1:1 S %ZISI=$O(^%ZIS(1,"CPU",%ZISV_"."_IO,%ZISI)) Q:%ZISI=""  S ZISLP=$O(^%ZIS("Z",106,"B",%ZISI,0)) I ZISLP'="" S ZISLP=$P(^%ZIS("Z",106,ZISLP,0),"^",2) Q:ZISLP'=""
ZISLPC1	G:ZISLP="" ZISLPCQ S ZISLL=^%ZIS("Z",106,ZISLL,0),ZISLL=$P(ZISLL,"^",4) G:ZISLL="" ZISLPCQ G:ZISLL=ZISLP ZISLPCQ D ^%ZISLPC C:POP IO Q
ZISLPCQ	K ZISLL,ZISLP Q

ZIS3VXD
%ZIS3	;GFT/SF,MVB ; 10/6/88  14:12 ; DEVICE SELECTOR FOR VAX-DSM V3;4/4/88  6:14 PM
	;;5.976;
	;
SPOOL	;%ZDA=pointer to ^XMB(3.51, %ZFN=spool file name.
	I $D(ZISDA) W:'$D(IOP) !?5,*7,"You may not Spool the printing of a Spool document" G N
	I $D(DUZ)[0 W:'$D(IOP) !,"Must be a valid user." G N
R	S %ZY=-1 D NEWDOC^ZISPL1 G N:%ZY'>0 S %ZDA=+%ZY,%ZFN=$P(%ZY(0),U,2),IO("DOC")=$P(%ZY(0),U,1) G OK:$D(IO("Q"))
	G:'%ZISB OK I '$P(%ZY,"^",3),%ZFN]"" D SPL3 G N:%ZFN']"",DOC
	S %ZFN="SPOOL_no_"_%ZDA_".TMP" D SPL2 G:%ZFN']"" N S $P(^XMB(3.51,%ZDA,0),U,2)=%ZFN,^XMB(3.51,"C",%ZFN,%ZDA)=""
DOC	S IO=%ZFN,IO("SPOOL")=%ZDA,^XUTL("XQ",$J,"SPOOL")=%ZDA,IOF="#"
OK	K %ZDA,%ZFN G KIL^%ZIS2 ;OK return
N	K %ZDA,%ZFN,IO("DOC") S:$D(IOP) IOP="^" G A^%ZIS ;Error return
	;
SPL2	O %ZFN:NEWVERSION G:$ZA<0 SPL4 Q
SPL3	O %ZFN:READONLY G:$ZA<0 SPL4 Q
SPL4	W:'$D(IOP) !?5,*7,"Couldn't open the spool file." S %ZFN="" Q
	;
CLOSE	C:IO=IO(0) IO D MAIL^ZISPL1 Q:%ZDA'>0
	S %ZFN=$P(%ZS,"^",2) D SPL3 Q:%ZFN']""  U %ZFN S %ZCR=$C(13),%Y="",$ZT="SPLEOF^%ZIS3"
	F %=0:0 R %X:5 Q:$ZA<0  S %2=%X D CL2
SPLEOF	I $ZE["ENDO" C %ZFN:DELETE D CLOSE^ZISPL1 K %Y,%X,%1,%ZFN Q
	ZQ  ;Send error up
CL2	I %2[$C(12) S %=%+1,^XMB(3.9,XMZ,2,%,0)="|TOP|"
	S %=%+1,^XMB(3.9,XMZ,2,%,0)=%2 Q
	;
	;
	;
F	I %IS["Q" S %A=0 R:'$D(IOP) !,"Do you want to free up this terminal? NO// ",%A:$S($D(DTIME):DTIME,1:60) I %A?1"Y".E!(%A?1"y".E) C IO S IO("Q")=1
	G OK
HFS	;
	I $S($D(^%ZIS(1,%E,1)):$S($P(^(1),"^",5):0,1:1),1:1) S %ZHFN=IO G H1
	W !,"HOST FILE NAME: "_IO_"//" D SBR^%ZIS I %X?1."?".E W !,"ENTER HOST FILE NAME" G HFS
	I $D(DTOUT)!$D(DUOUT) Q  ; G N^%ZIS2
H1	S %ZHFN=$S(%X]"":%X,1:IO),%XX=$ZC(%PARSE,%ZHFN)
	I %XX]"",$ZC(%GETDVI,%XX,"DEVCLASS")="DISK"
	E  S DUOUT=1 W !,"HOST FILE NAME NOT VALID" Q
	S IO=$ZC(%PARSE,%ZHFN,".DAT")
	Q
ZISLPC	I $D(IO("Q")) Q:IO("Q")=1
	S ZISLL=$N(^%ZIS("Z",106,"B",IOS,0)) G:ZISLL<0 ZISLPCQ
	G:%ZISV="" ZISLPCQ
	S %ZISI=0,ZISLP="" I $O(^%ZIS(1,"CPU",0))'="" G ZISLMDF
	F %ZISR=1:1 S %ZISI=$O(^%ZIS(1,"C",IO,%ZISI)) Q:%ZISI=""  S ZISLP=$O(^%ZIS("Z",106,"B",%ZISI,0)) I ZISLP'="" S ZISLP=$P(^%ZIS("Z",106,ZISLP,0),"^",2) Q:ZISLP'=""
	G ZISLPC1
ZISLMDF	F %ZISR=1:1 S %ZISI=$O(^%ZIS(1,"CPU",%ZISV_"."_IO,%ZISI)) Q:%ZISI=""  S ZISLP=$O(^%ZIS("Z",106,"B",%ZISI,0)) I ZISLP'="" S ZISLP=$P(^%ZIS("Z",106,ZISLP,0),"^",2) Q:ZISLP'=""
ZISLPC1	G:ZISLP="" ZISLPCQ S ZISLL=^%ZIS("Z",106,ZISLL,0),ZISLL=$P(ZISLL,"^",4) G:ZISLL="" ZISLPCQ G:ZISLL=ZISLP ZISLPCQ D ^%ZISLPC C:POP IO Q
ZISLPCQ	K ZISLL,ZISLP,%ZISV Q

ZIS4
%ZIS4	;DEVICE LOOK-UP; 28APR1986 9:10 AM
	;;5.01
	S U="^",%DO="" S:%ZIS %ZIS=^DIC(%ZIS,0,"GL") I @("$D("_%ZIS_"0))") S %DO=^(0)
A	G:%ZIS(0)'["A" X I $D(%ZIS("A")) S %DD=%ZIS("A") G B
	S %DD="Select "_$P(%DO,U,1)_": "
B	I $D(%ZIS("B")),%ZIS("B")]"" S %YY=%ZIS("B"),@("%XX=$N("_%ZIS_"%D,%YY))"),@("%DIY=$S($F(%XX,%YY)-1=$L(%YY):%XX,$D("_%ZIS_"%YY,0)):$P(^(0),U,1),1:%YY)") W %DD,%DIY,"// " R %XX:$S($D(DTIME):DTIME,1:9999) G G:%XX]"" S %XX=%DIY G G
	W !,%DD R %XX:$S($D(DTIME):DTIME,1:9999)
G	G NO:'$T,NO:%XX["^" G:%XX?.N&(+%XX=%XX) NUM I %XX'?.ANP!($L(%XX)>30) W:%ZIS(0)["Q" *7," ??" G A
X	I %XX=" ",$D(^DISV($I,%ZIS)) S %YY=+^(%ZIS) D S G:'$T NO G GOT
F	G NO:%XX="" S %DS=0,%DD="",%DIX=%XX,%DIY=0
	I @("$D("_%ZIS_"%D,%XX))") G T1
TRY	S @("%DIX=$N("_%ZIS_"%D,%DIX))") G:$P(%DIX,%XX,1)'="" T2 S %DIY=0
T1	S @("%DIY=$N("_%ZIS_"%D,%DIX,%DIY))") G:%DIY<1 TRY S %YY=%DIY D S G:'$T T1
	I %DS=10 D LST G NO:%XX=U,ADD:%YY<0,GOT:%YY>0
	S %DS=%DS+1,%DD=%DD_%DIY_U G T1
S	I @("$D("_%ZIS_"%YY,0))") X:$D(%ZIS("S")) %ZIS("S")
	Q
T2	G:'%DS NO S %DIY="" D LST G NO:%XX=U,ADD:%YY<1,GOT
LST	I %DS=1 S %YY=$P(%DD,U,1) Q
	S %YY=-1 Q:%ZIS(0)'["E"  W ! F %DZ=1:1:%DS W !,$J(%DZ,2)," ",$P(@(%ZIS_$P(%DD,U,%DZ)_",0)"),U,1) I $D(%ZIS("W")) W "  " X %ZIS("W")
L1	W:%DIY !,"Type '^' to Stop, or" W !,"Choose 1" W:%DS>1 "-",%DS
	R "> ",%YY:$S($D(DTIME):DTIME,1:9999) I %YY="",%DIY S %DD="",%DS=0,%YY=0 W ! Q
	I %YY=U!(%YY="") S %YY=-1 S:%YY=U %XX=U Q
	I +%YY'=%YY!(%YY<1)!(%YY>%DS) W:%ZIS(0)["Q" *7," ??" G L1
	S %YY=$P(%DD,U,%YY) Q
GOT	S @("%DZ="_%ZIS_"+%YY,0)")
	W:%ZIS(0)["E" "  ",$P(%DZ,U,1)
R	I %ZIS(0)'["F" S ^DISV($I,%ZIS)=+%YY
	I %ZIS(0)["Z" S @("%YY(0)="_%ZIS_"+%YY,0)")
Q	K %ZIS,%DS,%D,%DO,%DD,%DIX,%DIY,%DZ Q
ADD	;can't add to files
NO	S %YY=-1 G Q
NUM	I @("$D("_%ZIS_"%XX))") S %YY=%XX D S I $T G GOT
	G F
1	S %D="B",%ZIS="^%ZIS(1,",%ZIS(0)=$S($D(IOP):"M",1:"EMQ") D %ZIS4 Q
2	S %D="B",%ZIS="^%ZIS(2,",%ZIS(0)=$S($D(IOP):"M",1:"EMQ") D %ZIS4 Q

ZIS4DSM
%ZIS4	;SFISC/RWF,AC -- SPOOL & OPEN O/S SPECIFIC CODE(DSM-11) ;5/24/89  10:44 ;3/30/89  10:05 AM
	;;6.0;
	;
	;O 2:1 Should start a new output to document 1; O 2:513 Should re-open at start.
	;C 2   Should end document; C 2:256 close and erase
SPOOL	;%ZDA=pointer to ^XMB(3.51, %ZFN=spool file num.
	I '$D(^XMB(3.51,0)) W:'$D(IOP) !?5,"The spooler files are not setup in this account." G N
	I $D(ZISDA) W:'$D(IOP) !?5,*7,"You may not Spool the printing of a Spool document" G N
R	S %ZY=-1 D NEWDOC^ZISPL1:$D(DUZ)'[0 G N:%ZY'>0 S %ZDA=+%ZY,%ZFN=$P(%ZY(0),"^",2),IO("DOC")=$P(%ZY(0),"^",1) G OK:$D(IO("Q"))
	G:'%ZISB OK I '$P(%ZY,"^",3),%ZFN D SPL3 G N:%ZFN<0,DOC
	S %ZFN=-1 D SPL2 G:%ZFN<0 N S $P(^XMB(3.51,%ZDA,0),"^",2)=%ZFN,^XMB(3.51,"C",%ZFN,%ZDA)=""
DOC	S IO("SPOOL")=%ZDA,^XUTL("XQ",$J,"SPOOL")=%ZDA,IOF="#"
OK	K %ZDA,%ZFN Q
N	K %ZDA,%ZFN,IO("DOC") S POP=1 Q
	;
SPL2	O 2:1 G:$ZA<0 SPL4 S %ZFN=$ZA#256 S IO(1,2)="" Q
SPL3	O 2:%ZFN+256 G:$ZA<0 SPL4 S IO(1,2)="" Q
SPL4	W:'$D(IOP) !?5,*7,"Couldn't open the spool file." S %ZFN=-1 Q
	;
CLOSE	C 2 K IO(1,2) D MAIL^ZISPL1 Q:%ZDA'>0
	S %ZFN=$P(%ZS,"^",2) D SPL3 Q:%ZFN'>0  U 2 S %ZCR=$C(13),%Y=""
	F %=0:0 R %X:5 Q:$ZA<0  F %1=0:0 S %1=$L(%Y),%Y=%Y_$E(%X,1,255-%1),%X=$E(%X,256-%1,999),%1=$F(%Y,%ZCR) Q:%1'>0  S %2=$E(%Y,$A(%Y)=10+1,%1-2),%Y=$E(%Y,%1,999) D CL2
	C 2:256 K IO(1,2) D CLOSE^ZISPL1 K %Y,%X,%1
	Q
CL2	S %1=$F(%2,$C(12)) I %1>0 S %=%+1,^XMB(3.9,XMZ,2,%,0)="|TOP|",%2=$E(%2,1,%1-2)_$E(%2,%1,999)
	S %=%+1,^XMB(3.9,XMZ,2,%,0)=%2 Q
	;
OPEN	;
	O IO:"":%ZISTO S:$T IO(1,IO)="" G NOPEN:'$D(IO(1,IO))
	I $D(%ZISHP),'$D(IOP) W !,*7," Routing to device "_$P(^%ZIS(1,%E,0),"^",1)_$S($D(^(1)):" "_$P(^(1),"^",1)_" ",1:"")
	Q
NOPEN	;
	I %IS'["D",$D(%ZISHP)!(%ZISHG]"") S POP=1 Q
	I '$D(IOP) W *7,"  [BUSY]" W "  ...  RETRY" N DTIME S DTIME=5,%=2,U="^" D YN^%ZIS1 G OPEN:%=1
	S POP=1 Q
	Q
O	D:$D(%ZISIOS) ZISLPC^%ZIS Q:'%ZISB
OPRTPORT	I $D(IO("S")),$D(^%ZIS(2,IO("S"),10)),^(10)]"" U IO(0) D X10^ZISX
OPAR	S %A=$S(%ZISOPAR]"":%ZISOPAR,%ZTYPE["TRM":+%Z91,1:""),%A=""""_IO_""":"_%A_":"_%ZISTO O @%A I '$T S POP=1 W:'$D(IOP) !,?5,*7,"[DEVICE IS BUSY]" Q
	S IO(1,IO)="" I %ZISUPAR]"" S %A1=""""_IO_""":"_%ZISUPAR U @%A1 U:%IS'[0 IO(0)
OXECUTE	I $D(^%ZIS(2,%ZISIOST(0),2))=1 S %Y=^(2) D 2
ANSBAK	I $D(^%ZIS(2,%ZISIOST(0),102)) S %Y=^(102) D 2 E  S POP=1 W:'$D(IOP) *7,"NOT ON LINE" C:%ZISB IO K IO(1,IO) Q
	I $D(%ZISMTR) U IO W *5 U IO(0)
	Q
	;
2	Q:%Y=""  I %IS'[0 O IO(0)::0 S IO(1,IO(0))=""
	S %X=$T U IO D %Y^ZISX Q:'%X  U IO(0) Q
	;
HFS	;Host File Server (Not available on DSM-11)
	S POP=1 W:'$D(IOP) *7,"  [NOT AVAILABLE ON THIS SYSTEM]" Q
	;

ZIS4M11
%ZIS4	;SFISC/GFT,RWF - DEVICE HANDLER SPOOL SPECIFIC CODE (M11); 8/3/88  13:34 ;5/24/89  10:44
	;;6.0;
	;
HANG	H 60 Q
	;
SPOOL	D SPL S:%<0 POP=1 Q
	;
SPL	N DIC,X,Y ;%ZDA=pointer to ^XMB(3.51, %ZFN=spool file num.
	I '$D(^XMB(3.51,0)) W:'$D(IOP) !?5,"The spooler files are not setup in this account." G N
	I $D(ZISDA) W:'$D(IOP) !?5,*7,"You may not Spool the printing of a Spool document" G N
R	S Y=-1 D NEWDOC^ZISPL1:$D(DUZ)=11 G N:Y'>0 S %ZDA=+Y,%ZFN=$P(Y(0),U,2),IO("DOC")=$P(Y(0),U,1) G K:$D(IO("Q"))
	G:'%ZISB K I '$P(Y,"^",3),%ZFN D SPL3 G N:%ZFN<0,DOC
	F %ZFN=1:1 I '$D(^XMB(3.51,"C",%ZFN))!$D(^(%ZFN,+Y)) Q:%ZFN<256  W:'$D(IOP) *7,"  DELETE SOME OTHER DOCUMENT!" G N
	D SPL2 S $P(^XMB(3.51,+Y,0),U,2)=%ZFN,^XMB(3.51,"C",%ZFN,+Y)=""
DOC	S IO("SPOOL")=%ZDA,^XUTL("XQ",$J,"SPOOL")=%ZDA
K	K %ZDA,%ZFN S %=0 Q  ;OK return
N	K %ZDA,%ZFN,IO("DOC") S POP=1 Q
	;
SPL2	O IO:(%ZFN:0) S IO(1,IO)="",^SPOOL(0,IO("DOC"),%ZFN)="",^SPOOL(%ZFN,0)=IO("DOC")_"{"_$H Q
SPL3	G SPL4:'$D(^SPOOL(%ZFN,16777215)) O IO:(%ZFN:$P(^(16777215),"{",3)) K ^(16777215) S IO(1,IO)="" Q
SPL4	W:'$D(IOP) !,"Spool file already open" S %ZFN=-1 Q
	;
CLOSE	C 2 K IO(1,2) D MAIL^ZISPL1 Q:%ZDA'>0
	S %ZFN=$P(%ZS,"^",2),%ZCR=$C(13),%Y="",%=0,%3=$P(^SPOOL(%ZFN,16777215),"{",3)-1
	F %2=1:1:%3 S %X=^SPOOL(%ZFN,%2),%=%+1,^XMB(3.9,XMZ,2,%,0)=$S($C(13,10)[%X:"",%X[$C(12):"|TOP|",1:$P(%X,$C(13),1))
	K ^SPOOL(%ZFN),^SPOOL(0,$P(%ZS,U,1)),%Y,%X,%1,%2,%3 D CLOSE^ZISPL1
	Q
	;
OPEN	;
	O IO:"":%ZISTO S:$T IO(1,IO)="" G NOPEN:'$D(IO(1,IO))
	I $D(%ZISHP),'$D(IOP) W !,*7," Routing to device "_$P(^%ZIS(1,%E,0),"^",1)_$S($D(^(1)):" "_$P(^(1),"^",1)_" ",1:"")
	Q
NOPEN	;
	I %IS'["D",$D(%ZISHP)!(%ZISHG]"") S POP=1 Q
	I '$D(IOP) W *7,"  [BUSY]" W "  ...  RETRY" N DTIME S DTIME=5,%=2,U="^" D YN^%ZIS1 G OPEN:%=1
	K:%E'=%H ^XUTL("ZIS","EON",IO),^XUTL("ZIS","TYPE-AHEAD",IO),^XUTL("ZIS","TRMON",IO)
	S POP=1 Q
	;
O	D:$D(%ZISIOS) ZISLPC^%ZIS Q:'%ZISB
OPRTPORT	I $D(IO("S")),$D(^%ZIS(2,IO("S"),10)),^(10)]"" U IO(0) D X10^ZISX
OPAR	S %A=$S(%ZISOPAR]"":%ZISOPAR,%ZTYPE["TRM":+%Z91,1:""),%A=""""_IO_""":"_%A_":"_%ZISTO O @%A
	I '$T S POP=1 W:'$D(IOP) !,?5,*7,"[DEVICE IS BUSY]" Q
	S IO(1,IO)="" I %ZISUPAR]"" S %A1=""""_IO_""":"_IOUPAR U @%A1 U:%IS'[0 IO(0)
OXECUTE	I $D(^%ZIS(2,%ZISIOST(0),2))=1 S %Y=^(2) D 2
ANSBAK	I $D(^%ZIS(2,%ZISIOST(0),102)) S %Y=^(102) D 2 E  S POP=1 W:'$D(IOP) *7,"[NOT ON LINE]" C:%ZISB IO K IO(1,IO) Q
	I $D(%ZISMTR) U IO W *5 U:%IS'[0 IO(0)
	Q
	;
2	Q:%Y=""  I %IS'[0 O IO(0)::0 S IO(1,IO(0))=""
	S %X=$T U IO D %Y^ZISX Q:'%X  U IO(0) Q
	;
HFS	;Host File Server (Not available on M11+)
	S POP=1 W:'$D(IOP) *7,"  [NOT AVAILABLE ON THIS SYSTEM]" Q
	;

ZIS4M11P
%ZIS4	;SFISC/GFT,AC,RWF -- SPOOL & OPEN OS SPECIFIC CODE(M11P) ;5/24/89  10:44 ;4/3/89  11:31 AM
	;;6.0;
	;
	;O 2:1 Should start a new output to document 1; O 2:513 Should re-open at start.
	;C 2   Should end document; C 2:256 close and erase
SPOOL	;%ZDA=pointer to ^XMB(3.51, %ZFN=spool file num.
	I '$D(^XMB(3.51,0)) W:'$D(IOP) !?5,"The spooler files are not setup in this account." G N
	I $D(ZISDA) W:'$D(IOP) !?5,*7,"You may not Spool the printing of a Spool document" G N
