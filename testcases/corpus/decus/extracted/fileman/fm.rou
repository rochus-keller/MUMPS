	;
SCR	I @("$D("_DIC_"Y,0))") X DO("SCR")
	Q
	;
DT	W:$E(%,4,5) $E(%,4,5)_"-" W:$E(%,6,7) $E(%,6,7)_"-" W $E(%,1,3)+1700 W:%["." " @ "_$E(%_0,9,10)_":"_$E(%_"000",11,12)_$S(+$E(%,13,14):":"_$E(%_0,13,14),1:"   ") Q
	;
0	;
	K DIW,DIZ,DS Q:DIC(0)'["L"  S XQH=-1
	I $D(%Y) S:%Y="??" DZ=%Y S:%Y?1P DZ="?"
	I $S($D(DLAYGO):DO(2)-DLAYGO\1,1:1),DUZ(0)'="@",'$D(^DD(+DO(2),0,"UP")) G JMP
10	I DZ="?" W:$X>5 ! W ?5,"YOU MAY ENTER A NEW ",$P(DO,U),", IF YOU WISH" F DG=3,12 I $D(^DD(+DO(2),.01,DG)) S X=^(DG) F %=$L(X," "):-1:1 I $L($P(X," ",1,%))<70 W !?5,$P(X," ",1,%) W:%'=$L(X," ") !?5,$P(X," ",%+1,99) Q
	D H
	I $D(DZ),DO(2)["S" W !,"CHOOSE FROM: " F X=1:1 S Y=$P($P(^DD(+DO(2),.01,0),U,3),";",X) Q:Y=""  W !?7,$P(Y,":",1),?15," ",$P(Y,":",2)
	I DO(2)["V" S DU=+DO(2),D=.01 D V^DIEQ
	;
RCR	Q:DO(2)'["P"!$D(DZ(1))
	S DZ(1)=DIC,DZ(0)=DIC(0),DS=^DD(+DO(2),.01,0),DIC=U_$P(DS,U,3),DIC(0)=$E("L",$P(DS,U,2)'["'")
	F Y=1:1:3 S X=$E("VWS",Y) S:$D(DIC(X)) DZ(X)=DIC(X) K DO K:Y<3!'DS DIC(X)
	K:DS DZ("S") D DQ^DICQ K DICW,DICS S DIC=DZ(1),DIC(0)=DZ(0)
	F Y=1:1:3 S X=$E("VWS",Y) K DO,DIC(X) S:$D(DZ(X)) DIC(X)=DZ(X) K DZ(X)
	Q
H	S %=DIC N DIC S DIC=% I $D(^DD(+DO(2),.01,4)),^(4)]"" X ^(4) Q:'$D(DZ)
	Q:DZ'?1"??".E  I $D(^DD(+DO(2),.01,22)),^(22)]"" S XQH=^(22) N DO,D,DZ D EN1^XQH K XQDSH,XQSHL,XQY,XQAU,XQB3,XQBL,X1 Q:'XQH
	F X=1:1 Q:'$D(^DD(+DO(2),.01,21,X,0))  W !?5,^(0)
	Q
JMP	I $D(^DIC(3,"AFOF")) G RCR:'$D(^DIC(3,DUZ,"FOF",+DO(2),0)),RCR:'$P(^(0),U,4),10
	G:'$D(^DIC(+DO(2),0,"LAYGO")) 10
