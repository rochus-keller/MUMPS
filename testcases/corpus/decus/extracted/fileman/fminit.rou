	;;=^^5^5^2890124^^
	;;^DD(3,19.2,21,1,0)
	;;=This field records the level of delegation authority with respect to
	;;^DD(3,19.2,21,2,0)
	;;=the systems manager, level zero.  When the systems manager delegates
	;;^DD(3,19.2,21,3,0)
	;;=authority to someone else, that person will be at level one.  Levels
	;;^DD(3,19.2,21,4,0)
