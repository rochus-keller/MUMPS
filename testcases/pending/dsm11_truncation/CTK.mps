CTK     Q  ;CARETAKER INITIALIZATION
START   S OLDH=$H,SEQ=0 V 2:$J:$V(2,$J)+2048
ST1     S TIM=10,$ZE="ERR",ST=$V(44) F DEV=3:1:19,64:1:$V(ST+462)#256 I $V($V(ST+8)+DEV)#256'=255 ZU DEV I $ZA\2#2 S LP(DEV)=""
        S MAXERR=$P(^%ER,"\",2),JCDEV=$S($D(^SYS(0,"STARTUP","ERR JCDEV")):^("ERR JCDEV"),1:"N"),JCDEV=$S(JCDEV="N":0,1:JCDEV-1) O:J
CDEV JCDEV
WAIT    I ^SYS(0,"STARTUP","CARETAKER")="N" H 1 G WAIT
        G LOOP^CTK0
ERR     S ZE=$ZE,$ZT="ERR2" ZU $V(ST+346)#256:(:::::32) W !!,ZE
        I ZE["DKHER" S MPMS=$V(ST+205)*65536+$V(ST+206) I MPMS W " at block ",MPMS," on ",$C($V(ST+208)#256),$C($V(ST+209)),$C($V(ST
+210)#256+48)
        G ST1
ERR2    I $V(ST+204)\8#2 H TIM G ERR
        H
