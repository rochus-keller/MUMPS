OPEN	G L:IOT="SPL"!(IOT="SDP")!'%B O IO::1
	G L:$T,N:$D(IOP) W *7
	W:'$T "  [BUSY]" W "  ...  WAIT? " R %X:5 G OPEN:%X?1"Y".E
I	G ^%ZIS
	;
IC	C:%B IO G ^%ZIS
	;
L	G M:IO=$I I %B,$D(^%ZIS(1,%E,"TIME")) S %A=$P(^("TIME"),"^",1),%X=$P($H,",",2),%=%X\60#60+(%X\3600*100),%X=$P(%A,"-",2) G:%X'<%A X:%'>%X&(%'<%A),DUZ G X:%>%A!(%<%X)
DUZ	G M:'$D(^(95)),M:^(95)="" S %X=$S($D(DUZ(0)):DUZ(0),1:"") F %A=1:1:$L(%X) G M:%X="@",M:^(95)[$E(%X,%A)
X	G IOPC:$D(IOP) W *7,"  [ACCESS PROHIBITED]" G IC
M	S %A=$P(%Y,";",1) I %A?1A.ANP S %A=$N(^%ZIS(2,"B",%A,0)) I $D(^%ZIS(2,%A,1)) D ST,STP S %Y=$P(%Y,";",2,3) G M
	S:$P(%Y,";",2) IOSL=+$P(%Y,";",2) I %A>3 S IOM=+%A G S
	I %IS["M",'$D(IOP),IOT="TRM",$P(^%ZIS(1,%E,0),"^",3,4)="1^1" W "    RIGHT MARGIN: " W:IOM]"" IOM,"// " D SBR^%ZIS G N:$D(DTOUT)!$D(DFOUT) S:%X=""&IOM %X=IOM G M:%X'?1N.N S IOM=%X
S	G SPOOL^%ZIS2:IOT="SPL" I '$D(IOP),IOT'="TRM",$P(^%ZIS(1,%E,0),"^",4) W "  ADDRESS/PARAMETERS: " W:IOPAR]"" IOPAR_"// " D SBR^%ZIS G N:$D(DTOUT)!$D(DFOUT) S:%X]"" IOPAR=%X S:$A(IOPAR)-40 IOPAR="("_IOPAR_")"
O	G R:'%B S %A=$S(IOT="TRM":"WIDTH="_IOM,1:IOPAR),%A=""""_IO_""""_$E(":",%A]"")_%A C:IOT="MT" IO O:$I'=1 @%A I $D(^%ZIS(2,IOST(0),2))=1 S %Y=^(2) D 2
	I $D(^%ZIS(2,IOST(0),102)) S %Y=^(102) D 2 E  G IOPC:$D(IOP) W *7,"NOT ON LINE" G IC
	;I IOT="MT",'$D(IOP) R "  REWIND? NO// ",%X I %X?1"Y".E!(%X?1"y".E) U IO W *5 U IO(0)
	;M-11 tape handling
R	W:'$D(IOP) ! G KIL:IO=IO(0) S ^DISV(IO(0),"^%ZIS(1,")=%E G KIL:'%B!(IOST'["K"&(IOST["SINGLE"))!(%IS'["F"),F^%ZIS2
	;
IOPC	C:%B IO
N	K IO("L"),IO("C") S POP=1,IOF="#",(IO,IOT,IOM,ION,IOST,IOSL,IOBS,IOPAR)=""
KIL	K %ZIS,%IS,%A,%B,%E,%X,%Y Q
	;
2	Q:%Y=""  I %IS'[0 O IO(0)::0
	S %X=$T U IO X %Y Q:'%X  U IO(0) Q
	;
ST	S IOST(0)=%A,IOST=$S($D(^%ZIS(2,%A,0)):$P(^(0),"^",1),1:"") Q
	;
STP	I '$D(^(1)) S IOF="#",IOSL=66,IOBS="*8",IOM=132,USIO="" Q
	S %A=^(1),IOM=+%A,IOF=$P(%A,"^",2),IOSL=$P(%A,"^",3),IOBS=$P(%A,"^",4)

