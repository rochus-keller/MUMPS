	S I="DIC"_DICR,D="X ""I 0"" F "_I_"=0:0 S "_I_"=$N"_Y,%=""""_%_"""" I @("$N"_Y_%_",0))>0") S D=D_%_",Y,"_I_")) Q:"_I_"'>0  I $D"_Y_I_",0))"
	E  I DS["DINUM=X" S D="I $D"_Y_"Y,0)) S "_I_"=Y"
