PARVEC0 ;;FDN13-JUN-80;;PARTITION VECTOR UPDATED FOR DSM V2/ FOR 3.0 KFD
        W !?5,*7,"This subroutine should be run using the ^PARVEC utility.",!,*7 Q
START   K ^PARVEC S ^PARVEC="DSM-11 V 3.0 Partition Dump"
        W !,"Creating Global ^PARVEC"
        F I=1:1 S T=$T(ST+I) Q:T=""  D NEWSA W:'(I#10) "."
        K I,J,P,SA,T W ! Q
NEWSA   S SA=+T,T=$P(T,";;",2)
        F J=1:1 S P=$P(T,";;",J) Q:P=""  S ^PARVEC(SA)=P,SA=SA+P
        Q
