NM	D BB:X["B" I X["P"!(X["V") S P=P_Q_+Y,I=$P(Y,U,2),DPP(DJ)=DL_U_Y_U_P D DPQ^DIP1 S X=I,DPP=I G C^DIP0
	I +Y=.001 S Y=0_U_$P(Y,U,2),R=R_U_U_X
S	;
	S X=DL_U_+Y,DPP(DJ)=DL_U_Y_U_P_R I P'["-",$P(Y,U,3)="" D XR
	D DJ^DIP1 S:X'=U X=1 Q
	;
B	W *7,"??" Q:$D(DIJS)  G DJ
	;
XR	S P=$S($D(^DD(DL,+Y,0)):$P(^(0),U,2),1:0) I P'["O"!(P["D") F P=0:0 S P=$N(^DD(DL,+Y,1,P)) Q:P'>0  I +^(P,0)=S S X=$P(^(0),U,2,9) I X?1A.A S DPP(DJ,"IX")=DI_Q_X_Q_C_DI_U_2,Y=$N(^DD(S,0,"IX",X,-1)),DU=$N(^(Y,-1)),DV=$P(^DD(Y,DU,0),U,1) Q
	Q
ADD	;
	S X=$E(X,2,99),DIJS=DIJ,DIJ=0 D D S:$D(X) DJ=DJ+1 S DIJ=DIJS K DIJS G DJ

DIP0
DIP0	; SF/XAK - COMPUTED FIELD ON A SORT, EDITING A SORT TEMPLATE ;4/14/89  13:52 ;
	;;17.7;VA FileMan; 6/9/89
	S P=P_Q,DPP=$P(X,U,1)
C	;
	S DICOMP=N_$E("?",''L),DM=X,DQI="Y(",DA="DPP("_DJ_",""OVF"_N_""",",DICMX="D M" G COLON:X?.E1":" D EN^DICOMP G X:'$D(X),X:Y["m" ;I Y["m" S X=DM_":" G C
	D XA,BB^DIP:Y["B" S:Y["D" R=R_"^^D" S Y=U_DPP,DPP(DJ,"CM")=X_" I D"_(N#100)_">0 S X("_DJ_")=X" G S^DIP
	;
XA	F %=0:0 S %=$N(X(%)) Q:%<0  S @(DA_"%)=X(%)")
	Q
	;
	;
COLON	D ^DICOMPW
	I $D(X),$S($D(DIL(+DP)):DIL(+DP)=DL,1:1) S DPP(DJ,DL,+Y)=DP_U_(Y["m")_U_X,DIL(+DP)=DL,N=+Y,DL=+DP,DV=$J("",DJ*2-2)_$N(^DD(DL,0,"NM",0))_" FIELD: " S:$D(DIPP(DIJ)) $P(DIPP(DIJ),U,3)=DIPP(DIJ,+DP),DV=DV_DIPP(DIJ,+DP)_"//" D XA,L G Y^DIP
X	I $D(BY),BY]"" S X=DM_C_BY,BY="" G C
	G B^DIP
	;
EDT	;
	S DIE="^DIBT(",DR=".01;3;6",DA=X,DIPP=DI D ^DIE S DI=DIPP,DE=$S(L=0!L:"SORT",1:L) K DR,DIE,DIPP I '$D(DA) S DJ=0 Q
	S DIPP="",%X="DPP(",%Y="DIPP(" D %XY^%RCR
	F DIJ=0:0 S DIJ=$N(DPP(DIJ)) Q:DIJ<0  S $P(DIPP(DIJ),U,3)=$P($P(DPP(DIJ),U,4),Q,1)_$P(DPP(DIJ),U,3)_$P(DPP(DIJ),U,5),%=+DPP(DIJ) D E1 S %X=0 D E2
	K DPP S DJ=0 F DIJ=0:0 S DIJ=$N(DIPP(DIJ)) Q:DIJ<0  S DJ=DJ+1 D DJ^DIP Q:X=U  W:X="@" "  Deleted."
	K DIPP S:X'=U X=1 S:'$D(DXS) DXS=1 S DIEDT=1 Q
E1	;
	F DJ=0:1 Q:'$D(^DD(%,0,"UP"))  S DIPP(DIJ,%)=$P(DIPP(DIJ),U,3),%=+^("UP"),$P(DIPP(DIJ),U,3)=$O(^("NM",0)),$P(DIPP(DIJ),U,1)=%
	Q
E2	S %X=$O(DPP(DIJ,%X)) I %X'>0 K %X Q
	G E2:'$D(DPP(DIJ,%X,100)) S %=%X D E1 S %=DPP(DIJ,%X,100)
	I $P(%,U,3) S DIPP(DIJ,+%)=$P(DIPP(DIJ),U,3),$P(DIPP(DIJ),U,3)=$P(^DIC(+%,0),U)_":",$P(DIPP(DIJ),U)=+% G E2
	I %'["Y(1)" S %=$F(%,"OVF0") Q:'%  S %=+$E(DPP(DIJ,%X,100),%+2,99),%=$P(DPP(DIJ,%X,100),U)_U_DPP(DIJ,"OVF0",%) Q:%'["Y(1)"
	S G=$P($P($P(%,"Y(1)",2),")):^(",2),")",1),P=$P(%,"Y(1)",3),P=$P($P(P,"U,",2),")",1),P=$N(^DD(%X,"GL",G,P,0))
	I $D(^DD(%X,P,0)) S:DJ DIPP(DIJ,+%)=DIPP(DIJ,%X),DIPP(DIJ,%X)=$P(^(0),U)_":" S:'DJ DIPP(DIJ,+%)=$P(DIPP(DIJ),U,3),$P(DIPP(DIJ),U,3)=$P(^(0),U)_":"
	G E2
	;
L	K DIC S DIC="^DD(DL,",X=""
	I $D(BY) S DIC(0)="Z",X=$P(BY,C,1),BY=$P(BY,C,2,99) Q:X'="@"
	S DIC("S")="S %=$P(^(0),U,2) I %'[""m"",$S('%:1,1:$P(^DD(+%,.01,0),U,2)'[""W""&$S($D(DIL(+%)):DIL(+%)=DL,1:1))"_$S($D(DICS):" "_DICS,1:""),DIC("W")="W:$P(^(0),U,2) ""  (multiple)""",DIC(0)="ZE"_$E("O",$D(DIPP)#10)
	W !,DV R X:DTIME S:'$T X=U,DTOUT=1
	S:X=""&$D(DIPP(DIJ)) X=$P(DIPP(DIJ),U,3) I X="@" K DPP(DJ) S DJ=DJ-1 Q
L2	Q:X'?1"?"."?"!($D(DTOUT))  D ^DIC,DIP^DIQQ G L
	;

DIP1
DIP1	; SF/GFT - PROCESS FROM-TO ;5/8/89  17:53 ;
	;;17.7;VA FileMan; 6/9/89
	D DJ Q
DUP	D DPQ G DIP1^DIQQQ:$D(A(1))
	I '$D(BY),$D(DPP(2,"T"))!$D(DPP(3))!$D(DXS)!$D(DIAR) S DK=S G S^DIBT:'$D(DIAR),N:DUZ(0)'="@",S^DIBT
DIP2	S DC=0 D:'$D(DISYS) OS^DII G ^DIP2
N	;
	S DCC=DI,C="," G DIP2
	;
DPQ	K A F X=1:1 Q:$D(DPP(X))#2=0  S A=$E($P(DPP(X),U,1,3),1,30),Y=$P(DPP(X),U,4),DPP=X S:Y'["'" (A($D(A(A))),A(A))=0 I Y'["@",Y'["'" S DPQ(+DPP(X),$P(Y,"""",2)+$P(DPP(X),U,2))=""
	K DPP(X) Q
	;
DJ	Q:$D(DPP(DJ,"F"))
J	I $D(DIAR) S X=$P(DIARB0,U,2) I +X>0,$D(^DIBT(X,2,DJ))=11,DPP(DJ)'=^(DJ) S X="@" K DJ G ENTT^DIQQ
	S %=$P(DPP(DJ),U,2),R=%+$P($P(DPP(DJ),U,4),"""",2),DC=$S($D(^DD(+DPP(DJ),$S(R:R,%="":U,1:.001),0)):$P(^(0),U,2,3),1:$P(DPP(DJ),U,7,8)),R=$P(DPP(DJ),U,3)
	K DIC,DIARE,DIARS
S	S A="FIRST" I 'L,$D(FR)#2 S %=FR D Z I  G S0:'$D(DIAR)
	I $D(DIAR) D FROM^DIARCALC
	W !?DJ+DJ-2,"START WITH ",R,": ",A,"// " R X:DTIME E  S X=U W *7
S0	I X="" Q:'$D(DIAR)&(A="FIRST")  S X=$S(A="FIRST":"",1:A)
	I X["?" D DIP1F^DIQQ G S
	D CK:X'="" G Q:X[U I X'="" G S:X'?.ANP,S:Y<0
	I $D(DIARS),$P(DIARS,U,1)]Y D FER^DIQQ G S
	S M=1 D PAR I +Y=Y S Y=Y-$S(Y:.00001,$P(DPP(DJ),U,2)'=0&$L(DC):1,1:0)
	E  F %=$L($E(Y,1,30)):-1:1 S M=$A(Y,%) I M>32 S Y=$E(Y,1,%-1)_$C(M-1)_$C(122) Q
	S B=Y S:$D(DIAR)&'$D(DPP(DJ,"ASK")) Y=Y_U_X S (B,DPP(DJ,"F"))=Y
T	S Y="z",A="LAST" I 'L,$D(TO)#2 S %=TO D Z I  G T0:'$D(DIAR)
	I $D(DIAR) D TO^DIARCALC I A'="LAST",$D(DIARE),$P(DPP(DJ,"F"),U,1)]$P(DIARE,U,1) D TER^DIQQ G S
	W !?DJ+DJ-2,"GO TO ",R,": ",A,"// " R X:DTIME E  S X=U W *7
T0	I X["?" D DIP1T^DIQQ G T
	I X="",A'="LAST" S X=A
	D:X]"" CK G Q:X[U,T:Y<0
	I $D(DIARE),Y]$P(DIARE,U,1) D TER^DIQQ G T
	I $D(DIARS),$P(DIARS,U,1)]Y D FER^DIQQ G T
	S M=2 D PAR:Y'="z"
	I $P(DC,U,1)["D",+$E(Y,6,7),(Y'[".") S Y=Y_.9999
	I $D(DIAR),'$D(DPP(DJ,"ASK")) S Y=Y_U_X
	S DPP(DJ,"T")=Y Q:B["?z"!(Y="@")
	I +B=B,+Y=Y,B'>Y Q
	I $P(B,U,1)]$P(Y,U,1) D FER1^DIQQ G T
	Q
Q	G Q^DIP
	;
PAR	S M=$P($P($P($P(DPP(DJ),U,5),";P",2),";",1),"-",M) I M]"",M?.ANP S DIPA($E(M,1,30))=Y
	Q
	;
CK	G QQ:X["""" I X="@" S Y=X K DPP(DJ,"IX") Q
	S M=$P(DC,U,1)
P	I M["P",$D(^DD(+$P(M,"P",2),.01,0)) S M=$P(^(0),U,2) G P
	I M["D" S %DT="T"_$E("E",L) D ^%DT K %DT Q
	I M["S" G QQ:X[":"!(X[";") F Y=1:1 S D=$P($P(DC,U,2),";",Y),DA=$P(D,":",1),D=$P(D,":",2) Q:DA=X!'$L(D)  I $P(D,X,1)="" W:L $P(D,X,2,9) S X=DA Q
	I +X=X!(M'["N") S Y=X Q
QQ	W *7,"??" S Y=-1 Q
	;
Z	S X=$P(%,C,DJ) I X'="?"

DIP11
DIP11	; SF/XAK - GET SORT TEMPLATE ;4/14/89  13:59
	;;17.7;VA FileMan; 6/9/89
TEM	;
	G B^DIP:DJ-1 K DPP,DIC
	S X=$P($E(X,2,99),"]",1),DIC(0)="ZQS"_$E("E",L'=0),DIC="^DIBT(",D="F"_DL
	S DIC("S")="I $P(^(0),U,4)=DL,$S(L=0:1,'$D(^(1)):1,'$P(^(0),U,5):1,1:$P(^(0),U,5)=DUZ)"
	I X?."?" S:X'?1"???" X="??" D IX^DIC S DJ=0 Q
	D ^DIC I Y<0 S DJ=0 Q
	S DPP(1)=DL_"^^'"_$P(Y,U,2)_"' NUMBER^@'"_P,(DIBT1,X)=+Y,D=DIC_X_C,Y=1 K DIC
	I '$D(FLDS),$D(^("DIPT")),^("DIPT")]"" S FLDS="["_^("DIPT")_"]" S:L L=0
	I $D(^(1)) S DIC=D_1_C F DY=1:1 S Y=$N(^(Y,-1)) S:$N(^(Y))>0 Y=$N(^(Y)) I $D(^(Y))<9 S DPP(DJ,"IX")=DIC_DI_U_DY,DIBT=X Q
	Q:'$D(^DIBT(X,2))  S %Y="DPP(",%X=D_2_C D %XY^%RCR
	I $D(DIAR) S DIARU=X I '$P(DIARB,U,2) S $P(DIARB,U,2)=DIARU
	F D=0:0 S D=$N(^DIBT(X,3,D)) Q:D<0  S DSC(D)=^(D)
	G T1:'L S %=$P(^DIBT(X,0),U,6)
	I %]"" F D=1:1:$L(%) I DUZ(0)[$E(%,D)!(DUZ(0)="@") S %="" Q
	I %="" W !,"WANT TO EDIT '"_$P(Y(0),U,1)_"' TEMPLATE" S %=2 D YN^DICN G EDT^DIP0:%=1,Q^DIP:%<1
T1	F DJ=1:1 Q:'$D(DPP(DJ))  I $D(DPP(DJ,"ASK")) K DPP(DJ,"F"),DPP(DJ,"T"),DIARS,DIARE D J^DIP1 G Q^DIP1:'$D(DJ)
	D DPQ^DIP1 S X="["_$P(Y(0),U,1) K DIARE,DIARS,DIARB Q
	;
Z	S X=$P(%,C,DJ) I X'="?"
	Q

DIP2
DIP2	; SF/GFT - PRINT FLDS OR TEMPLATES ;4/12/89  13:46
	;;17.7;VA FileMan; 6/9/89
	K ^UTILITY("DIP2",$J),DG,K,DISH,DIL,DXS,A,P,I,J S I(0)=DI,(DE,DINS,DV,DNP)="",(DXS,DL,R)=1,(DIPT,DJ,DCL,DIL)=0,DK=+$P(@(DI_"0)"),U,2),J(0)=DK
EN	;
F	S (P,S)=""
1	I $D(DIAR),'DC G ER:'$D(^DIAR(0,DK,0)) S DU=$P(^(0),U,5) S:DU="" DU=$O(^(2,"C",0)) S:DU="" DU="CAPTIONED" S DU="["_DU_"]" G 2
	S DU=$P(^DD(DK,0),U,1) I DL>1 S:DU="FIELD" DU=$N(^(0,"NM",0))_" "_DU I $N(^($N(^DD(DK,0))))'>0,$P(^(.01,0),U,2)["W" S:'DINS&DC DC=DC-2 S Y=.01 D P G N
	K DIC,Y K:$D(DALL)<9 DALL I 'L,$D(FLDS) S X=$P(FLDS,C,R),R=R+1 G LIT
	I DC D ^DIP22:'$D(DC(DC))
2	W !?DL+DL-2 I '$D(DIAR)!DC W $S(DE]""!($D(DJ)>9):"THEN",1:"FIRST")_" PRINT "_DU_": "
	E  I 'DC W "USE PRINT TEMPLATE: ",DU,"// "
	I DC W DC(DC) D RW G Q^DIP:X=U S DINS=X?1"^"1E.E,X=$S(DINS:$E(X,2,999),X="":DC(DC),1:X) S:DC(DC)=""&$L(X) DINS=1 G LIT
	R X:DTIME G Q^DIP:X=U!'$T I '$D(DIAR),X="ALL",DE="",$D(DJ)<2 W "  Do you mean ALL the fields in the file" S %=2 D YN^DICN G Q^DIP:%<1,N:%=1 W !?10,X
LIT	I X?1"""".E1"""".E,$P($P(X,Q,3),";",1)="" S S=X G S
	S DIC="^DD(DK,",DIC(0)=$E("ZE",1,'$D(FLDS)!''L+1)_$E("O",1,DC>0),DIC("W")="S %=$P(^(0),U,2) I % W $S($P(^DD(+%,.01,0),U,2)[""W"":""  (word-processing)"",1:""  (multiple)"")" S:$D(DICS) DIC("S")=DICS
DIC	G DIC^DIP22
RTN	I DC,X="@" D DC G F
	G DIP2^DIQQ:X?."?",Q^DIP:X=U I $P("NUMBER",X,1)="" W $P("NUMBER",X,2) S S=0_S G S
	S DIC(0)="EYZ",D="GR" I $D(^DD(DK,D)) D IX^DIC G GF:Y>0 I 'Y F Y=0:0 S Y=$N(Y(Y)) G F:Y<0 S X=^DD(DK,Y,0) D Y
	G HARD^DIP22
	;
GF	I $P(Y(0),U,2) D D,DC:DC S X=$P($P(Y(0),U,4),";",1),I(DIL)=$S(+X=X:X,1:Q_X_Q),J(DIL)=DK G 1
	I +Y=.001 S Y=0
	S S=+Y_S I P]"",$D(DCL(DK_U_+Y)) G QQ^DIP22
S	D DJ G F
	;
D	S DIL(DL)=DIL,DV(DL)=DV,DL(DL)=DK,DK=+$P(^DD(DK,+Y,0),U,2),DL=DL+1,DIL=DIL+1,DV=DV_+Y_C,Y=0 Q
	;
U	S DL=DL-1,DV=DV(DL),DK=DL(DL),DIL=DIL(DL) F %=DIL:0 S %=$N(I(%)) Q:%<0  K I(%),J(%)
	Q
	;
DC	Q:DINS  K:DC>1 DC(DC) S DC=DC+1 Q:'$D(DIAR)
	I $D(DC(DC)),DC(DC)'="" Q
	D U:DL>1 S:$O(DC(DC)) DC=$O(DC(DC)) S:'$D(DC(DC)) DC(DC)="" Q
	;
Y	S S=Y_S
DJ	I $L(DE)+$L(S)>150 S DJ=DJ+1,^UTILITY("DIP2",$J,DJ)=DE,DE=""
	S DE=DE_DV_S_$C(126),S="" D DC:DC
P	Q:'$D(P)  I P="" K DNP Q
	I P="*" S DCL=DCL+1
	S DCL(DK_U_+Y)=$S($T:DCL_P,1:P) Q
	;
N	S I=DL S:I=1 DALL=1
NN	S Y=.001 I $D(^DD(DK,Y)) S Y=0 D Y S Y=.001
A	S Y=$N(^DD(DK,Y)) I $D(^(Y,8)),$D(DICS) X DICS E  G A
	I Y'>0 G UP:I'<DL S Y=$P(DV,C,DL-1) D U G A
	I $P(^(0),U,2) D D G NN
	D Y G A
	;
UP	K DIC I DL>1 D U,DC:DC G F
	I DE="",'DJ,'$D(DHIT),'$D(DIS) G F
	I $D(FLDS)>9 S X=$O(FLDS("")) I X]"" S FLDS=FLDS(X),R=1 K FLDS(X) G F
	G ^DIP3
	;
RW	I $L(DC(DC))>19 S Y=DC(DC) D RW^DIR2 Q
	W "// " R X:DTIME S:'$T X=U,DTOUT=1 Q
	;
ER	W *7,!!,"Archivers MUST use templates!",! G 2

DIP21
DIP21	; SF/GFT - PROCESS PRINT TEMPLATE ;4/18/89  10:43 ;2/14/89  12:37 PM
	;;17.7;VA FileMan; 6/9/89
	D D S DIC(0)=$E("E",'$D(FLDS)!''L)_"QZS",DIC("S")="I $D(^(""F"")) "_DIC("S")
	D IX^DIC K DIC I Y<0 G Q^DIP:$D(DTOUT),^DIP2:L,Q^DIP
C	I L,+Y=.01 K DPQ(DK) S %=2,DIQ(0)="" W "PRINT COMPUTED FIELDS" D YN^DICN G Q^DIP:%<0 S:%=1 DIQ(0)="C" I '% W !?5,"Answer 'Y' if you want computed fields to be printed.",!?39 G C
	I L,Y'<1 D W:DUZ(0)'="@" I  S %=2 W !,"WANT TO EDIT '",$P(Y,U,2),"' TEMPLATE" D YN^DICN G ED:%=1
	K:'$D(^("DNP")) DNP S DIPT=+Y,DALL=1,DHD=$S($D(DHD)=1:DHD,$D(^("H")):^("H"),1:""),DC(0)=+Y I $D(^("SUB")),^("SUB") S DISH=1
	I $D(^("ROU")),^("ROU")[U S DIPZ=+Y G PAGE^DIP3:DHD="@"
	E  D F
