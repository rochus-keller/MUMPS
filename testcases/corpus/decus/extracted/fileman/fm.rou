	;
F	;
	S DE="",R=0
	F X=0:0 S R=$N(^DIPT(+Y,"DCL",R)) Q:R<0  F D=1:1 Q:D>$L(^(R))  S Z=$E(^(R),D) I Z?1P S DCL(R)=$S($D(DCL(R)):DCL(R)_Z,1:Z)
	F X=0:0 S X=$N(^DIPT(+Y,"DXS",X)),%=-1 Q:$N(^(X,%))<0  I '$D(DIPZ)!$D(^(9.2))!$D(^(9)) F X=X:0 S %=$N(^(%)) Q:%<0  S DXS(X,%)=^(%)
	Q
	;
ED	S DA=+Y,DRK=DK K Y
	S DRK=DK,DIE="^DIPT(",DR=".01;3;6" D ^DIE K DR G Q^DIP:$D(Y)
	S DC=0,DI=I(0) I $D(DA) S D9="",DC(0)=DA,DC(1)=-1 D ^DIP22
	S DALL(1)=1 G ^DIP2
	;
PUT	;
	D NOW^%DTC S DIPDT=+$J(%,0,4) R !,"STORE PRINT LOGIC IN TEMPLATE: ",X:DTIME G Q^DIP:X=U!'$T,OUT:X=""
	D D S DIC(0)="ELZSQ",DIC("S")="I Y'<1 "_DIC("S"),Y=-1,DLAYGO=0 D IX^DIC:X]"" K DIC,DLAYGO,IOM G:Y<0 PUT:X'[U,Q^DIP
	S S=$N(^(0))+1,DA=$S('$D(^("ROU")):1,^("ROU")'[U:1,'$D(^("IOM")):1,'$D(^("ROUOLD")):1,1:^("ROUOLD")) S:'DA IOM=^("IOM")
	I S W *7,!,"TEMPLATE ALREADY STORED THERE...." D W:DUZ(0)'="@" G PUT:'$T W " OK TO REPLACE" S %=0 D YN^DICN W ! G PUT:%-1 L ^DIPT S %Y="" F %X=0:0 S %Y=$O(^DIPT(+Y,%Y)) Q:%Y=""  K:%Y'="%D" ^DIPT(+Y,%Y)
	S ^DIPT("F"_J(0),$P(Y,U,2),+Y)=1,^DIPT(+Y,0)=$P(Y,U,2)_U_DIPDT_U_$S('S:DUZ(0),1:$P(Y(0),U,3))_U_J(0)_U_DUZ_U_$S('S:DUZ(0),1:$P(Y(0),U,6))_U_DT S:DHD]"" ^("H")=DHD S:$D(DNP) ^("DNP")=1 S X=$D(^("DCL",0)) L  K DIPDT,%I
	F S=0:0 S X=$N(DCL(X)) Q:X<0  S ^(X)=DCL(X)
	F S=0:0 S S=$N(DXS(S)) Q:S<0  F %=0:0 S %=$N(DXS(S,%)) Q:%<0  S ^DIPT(+Y,"DXS",S,%)=DXS(S,%)
	F S=1:1:DJ S ^DIPT(+Y,"F",S)=^UTILITY("DIP2",$J,S)
	I DE]"" S ^DIPT(+Y,"F",S+1)=DE
	I $D(DIAR) S DIARP=+Y
SUB	I DHD="@" W !,"DO YOU ALWAYS WANT TO SUPPRESS SUBHEADERS WHEN PRINTING TEMPLATE" S %=1 D YN^DICN G DIP21^DIQQQ:'%,Q^DIP:%<0 I %=1 S ^DIPT(+Y,"SUB")=1,DISH=1
	I 'DA,$D(^DD("OS",DISYS,"ZS")) S X=DA,DMAX=^DD("ROU") D ENDIP^DIPZ I $D(^DIPT(DIPZ,"H")) S DHD=^("H")
OUT	G PAGE^DIP3
	;
W	S %=$P(^(0),U,6) F X=1:1:$L(%) I DUZ(0)[$E(%,X) Q
	Q
	;
D	;
	S X=$P(X,"]",1),X=$P(X,"[",1)_$P(X,"[",2),D="F"_DK S:'$D(^DIPT(D,"CAPTIONED",.01)) ^(.01)=1 I $D(^DIPT("B","WPDI",.001)),'$D(^DIPT(D,"WPDI",.001)) S ^(.001)=1
	K DIC S DIC="^DIPT("
	S DIC("S")="S %=^(0) I $P(%,U,4)=DK!'$L($P(%,U,4))"_$P(" F DW=1:1:$L($P(%,U,3)) I DUZ(0)[$E($P(%,U,3),DW) Q",U,DUZ(0)'="@"&L)
	Q

DIP22
DIP22	; SF/GFT - EDIT PRINT TEMPLATE ;6/9/89  12:01
	;;17.7;VA FileMan; 6/9/89
	S DC(1)=$N(^DIPT(DC(0),"F",DC(1))),DC=0 Q:DC(1)<0  S DC=2,DY=^(DC(1)),Y=2
Y	S X=$P(DY,$C(126),1),DY=$P(DY,$C(126),2,99) I X="" G DIP22:'$D(DC(2)) Q
	I D9]"" G UP:$P(X,D9,1)]"" S X=$P(X,D9,2,99)
R	I X'>0 G 0:$E(X,2)'=C&'X S:+X D9=D9_+X_C,DRK=-X G M
	I X[C S DA=$P(X,C,1) I +DA=DA S:DA<0 DA=-DA G Y:'$D(^DD(DRK,DA,0)) S X=$P(X,C,2,99),DC(Y)=$P(^(0),U,1),%=+X,D=+$P(^(0),U,2) G Y:'$D(^DD(D,.01,0)),W:$P(^(0),U,2)["W" S DRK=D,Y=Y+1,D9=D9_DA_C G R
	S %=+X,D=DRK_U_% D DCL
	G Y:'$D(^DD(DRK,%,0))
W	S X=$P(^(0),U,1)_$E(X,$L(%)+1,999)
P	S DC(Y)=X,Y=Y+1 G Y
0	S:X?1"0".E X=$S($D(^DD(DRK,.001,0)):$P(^(0),U,1),1:"NUMBER")_$E(X,2,999) S D=DRK_"^0" D DCL
M	S %=$F(X,";Z;""") G P:'% S %=%-$L($P(X,";",1)),X=";"_$P(X,";",2,99) F D=%:0 S D=$F(X,Q,D) I ";"[$E(X,D) S X=$E(X,%,D-2)_$E(X,1,%-5)_$E(X,D,999) G P
	;
UP	S DRK=J(0),%=D9,DA=""
DOWN	I X[C,+X=$P(X,C,1),$P(D9,DA_+X_C,1)="" S DA=DA_+X_C,%=$P(%,C,2,99),DRK=$S(X'>0:-X,1:+$P(^DD(DRK,+X,0),U,2)),X=$P(X,C,2,99) G DOWN
NUL	S D9=DA,DC(Y)="",Y=Y+1,%=$P(%,C,2,99) G NUL:%]"",R
	;
X	;
	S DC(1)=DD D Y F D=2:1 Q:'$D(DC(D))  S X=DC(D) X DICMX I '$D(D) K DD Q
	Q
	;
HARD	;
	S DM=X,DQI="DIP(",DA="DXS("_DXS_C,S=S_";Z;"""_X_Q,DICOMP=DIL_$E("?",''L)_"TI"
	S DICOMPX=""
	I X'?.E1":" S DICMX="X DICMX" D EN^DICOMP G QQ:'$D(X)&'$D(FLDS) D FLY G S^DIP2
	S DICMX="S DIXX=DIXX("_DL_") D M" D ^DICOMPW
	I $D(X) S %=Y D OVFL,F S S=U_$P(DP,U,2)_U_$E(1,%["m")_U_S,X=1,P="",DIL(DL)=DIL,DV(DL)=DV,DL(DL)=DK,DK=+DP,DV=DV_-DP_C,Y=0,DL=DL+1,DIL=+% K P G S^DIP2
QQ	;
	W *7,"??" G F^DIP2
	;
FLY	;
	S:'$D(X) X=DM S %=Y["D"
	I %,S'[";R",S'[";L" S S=S_";L18"
	I Y["W",S'[";X" S S=S_";X"
	I Y["m" S:S'[";m" S=S_";m" I Y["w",S'[";w" S S=S_";w"
	D OVFL I P="",Y'["X" S X=X_$S(S[";W":"",%:" S Y=X D DT",1:" W X")_" K DIP"
F	S S=X_S S:P]"" S=S_";"_P
DXS	F Y=0:0 S Y=$N(X(Y)) Q:Y=-1  S @(DA_"Y)")=X(Y)
	S DXS=$D(X)>1+DXS K DATE,X Q
	;
OVFL	I $L(X)+$L(S)>180 S X(9)=X,X="X DXS("_DXS_",9)"
	Q
DIC	I X="NUMBER" G B:'$D(DIAR),B:'$D(DC(DC)),B:DC(DC)=""
	I $D(DIAR),'DC S:X="" X=DU G ER^DIP2:$E(X)'="[",^DIP21
	D ^DIC G E:'$D(DIAR)
	I $D(DC(DC)) G E:DC(DC)=""
	G E:$P(X,";",1)=$P(DC(DC),";",1) I X="" G UP^DIP2:DL>1,E
	G E:'$D(DC(DC))
	I $P(X,";",1)'=$P(DC(DC),";",1) G E:$P($P(Y,U,2),";",1)=$P(DC(DC),";",1)
	W !,*7,"Because this is an ARCHIVING process:"
	W !!,"You may ADD fields to output or CHANGE PREDIFINED FIELD formats"
	W !,"but NOT change, delete or do calculations on predefined fields.",!
	G 2^DIP2
E	I $D(Y) G GF^DIP2:Y>0
	G UP^DIP2:X="",^DIP21:X?1"[".E&(DE="")
B	S %=$L(X) F D="+","#","*","&","!" S Y=$S($E(X)=D:$E(X,2,999),$E(X,%)=D:$E(X,1,%-1),1:"") I Y]"" S P=D,X=Y G DIC
	I X[";" S S=";"_$P(X,";",2,99)_S,X=$P(X,";",1) G DIC
	I $E(X)="]" S X=$E(X,2,999),DALL(1)=1 G DIC
	G RTN^DIP2
	;
DCL	I $D(^DIPT(DC(0),"DCL",D)) S X=X_$E(^(D),$L(^(D)))
	Q

DIP3
DIP3	; SF/GFT - PRINT HEADING, PAGE, COPIES ; 7/14/88  12:13 ;
	;;17.7;VA FileMan; 6/9/89
	I DJ,DE]"" S DJ=DJ+1,^UTILITY("DIP2",$J,DJ)=DE,DE=""
H	G G:L?1"]".E,PAGE:'L D HD W !,"HEADING: " S DA=X
	I $L(X)>19 S Y=X W Y D RW^DIR2 S DHD=$S(X="@":X,X=U:X,1:Y) G Q^DIP:X=U!($D(DTOUT)),Q
	W X,"// " R DHD:DTIME G Q^DIP:DHD=U!'$T I DHD="" S DHD=X G G
Q	I DHD="?" W !,"FOR NO HEADING AT ALL, TYPE '@'",!,"TO USE A PRINT TEMPLATE FOR HEADING, TYPE '[TEMPLATE NAME]'",! G H
	I DHD?.P1"["1E.E F DC=1,2 S X=$P($P(DHD,"[",DC+1),"]",1) D D^DIP21 S DIC(0)="ESF",DIC("S")="I '$D(^(""DCL"")) "_DIC("S") D IX^DIC K DIC G H:Y<0&$L(X) I Y>0 S DHD=$P(DHD,"[",1,DC)_"["_$P(Y,U,2)_"]"_$P(DHD,"]",DC+1,9) W:L !
	I DHD?1"W ".E G G:DUZ(0)="@"!(DA=DHD) F %=1:2 G G:$P(DHD,Q,%,999)="" I $P($E(DHD,3,999),Q,%)[" " G H
	G H:DHD[Q
G	S:'$D(DHD) DHD="" G PUT^DIP21:$S(L?1"]".E:1,$D(DALL)>9:1,$D(DALL):0,1:$L(DE)>13!DJ),PAGE
X	W *7,!,"TRY LATER" K IO("Q") G Q^DIP
	;
PAGE	;
	K DICOMPX,DA,ION,IO("C") S DC="," S:$D(DOUT)#2 DA=DOUT I 'L,$D(PG) S DC=C_(PG-1) K PG
	E  I L,DHD'="@" F X=1:1:DPP I $D(DPP(X,"F")) R !,"START AT PAGE: 1// ",X:DTIME S:'$T X=U Q:X=""  G DIP3^DIQQQ:X["?",X:X[U,DIP3:X\1'=X S DC=C_(X-1) Q
	I $D(%IS)[0,$D(^%ZTSCH("RUN")),$D(^%ZOSF("UCI")),$D(^DD("OS",DISYS,8)) S %IS="QM",%IS("B")=""
ZIS	S:$D(IOP) DIOP=IOP D ^%ZIS S:$D(DIOP) IOP=DIOP K DIOP G X:IO=""
	I $D(IOT),IOT="SDP",$D(^DD("OS",DISYS,"SDP")) G SDP
	G FREE
	;
SDP	S O=IO,W=IOPAR,R=IOST
	I '$D(DCOPIES) R !,"NUMBER OF COPIES: ",F:DTIME G SDPCLO:F[U!'$T,SDP:F\1'=F S DCOPIES=F
O	K IOP,%IS S:$D(IO("Q")) %IS="NM" W !,"OUTPUT COPIES TO"
	D ^%ZIS G SDPCLO:IO="",O:IO=O
	S DOUT=$S($D(ION):ION_";"_IOM_";"_IOST,1:IO),DA=IO,IO=O,IOPAR=W,IOST=R
FREE	S:'$D(IO(0)) IO(0)=$I S %=2,F=IOST["K",W=IOST["SINGLE"
	I $D(DIPZ),'$D(IOP),IO(0)=$I,$D(^DIPT(DIPZ,"IOM")),^("IOM")>IOM W *7,?8,"MARGIN WIDTH IS NORMALLY AT LEAST "_^("IOM"),!?8,"ARE YOU SURE" D YN^DICN G X:%<0,ZIS:%-1
	I IO(0)'=IO,'$D(IO("Q")),'$D(IOP)!$D(IOFREE),'W!F,IO(0)=$I,$S($D(DA):DA'=$I,1:1),$S($D(%IS)[0:1,1:%IS'["F"),$P(^DD("OS",DISYS,0),U,5) S %=2 W !,"WANT TO FREE UP THIS TERMINAL" D YN^DICN G CLO:%<0,DIP3^DIQQ:'% I %=1
	I $T!$D(IO("C")) W !,"THIS TERMINAL IS NOW FREE",!!,"Exit",! S IO("C")=1,X=$I,DM="" X ^DD("FUNC",7,1) S:$D(DIOEND)#2 DIOEND(9)=DIOEND,DM="X DIOEND(9) " S DIOEND=DM_$S($D(^%ZIS("C")):"G H^XUS",1:"H") K DUZ("NEWCODE")
	S X=$S($D(DHD):DHD,1:"") D HD:X="" S DHD=X,X=DC
	K DC,S,N,Q,H,DA,FR,TO,BY,DM,J,T,V,CP,DIC,DIE,DRK,DINS,DALL,%IS,IOS S O=0,DK=DI,DC=X,C=","
	G ^DIP5:'$D(IO("Q")),^DIP4
	;
SDPCLO	S IO=O
CLO	S X=IO X ^DD("FUNC",7,1) G X
	;
HD	S @("X=$P("_DI_"0),U,1)"),X=X_$S($D(DCL)>9:" STATISTICS",$D(DIS)>9:" SEARCH",1:" LIST")
	I $D(DC(0)),$D(^DIPT(DC(0),"H")) S X=^("H")

DIP4
DIP4	; SF/XAK - QUEUE & DEQUEUE ;3/29/89  14:47
	;;17.7;VA FileMan; 6/9/89
	K IO("Q") S %DT="TEX",X="" I $D(DQTIME)#2 S X=DQTIME,%DT="XT"
W	R:'$D(DQTIME) !,"REQUESTED TIME TO PRINT: NOW// ",X:DTIME G X^DIP3:X[U!'$T S Y=$H
	I $P("NOW",X)]"" S:X'["@" X="T@"_X S %DT(0)="NOW" D ^%DT K %DT(0) G:Y<1 X^DIP3:$D(DQTIME),W S X=+Y D H^%DTC S Y=Y_"000",Y=%H_","_($E(Y,9,10)*60+$E(Y,11,12)*60)
	W ! S ZTDTH=Y X ^%ZOSF("UCI") S ZTUCI=Y,ZTRTN="ZTSK^DIP4",ZTDESC=DHD
	S DX=$O(^DIC(9.4,"B","KERNEL","")) I DX S DX=$S($D(^DIC(9.4,+DX,"VERSION")):^("VERSION")'<6,1:0)
	I 'DX L ^%ZTSK S (^%ZTSK(0),ZTSK)=^%ZTSK(0)+1 L  S ^%ZTSK(ZTSK,0)=ZTRTN_U_DUZ_U_ZTUCI_U_$H_U_ZTDTH_U,X="^%ZTSK("_ZTSK_"," X ^DD("OS",DISYS,8)
	S:DX ZTSAVE("^UTILITY(""DIP2"",$J,")=""
	I 'DX F J=1:1:DJ S ^%ZTSK(ZTSK,97,J)=^UTILITY("DIP2",$J,J)
	I $D(DPP(1,"IX")),DPP(1,"IX")["^UTILITY(U,$J" S:DX ZTSAVE("^UTILITY(U,$J,")="" I 'DX F J=0:0 S J=$O(^UTILITY(U,$J,J)) Q:J'>0  S %=$N(^(J,0)) S:% ^%ZTSK(ZTSK,"^UTILITY(U,$J,",J,%)=""
	S ZTIO=$S($D(ION)#2:ION,1:IO) I $D(IOST)#2,IOST]"" S ZTIO=ZTIO_";"_IOST
	I $D(IO("DOC")),IO("DOC")]"" S ZTIO=ZTIO_";"_IO("DOC") G ZTM
	I $D(IOM)#2,IOM S ZTIO=ZTIO_";"_IOM I $D(IOSL)#2,IOSL S ZTIO=ZTIO_";"_IOSL
ZTM	I DX S ZTSAVE("*")="" D ^%ZTLOAD
	S:'DX ^%ZTSCH(ZTDTH,ZTSK)=ZTIO
	K ^%ZTSK(ZTSK,"DT"),^("ZTSK"),^("DISYS"),^(0,"DISYS") S:'DX ^("ZTDESC")=DHD
	K ^UTILITY("DIP2",$J),^UTILITY(U,$J),DIS,DXS,DX,DHD,ZTDESC,ZTDTH,ZTIO,ZTRTN,ZTUCI,FLDS,DCC,DIPT
	W "REQUEST QUEUED!",! X:$D(^%ZIS("C")) ^("C") G Q^DIP
	;
ZTSK	;
	D 0^DICRW K ^%ZTSK(ZTSK,"Y") S POP=0 I $D(DX),DX G K
	S Y="%" F Z=0:0 S Y=$N(^%ZTSK(ZTSK,Y)),%=$D(^(Y)) Q:'%  S:%#2 @(Y_"=^(Y)") I %>9 S %X="^%ZTSK(ZTSK,Y,",%Y=Y_$E("(",Y'["(") D %XY^%RCR
	K ^UTILITY("DIP2",$J) F Z=1:1:DJ S ^UTILITY("DIP2",$J,Z)=^%ZTSK(ZTSK,97,Z)
	S IOP=$S($D(ION):ION,1:IO) I $D(IOST)#2,IOST]"" S IOP=IOP_";"_IOST
	I $D(IO("DOC")),IO("DOC")]"" S IOP=IOP_$S($D(IO("DOC")):";"_IO("DOC"),1:"")
	I $D(IOM)#2,IOM S IOP=IOP_";"_IOM I $D(IOSL)#2,IOSL S IOP=IOP_";"_IOSL
	D ^%ZIS
K	G Q^DIP:POP,DQ^DITC1:$D(DIT),^DIP5

DIP5
DIP5	; SF/GFT - INITIALIZE TO PROCESS THE PRINT ;4/12/89  12:12 ;
	;;17.7;VA FileMan; 6/9/89
	S %H=$H D YMD^%DTC S DT=X K %H,^UTILITY($J),^("DIL",$J) U IO
	S Z=IOM-33,DIOSL=IOSL,^UTILITY($J,1)=$P("I 1 S Y=1 W:DC?.N *7 R:DC?.N Y:DTIME S:'$T Y=U S:Y=U DN=0 I Y'=U ",U,IOST?1"C".E)_"S DC=$P(DC,"","",2)+DC+1 W "_IOF_$P(",#",U,IOF'["#"),M=DHD?1"W ".E
	I W S ^(1)=^(1)_",*7"_$S(F:"",1:" U """_IO(0)_"""")_" R Y"_$S(F:"",1:" U IO")_" W """""
	I M S ^(1)=^(1)_" X ^(1.5)",^(1.5)=DHD G GO
	I DHD'?.P1"[".E1"]",DHD'="@" S M=$P($H,C,2)\60,^(2)=","_$E("!",$L(DHD)+2>Z)_"?"_Z_" S Y="_(M#60/100+(M\60)/100+DT)_" D DT W ""    PAGE "",DC",M="W """_DHD_"""" S:$L(M)+$L(^(2))>252 ^(2.5)=DHD,M="W ^(2.5)" S ^(2)=M_^(2),DHD=3
GO	S X=0 F Y=1:1:DPP I $P(DPP(Y),U,4)["!" S X=1
	G DIPZ:$D(DIPZ) D INIT S R=DE,DJ=-1 I X S (X,W)="",Y=",DRK",DRJ=0,DLN=3 K DNP D O^DIL
DIL	D ^DIL:R]"" S DJ=$S(DIPT:$N(^DIPT(DIPT,"F",DJ)),1:$N(^UTILITY("DIP2",$J,DJ))) I DJ+1 S R=^(DJ) G DIL
	D UNSTACK^DIL:DM,A^DIL G ^DIL2
	;
INIT	;
	D:'$D(DISYS) OS^DII K DIL,DIWR S DN=-2,(DIL,DIL0,DIWL,DIO,DM,DG,DX,DHT,DLN)=0,DY="D0",DI=DK_DY,@("DP=+$P("_DK_"0),U,2)"),M(DP)=1,DP(0)=DP,F="",Y=$S($D(^DD("OS"))[0!'$D(^DD("OS",DISYS,0)):0,1:$P(^(0),U,2)),DISMIN=99999
	Q
	;
DIPZ	I $S('$D(^DIPT(DIPZ,"ROU")):1,^("ROU")'[U:1,'$D(^("IOM")):1,1:^("IOM")>IOM)!X S Y=DIPZ D F^DIP21 K DIPZ G GO
	S DK=DCC D INIT S ^UTILITY($J,99,1)="D "_^DIPT(DIPZ,"ROU"),DX=1
	S X="" F DG=0:0 S X=$N(^DIPT(DIPZ,"STATS",X)) Q:X<0  S %X="^DIPT(DIPZ,""STATS"",X,",%Y=X_"(" D %XY^%RCR
	F X=-1:0 S X=$N(^DIPT(DIPZ,"T",X)) Q:X'>0  S ^UTILITY($J,"T",X)=^(X)
	F X=-1:0 S X=$N(DPQ(X)) Q:X<0  F %=-1:0 S %=$N(DPQ(X,%)) Q:%<0  K:$D(^DIPT("AF",X,$S(%:%,1:.001),DIPZ)) DPQ(X,%)
	G ^DIL2

DIPT
DIPT	; SF/XAK - DISPLAY PRINT OR SORT TEMPLATE ;11:52 AM  May 16, 1988
	;;17.7;VA FileMan; 6/9/89
	Q:'$D(^DIPT(D0,0))  S (DRK,J(0))=$P(^(0),U,4),L=0,DS(1)=0,D(L)="0FIELD",C=",",Q="""",D9="",Y=2
	F DS(1)=0:0 S DS(1)=$N(^DIPT(D0,"F",DS(1))) Q:DS(1)<0  S DY=^(DS(1)) D Y
	D:D9]"" UP F D=2:1 Q:'$D(DS(D))  S X=DS(D) W !?DIWD(D)*2,$S(D=2:"FIRST",1:"THEN")_" PRINT "_$P(DIWD(D),+DIWD(D),2)_": "_X_"//" I '$D(D) K DD
	W ! K DS,DIWD,D,DRK,J S X="" Q
Y	;
	S X=$P(DY,$C(126),1),DY=$P(DY,$C(126),2,99) Q:X=""
	I D9]"" G UP:$P(X,D9,1)]"" S X=$P(X,D9,2,99)
R	I X'>0 G 0:$E(X,2)'=C&'X S:+X D9=D9_+X_C,DRK=-X S:X<0 L=L+1,D(L)=L_$P(^DIC(DRK,0),U,1)_" FIELD" G M
	G NC:X'[C S DA=$P(X,C,1) G NC:+DA'=DA
	S:DA<0 DA=-DA G Y:'$D(^DD(DRK,DA,0)) S X=$P(X,C,2,99),DS(Y)=$P(^(0),U,1),%=+X,D=+$P(^(0),U,2),DIWD(Y)=L_$P(^DD(DRK,0),U,1) G Y:'$D(^DD(D,.01,0)),W:$P(^(0),U,2)["W" S DRK=D,D9=D9_DA_C,Y=Y+1,L=L+1,(DIWD(Y),D(L))=L_$P(^DD(D,0),U,1) G R
NC	S %=+X,D=DRK_U_% I $D(^DIPT(D0,"DCL",D)) S X=X_$E(^(D),$L(^(D)))
	G Y:'$D(^DD(DRK,%,0))
W	S X=$P(^(0),U,1)_$E(X,$L(%)+1,999)
P	S DS(Y)=X,DIWD(Y)=D(L),Y=Y+1 G Y
0	S:X?1"0".E X="NUMBER"_$E(X,2,999)
M	S %=$F(X,";Z;""") I '% S D=X G P
	S %=%-$L($P(X,";",1)),X=";"_$P(X,";",2,99) F D=%:0 S D=$F(X,Q,D) I ";"[$E(X,D) S X=$E(X,%,D-2)_$E(X,1,%-5)_$E(X,D,999) G P
	;
UP	S DRK=J(0),%=D9,DA=""
DOWN	I X[C,+X=$P(X,C,1),$P(D9,DA_+X_C,1)="" S DA=DA_+X_C,%=$P(%,C,2,99),DRK=$S(X'>0:-X,1:+$P(^DD(DRK,+X,0),U,2)),X=$P(X,C,2,99) G DOWN
NUL	S D9=DA,DS(Y)="",DIWD(Y)=D(L),L=L-1,Y=Y+1,%=$P(%,C,2,99) G NUL:%]"",R
	;
DIBT	; DISPLAY SORT FIELDS
	I '$D(^DIBT(D0,0))!'$D(^(2)) S X="" Q
	K DIPP,DPP S %X="^DIBT(D0,2,",%Y="DPP(" D %XY^%RCR
	F DIJ=0:0 S DIJ=$N(DPP(DIJ)) Q:DIJ<0  S DIPP(DIJ)=DPP(DIJ),%=+DPP(DIJ) D E1^DIP0 S %X=0 D E2^DIP0
	K DPP F DIJ=0:0 S DIJ=$N(DIPP(DIJ)) Q:DIJ<0  D DJ
	K DIPP,DIJ,DPP,DJ S X="" Q
	;
DJ	W !?DIJ*2-2,$S(DIJ>1:"WITHIN "_DPP(DIJ-1)_", ",1:"")_"SORT BY: "_$P($P(DIPP(DIJ),U,4),"""",1)_$P(DIPP(DIJ),U,3)_$P(DIPP(DIJ),U,5)_"//" S DPP(DIJ)=$P(DIPP(DIJ),U,3)
	I $D(^DD(+DIPP(DIJ),+$P(DIPP(DIJ),U,2),0)) S X=+$P(^(0),U,2) I X,$D(DIPP(DIJ,X)),$D(^DD(X,0)) W !?DIJ*2-2,$P(^(0),U,1)_": "_DIPP(DIJ,X)_"//" K DIPP(DIJ,X)
	F %=0:0 S %=$N(DIPP(DIJ,%)) Q:%'>0  I $D(DIPP(DIJ,%))#2 W !?DIJ*2-2,$S('$D(^DD(%,0,"UP")):$N(^("NM",0))_" ",1:""),$P(^DD(%,0),U,1)_": "_DIPP(DIJ,%)_"//" S DPP(DIJ)=DIPP(DIJ,%)
	I $D(^DIBT(D0,2,DIJ,"ASK")) W "    (User is asked range)" Q
	Q:'$D(^DIBT(D0,2,DIJ,"F"))
	S Y=^("F"),%Y=$S('$D(^("T")):"",^("T")="z":"",1:^("T")) S:Y[".9999" Y=$P(Y,".",1)+1 X:Y?1"2"6N.NP ^DD("DD") S %=$F(Y,"z"),X="     From '"_$S(%:$E(Y,1,%-3)_$C($A(Y,%-2)+1),1:Y)_"'",Y=%Y
	I Y]"" S:Y[".9999" Y=Y\1 X:Y?1"2"6N.NP ^DD("DD") S X=X_"  To '"_Y_"'"
	W X

DIPZ
DIPZ	; SF/XAK -  COMPILE PRINT TEMPLATES ;4/14/89  16:10 ;
	;;17.7;VA FileMan; 6/9/89
	I $S($D(DUZ(0)):DUZ(0)'="@",1:1) W *7,"FOR PROGRAMMERS ONLY" Q
EN1	D K,OS^DII:'$D(DISYS)
	I '$D(^DD("OS",DISYS,"ZS")) W "YOUR SYSTEM HAS NO WAY TO SAVE ROUTINES",*7 Q
	S T=^DD("ROU"),DTIME=$S('$D(DTIME):600,1:DTIME)
SIZ	W !!,"MAXIMUM ROUTINE SIZE ON THIS COMPUTER (IN BYTES): "_T_"// "
	R X:DTIME G:X="^"!'$T K S:X="" X=T
	I +X=X,X>2000 S ^DD("ROU")=X G TEM
	W *7,!?5,"The size must be a number greater than 2000, the larger, the better." G SIZ
TEM	S DMAX=X,DIC="^DIPT(",DIC(0)="AIEQ"
	S DIC("W")="W ?40,""FILE #"",$P(^(0),U,4) W:$D(^(""ROU"")) ?60,^(""ROU"")"
	S DIC("S")="I $D(^(""F""))>9" D ^DIC G K:Y<0 K DIC
DNM	S DIX="" I $D(^("ROUOLD")) S DIX=^("ROUOLD")
	W !,"NAME OF THE ROUTINE TO BE CREATED: " W:DIX]"" DIX_"// "
	R X:DTIME G K:X=U!'$T I X="",DIX]"" S X=DIX
	I X'?1U.NU&(X'?1"%"1U.NU)!($L(X)>7)!($L(X)<3)!(X?1"DI".E) W *7,!?5,"Use a valid MUMPS routine name of from 3 to 7 characters." G DNM
	I $D(^DD("OS",DISYS,18)) X ^(18) I  W *7,!?5,"NOTE THAT '",X,"' IS ALREADY IN YOUR ROUTINE DIRECTORY!"
IOM	S DIOM="" I $D(^DIPT(+Y,"IOM")) S DIOM=^("IOM")
	W !,"MARGIN WIDTH FOR OUTPUT: " W:DIOM]"" DIOM_"// "
	R IOM:DTIME G:IOM=U!'$T K I IOM="",DIOM S IOM=DIOM
	I IOM'?.N!(IOM>255)!(IOM<19) W *7,!?5,"Type a number from 19 to 255 which is the number of columns on the report." G IOM
	S %=0 W !,"READY TO COMPILE" D YN^DICN G K:%-1
	D ENZ
K	K DMAX,DIX,DIC,DCL,R,M,DE,DI,DPP,DIPZ,DHD,DIWL,DIWR,DK,DP,DNP,DCL,DITTO
	K %,%H,I,O,C,D,DD,DHT,DIL0,DIOM,DIP,DN,DU,F,H,L,N,S,Q,CP,DINC Q
	;
EN	;
	Q:'$D(^DIPT(Y,"IOM"))  S IOM=^("IOM") D ENZ G K
	;
ENZ	S (R,DCL,DPP)=0 F %=0:0 S R=$O(^DIPT(+Y,"DCL",R)) Q:R=""  F %=1:1 Q:%>$L(^(R))  S Z=$E(^(R),%) I Z?1P S DCL(R)=$S($D(DCL(R)):DCL(R)_Z,1:Z)
ENDIP	;
	W ! K ^UTILITY($J),^("DIL",$J),^UTILITY("DIPZ",$J),DIPZ,DNP,DIPZLR,DRN,DIPZL,DX,DXS,R
	S DNM=X,DIPZ=+Y,DRD=0,DP=$P(^DIPT(DIPZ,0),U,4),DHD=$S(^("H")="@":"@",1:3) S:$D(^("DNP")) DNP=1
	S DK=^DIC(DP,0,"GL"),DMAX=DMAX-450,DRN=0,R="",L=0,DINC=1
	I $D(DCL)>9 S DMAX=DMAX-600
	I '$D(IOM) Q:$D(^DIPT(DIPZ,"IOM"))[0  S IOM=^("IOM")
AF	D DT^DICRW,INIT^DIP5 S X=-1
	W !,"Compiling "_$P(^DIPT(DIPZ,0),U)_" print template of File "_DP
	F T=0:0 S X=$N(^DIPT("AF",X)) Q:X<0  F %=0:0 S %=$N(^DIPT("AF",X,%)) Q:%'>0  K:$D(^(%,DIPZ)) ^(DIPZ)
	F C=1:1 Q:'$D(^DIPT(DIPZ,"DXS",C,9.2))&'$D(^(9))  S DXS(C)=""
	S IOSL=24,DL=1,DIPZL=0,DHT=-1,C=",",Q="""",^UTILITY($J,1)=""
	F DIP=-1:0 S DIP=$O(^DIPT(DIPZ,"F",DIP)) Q:DIP=""  S R=^(DIP) D ^DIL
	D UNSTACK^DIL:DM,A^DIL,T^DIL2 K ^DIPT(DIPZ,"T") F R=-1:0 S R=$O(^UTILITY($J,"T",R)) Q:R=""  S ^DIPT(DIPZ,"T",R)=^(R)
	S DX=DX+999,Y=$P(" D ^DIWW",1,''$D(DIWR))_" K Y" I DIWL S Y=Y_" K DIWF" S:DIWL=1 ^UTILITY("DIPZ",$J,.5)=" S DIWF=""W"""
	D PX^DIPZ1 G ^DIPZ2

DIPZ1
DIPZ1	; SF/GFT,XAK - COMPILE PRINT TEMPLATES ;04:59 PM  May 11, 1988
	;;17.7;VA FileMan; 6/9/89
PX	;
	F DX=DX+1:1 I '$D(^UTILITY("DIPZ",$J,DX)) S ^(DX)=" "_$E(Y,2,999) Q
	W "." S O=0,DIPZL=$L(Y)+DIPZL I DIPZL>DMAX S DRN(DRN)=DX,^(DX+1)=^(DX),DIPZL=$L(Y),DRN=DRN+1,^(DX)=" G ^"_DNM_DRN,DX=DX+1
	Q
	;
DE	;
	D SUBNAME S DX=F(DM-1),^(DX)=^(DX)_" D "_X
D	S DIPZL(DM)=DX+1,DIPZLR(DM)=DRN,^(DX+1)=" G "_X_"R",^(DX+2)=X_" ;",DX=DX+2 Q
	;
DIWR	;
	S I=$D(^UTILITY("DIPZ",$J,1)) I $D(DIWR(DM)),DX=DIWR(DM) S ^(DX)=" D A^DIWW"
	E  I $D(DIWR(DM)) S DX=DX+1,^(DX)=" D ^DIWW"
	E  F I=DM-1:-1:0 I $D(DIWR(I)) K DIWR(I) S I=F(I),^(I-.1)=" D ^DIWW" Q
	K DIWR(DM) Q
	;
WP	;
	S I=$E(^UTILITY("DIPZ",$J,X),2,999) D WPX^DIL0 S ^UTILITY("DIPZ",$J,X)=" "_I Q
	;
DREL	;
	S %=X,DHT=Y,DM=DM+1 D SUBNAME F DX=DX+1:1 I '$D(^UTILITY("DIPZ",$J,DX)) S ^(DX)=" S DIXX("_DM_")="""_X_""""_% Q
	D D S DX=DX+2,^(DX-1)=" I $D(DSC("_DP_")) X DSC("_DP_") E  Q",^(DX)=" W:$X>"_DG_" !"_DHT,DHT=-1,F=F_+W_C,DIL=DIL+1,DD=DD-1,%=DX Q
	;
UP	;
	S ^UTILITY("DIPZ",$J,DX+1)=" Q",X=DIPZ(DM) D X
	S (F(DM-1),DX)=DX+2,^UTILITY("DIPZ",$J,DX)=X_"R ;" S:DIPZLR(DM)'=DRN ^(DIPZL(DM))=^(DIPZL(DM))_"^"_DNM_DRN Q
	;
SUBNAME	S (DIPZ(DM),X)=$S($D(DIPZ(DM))#2:DIPZ(DM)+1,1:1)
X	S X=$S(X<27:$C(64+X),1:$C(X\26+64,X#26+65))_DM Q

DIPZ2
DIPZ2	; SF/GFT,XAK - COMPILE PRINT TEMPLATES ; 7/13/88  11:46 ;
	;;17.7;VA FileMan; 6/9/89
	F R=0:0 S R=$O(DXS(R)),W="" Q:'R  K:$D(DXS(R))>9 ^DIPT(DIPZ,"DXS",R) F R=R:0 S W=$O(DXS(R,W)) Q:W=""  S ^DIPT(DIPZ,"DXS",R,W)=DXS(R,W)
	S DIPZLR=DRN,DRN="",DIL=0 D NEW I $D(^DIPT(DIPZ,"DXS")) S X=" I $D(DXS)<9 F X=0:0 S X=$O(^DIPT("_DIPZ_",""DXS"",X)) Q:'X  S Y=$O(^(X,"""")) F X=X:0 Q:Y=""""  S DXS(X,Y)=^(Y),Y=$O(^(Y))" D L
DIL	S DIL=$O(^UTILITY("DIPZ",$J,DIL)) G DHD:'DIL
	S DHT=^(DIL) I DRN<DIPZLR,DIL>DRN(+DRN) D SAVE
	S X=DHT D L G DIL
	;
DHD	F F=2.9:0 S F=$O(^UTILITY($J,F)) Q:'F  S DIL=$L(^(F))+DIL
	I DIL+DIPZL>DMAX D SAVE
	S X=" Q" D L S X="HEAD ;" D L F F=2.9:0 S F=$O(^UTILITY($J,F)) Q:'F  S X=" "_^(F) D L
	S X=" W !,""" F %=1:1 S X=X_"-" I %=IOM!(%>239) S X=X_""",!!" D L Q
END	D SAVE S ^DIPT(DIPZ,"ROUOLD")=DNM,^("IOM")=IOM,^("ROU")=U_DNM,^("LAST")=$S(DRN>1:DRN-1,1:""),DM=0,F=""
	K ^("STATS"),DXS F DIP="L","H","DITTO","CP","Q","N","S" I $D(@DIP)>9 S %X=DIP_"(",%Y="^DIPT(DIPZ,""STATS"",DIP," D %XY^%RCR
	F DIP=-1:0 S DIP=$O(^DIPT(DIPZ,"F",DIP)) Q:DIP=""  S R=^(DIP) W "." D R
K	K ^UTILITY($J),^("DIPZ",$J),DIPZL,DISMIN,%X,%Y,DG,DIL,DLN,DL,DM,DMAX,DNM,DRD,DRJ,DIO,DX,DY,IOM,DRN,DIPZLR,V,R,W,Y,T
	Q
	;
R	Q:R=""  S W=$P(R,$C(126),1),R=$P(R,$C(126),2,999)
DM	I DM G UP:$P(W,F,1)]"" S W=$P(W,F,2,999)
	I 'W S:W?1"0".E ^DIPT("AF",DP,.001,DIPZ)="" G R
	I $P(W,";",1)=+W S ^DIPT("AF",DP,+W,DIPZ)="" G R
	G R:W'?.NP1",".E I W<0 S X=-W G DOWN
	G R:'$D(^DD(DP,+W,0)) S X=+$P(^(0),U,2) G R:'X
DOWN	S DM=DM+1,DP(DM)=DP,DP=X,F=F_+W_C G DM
UP	S DP=DP(DM),DM=DM-1,F=$P(F,C,1,DM)_$E(C,DM>0) G DM
	;
SAVE	;
	S L=1.001,DINC=.001 S X=" G BEGIN" D L,OS^DII:'$D(DISYS) F %=$S($D(DCL)>9:1,0'[DCL:7,1:10):1 S X=$T(TEXT+%) Q:X=""  D L
	S X=DNM_DRN X ^DD("OS",DISYS,"ZS") W !,"'"_X_"' ROUTINE FILED"
	S DRN=DRN+1
NEW	K ^UTILITY($J,0) S X=DNM_DRN_" ; GENERATED FROM '"_$P(^DIPT(DIPZ,0),U,1)_"' PRINT TEMPLATE (#"_DIPZ_") ; "_$E(DT,4,5)_"/"_$E(DT,6,7)_"/"_$E(DT,2,3)
	S X=X_" ; ("_$S(DRN="":"FILE "_DP_", MARGIN="_IOM_")",1:"continued)"),L=1,DINC=1,^UTILITY($J,0,L)=X,X=" S:'$D(DN) DN=1"
L	S L=L+DINC,^UTILITY($J,0,L)=X Q
	;
TEXT	;
CP	G CP^DIO2
C	S DQ(C)=Y
S	S Q(C)=Y*Y+Q(C) S:L(C)>Y L(C)=Y S:H(C)<Y H(C)=Y
P	S N(C)=N(C)+1
A	S S(C)=S(C)+Y
	Q
D	I Y=DITTO(C) S Y="" Q
	S DITTO(C)=Y
	Q
N	W !
T	W:$X ! I '$D(DIOT(2)),DN,$D(IOSL),$S('$D(DIWF):1,$P(DIWF,"B",2):$P(DIWF,"B",2),1:1)+$Y'<IOSL,$D(^UTILITY($J,1))#2,^(1)?1U1P1E.E X ^(1)
	Q
DT	I Y W $P("JAN^FEB^MAR^APR^MAY^JUN^JUL^AUG^SEP^OCT^NOV^DEC",U,$E(Y,4,5))_" " W:Y#100 $J(Y#100\1,2)_"," W Y\10000+1700 W:Y#1 "  "_$E(Y_0,9,10)_":"_$E(Y_"000",11,12) Q
	W Y Q
M	D @DIXX
