R2	I DUZ(0)'="@" S DICS="I 1 Q:'$D(^(8))  F DW=1:1:$L(^(8)) I DUZ(0)[$E(^(8),DW) Q"
	K DIA Q
	;
AUDIT	S D="AUDIT FROM",DIC(0)="QEI",DIC("S")="I Y>1.1" S:DIA ^DISV(DUZ,"^DIC(")=DIA D DIC Q:'$D(DIC)  G AUDIT:Y<0 I '$D(^DIA(+Y,0))#2 W *7,"   NO AUDIT ENTRIES" G AUDIT
	S DIA=+Y,Y="1.1^"_$P(Y,U,2)_"AUDIT",DIC="^DIA(DIA," Q
R1	I DUZ(0)'="@" S DIC("S")="I 1 Q:'$D(^(0,""RD""))  F DC=1:1:$L(^(""RD"")) I DUZ(0)[$E(^(""RD""),DC) Q" I $D(^DIC(3,"AFOF")) S DIC("S")="I $P(^(0),U,5)"
	Q
DT	;
	W ! S:$D(DUZ)#2-1 DUZ=0 S:$D(DUZ(0))#2-1 DUZ(0)="" S X=DUZ(0)="@" D 1
	I '$D(DTIME) S DTIME=999
	K %DT,DT S:$D(IO(0))[0 IO(0)=$I D NOW^%DTC S DT=X
	K DIK,DIC,%I,DICS Q
	;
0	S X=0
1	D:'$D(DISYS) OS^DII I $D(^DD("OS",DISYS,1)) X ^(1)
	Q
	;
W	D DT S D="INPUT TO",DIC(0)=$E("L",$D(DLAYGO)>0)_"EQI"
	D W1,DIC Q:$T  G W:'$P(Y,U,3) K DIC Q
W1	S DIC("S")="I Y>.19,Y-1,Y-1.1"
	I DUZ(0)'="@" S DIC("S")="I 1 Q:'$D(^(0,""WR""))  F DC=1:1:$L(^(""WR"")) I DUZ(0)[$E(^(""WR""),DC) Q" I $D(^DIC(3,"AFOF")) S DIC("S")="I $D(^DIC(3,DUZ,""FOF"",Y,0)),$P(^(0),U,6)"
	Q
	;
DIC	W ! S U="^",D=D_" WHAT FILE: ",DIC="^DIC("
	I DUZ(0)'="@",DIC(0)'["L",$D(^DIC(3,"AFOF")) S DIC=DIC_"3,DUZ,""FOF"","
	I $D(^DISV(DUZ,DIC)) S Y=^(DIC) I $D(@(DIC_Y_",0)")) X:$D(DIC("S")) DIC("S") I  S Y=Y_U_$P(^DIC(Y,0),U,1),D=D_$P(Y,U,2)_"// "
	W D S %=$T R X:DTIME E  W *7 S X=U,DTOUT=1
	I '$D(@(DIC_"0)")) W "  There are no selectable files." K DIC S Y=-1 Q
	S:DIC["FOF" DIC(0)=DIC(0)_"O" I X="",% G WW
	S DIC("W")=$E($T(WW),4,999) D ^DIC Q:$D(DTOUT)
GOT	I $D(^DIC(+Y,0,"GL")) K DIC S DIC=^("GL") Q
	I U[X K DIC
	Q
WW	W:$X>53 !?9 I Y-1.1,$D(^DIC(Y,0,"GL")),^("GL")'["[",$D(@(^("GL")_"0)")) S %=+$P(^(0),U,4) W ?40,"  ("_%_" entr"_$P("ies^y",U,%=1+1)_")"
	G GOT
	;
D	D DT S D="MODIFY",DIC(0)="LQEI",DIC("S")="I Y>1.1"
	I DUZ(0)'="@" S DIC("S")="I 1 Q:'$D(^(0,""DD""))  F DC=1:1:$L(^(""DD"")) I DUZ(0)[$E(^(""DD""),DC) Q" I $D(^DIC(3,"AFOF")) S DIC("S")="I $D(^DIC(3,DUZ,""FOF"",Y,0)),$P(^(0),U,2)"
	D DIC S:DUZ(0)'="@" DICS="I 1 Q:'$D(^(9))  Q:^(9)=U  F DW=1:1:$L(^(9)) I DUZ(0)[$E(^(9),DW) Q"
	Q:$T  G D:'$P(Y,U,3) K DIC
	Q
L	;LIST MULTIPLE DD'S
	S DIB(1)=0 S D="START WITH" D C2 G C4:U[X&(Y<0),L:Y<0
C3	S D="GO TO" D C2 G C3:Y<0&(X'[U)
	I Y<DIB(1),X'[U W *7,!," The 'START WITH' File Number must be less than the 'GO TO' File Number." G L
C4	I X[U!'$D(DIC) K DIC Q
	S X=DIB(1),DIB(1)=+Y,Y=X Q
C2	D R1 S DIC(0)="QEI" D DIC Q:X[U!'$D(DIC)!(Y=-1)  S:DIB(1)=0 DIB(1)=+Y Q
DIAR	;
	S D="ARCHIVAL "_DIART_" FOR",DIC(0)="QEI" D R1,DIC G R2:$T,DIAR
	Q
T	; COMPARE/MERGE
	D DT S D="COMPARE ENTRIES IN",DIC=1,DIC(0)="QEI" D W1,DIC Q:$T  G T

DID
DID	; SF/XAK - LIST DD'S  ;5/31/89  13:53 ;3/1/89  3:03 PM
	;;17.7;VA FileMan; 6/9/89
	D KL,L^DICRW I $D(DIC) S (DUB,DIB,DFF)=+Y G O:Y'=+DIB(1),SUB
KL	K DHIT,DIB,DINM,DIDX,DIGR,DIDH,BY,DICMX,DIOEND,FLDS
	K DFF,DID,DUB,DHD,DIC,DICS,POP,DA,DR,S,F,J,K,Z,W,X,Y,M,G,N,I,DIGG
	K DIWF,DIJS,DIPP,DPP,DIMS,DIPQ,DJ,IOP,DDL1,DDL2,DDL3,DDLF,DDN1,X1,DDRG,I1 Q
	;
SUB	S DIC="^DD("_+Y_"," G O:$N(^DD(+Y,"SB",0))'>0 S DIC(0)="AEQZ",DIC("A")="Select SUB-FILE: ",DIC("S")="I $P(^(0),U,2)" D ^DIC G KL:$D(DTOUT) I Y>0 S (DFF,Y)=+$P(Y(0),U,2) G SUB
	G KL:X[U
O	K DIC S:DFF-DUB DIC("S")="I Y-5" S DIC="^DOPT(""DID"",",DIC(0)="AEQ",DIC("B")=1 D ^DIC G KL:Y<0
O1	K DIC S DIC="^DD(DFF,"
	I +Y=3 S DIS(0)="I $D(^DD(DFF,D0,0))",DIOEND="G L^DIDC",DIOBEG="S L=0 I $D(DQI),DQI,$D(^UTILITY($J,2)) S ^(1.5)=""W $O(^DD(DIB,0,""""NM"""",0))_"""" FILE """""",^(2)=""X ^(1.5) ""_^(2)" D EN^DIP G KL
	I +Y=4 D MOD^DID2 G KL:X[U
	S L=0,FLDS="",BY="@.001" I +Y=5 S (FR,TO)=.01,DHIT="S F(1)=DUB",DHD="W """" D H1^DIDG",DIOEND="D T^DID" G G
	S DHIT="D ^DID1",DHD="W """" D ^DIDH",(FR,TO)="",DIOEND="D END^DID"
	I +Y=6 S DHIT="D ^DIDG",DIOEND="D END^DIDG"
	I +Y=2 S DHIT="D ^DIDX",DIDX=0,%=2 W !,"ALPHABETICALLY BY LABEL" D YN^DICN Q:%<1  S:%=1 DIDX=1
	I +Y=7 S DHIT="S (X1,X2)=DFF D ^DIDC",DHD="@" S DIOEND="D IOF^DID"
G	Q:DIB=0  S DIOEND(1)=DIOEND,DIOEND="D LOOP^DID" D EN1^DIP G KL
LOOP	I $D(Y),Y=U Q
	X DIOEND(1) I $D(M),M=U Q
	I IOST?1"C-".E W *7 R X:DTIME I X[U!'$T Q
	S DN=1,D0=0,DIB=$O(^DIC(+DIB)) Q:DIB>DIB(1)!(+DIB'=DIB)  S (F(1),DUB,DFF)=DIB,DC="," D ^DIO2 I $D(M),M=U Q
	G LOOP
	;
END	;
	I $D(^UTILITY($J,"P")) W !!!?6,"FILES POINTED TO",?44,"FIELDS",! D PTR^DIDC
D	K ^UTILITY($J,"P") G IOF:DHIT["DIDX"
T	;
	S DA="",S=0,M=1
T1	S S=S+1 W !!,$P("INPU^PRIN^SOR",U,S)_"T TEMPLATE(S):" S DFF="^DI"_$P("E^PT^BT",U,S)
	X "F %=0:0 S DA=$O("_DFF_"(""F"_F(1)_""",DA)) Q:DA=""""  F DUB=0:0 S DUB=$N("_DFF_"(""F"_F(1)_""",DA,DUB)) Q:DUB'>0  I $D("_DFF_"(DUB,0))#2 S %1=^(0) D TEMPL G Q:M=U"
	G Q:M=U,T1:S<3
IOF	W:IOST'?1"C".E @IOF Q
	;
TEMPL	I $Y+3>IOSL D HDR^DIDG Q:M=U
	W !,$P(%1,U),?30 S W="",Y=$P(%1,U,2) I Y D DD^%DT W Y
	W ?50,"USER #"_+$P(%1,U,5),?61 W:$D(@(DFF_"(DUB,""ROU"")")) ^("ROU")_" "
	I $D(^("H")) S Y=^("H"),%=$L(Y) W:65+%>IOM ! W "   ",?IOM-%-1,$E(Y,1,IOM-4)
	G DES:DFF'="^DIBT"
	I $D(^("DIPT")) W ?55 S Y=" '"_^("DIPT")_"' Print Template always used" W:$X+$L(Y)>IOM ! W ?IOM-$L(Y)-1,Y
	I $D(^(2)) S D0=DUB,DICMX="W !?4,X" X $P(^DD(.401,1620,0),U,5,99)
	F Y=1:1 Q:'$D(^DIBT(DUB,"O",Y,0))  W "  " S %=^(0),D=IOM-$L(%)-5 W:$X>D !?$S(D>55:55,1:D) W %
DES	F %1=0:0 S %1=$N(@(DFF_"(DUB,""%D"",%1)")) Q:%1'>0  I $D(^(%1,0))#2 W !?5,^(0)
Q	W:DFF["DIBT" ! Q
DT	G DT^DIO2

DID1
DID1	; SF/XAK,JLT - STD DD LIST ;3/8/89  12:58
	;;17.7;VA FileMan; 6/9/89
	S DJ(Z)=D0,DDL1=14,DDL2=32 G B
	;
L	S DJ(Z)=0
A	S DJ(Z)=$N(^DD(F(Z),DJ(Z))) I DJ(Z)'>0 W !! S Z=Z-1 Q
B	S N=^DD(F(Z),DJ(Z),0) K DDF I $D(DIGR),Z<2!(DJ(Z)-.01) X DIGR E  G ND
	D HD:$Y+6>IOSL Q:M=U  W !!,F(Z),",",DJ(Z)
	W ?(Z+Z+12),$P(N,U,1),?DDL2+4," "_$P(N,U,4)
	S X=$P(N,U,2) I X,$D(^DD(+X,.01,0)) S W=$P(^(0),U,2) I W["W" W "   WORD-PROCESSING #",+X W:W["L" " (NOWRAP)" S X=""
	F W="BOOLEAN","COMPUTED","FREE TEXT","SET","DATE","NUMBER","POINTER","K","VARIABLE POINTER" I X[$E(W) D VP^DIDX:$E(W)="V" S:W="K" W="MUMPS" W ?40," "_W G ND:M=U
	I +X S W=" Multiple" S W=W_" #"_+X D W G ND:M=U
	I X["V" F I=0:0 S I=$N(^DD(F(Z),D0,"V",I)) Q:I'>0  S %Y=$P(^(I,0),U) I $D(^DIC(%Y,0)),$D(@(^(0,"GL")_"0)")) S ^UTILITY($J,"P",$E($P(^(0),U),1,30),0)=%Y,^(F(Z),DJ(Z))=0
	G MP:X'["P"!X S Y=$P(N,U,3) I Y]"",$D(@("^"_Y_"0)")) S %Y=+$P(X,"P",2),W=" TO "_$P(^(0),U,1)_" FILE (#"_%Y_")",^UTILITY($J,"P",$E($P(^(0),U,1),1,30),0)=%Y,^(F(Z),DJ(Z))=0 D W G ND:M=U,MP
	S W=" ** TO AN UNDEFINED FILE ** " W:($L(W)+$X)'<IOM ! D W G ND:M=U
MP	I X'["V" D RT^DIDX G:M=U ND
S	I X["S" S N=$P(N,U,3) F %1=1:1 S Y=$P(N,";",%1) Q:Y=""  W ! S W="'"_$P(Y,":",1)_"' FOR "_$P(Y,":",2) D W W:$P(N,";",%1)'="" "; " G ND:M=U
	G RD:$D(DINM) I X["C" S W=$P(N,U,5,99) W !?DDL1,"MUMPS CODE: " D W G ND:M=U G RD
	I "Q"'[$P(N,U,5) W !?DDL1,"INPUT TRANSFORM:" S W=$P(N,U,5,99) D W G ND:M=U
	I $D(^DD(F(Z),DJ(Z),2))#2 W !?DDL1,"OUTPUT TRANSFORM:" S W=$S($D(^DD(F(Z),DJ(Z),2.1)):^(2.1),1:^(2)) D W G ND:M=U
RD	D ^DID2:$O(^DD(F(Z),DJ(Z),2.99))]"" G ND:M=U I 'X S W="UNEDITABLE" W:X["I" ! D W:X["I" G N
	S Z=Z+1,DDL1=DDL1+2,DDL2=DDL2+2,F(Z)=+X F %=0:0 S %=$N(^DD(+X,0,"ID",%)) Q:%'>0  S W="IDENTIFIED BY "_$P(^DD(+X,%,0),U,1) D W G ND:M=U
	D L
N	K DDN1 I X["X" S DDN1=1 W !,?DDL1,"NOTES:",?DDL2,"XXXX--CAN'T BE ALTERED EXCEPT BY PROGRAMMER" W ! G ND:M=U
	S W=0 I $O(^DD(F(Z),DJ(Z),5,W))'="",'$D(DDN1) W !?DDL1,"NOTES:"
TR	S W=$N(^DD(F(Z),DJ(Z),5,W)) G IX:W'>0 S I=^(W,0),%=+I I '$D(^DD(%,$P(I,U,2),0))!$D(W(I)) K ^DD(F(Z),DJ(Z),5,W) G TR
	S W(I)=0 S WS=W D WR^DIDH1 W ! S W=WS K WS G TR
IX	F F=0:0 S F=$N(^DD(F(Z),DJ(Z),1,F)) Q:F'>0  G ND:M=U W !?DDL1,"CROSS-REFERENCE:" D IX1
ND	S X="" G:M'=U A:Z>1 Q
IX1	S W=^(F,0)_" " K DDF W ?DDL2,W,! G ND:M=U D TP:$P(W,U,3)["TRIG" I '$D(DINM) S X=0 F %=0:0 S X=$N(^DD(F(Z),DJ(Z),1,F,X)) Q:X<0  S W=^(X) S:$L(W)<248 W=X_")= "_W D W W ! G ND:M=U
	Q
	;
TP	S X=+$P(^(0),U,4) I F(Z)-X,$D(^DIC(X,0))#2 S ^UTILITY($J,"P",$E($P(^(0),U,1),1,30),0)=X,^(F(Z),DJ(Z))=6
	Q
W	F K=0:0 W:$D(DDF) ! W ?DDL2 S %Y=$E(W,IOM-$X,999) W $E(W,1,IOM-$X-1) Q:%Y=""  S W=%Y,DDF=1
	K:'X DDF Q:$Y+6<IOSL
HD	S DC=DC+1 D ^DIDH Q

DID2
DID2	; SF/GFT - MODIFIED DD ;2/15/89  09:24
	;;17.7;VA FileMan; 6/9/89
	I $D(DINM) G DZ:X'["C"!(X["X")!'$D(^DD(F(Z),DJ(Z),9.1)) S %Y=X,X=^(9.1),W=" --  "_X D ^DIM,W1^DIDH1:'$D(X) S X=%Y G ND^DID1:M=U G DZ
	F I=9.2:.1 Q:'$D(^(I))#2  W ! S W=I_" = "_^(I) D W G ND^DID1:M=U
	I $D(^(9.1))#2 S W=^(9.1),%Y="9.1 = " S:X["C" %Y="ALGORITHM:  " W !,?DDL1,%Y D W S W=$P("  (ALWAYS "_$E(N,$L(N)-1)_" DECIMAL DIGITS)",U,N?.E1" S X=$J(X,0,"1N1")") D W G ND^DID1:M=U
DZ	;
	I $D(^("DT")) S Y=^("DT") D D^DIQ W !?DDL1,"LAST EDITED: " S W=Y D W1^DIDH1 G ND^DID1:M=U
H	K W I $D(^DD(F(Z),DJ(Z),3)),^(3)]"" W !?DDL1,"HELP-PROMPT:" S W=^(3) D W1^DIDH1 G ND^DID1:M=U
	G:$N(^DD(F(Z),DJ(Z),21,0))'>0 SC W !?DDL1,"DESCRIPTION:" S DIGG=Z_U_X F D=0:0 S D=$N(^DD(F(+DIGG),DJ(+DIGG),21,D)) G:'$D(^(D,0)) SC S W=^(0) D W1^DIDH1 G ND^DID1:M=U
SC	;
	I $D(^DD(F(Z),DJ(Z),12.1)),'$D(DINM) I (X["P")!(X["S") W !?DDL1,"SCREEN:" S W=^(12.1) D W I $D(^(12)) W !?DDL1,"EXPLANATION:" S W=^(12) D W G ND^DID1:M=U
	I $D(^DD(F(Z),DJ(Z),22)) W !?DDL1,"HELP FRAME:" S W=^(22) D W G ND^DID1:M=U
	I '$D(DINM),$D(^DD(F(Z),DJ(Z),4)),^(4)]"" W !?DDL1,"EXECUTABLE HELP:" S W=^(4) D W G ND^DID1:M=U
	I $D(^(9.02))#2 W !?DDL1,"SUM:" S W=^(9.02) D W G ND^DID1:M=U
D	I $D(^(8.5)) W !?DDL1,"DELETE AUTHORITY: " S W=^(8.5) D W G ND^DID1:M=U
	I X'["C",$D(^(9))#2,^(9)]"" W !?DDL1,"WRITE AUTHORITY:" S W=^(9) D W G ND^DID1:M=U
RD	I $D(^(8))#2,^(8)]"" W !?DDL1,"READ AUTHORITY:" S W=^(8) D W G ND^DID1:M=U
	I $D(^(10))#2,^(10)]"" W !?DDL1,"SOURCE OF DATA:" S W=^(10) D W G ND^DID1:M=U
	I $N(^(11,0))>0 W !?DDL1,"DATA DESTINATION:" F I=0:0 S I=$N(^DD(F(Z),DJ(Z),11,I)) Q:I<0  S:$D(^DIC(.2,+^(I,0),0)) W=$P(^(0),U)
	I  D W G ND^DID1:M=U
	I $D(^DD(F(Z),DJ(Z),20)) W !?DDL1,"GROUP:" F I=0:0 S I=$N(^DD(F(Z),DJ(Z),20,I)) S:I>0 W=$P(^(I,0),U) I I<0 D W Q
	Q
	;
W	F K=0:0 W ?DDL2 S %Y=$E(W,IOM-$X,999) W $E(W,1,IOM-$X-1) Q:%Y=""  S W=%Y W !
	I $Y+6>IOSL S DC=DC+1 D ^DIDH
	I $D(^DD(F(Z),DJ(Z),0))
	Q
	;
MOD	;FROM DID
	S X=U,%=2 W !,"WANT THE LISTING TO INCLUDE MUMPS CODE" D YN^DICN Q:%<0  S:%=2 DINM=1 I '% W !?5,"Enter YES, to see the MUMPS code as in the STANDARD listing.",!?5,"Enter NO, to eliminate MUMPS code from the listing." G MOD
MOD2	S %=2 W !,"WANT TO RESTRICT LISTING TO CERTAIN GROUPS OF FIELDS" D YN^DICN S:%=2 X=0 Q:%<0!(%=2)  I '% W !?5,"Enter YES, to select the Groups you wish to see in this listing.",!?5,"Enter NO, to see all fields." G MOD2
	W ! S DP="",L=""","_$S(Y-2:"DJ(Z)",1:"D1")_"))"
G	R "Include GROUP: ",X:DTIME S:'$T X=U,DTOUT=1 I X[""""!($L(X)>30)!(X'?.ANP) W *7,!,"SORRY, THAT ISN'T WHAT A 'GROUP' NAME CAN LOOK LIKE",! G G
	Q:X[U  I X'?."?" S C="!" S:X?1"'"1E.E X=$E(X,2,99),C="&'" S DP=DP_C_"$D(^DD(F(Z),""GR"","""_X_L W !,"And " G G
	I X="" S:DP]"" DIGR="I "_$E(DP,2,999) Q
	W !?5,"To list only those fields which have a particular 'GROUP'",!?5,"(or several 'GROUPS') associated with them, Enter the GROUP NAME",!
	W ?5,"To screen out a group, Type ""'"" in front of its name.",!
	G G

DIDC
DIDC	; SF/XAK - CONDENSED DD ;5/31/89  15:14
	;;17.7;VA FileMan; 6/9/89
	S DM="",DAT=$E(DT,4,5)_"/"_$E(DT,6,7)_"/"_$E(DT,2,3),X="I $Y-3>IOSL W *7 D P"
EN	S N(0)=X1-.0000001 F I=0:0 S N(0)=$O(^DD(N(0))) Q:N(0)'>0!(N(0)>X2)  S NAME=$N(^DD(N(0),0,"NM",0)) I NAME'="" S P=0 D P,P2 G:DM["^" EXIT
EXIT	K %DT,%ZIS,DAT,I,J,K,K1,M,N,N1,NAME,MO,P,X,X1,X2,Y,KK,NF,NY,POP S D0="B",M=DM K DM Q
P	S P=P+1 I IOST?1"C-".E R:P'=1 DM:DTIME Q:DM["^"!'$T
	W @IOF,!!,"CONDENSED DATA DICTIONARY---",NAME," FILE"," (#",N(0),")" I $D(^%ZOSF("UCI"))#2 X ^("UCI") W ?47,"UCI: "_Y
	W ?63,$S($D(^DD(N(0),0,"VR")):"   VERSION: "_^("VR"),1:" ") W !!,"STORED IN: ",$S($D(^DIC(N(0),0,"GL")):^("GL"),1:""),?58,DAT,?70,"PAGE ",P W ! F I=0:1:IOM-1 W "-"
	G P1:P'=1 W !!,?50,"FILE SECURITY"
	W !,?35,"DD SECURITY    : ",$S($D(^DIC(N(0),0,"DD")):^("DD"),1:""),?58,"DELETE SECURITY: ",$S($D(^("DEL")):^("DEL"),1:"")
	W !,?35,"READ SECURITY  : ",$S($D(^("RD")):^("RD"),1:""),?58,"LAYGO SECURITY : ",$S($D(^("LAYGO")):^("LAYGO"),1:"")
	W !,?35,"WRITE SECURITY : ",$S($D(^("WR")):^("WR"),1:"")
	W !,"CROSS REFERENCED BY:",!,?5
	S NY="" F KK=1:1 S NY=$O(^DD(N(0),0,"IX",NY)) Q:NY=""  S NF=$O(^(NY,0)),N1=$O(^(NF,0)) W:$X>50&($L($P(^DD(NF,N1,0),"^",1)>20)) !,?5 W " ",$P(^DD(NF,N1,0),"^",1),"(",NY,") "
P1	W !!!,?33,"FILE STRUCTURE",!! W "FIELD",?10,"FIELD",!,"NUMBER",?10,"NAME",! Q
P2	S M(0)=0 F K1=0:0 S M(0)=$O(^DD(N(0),M(0))),K=0 Q:+M(0)'>0!(M(0)?1U.U)  X X Q:DM["^"  W !,M(0),?10,$P(^DD(N(0),M(0),0),U,1)," " D M I J S K=K+1 D MO Q:DM["^"
	Q
MO	X X Q:DM["^"  S N(K)=+$P(^DD(N(K-1),M(K-1),0),U,2) S M(K)=0
	F L=0:0 S M(K)=$O(^DD(N(K),M(K))) Q:M(K)'>0  X X Q:DM["^"  W !,?10+((K-1)*5),M(K),?15+((K-1)*5),$P(^DD(N(K),M(K),0),U,1)," " D M I J S K=K+1 D MO Q:DM["^"
	Q:DM["^"  X X Q:DM["^"  S K=K-1 Q
M	S J=$P(^(0),U,2) W $S(+J:"(Multiple-"_+J,1:"("_J),"), [",$P(^(0),U,4),"]"
	Q
PTR	;
	S F=0 F I=0:0 S F=$N(^UTILITY($J,"P",F)) Q:F<0  D PT
	Q
