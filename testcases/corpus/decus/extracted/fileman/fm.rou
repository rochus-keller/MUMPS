Fileman DI* Routines
DI
DI	; SF/GFT - DIRECT ENTRY TO VA FILEMAN ;4/17/89  12:16 ;
V	;;17.7;VA FileMan; 6/9/89
	K (DTIME,DUZ) G ^DII
P	K (DTIME,DUZ)
Q	S DUZ(0)="@" G ^DII
VERSION	;
	S VERSION=$P($T(V),";",3),X="VA FileMan V."_VERSION Q

DIA
DIA	; SF/GFT - SELECT FIELDS TO EDIT ;4/12/89  11:32
	;;17.7;VA FileMan; 6/9/89
	D DICS
1	D F W !?F*3,"EDIT WHICH "_X I $S(DB:DIAT="",1:1) R ": ALL// ",X:DTIME S:'$T X=U,DTOUT=1 G ALL^DIA1:X=""!(X="ALL"),TEMP^DIA1:X?1"[".E&'F,L
ED	G NDB:DIAT=""
GDB	S Y=$P(DIAT,";",DB) I "Q"[Y G NDB:Y="" D DB G GDB
	I Y?.NP,$P(Y,":",2),Y'["/" S Y=+Y_"-"_$P(Y,":",2)
	I $D(DI(DB)),$D(DI(DB,F,DI,DIAO)) S Y=DI(DB,F,DI,DIAO)
	W ": "_Y D RW
	I X="" S X=Y I X="ALL" G ALL^DIA1
L	S DSC=X?1"^".E I DSC S X=$E(X,2,999) I U[X K DR Q
	I $A(X)=64 G X:X'?1P.N,P:$L(X)>1,X:'DB S DB=DB+1 G 2
	K DIC,DIAB D DICS S DV="",J=$P(X,"-",2) I +J=J,$P(X,"-",1)=+X,J>X S D(F)=J K DA D RANGE^DIA1 K D S Y=DA G X:Y="" D DB G 2
DIC	;
	S DIC(0)="EZI",DIC="^DD(DI,",Y=-1 G X^DIA3:X[";" S DIC("W")="S %=$P(^(0),U,2) I % W $S($P(^DD(+%,.01,0),U,2)[""W"":""  (word-processing)"",1:""  (multiple)"")" D ^DIC Q:$D(DTOUT)
	I Y>0 D SET S Y=$P(Y(0),U,2) G 2:'Y S L=L+1,(DI,J(L))=+Y,I(L)=""""_$P($P(Y(0),U,4),";",1)_"""" G DOWN
	I $E(X)="]" S DRS=9,X=$E(X,2,999) G DIC:X]"",2
	S DIC(0)="EY",D="GR" G DIA^DIQQQ:X?."?" I $D(^DD(DI,D)) D IX^DIC I Y>0 D SET G 2
	G X^DIA3
	;
F	S X=$P(^DD(DI,0),U,1) I F,X="FIELD" S X=$N(^(0,"NM",0))_" "_X
	Q
	;
X	;
	W *7,"??" D DICS
2	;
	G 1:'$D(DR(F+1,DI)) D F W !?F*3,"THEN EDIT "_X G ED:DB
R	R ": ",X:DTIME E  W *7 S X=U,DTOUT=1
	I X]"" G L
UP	;
	G ^DIA1:'F K I(L),J(L) S L=L-1 I '$D(J(L)) F L=L-99:1 Q:'$D(J(L+1))
	I DB S DB=DB(F),DIAO=DIAO(F),DIAT=$S(DIAO<0:"",DIAO:^DIE(DIAA,"DR",F,J(L),DIAO),$D(^DIE(DIAA,"DR",F,J(L))):^(J(L)),1:"")
	S DIAP=DIAP(F),DI=J(L),F=F-1 G 2
	;
NDB	I DB,DIAO'<0 S DIAO=DIAO+1 I $D(^DIE(DIAA,"DR",F+1,DI,DIAO)) S DIAT=^(DIAO),DB=1 G GDB
	S DIAO=-1 G R
	;
EN	;
	D OS^DII:'$D(DISYS),DICS
DOWN	S F=F+1,DIAP(F)=DIAP,DIAP=0 I DB S DB(F)=DB,DB=1,DIAO(F)=DIAO,DIAO=0,DIAT=$S($D(^DIE(DIAA,"DR",F+1,DI)):^(DI),1:"")
	G 1:$P(^DD(DI,.01,0),U,2)'["W",1:L#100=0,UP
DICS	;
	S DIC("S")="I Y>.001,$P(^(0),U,2)'[""C"""_$S(DUZ(0)="@":"",1:",$P(^(0),U,2)'[""K""")_" Q:'$D(^(9))  I ^(9)'=U"_$S(DUZ(0)'="@":" F DW=1:1:$L(^(9)) I DUZ(0)[$E(^(9),DW) Q",1:"") Q
	;
P	;
	S DRS=99,Y=X D DB G 2
	;
SET	S Y=+Y_DV
DB	;
	I DB,'DSC S DB=DB+1
D	;
	I '$D(DR(F+1,DI)) S DR(F+1,DI)="",DIAP=0
	E  I $L(DR(F+1,DI))+$L(Y)>230 F %=0:1 I '$D(DW(DI,%)) S DIAP=DIAP\1000+1*1000,DW(DI)=F+1,DW(DI,%)=DR(F+1,DI),DR(F+1,DI)="" Q
	S DR(F+1,DI)=DR(F+1,DI)_Y_";",DRS=DRS+1,DIAP=DIAP+1 I $D(DIAB) S ^UTILITY($J,DIAP#1000,F,DI,DIAP\1000)=DIAB K DIAB
	Q
RW	I $L(Y)>19 D RW^DIR2 Q
	W "// " R X:DTIME I '$T S X=U,DTOUT=1 W *7

DIA1
DIA1	; SF/GFT - PROCESS TEMPLATES, RANGES FOR INPUT ;4/12/89  14:14 ;3/1/89  3:07 PM
	;;17.7;VA FileMan; 6/9/89
	F X=-1:0 S X=$N(DW(X)) Q:X'>0  S F=DW(X),J=DR(F,X),DR(F,X)=DW(X,0),I=1 D OV
S	D NOW^%DTC S DIADT=+$J(%,0,4) K %,DW G Q:DRS<5 R !,"STORE THESE FIELDS IN TEMPLATE: ",X:DTIME S:'$T DTOUT=1 G Q:X="" S DIC(0)="LZSEQ",DLAYGO=0 D T K DLAYGO,DIC I Y<0 G S:X'[U K DR G Q
	S X=$P(^(0),U,6) I DUZ(0)'["@",X]"" F %=1:1 I DUZ(0)[$E(X,%) Q:%'>$L(X)  W !?7,*7,"YOU HAVE NO 'WRITE ACCESS' TO THIS TEMPLATE",! G S
	S DW=$S('$D(^("ROU")):1,^("ROU")'[U:1,$D(^("ROUOLD")):^("ROUOLD"),1:1),%=0,X=$P(Y,U,2)
	I $N(^(0))+1 W *7,!,X_" TEMPLATE ALREADY EXISTS.... OK TO REPLACE" D YN^DICN W ! G S:%-1 L ^DIE(+Y) S %Y="" F %X=0:0 S %Y=$O(^DIE(+Y,%Y)) Q:%Y=""  K:%Y'="%D" ^(%Y)
	S ^DIE(+Y,0)=X_U_DIADT_U_$S('%:DUZ(0),1:$P(Y(0),U,3))_U_DI_U_DUZ_U_$S('%:DUZ(0),1:$P(Y(0),U,6))_U_DT,^DIE("F"_DI,X,+Y)=1 L
	S %X="DR(",%Y="^DIE(+Y,""DR""," D %XY^%RCR S %X="^UTILITY($J,",%Y="^DIE(+Y,""DIAB""," D %XY^%RCR S X=DW,DP=DIA("P"),DMAX=^DD("ROU") I X'=1,$D(^DD("OS",DISYS,"ZS")) D EN^DIEZ S DR(1,DIA("P"))=U_DNM
Q	K DNM,DIAO,DI,DIAP,%,%I,DIADT,DIAT,DIE,DMAX,%X,%Y Q
	;
ALL	;
	S %=DI,^UTILITY($J,1,F,%,DIAP\1000)="ALL" K DA D A G UP^DIA:F,S:$D(DRS) Q
	;
RANGE	;
	S %=DI I X>0 S Y=X-.000001 G B
A	S Y=0
B	S DA="",X=0
G	S DG=Y
DR	S Y=$N(^DD(%,Y)) I $D(D(F)),Y'>0!(Y>D(F)) D DG:X Q
	I Y'>0 D DG:X S:$D(DR(F+1,%))[0 DR(F+1,%)=DA Q
	I $D(^(Y,0)),X X DIC("S") G G:$T D DG G DR
	X DIC("S") E  G DR
	S X=Y G G
	;
DG	S DA=DA_$E(";",1,$L(DA))_X_$P(":"_DG,U,X'=DG)
	F DQ=0:0 S DQ=$N(^DD(%,"SB",DQ)),DP=$N(^(DQ,0)) Q:DQ<0  I DP'<X,DP'>DG S Y(F,DQ)=""
Y	S X=$N(Y(F,0)) I X>0 K Y(F,X) S DA(F)=DA,Y(F)=Y,%(F)=%,F=F+1,%=X D A S F=F-1,%=%(F),Y=Y(F),DA=DA(F) G Y
	S X="",DG=0 K DP Q
	;
TEMP	;
	S DIC(0)="ZSEQ" D T K DIC Q:$D(DTOUT)  G DB:Y<0
	S %=$P(Y(0),U,6) G ED:DUZ(0)="@"!'$L(%) F X=1:1:$L(%) I DUZ(0)[$E(%,X) G ED
GT	I $D(^("ROU")),^("ROU")[U S DR(1,DIA("P"))=^("ROU")
	E  S:$D(^("W")) DIE("W")=^("W") S:$D(^("DR"))#2 ^("DR",1,DIA("P"))=^("DR") S %X="^DIE(+Y,""DR"",",%Y="DR(" D %XY^%RCR
	S $P(^DIE(+Y,0),U,7)=DT
	Q
	;
T	K DIC("W") S D="F"_DI,X=$P(X,"]",1),X=$P(X,"[",1)_$P(X,"[",2),DIC="^DIE(",DIC("S")="I $P(^(0),U,4)=DI"_$P(" S %=$P(^(0),U,3) F DW=1:1:$L(%) I DUZ(0)[$E(%,DW) Q",9,DUZ(0)'="@") G IX^DIC
	;
ED	S %=2 W !,"WANT TO EDIT '",$P(Y,U,2),"' INPUT TEMPLATE" D YN^DICN G GT:%-1
	S DIE="^DIE(",DA=+Y,DR=".01;3;6" D ^DIE K DR I '$D(DA) S DB=0 G DB
	S:$D(^DIE(DA,"DR"))#2 ^("DR",1,J(0))=^("DR")
	S DIAA=DA,DRS=9,DIAT=$S($D(^DIE(DA,"DR",1,J(0))):^(J(0)),1:"")
	I $D(^DIE(DA,"DIAB")) S %X="^DIE(DA,""DIAB"",",%Y="DI(" D %XY^%RCR
	S F=0,DB=1,DIAO=0 F DXS=1:1 Q:'$D(DR(99,DXS))
DB	S DI=J(0) G ^DIA
	;
OV	I '$D(DW(X,I)) S DR(F,X,I)=J Q
	S DR(F,X,I)=DW(X,I),I=I+1 G OV

DIA2
DIA2	; SF/GFT - SELECT ENTRY TO EDIT, ^LOOP ;3/27/89  17:19 ;
	;;17.7;VA FileMan; 6/9/89
	K ^UTILITY("DIT",$J),DA,DRS,DW,DIAP,DI I '$D(DR(1,J(0))) S DR(1,J(0))=".01:99999999"
	I $L(DR(1,J(0)))+$L(DIA)<216,+DR(1,J(0))=.01 S DR(1,J(0))="S:DIA(9) DQ=2,X=$P("_DIA_"DA,0),U,1);"_DR(1,J(0))
DIC	W !! G Q^DIB:$D(DTOUT) D L S DIA(1)=+Y,DIA(9)=$P(Y,U,3) I Y>0 D DIE,^DIA3:'$D(DA) G DIC
	I X'["LOOP",X'["loop" D PTS^DITP:$N(^UTILITY("DIT",$J,0))>0 K ^UTILITY("DIT",$J) G Q^DIB
	S L="EDIT ENTRIES",DHD="@",IOP="HOME",FLDS="",DHIT="D LOOP^DIA2 S:'$D(DCC) DN=0" D EN1^DIP W !!?4,"LOOP ENDED!" Q:$D(DTOUT)  G DIC
	;
L	K Y,I,J,F,DIC S (DIC,DIE)=DIA,DIC(0)="QEALM" G ^DIC
	;
DIE	S DP=DIA("P"),DA=+Y,DR=DR(1,DP)
	K DIC,Y,C,DB S DIC=DIE L @(DIE_DA_"):0")
	E  W *7,!,"ANOTHER TERMINAL IS EDITING THIS ENTRY!" Q
	I DR?1"^".AN D @DR L  Q
	E  D GO^DIE L  Q
	;
LOOP	;
	W !!?3 S X=$P(@(DCC_"0)"),U,2) G NUL:'$D(^(D0,0)) S (DI,Y)=$P(^(0),U,1),C=$P(^DD(+X,.01,0),U,2) D Y^DIQ W Y
	S Y=D0,(DIE,DIC)=DCC,%C=0 I X["I" F %Y=0:0 S %C=$N(^DD(+X,0,"ID",%C)) Q:%C<0  S %=^(%C) W "  ",$E(@(DCC_"Y,0)"),0) X %
	K DO S DO(2)=X,Y=Y_U_DI,DIC(0)="E" D ACT^DICM1 S DI=99 K DO,DIY Q:Y<0
	S Y=D0 D DIE I $D(DTOUT) K DCC,Y
	I $D(Y) K Y S %=1 W *7,!!,"WANT TO STOP LOOPING" D YN^DICN I %-2 K DCC
NUL	S DI=99,(^UTILITY($J,99,0),DX(0))="Q" K D1,D2,D3,D4,D5
	Q

DIA3
DIA3	; SF/GFT - UPDATE POINTERS, CHECK CODE IN INPUT STRING, CHECK FILE ACCESS ;3/3/89  01:06 ;
	;;17.7;VA FileMan; 6/9/89
	S Y=DIA("P"),DH=1,DTO=DIA D PTS^DIT:'$D(^UTILITY("DIT",$J,0)) S ^UTILITY("DIT",$J,0)=0 Q:$D(^(0))<9
	D ASK^DITP Q:%-1
	S Y=0 I @("$N("_DIC_"0))'>0") G D
C	W !,"WHICH DO YOU WANT TO DO? --",!?4,"1) DELETE ALL SUCH POINTERS",!?4,"2) CHANGE ALL SUCH POINTERS TO POINT TO A DIFFERENT '"_$P(^(0),U,1)_"' ENTRY",!!,"CHOOSE 1) OR 2): " R %:DTIME G F:U[%,W:%=2,C:%'=1
D	W !,"DELETE ALL POINTERS" D YN^DICN G F:%<0,C:%-1,DITP
W	W !,"THEN PLEASE INDICATE WHICH ENTRY SHOULD BE POINTED TO" D L^DIA2 G DITP:Y>0
F	W *7,!,"OK... FORGET IT... LET'S GO ON TO EDIT ANOTHER ENTRY" Q
DITP	S (^UTILITY("DIT",$J,DIA(1)),^(DIA(1)_";"_$E(DIA,2,999)))=+Y_";"_$E(DIA,2,999)
	W !?4,"("_$P("DELETION^RE-POINTING",U,''Y+1)_" WILL OCCUR WHEN YOU LEAVE 'ENTER/EDIT' OPTION)"
	Q
	;
X	;
	I 'Y S:'DSC&DB DB=DB+1 F Y=0:0 S Y=$N(Y(Y)) G 2^DIA:Y<0 D D^DIA
	S Y=X I DUZ(0)="@",X'?.E1":" D ^DIM G P^DIA:$D(X)=1
	I Y[";" F %=2:1 S D=$P(Y,";",%) Q:D=""  S D=$S(D="DUP":"d",D="REQ":"R","""R""d"""[D:"",$A(D)=34:$E(D,2,$F(D,"""",2)-2),1:D) G BAD:D="",DIA3^DIQQQ:$A(D)>45&($A(D)<58)!(D[":") S DV=D_$C(126)_DV
	I Y[";" S X=$P(Y,";",1) S:'$D(DIAB) DIAB=Y G DIC^DIA
	F DK="///+","//+","///","//" I Y[DK S DP=$P(Y,DK,2,9) I DP'?1"/".E&(DP'?1"^".E)!(DUZ(0)="@") G DEF
	G BAD:Y'?.E1":"
E	K X S:'$D(DIAB) DIAB=Y S DICOMP=L_"WE?",DQI="Y(",DA="DR(99,"_DXS_",",X=Y,DICMX=1 D ^DICOMPW I '$D(X) K DIAB G BAD:'$D(DP),ACC
	;G L:DUZ(0)="@"
	;I $D(^DIC(3,"AFOF")) G ACC:'$D(^DIC(3,DUZ,"FOF",+DP,0)),ACC:'$P(^(0),U,6),L
	;I $D(^DIC(+DP,0,"WR")) F D=1:1 S %=$E(^("WR"),D) I DUZ(0)[% Q:%]""  G ACC
L	I $D(X)>1 S DXS=DXS+1 F %=0:0 S %=$N(X(%)) Q:%<0  S @(DA_"%)=X(%)")
	S L=$S(Y>L:+Y,1:L\100+1*100),Y=U_DP_U_U_X_" S X=$S(D(0)>0:D(0),1:"""")",DRS=99 K X D DB^DIA S DI=+DP G EN^DIA
	;
DEF	S X="DA,DV,DWLC,0)=X" F J=L:-1 Q:I(J)[U  S X="DA("_(L-J+1)_"),"_I(J)_","_X
	S DICMX="S DWLC=DWLC+1,"_DIA_X,DA="DR(99,"_DXS_",",DHIT=Y,X=DP,DQI="X(",DICOMP=L_"T?" D EN^DICOMP,DICS^DIA,XEC K X S X=$P(DHIT,DK,1),DV=DV_DK_DP G DIC^DIA:DV'[";"
BAD	Q:$D(DTOUT)  G X^DIA
ACC	K DIAB W !?9,"YOU HAVE NO WRITE ACCESS TO FILE "_+DP G BAD
	Q
	;
XEC	I $D(X),Y["m" S DIC("S")="S %=$P(^(0),U,2) I %,$D(^DD(+%,.01,0)),$P(^(0),U,2)[""W"",$D(^DD(DI,Y,0)) "_DIC("S")
	F Y=0:0 S Y=$N(X(Y)) Q:Y<0  S @(DA_"Y)=X(Y)")
	I $D(X) S %=1,Y="DO YOU MEAN '"_DP_"' AS A VARIABLE" W !?63-$L(Y),Y D YN^DICN Q:%-1  S Y="Q",DXS=DXS+1,DP=U_X,DRS=99 D D^DIA:$S(DIAP:$P(DR(F+1,DI),";",DIAP#1000)'="Q",1:1) S:'$D(DIAB) DIAB=DHIT
	Q:DP'="@"  I DK="//" S DA=U_U Q
	W !,*7,"    WARNING: THIS MEANS AUTOMATIC DELETION!!"

DIAR
DIAR	; WISC/CAP - ARCHIVING FUNCTIONS ; 5/12/88  10:19 ;
	;;17.7;VA FileMan; 6/9/89
	;
	;ENTRY FOR CREATE/EDIT SELECT/PRINT TEMPLATE
ENTT	S DIAR=1 D ^DICRW Q:'$D(DIC)  S DHIT="S "_DIC_"D0,-9)=1",SF=1 D EN^DIP
	;
K	K DIAR,DIARB,DIARB0,DIARC,DIARE,DIARN,DIARS,DIART,DIARU Q
	;
	;UPDATE ^DIAR(0,,1 TEMPLATE [SORT]
ENTS	S B=+DIARU,E=^DIBT(B,0),F=+$P(E,U,4),E=$P(E,U) Q:'F
	Q:$D(^DIAR(0,F,1,B))  S %="^1.111P^"_B_"^1" S:$D(^(0)) %=^(0),$P(%,U,3,4)=B_U_($P(%,U,4)+1) S ^(0)=%,^(B,0)=B_U_E,^DIAR(0,F,1,"B",E,B)=""
	S %=DIARB0,$P(%,U)=F
	I $P(%,U,3)=""!'$P(%,U,2) S $P(%,U,2,3)=B_U_E,(DIARB0,^DIAR(0,F,0))=%
	K % Q
EQ	D ENTR Q:DIARB0=DIARB  S $P(DIARB0,U,1)=F,^DIAR(0,F,0)=DIARB0 Q
	;
	;UPDATE ^DIAR(0,,2 TEMPLATES [OUTPUT]
ENTO	S B=+DIART,X=$P(DIART,U,2)
	Q:$D(^DIAR(0,J(0),2,B))  S %="^1.112P^"_B_"^1" S:$D(^(0)) %=^(0),$P(%,U,3,4)=B_U_($P(%,U,4)+1) S ^(0)=%,^(B,0)=B_U_X,^DIAR(0,J(0),2,"B",B,B)="",^DIAR(0,J(0),2,"C",X,B)=""
	S %=DIARB0
	I $P(%,U,5)=""!'$P(%,U,4) S $P(%,U,4,5)=B_U_E,(DIARB0,^DIAR(0,J(0),0))=%
	Q
	;
	;CORRECT MOST RECENTLY USED INFORMATION
ENTR	Q:'$D(DIARC)
	S DIART=DIC,DIC="^DIAR(1,",DA=F,DR=".01///"_$E(DT,4,5)_"-"_$E(DT,6,7)_"-"_(1700+$E(DT,1,3))_";1///"_DIARC_";2///"_DUZ_";3///"_DIARN_";4///"_(+DIARU)
	D ^DIE S DIC=DIART K DIART Q

DIARCALC
DIARCALC	; WISC/CAP - ARCHIVING FUNCTIONS ; 5/12/88  10:19 ;
	;;17.7;VA FileMan; 6/9/89
	;
DOC	;The code at tag CODE finds the most recent select code.
	;Since there may be many entries selected the length of the code has
	;been minimized by making it a base 126-32 (94) number, using
	;the ASCII characters from $C(33) through $C(126) as the 'numbers'.
	;The first 8 numbers are !"#$%&'(
	;The 94th select code would be the tilda (~).
	;The 95th would be !!
	;
	;There are 8836 possible codes with a maximum length of 2. (! TO ~~).
	;
	;
	;GET MOST RECENT SELECT CODE
CODE	S X="",Y=-1 I $D(^DIAR(1,DL,1,0)) S B=$P(^(0),U,3) I B,'$O(^("B",B)) S Y=^DIAR(1,DL,1,B,0),X=$P(Y,U,2) Q
A	S Y=X,X=$O(^DIAR(1,DL,1,X)) G A:X S Y=^(Y,0),X=$P(Y,U,2) Q
	;
	;CALCULATE NEXT SELECT CODE TO USE
NEXT	D CODE S B="" I X="" S Y="",X="!" Q
	Q:'$D(^DIAR(1,DL,1,+Y,0))  Q:'$P((0),U,4)
	S B=$E(X,1),E="!"
B	S X=E G:X?2E NRR:X>"!~" D NC
	I $D(^DIAR(1,DL,1,"C",X)) S F=$O(^(X,0)),Y=^DIAR(1,DL,1,F,0),X=$P(Y,U,2) G B:$P(Y,U,4) Q
	S X="" G NRR:E="" S X=E Q
NC	I E?1E,$A(E)<126 S E=$C($A(E)+1) Q
	S I=$E(E,2) I I="",E?1E S E="!!" Q
	I $A(I)<126 S E=$E(E,1)_$C($A(I)+1) Q
	I $A(E)>125 S E="" Q
	S E=$C($A(E)+1)_"!" Q
	;
	;
NRR	W "  OUT OF ARCHIVE SELECT CODES (DD=1.12)."
	W !,*7,"  8836 SELECTS RUN ON THIS FILE !!!"
	Q
	;
	;COMPUTE BOUNDARIES
FROM	;SELECT FROM VALUE 4 SORT
	S X="F" D G
	I $D(DIARS) S:A="" A=$P(DIARS,U,2) S:A="" A="FIRST" G Q
	D H Q:X=""  S DIARS=Y_U_X Q
TO	;SELECT TO VALUE 4 SORT
	S X="T" D G
	I $D(DIARE) S:A="" A=$P(DIARE,U,2) S:A="" A="LAST" G Q
	D H Q:X=""  S DIARE=Y_U_X Q
G	S DIART=L,L=0 I $D(DIPP(DJ,X)) S A=$P(DIPP(DJ,X),U,2) Q
	I $D(DPP(DJ,X)) S A=$P(DPP(DJ,X),U,2) Q
	S A="" Q
H	S %=X,%1=$P(DIARB,U,2)
	I +%1,$D(^DIBT(%1,2,DJ,%)) S (X,%2)=$P(^(%),U,2) I "z"'[X
	E  S %2=$S(%="T":"LAST",1:"FIRST"),X=""
	I X="",'$D(DIAR) S A=%2,L=DIART G Q
	D CK:X'="" S L=DIART,A=$S(%="F"&(X]%2):X,%="T"&(%2]X)&(X'=""):X,A'="":A,1:%2)
Q	K %,%1,%2,DIART Q
CK	S DIART=%_U_%2_U_A D CK^DIP1
	S %=$P(DIART,U,1),%2=$P(DIART,U,2),A=$P(DIART,U,3) Q

DIB
DIB	; SF/GFT,XAK - CREATE A NEW FILE ;2/13/89  10:34
	;;17.7;VA FileMan; 6/9/89
	W !! K DLAYGO,DTOUT D W^DICRW G Q:$D(DTOUT) K DICS,DIA Q:Y<0
1	Q:'$D(@(DIC_"0)"))  S DIA=DIC,X=^(0),(DI,J(0),DIA("P"))=+$P(X,U,2)
	D QQ S DR="",(L,DRS,DIAP,DB,DSC)=0,F=-1,I(0)=DIA,DXS=1
	D EN^DIA:$N(^DD(DI,.01))>0 I $D(DR) G ^DIA2
Q	K DI,DLAYGO,DIA,I,J
QQ	K ^UTILITY($J),DIAT,DIAB,DIZ,DIAO,DIAP,DIAA,IOP,DSC,DHIT,DRS,DIE,DR,DA,DG,DIC,F,DP,DQ,DV,DB,DW,D,X,Y,L Q
	;
DIE	;
	S F=+Y,(DG,X)="^DIZ("_F_","
	I DUZ(0)="@" W !!,"INTERNAL GLOBAL REFERENCE: "_DG R "// ",X:DTIME S:'$T X="^" S:X="" X=DG I X?."?" W !,"TYPE A GLOBAL NAME, LIKE '^GLOBAL(' OR '^GLOBAL(4,'",!,"OR JUST HIT 'RETURN' TO STORE DATA IN '"_DG_"'" G DIE
	I X?1"^".E S X=$P(X,U,2,9) I X?.P W !?9,*7,"NO NEW FILE CREATED!" S DIK="^DIC(",DA=F K DG G ^DIK
	I "(,"[$E(X,$L(X)),X?1A.E!(X?1"%".E)!(X?1"[".E1"]"1AP.E) S DG=U_X,@("%=$N("_DG_"0))<0") G SET:% W !,*7,"WARNING -- "_DG_" ALREADY EXISTS!  " G SET:DUZ(0)'="@" W "--OK" D YN^DICN G SET:%=1
	W *7,"??" G DIE
SET	D WAIT^DICD S ^DIC(F,"%A")=DUZ_U_DT,X=$P(^(0),U,1),^(0,"GL")=DG
	I DUZ(0)]"" F %="DD","DEL","RD","WR","LAYGO","AUDIT" S ^(%)=DUZ(0)
	I DUZ(0)'="@",$D(^DIC(3,"AFOF")) S:'$D(^DIC(3,DUZ,"FOF",0)) ^(0)="^3.032PA^"_+F_"^1" S ^(+F,0)=F_"^1^1^1^1^1^1",DIK="^DIC(3,DUZ,""FOF"",",DA=F,DA(1)=DUZ D IX1^DIK
	S %="" I @("$D("_DG_"0))") S %=^(0)
	S @(DG_"0)=X_U_F_U_$P(%,U,3,9)")
	K ^DD(F) S ^(F,0)="FIELD^^.01^1",^DD(F,.01,0)="NAME^RF^^0;1^K:$L(X)>30!(X?.N)!($L(X)<3)!'(X'?1P.E) X"
	S ^(3)="NAME MUST BE 3-30 CHARACTERS, NOT NUMERIC OR STARTING WITH PUNCTUATION" W !?5,"A FreeText NAME Field (#.01) has been created."
	S DA="B",^DD(F,.01,1,0)="^.1",^(1,0)=F_U_DA,X=DG_""""_DA_""",$E(X,1,30),DA)",^(1)="S "_X_"=""""",^(2)="K "_X
	S DIK="^DIC(",DA=F D IX1^DIK
	S DLAYGO=F,DIK="^DD(DLAYGO,",DA=.01,DA(1)=DLAYGO G IX1^DIK
	;
EN	; Enter here when the user is allowed to select his fields
	S DIC=DIE S:DIC DIC=$S($D(^DIC(DIC,0,"GL")):^("GL"),1:"")
	D 1:DIC]"" K DIC Q

DIBT
DIBT	; SF/GFT - STORE A SORT TEMPLATE ;4/17/89  11:44 ;3/16/89  12:09 PM
	;;17.7;VA FileMan; 6/9/89
0	;
	S DIC="^DOPT(""DIBT""," G 1:$D(^DOPT("DIBT",.402)) S ^(0)="TEMPLATE FILE^1.01" K ^("B") F X=.4,.401,.402 S ^DOPT("DIBT",X,0)=$P("PRINT^SORT^INPUT",U,$E(X,4)+1)_" TEMPLATE"
	S DIK=DIC D IXALL^DIK
1	;
	S DICF=DI,DIC(0)="QEAIN" D ^DIC K DIC Q:Y<0  S DIC=+Y
11	W !! Q:$D(DTOUT)  S DIC("S")="I $P(^(0),U,4)="_DICF,D="F"_DICF
	S DIC(0)="AEQI" D IX^DIC I Y<0 K DIC,DICF Q
	S DA=+Y,DIE=DIC,DR=".01:3;5:7;10;707;491620" D ^DIE K DR G 11
	;
S	;
	R !,"STORE IN 'SORT' TEMPLATE: ",X:DTIME G Q^DIP:'$T,N:X="" D DIC
	G Q^DIP:X=U,S:Y<0 S DIBT1=+Y
	S %X="DPP(",%Y="^DIBT("_+Y_",2,"
	D %XY^%RCR S X=0
S0	S X=X+1 G N:X>DPP,S0:'$D(DPP(X,"F")),S0:$P(DPP(X),U,4)["B"
	W !,"SHOULD TEMPLATE USER BE ASKED 'FROM'-'TO' RANGE FOR '",$P(DPP(X),U,3),"'"
	S %=2 D YN^DICN G S0:%=2
S1	S ^DIBT(+Y,2,X,"ASK")=""
	G S0
N	K DIEDT G N^DIP1
	S DCC=DI G EN^DIP2
MRG	;
	S DIBT1=1
DIC	K DIC S DIC="^DIBT(",DLAYGO=0,DIC(0)="QELS",DIC("S")="I $P(^(0),U,4)=DK,$P(^(0),U,5)=DUZ!'$P(^(0),U,5)!$D(DIEDT)",D="F"_DK
	D IX^DIC K DIC,DLAYGO,DIEDT D ALR:$N(^DIBT(+Y,0))+1,NOW^%DTC:Y>0
	S:Y>0 ^DIBT("F"_DK,$P(Y,U,2),+Y)=1,^DIBT(+Y,0)=$P(Y,U,2)_U_+$J(%,0,4)_U_DUZ(0)_U_DK_U_DUZ_U_DUZ(0)
	K DIBT1,%I Q
ALR	W !,*7 I $D(DIBT),+Y=DIBT W "NO!! YOU ARE USING THAT TEMPLATE FOR YOUR LIST OF ENTRIES!" S Y=-1 Q
	I $D(DISV),+Y=DISV W "NO!! YOU ARE GOING TO STORE SEARCH RESULTS IN THAT TEMPLATE!" S Y=-1 Q
	W "DATA ALREADY STORED THERE ...OK TO PURGE" S %=2 D YN^DICN I %=1 S %Y="" F %X=0:0 S %Y=$O(^DIBT(+Y,%Y)) Q:%Y=""  K:%Y'="%D" ^DIBT(+Y,%Y)
	Q:%=1  S %Y=-1 I $N(^(1,0))'>0!(%-2)!'$D(DIBT1) S Y=-1 Q
	F %=0:0 S %=$N(^(%)),%Y=%Y+1 Q:%'>0
	W !,"WANT TO MERGE THESE ENTRIES",!,"WITH THE ",%Y," ALREADY IN '",$P(Y,U,2),"' TEMPLATE" S %=2 D YN^DICN S:%-1 Y=-1 W !

DIC
DIC	; SF/XAK - LOOKUP ;5/8/89  14:01 ;
	;;17.7;VA FileMan; 6/9/89
	S D="B" K DF,DS,DIROUT,DTOUT,DUOUT
EN	K DO,DICR S U="^" S:DIC DIC=^DIC(DIC,0,"GL") D PGM I $D(DIPGM) S DIPGM(0)=1 G @DIPGM
ASK	I DIC(0)["A" W ! D ^DIC1
	I $D(DIADD),X'["""",U'[X,X'?."?" S X=""""_X_""""
X	;
	D DO^DIC1:'$D(DO) I U'[X,X'?."?",$D(^DD(+DO(2),.01,7.5)) X ^(7.5) G:'$D(X) BAD^DIC1
	D PGM I $D(DIPGM) S DIPGM(0)=2 G @DIPGM
RTN	;
	G O^DIC1:X'?.ANP,N:$L(X)>30
	I X?.NP G NO:X="",N:U[X,NUM:+X=X&(X>0),^DICQ:X?1."?" I X=" ",$L(DIC)<29,$D(^DISV(DUZ,DIC))#2 S Y=+^(DIC) D S G GOT:$T,BAD^DIC1
F	;
	S (DD,DS)=0
T	S Y=$N(@(DIC_"D,X,0)")),DIX=X I Y'<0 G DIY:$N(^(Y))'<0!((DIC(0)'["O")&(DIC(0)["E")) D MN I  G K:DS S DS=1 G GOT
DIX	I DIC(0)'["X" S:X?.N&(DO(2)'["D")&'$D(DIDA) DIX=DIX_" " S DIX=$N(@(DIC_"D,DIX)")) I $P(DIX,X)="",DIX'=-1 S Y=$N(^(DIX,0)) G DIY
M	I DIC(0)["M" S D=$S($D(DID):$P(DID,U,DID(1)),1:$N(@(DIC_"D)"))) S:$D(DID) DID(1)=DID(1)+1 I D+1 G M:$D(@(DIC_"D)"))-10,T:X'?.NP,T:+X'=X D DO^DIC1:'$D(DO) S Y=$N(^DD(+DO(2),0,"IX",D,0)) G T:'$D(^DD(Y,$N(^(Y,0)),0)),M:$P(^(0),U,2)["P",T
	D D G G:DS=1,Y^DIC1:DS
N	I X[U S DUOUT=1 G NO
	D DO^DIC1:'$D(DO) I X?1"`".NP S Y=$E(X,2,30),DZ=0 G A:Y="" D S S DS=1,DD=Y G GOT:$T I DIC(0)'["L" W:DIC(0)["Q" *7,"  ??" G A
	G ^DICQ:X?."?",^DICM
NUM	D DO^DIC1:'$D(DO) G F:DO(2)<0!$D(DF) S DD=$D(^DD(+DO(2),.001)),DS=$P(^(.01,0),"^",2) I $D(@(DIC_"X)")) G:'DD P:DS["N"!'$N(^("A[")) S Y=X D S G GOT:$T
P	I DS["P"!(DS["V"),DIC(0)'["U" S (DD,DS)=0 G M
	G F
PGM	K DIPGM I DIC(0)'["I",'$D(DF),$D(@(DIC_"0)")),$D(^DD(+$P(^(0),U,2),0,"DIC"))#2,^("DIC")'?1"DI".E S DIPGM=U_^("DIC")
	Q
1	;
	D S G GOT:$T,F
MN	S DZ=$S(DIC(0)["D":1,$D(^(Y))-1:0,1:^(Y)) D:'$D(DO) DO^DIC1
	I 'DZ,'$D(DO("SCR")),$L(DIX)<30,D="B",'$D(DIC("S")),'$D(@(DIC_"Y,-9)")) S DIY="" Q
	D S S:D="B"&'DZ&($P(DIY,DIX)="") DIY=$P(DIY,DIX,2,9)
	Q
S	D:'$D(DO) DO^DIC1 I $D(@(DIC_"Y,0)")) S DIY=$P(^(0),U)
	E  S DIY="" Q
	I '$D(^(-9)) X:$D(DIC("S")) DIC("S") Q:'$T!'$D(DO("SCR"))  I $D(@(DIC_"Y,0)")) X DO("SCR")
	Q
Y	S Y=$N(@(DIC_"D,DIX,Y)"))
DIY	I Y<0 G DIX:DIC(0)'["O"&(DIC(0)["E"),G:DS=1&(D="B")&(DIX=X),DIX
	D MN E  G Y
K	F DZ=1:1:DS I $D(DS(DZ)),+DS(DZ)=Y,DIC(0)'["C" G Y
	D DS^DICN1:'$D(DISMN) I $S<DISMN F DZ=1:1:DS-7 K DS(DZ),DIY(DZ)
	S DS=DS+1,DS(DS)=Y_"^"_$P(DIX,X,2,99),DIY(DS)=DIY G Y:DS#5-1,Y:DS=1,Y:DIC(0)["Y",Y^DIC1
G	S DIY=1,DIX=X I DIC(0)["E",DIC(0)'["D",'$D(DICRS) W $P(DS(1),"^",2)
C	S Y=+DS(DIY),X=X_$P(DS(DIY),"^",2),DIY=DIY(DIY)
GOT	D WO^DIC1:DIC(0)["E" S Y=Y_"^"_$S(DIY="":X,1:DIY) I DIC(0)["E",DO(2)["O" G OK^DIC1
R	D:'$D(DICR) ACT^DICM1 G A:Y<0
	I DIC(0)["Z" K D S:$D(C)#2 D=C S Y(0)=@(DIC_"+Y,0)"),C=$P(^DD(+DO(2),.01,0),U,2),DS=Y,Y=$P(Y(0),U) D Y^DIQ S Y(0,0)=Y,Y=DS,Y(0)=@(DIC_"+Y,0)") S:$D(D) C=D
ACT	I DIC(0)'["F",$D(DUZ)#2 S ^DISV(DUZ,$E(DIC,1,28))=$E(DIC,29,999)_+Y
	I $D(@(DIC_"+Y,0)"))
Q	K DID,DIDA,DISMN,DIC("W"),DINUM,DS,DF,DD,DIX,DIY,DZ,DO,D Q
