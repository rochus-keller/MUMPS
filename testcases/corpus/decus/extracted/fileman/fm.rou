	I $D(DICR(DICR,"S")) S D=D_" S %Y"_DICR_"=Y,Y="_I_" X DICR("_DICR_",""S"") S Y=%Y"_DICR_" I "
	S DIC("S")=D_" Q",D="B",Y=0 D X^DIC
