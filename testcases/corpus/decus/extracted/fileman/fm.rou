DIX	;GFT/SF,NHRC/DRH - STATISTICS ;3/31/89  09:16
	;;17.7;VA FileMan; 6/9/89
	D DT^DICRW
	S DIK="^DOPT(""DIX"",",IO(0)=$I
	G F:$D(^DOPT("DIX",3)) S ^(0)="STATISTICAL ROUTINE^1.01^" F I=1:1:3 S ^DOPT("DIX",I,0)=$E($T(F+I),4,99)
	D IXALL^DIK
F	S DIC=DIK,DIC(0)="AEQZ" D ^DIC Q:Y<0  D @($P(Y(0),U,2,3)) W !! G DIX
	;;DESCRIPTIVE STATISTICS^D^DIXC
	;;SCATTERGRAM^^DIG
	;;HISTOGRAM^^DIH
	;;ESTIMATED LINEAR CORRELATION COEFFICIENTS^C^DIX2
	;;COEFFICIENTS OF DETERMINATION^D^DIX2
	;;RANDOM SAMPLE - DESCRIPTIVE STATISTICS^RS^DIX3
	;;GENERATE RANDOM NUMBERS (WITH REPLACEMENT)^R^DIX3
DHDR	;
	S:$D(^%ZTSK) %IS="Q" D ^%ZIS Q:IO=""!$D(IO("Q"))
DQ	U IO S:+DHDR'=0 IOM=+DHDR S:'$D(DHDR) DHDR="" I DHDR="" G HDR
SITE	W @IOF W:$D(^DD("SITE"))&(DHDR["S") !,"(",^("SITE"),")"
	I $D(DIC) I DHDR["F",@("$D("_DIC_"0))") W "  ",$P(^(0),U,1)," FILE"
	I $D(DUZ)#2,DHDR["U",$D(^DIC(3,+DUZ,0)) W "  USER: ",$P(^(0),U,1)," "
	W ?(IOM-(DHDR["T"*10)-($D(PG)*10)-8) I DHDR["T" D INT W %TIM W "  " K %TIM
	I '$D(DT) S X="T" D ^%DT S DT=Y
	W $E(DT,4,5),"/",DT#100,"/",$E(DT,2,3) I $D(PG) W "  PAGE ",PG S PG=PG+1
HDR	F J=1:1 Q:'$D(DHDR(J))  W !?(DHDR["C"*(IOM-$L(DHDR(J))\2)),$E(DHDR(J),1,IOM)
	W ! Q:DHDR'["L"
LINE	F %=1:1:IOM W "-"
	W ! Q
INT	S %M=$P($H,",",2)\60
20	S %N=" AM" S:%M'<720 %M=%M-720,%N=" PM" S:%M<60 %M=%M+720
25	S %I=%M\600 S:'%I %I=" " S %TIM=%I_(%M\60#10)_":"_(%M#60\10)_(%M#10)_%N
30	K %M,%N,%I

DIX1
DIX1	;DRH/NHRC - DESCRIPTIVE STATISTICS ;12:08 PM  Aug 5, 1988;
	;;17.57;VA FileMan; 11/15/88
D	D DESC G DESCX
	;
DLCOR	D ^%ZIS S DJ=IO(0),U="^"
	I '$D(^DOSV(0,IO(0),0,1,"N")) Q
	F NV=1:1 Q:'$D(^DOSV(0,DJ,0,NV,"S"))  S XDN(NV)=$E($P(^DOSV(0,IO(0),"F",NV),U,3),1,8),FN(NV)=$E($P(^DOSV(0,IO(0),"F",NV),U,1),1,9),FP(NV)=$E($P(^DOSV(0,IO(0),"F",NV),U,2),1,2)+1
	S NV=NV-1
	F J=1:1:NV S K=0,XN=0 F I=1:1 S K=$O(^DIZ(FN(J),K)) Q:K'?1N.N  S X(J,I)=$E($P(^DIZ(FN(J),K,0),U,FP(J)),1,15),XN=XN+1
	Q
DESC	;CALCULATE DESCRIPTIVE STATISTICS.
	D DLCOR Q:'$D(^DOSV(0,IO(0),"F"))  F I=1:1:NV I $D(^DOSV(0,DJ,0,I,"Q")) S (^DOSV(0,DJ,0,I,"V"),X)=^("Q")-((^("S")*^("S"))/^("N"))/(^("N")-1) D SQR^DIX11 S ^("D")=Y
	I '$D(^DOSV(0,IO(0),0,1,"S"))!('$D(^DOSV(0,IO(0),0,1,"N"))) W !!,"YOU MUST PRECEDE VARIABLE NAME IN ""PRINT FIELD:"" OPTION WITH ""+"" OR ""#""" Q
	F J=1:1:NV S XN(J)=XN F K=1:1:XN S Y(J,K)=X(J,K) I X(J,K)']$C(0) S XN(J)=XN(J)-1
	K X
	D EN^DIX11
	Q
	;
DESCX	;PRINT DESCRIPTIVE STATISTICS
	I '$D(^DOSV(0,IO(0),0,1,"S"))!('$D(^DOSV(0,IO(0),0,1,"N"))) Q
	I '$D(^DOSV(0,IO(0),"F")) W *7,!!,?5,"NO STATISTICAL DATA ENTERED" Q
PRINT	K DHDR S DHDR="77CUST",DHDR(1)="DESCRIPTIVE STATISTICS" D DHDR^DIX
	W "I. MEASURES OF CENTRAL TENDENCY :",!!
	W ?1,"VARIABLE",?15,"N",?26,"MEAN",?40,"MEDIAN",?56,"MODE"
	F I=1:1:NV W !,$J(XDN(I),8),?10 W $J(XN(I),6),?20,$J(M(I),11,3),?35,$J(MID(I),11,3),?46,$J(MD(I),30)
	W !!,"II. MEASURES OF DISPERSION :",!!,?1,"A. ACROSS THE RANGE OF DATA :",?51,"25%TILE",?66,"75%TILE"
	W !,?1,"VARIABLE",?15,"N",?24,"MINIMUM",?38,"MAXIMUM",?52,"SCORE",?67,"SCORE"
	F I=1:1:NV W !,$J(XDN(I),8),?10,$J(XN(I),6),$J(L(I),15,3),$J(H(I),15,3),?46,$J(PS25(I),15,2),$J(PS75(I),15,2)
	W !!," ","B. ABOUT THE MEAN :",?38,"STANDARD",?50,"STANDARD ERROR",!,?1,"VARIABLE",?15,"N",?24,"VARIANCE",?38,"DEVIATION",?52,"OF THE MEAN"
	F I=1:1:NV W !,$J(XDN(I),8),?10,$J(XN(I),6),$J(V(I),15,3),$J(SD(I),15,3),$J(SEM(I),15,3)
	W !! F J=1:1:NV W !,?15,XDN(J)," HAS ",XN-XN(J)," MISSING VALUE"_$S(XN-XN(J)=0:"S",XN-XN(J)=1:"",XN-XN(J)>1:"S",1:"")," OUT OF ",XN," RECORDS READ."
KL	I IO(0)'=IO S X=IO X ^DD("FUNC",7,1)
	U IO(0) K CFQ,DHDR,SD,SEM,SMXSQ,SXN,Y,V,VT,DJ,ERR,F,FN,FP,FRQ,G,H,I,J,K,L,M,N,NJ,MD,MFQ,MID,MQ,POP,PR,PR1,PR2,PR3,PR4,PS,PSMX,PS1,PS2,PS3,PS4,PS25,PS75,R,SMX,SQMX,SQR,SUMPX,SUMSQ,S,SN,SZ,NV,X,XDN,XN,Z Q

DIX11
DIX11	;DRH/NHRC - STAT SUBROUTINES ;12:15 PM  Aug 5, 1988;
	;;17.57;VA FileMan; 11/15/88
EN	;
	D SORT,MEAN,MEDIAN,MODE,PTILE,MINMAX,STDEV,SEM
	Q
	;THE FOLLOWING SUBROUTINES ASSUME DATA SORTED IN ASCENDING ORDER OF MAGNITUDE
MEAN	F J=1:1:NV S SMX=0 D L0
	Q
L0	F K=(XN-XN(J)+1):1:XN S SMX=SMX+Y(J,K)
	S M(J)=SMX/XN(J)
	Q
	;
MEDIAN	F J=1:1:NV D L5
	Q
L5	I XN(J)#2 S MID(J)=Y(J,(XN(J)+1)/2+XN-XN(J))
	E  S MID(J)=(Y(J,XN(J)/2+XN-XN(J))+Y(J,XN(J)/2+XN-XN(J)+1))/2
	Q
	;
MODE	F J=1:1:NV D L1
	Q
L1	F L=XN-XN(J)+1:1:XN S FRQ(J,L)=0,S(J,L)=Y(J,L) F K=XN-XN(J)+1:1:XN I S(J,L)=Y(J,K) S FRQ(J,L)=FRQ(J,L)+1
	S MFQ(J)=1 F L=XN-XN(J)+1:1:XN S:FRQ(J,L)>MFQ(J) MFQ(J)=FRQ(J,L),MQ(J)="Y("_J_","_L_")"
	I MFQ(J)>1 S MD(J)=@MQ(J)_" OCCURS "_MFQ(J)_" TIMES "
	I '$D(MD(J)) S MD(J)="NO MULTIPLE OCCURRENCES"
	K S Q
	;
PTILE	F J=1:1:NV D L2
	Q
L2	S K=XN-XN(J),F(J,XN-XN(J))=1,(PR(J,XN-XN(J)),PS(J,XN-XN(J)))=0 F L=XN-XN(J)+1:1 S K=K+F(J,L-1) Q:'$D(FRQ(J,K))  S F(J,L)=FRQ(J,K),PS(J,L)=Y(J,K)
	S CFQ(J,XN-XN(J))=0 F L=XN-XN(J)+1:1 Q:'$D(F(J,L))  S CFQ(J,L)=CFQ(J,L-1)+F(J,L),PR(J,L)=$E((CFQ(J,L)/XN(J))*100,1,6)
	F L=XN-XN(J)+1:1 I PR(J,L)>25!(PR(J,L)=25) S PR2(J)=PR(J,L),PS2(J)=PS(J,L),PR1(J)=PR(J,L-1),PS1(J)=PS(J,L-1) Q
	F L=XN-XN(J)+1:1 I PR(J,L)>75!(PR(J,L)=75) S PR4(J)=PR(J,L),PS4(J)=PS(J,L),PR3(J)=PR(J,L-1),PS3(J)=PS(J,L-1) Q
	S PS25(J)=(25-PR1(J))*(PS2(J)-PS1(J))/(PR2(J)-PR1(J))+PS1(J)
	S PS75(J)=(75-PR3(J))*(PS4(J)-PS3(J))/(PR4(J)-PR3(J))+PS3(J)
	K FRQ(J),CFQ(J),F(J),PR(J),PS(J) Q
	;
MINMAX	F J=1:1:NV S H(J)=Y(J,XN),L(J)=Y(J,XN-XN(J)+1)
	Q
	;
STDEV	F J=1:1:NV S (SMX,SMXSQ)=0 D L3
	Q
L3	F K=XN-XN(J)+1:1:XN S SMX=SMX+Y(J,K),SMXSQ=SMXSQ+(Y(J,K)*Y(J,K))
	S VT(J)=SMX*SMX/XN(J),V(J)=(SMXSQ-VT(J))/(XN(J)-1)
	S X=V(J) D SQR S SD(J)=Y Q
	;
SEM	F J=1:1:NV S X=XN(J) D SQR S SXN(J)=Y,SEM(J)=SD(J)/SXN(J)
	Q
	;
SORT	F J=1:1:NV D S1
S1	S G=XN\2
S2	F I=G+1:1:XN S L=I-G I (Y(J,L)>Y(J,L+G)) S T=Y(J,L),Y(J,L)=Y(J,L+G),Y(J,L+G)=T G S2
	S G=G\2 Q:G'>0  G S2
	Q
	;
SQR	S Y=0 Q:X'>0  S Y=1+X/2
L	S T=Y,Y=X/T+T/2 G L:Y<T
	K T Q

DIX2
DIX2	;DRH/NHRC - CORRELATION AND COEFFICIENT MATRIXES ;12:20 PM  Aug 5, 1988;
	;;17.57;VA FileMan; 11/15/88
C	D CORR G CORRX
D	D CORR G COEF
	;
CORR	;CALCULATE THE CORRELATION MATRIX
	D DLCOR^DIX1
	S NR=XN
	K ERR I $N(^DOSV(0,IO(0),0,1))'>0 W !!,"     AT LEAST TWO VARIABLES MUST BE DEFINED     " S ERR=1 Q
	I '$D(^DOSV(0,IO(0),0,1,"H")) W !!," YOU MUST PRECEDE VARIABLE NAME IN THE ""PRINT FIELD:"" OPTION WITH ""#""" S ERR=1 Q
	F J=1:1:NV I ^DOSV(0,DJ,0,J,"H")=^("L") W !,"CAN'T COMPUTE CORRELATION MATRIX-",XDN(J)," IS SINGLE-VALUED" S ERR=1 Q
	S (CT,PASS)=0
	F J=1:1:NV F K=1:1:XN I X(J,K)']$C(0) S X(1,K)=0,CT=CT+1
L1	S PASS=PASS+1 G:PASS>CT L2 F K=1:1 Q:'$D(X(1,K))  I X(1,K)=0 S XN=XN-1 F J=1:1 G:J>NV L1 F I=K:1:XN S X(J,I)=X(J,I+1)
L2	F J=1:1:NV S XN(J)=XN F K=1:1:XN S Y(J,K)=X(J,K)
	D MEAN^DIX11
	F J=1:1:NV F K=1:1:XN S SMX(J,K)=X(J,K)-M(J)
	S J=0 F NJ=NV-1:-1:1 S J=J+1 F I=1:1:NJ S SUMPX(J,I+J)=0 F K=1:1:XN S PSMX(J,I+J,K)=SMX(J,K)*SMX(I+J,K),SUMPX(J,I+J)=SUMPX(J,I+J)+PSMX(J,I+J,K)
	F J=1:1:NV S SUMSQ(J)=0 F K=1:1:XN S SQMX(J,K)=SMX(J,K)*SMX(J,K),SUMSQ(J)=SUMSQ(J)+SQMX(J,K)
	F J=1:1:NV S X=SUMSQ(J) D SQR^DIX11 S SQR(J)=Y
	S J=0 F NJ=NV-1:-1:1 S J=J+1 F I=1:1:NJ S R(J,I+J)=SUMPX(J,I+J)/(SQR(J)*SQR(I+J)),R(I+J,J)=R(J,I+J),RSQ(J,I+J)=R(J,I+J)*R(J,I+J),RSQ(I+J,J)=R(I+J,J)*R(I+J,J)
	Q
CORRX	;PRINT THE CORRELATION MATRIX
	G:$D(ERR) KL K DHDR S DHDR="72TSU",DHDR(1)="",DHDR(2)="" D DHDR^DIX
	W !!!,"CORRELATION MATRIX (MISSING DATA RECORDS,IF ANY,DELETED):",!!
	F L=1:1:NV S R(L,L)=1
	W ?10 F J=1:1:NV W $J(XDN(J),10)
	F J=1:1:NV W !!,$J(XDN(J),10) F K=1:1:NV W $J(R(J,K),10,3)
	W !!,?6,NR-XN," RECORD"_$S(NR-XN=0:"S",NR-XN>1:"S",NR-XN=1:"",1:"")," HAD ONE OR MORE OBSERVATIONS MISSING."
	W !,?6,XN," RECORDS OF THE ",NR," AVAILABLE WERE USED."
	G KL
COEF	;PRINT THE COEFFICIENTS OF DETERMINATION
	G:$D(ERR) KL K DHDR S DHDR="72TSU",DHDR(1)="",DHDR(2)="" D DHDR^DIX
	W !!!,"COEFFICIENTS OF DETERMINATION (MISSING DATA RECORDS,IF ANY,DELETED):",!!
	F L=1:1:NV S RSQ(L,L)=1
	W ?10 F J=1:1:NV W $J(XDN(J),10)
	F J=1:1:NV W !!,$J(XDN(J),10) F K=1:1:NV W $J(RSQ(J,K),10,3)
	W !!,?6,NR-XN," RECORD"_$S(NR-XN=0:"S",NR-XN>1:"S",NR-XN=1:"",1:"")," HAD ONE OR MORE OBSERVATIONS MISSING."
	W !,?6,XN," RECORDS OF THE ",NR," AVAILABLE WERE USED."
KL	I IO(0)'=IO S X=IO X ^DD("FUNC",7,1)
	U IO(0) K CFQ,CT,DHDR,RSQ,DJ,ERR,F,FN,FP,FRQ,G,I,J,K,L,M,N,NJ,NR,NX,MD,MFQ,MID,MQ,PASS,POP,PR,PR1,PR2,PR3,PR4,PS,PSMX,PS1,PS2,PS3,PS4,PS25,PS75,R,SMX,SQMX,SQR,SUMPX,SUMSQ,S,SZ,NV,X,XDN,XN,Y Q

DIX3
DIX3	;DRH/NHRC - SELECTS RANDOM SAMPLE & DOES DESCRIPTIVE STATS ;12:13 PM  Aug 5, 1988;
	;;17.57;VA FileMan; 11/15/88
R	S S=1 D ^%ZIS Q:POP  D L1^DIX31 G END
RS	S U="^",NV=1,S=0,Z=1
FILE	;
	S DIC="^DIC(",DIC(0)="AEMQ" D ^DIC Q:X="^"  G FILE:Y=-1
	S FN(Z)=$P(Y,"^",1)
VAR	;
	S DIC="^DD("_FN(Z)_",",DIC(0)="AEQZ" D ^DIC Q:X="^"  G VAR:Y=-1
	S XDN(Z)=$P(Y(0),"^",1),C="",FP(Z)=$N(^DD(FN(Z),"B",XDN(Z),C))+1
DATA	S K=0,XN=0 F I=1:1 S K=$O(^DIZ(FN(Z),K)) Q:K'?1N.N  S X(Z,I)=$E($P(^DIZ(FN(Z),K,0),U,FP(Z)),1,15),XN=XN+1
RAND	D ^DIX31 S XN(Z)=SN F K=1:1:SN S Y(Z,K)=X(Z,Y(K)) I Y(Z,K)']$C(0) S XN(Z)=XN(Z)-1
	D ^%ZIS Q:POP
	S XN=SN D EN^DIX11
	D PRINT^DIX1
END	I IO(0)'=IO S X=IO X ^DD("FUNC",7,1) Q

DIX31
DIX31	;DRH/NHRC - GENERATES SN RANDOM NUMBERS  X1<=Y(i)<=X2  0<=i<=SN ;12:23 PM  Aug 5, 1988
	;;17.57;VA FileMan; 11/15/88
ST1	;OBTAIN SAMPLE PARAMETERS
	W !!,"FILE ",FN(Z)," NOW HAS ITS RECORDS TEMPORARILY NUMBERED FROM 1 TO ",XN,".",!
L1	;ENTRANCE FOR RANDOM NUMBERS ONLY
	I '$D(^YRN(1)) S ^YRN(1)=813640269944916720
	S FLAG=S R !!,"ENTER THE NUMBER OF CASES DESIRED FOR THE SAMPLE ( N>1 ) : ",SN:DTIME G L1:SN="" Q:SN="^"
	R !!,"ENTER THE NUMBER FOR THE LOWER LIMIT OF THE SAMPLE RANGE : ",X1:DTIME G L1:X1="" Q:X1="^"
	R !!,"ENTER THE NUMBER FOR THE UPPER LIMIT OF THE SAMPLE RANGE : ",X2:DTIME G L1:X2="" Q:X2="^"
	I SN#1'=0 W !!,"CAN'T DO FRACTIONAL NUMBER OF CASES!" G L1
	I (X2-X1)<0 W !!,"YOU HAVE YOUR RANGE LIMITS REVERSED.",!! G L1
	I FLAG=0&(X2-X1=1) W !!,"RANGE MUST BE GREATER THAN 1",!! G L1
	I FLAG G ST2
	I X1<1!(X2>XN) W !!,"    YOU ARE OUT OF THE DATA RANGE.     ",!! G ST1
ST2	S B=0,C=0,F=1
	F J=10,100,1000,10000,100000 S B=B+1 I X2/J<1 S EXT=B Q
	I X2-X1=1 S EXT=6,F=10000
	I X2'>1 S F=100000,EXT=6
RNG	S Y1(1)=^YRN(1),Y2(1)=$E($E(^YRN(1),7,11),1,EXT)/F,K=262147
	F %=2:1:SN+1 S Y1(%)=$E(Y1(%-1)*K,1,19),Y2(%-1)=$E($E(Y1(%),7,11),1,EXT)/F
	I X1=1 F J1=1:1:SN S Y2(J1)=Y2(J1)+1
SEC	F J3=1:1:SN I (Y2(J3)'>X2)&(Y2(J3)'<X1) S C=C+1,Y(C)=Y2(J3)
	S ^YRN(1)=$E(Y1(SN+1),1,19)
	I C<SN G RNG
	I FLAG W !!,SN," RANDOM NUMBER"_$S(SN>1:"S",SN=1:"",1:"")," FROM THE RANGE ",X1," TO ",X2," "_$S(SN>1:"ARE",SN=1:"IS",1:"")," : ",! F J=1:1:SN W !,?19,J,".  ",Y(J)
	I FLAG K FLAG,SN,Y,S
END	K FLAG,Y1,Y2,B,C,F,L,M,K,X1,X2,J,J1,J2,J3,%,EXT Q

DIXC
DIXC	; SF/GFT - DESCRIPTIVE STATS, CORRELATION MATRIX ;3/31/89  14:29
	;;17.7;VA FileMan; 6/9/89
D	D DESC G DESCX
C	D CORR G CORRX
	;
SQR	S Y=0 Q:X'>0  S Y=1+X/2
L	S T=Y,Y=X/T+T/2 G L:Y<T
	K T Q
DLCOR	S DJ=IO(0),U="^",SZ=0
	F SZT=1:1 S:$D(^DOSV(0,DJ,"CP",SZT)) SZ=SZT Q:'$D(^DOSV(0,DJ,0,SZT,"S"))  S DN(SZT)=$E($P(^DOSV(0,IO(0),"F",SZT),U,3),1,8)
	S SZT=SZT-1 Q
DESC	;CALCULATE THE DESCRIPTIVE STATISTICS.
	D DLCOR K DS F I=1:1:SZT I $D(^DOSV(0,DJ,0,I,"Q")) S X=^("Q")-((^("S")*^("S"))/^("N"))/(^("N")) D SQR S ^("D")=Y
	Q
DESCX	;PRINT DESCRIPTIVE STATS
	K DHDR S DHDR="77CUST",DHDR(1)="DESCRIPTIVE STATISTICS" D DHDR^DIX G KL:IO="",QUE:$D(IO("Q"))
D1	W !!,?13,"N OF",?39,"STANDARD"
	W !,?13,"CASES",?25,"MEAN",?39,"DEVIATION",?54,"MINIMUM",?69,"MAXIMUM"
	F I=1:1:SZT D D10
	G KL
D10	W !,DN(I),?10 I $D(^DOSV(0,DJ,0,I,"N")) W $J(^("N"),6) W:^("N") $J(^("S")/^("N"),15,4)
	F X="D","L","H" W $S($D(^(X)):$J(^(X),15,4),1:$J("",15))
	Q
CORR	;CALCULATE THE CORRELATION MATRIX
	K ^UTILITY($J),ERR I $N(^DOSV(0,IO(0),1))'>0 W !!,"*****     AT LEAST TWO VARIABLES MUST BE DEFINED     *****" S ERR=1 Q
	D DLCOR ;F I=1:1:SZ I ^DOSV(0,IO(0),"BY",I,"H")=^("L") W *7,!,"CAN'T COMPUTE CORRELATION MATRIX--",DN(I+100)," IS SINGLE-VALUED" S ERR=1 G KL
	F I=2:1:SZ S N=^DOSV(0,DJ,0,I,"N"),S=^("S"),C=^DOSV(0,DJ,"CP",I,I) F J=1:1:I-1 I $D(^DOSV(0,DJ,"CP",I,J)) D C1
	G KL
C1	S X=N*C-(S*S)*(N*^DOSV(0,DJ,"CP",J,J))-(^DOSV(0,DJ,0,J,"S")*^("S"))
	D SQR S (^UTILITY($J,J,I),^UTILITY($J,I,J))=(N*^DOSV(0,DJ,"CP",I,J))-(S*^DOSV(0,DJ,0,J,"S"))/Y
	Q
CORRX	;OUTPUT THE CORRELATION MATRIX
	G:$D(ERR) KL K DHDR S DHDR="72TSU",DHDR(1)="CORRELATION MATRIX",DHDR(2)="" D DHDR^DIX
	F I=1:1:SZ S ^UTILITY($J,I,I)=1 I $D(^UTILITY($J,I,I)) W ?I*10-2,$J(DN(I),10)
	F I=1:1:SZ I $D(^UTILITY($J,I,I)) W !,DN(I) F J=1:1:I I $D(^UTILITY($J,I,J)) W ?J*10,$J(^UTILITY($J,I,J),8,4)
	W !!
KL	I IO(0)'=IO D CLOSE^DIO4
	U IO(0) K C,DHDR,I,II,J,JJ,N,POP,S,X,Y,Z,DJ,DN,SZ,SZT
	Q
QUE	;
	F I="DHDR*","^DOSV(0,$I,","SZT","DN*" S ZTSAVE(I)=""
	S ZTIO=ION_";"_IOST_";"_IOM_";"_IOSL,ZTRTN="DQ^DIXC"
	D ^%ZTLOAD G KL
	;
DQ	S DJ=$I D DQ^DIX G D1


