	;;=I $D(^%ZIS(1,DA,0)),$P(^(0),U,2)]"",$D(^%ZIS(1,"CPU",X_"."_$P(^(0),U,2),DA)) K ^(DA) S ^%ZIS(1,"CPU","."_$P(^%ZIS(1,DA,0),U,2),DA)=""
