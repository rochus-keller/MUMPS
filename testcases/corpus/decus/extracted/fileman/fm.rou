	F DIKL2=A-1:-1:1 S DIK1=DIK1_" S DA("_DIKL2_")=0"
	S ^UTILITY($J,DIKR+1)=DIK1_" S DA=0",DIKR=DIKR+2,^(DIKR)="A1 ;"
