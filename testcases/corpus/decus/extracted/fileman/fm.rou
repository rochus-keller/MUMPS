	I %&$D(DPS(DPS,"O"))!$D(DPS(DPS,"D"))!$D(DPS(DPS,"DATE")) S DATE(K+1)=1
	E  S K(K+1,9)=0
	K DPS(DPS) S DPS=DPS-1

