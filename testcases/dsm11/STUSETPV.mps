STUSETPV        ;SET UP PARTITION VECTOR ACCORDING TO SUBMITTED PARAMETERS:
        Q
START   S PROG=240,R4=40960,PV=$V(PROG,$J)-R4,TERM=255,ZE=182
        V 0:MM:MM+128 F I=2:2:PV V I:MM:0
        V PROG:MM:R4+PV,142:MM:R4+PV
        V 232:MM:R4+PV+2,234:MM:R4+PV+2,236:MM:R4+PV+2
        V 126:MM:TERM,134:MM:TERM,150:MM:TERM
        V PV:MM:TERM
        V PV+2:MM:0,PV+4:MM:0,PV+6:MM:0
        V PV+8:MM:$V($V(44)+284),PV+10:MM:0
        V PV+12:MM:2,228:MM:R4+PV+14
        V 264:MM:128*256,140:MM:SIZE1+R4
        V 146:MM:DEV,148:MM:UCI*256
        V 138:MM:SIZE1+R4-2,396:MM:SIZE1+R4
        S REF="G "_RTN_" "
        F I=1:2:$L(REF) V ZE+I-1:MM:$A($E(REF,I))+(256*$A($E(REF,I+1)))
        I $L(REF)#2=1 V ZE+I-1:MM:$V(ZE+I-1,MM)#256+(256*255) G DONE
        V ZE+I-1:MM:TERM
DONE    K ZE,I,REF,PV,R4,TERM
        Q
