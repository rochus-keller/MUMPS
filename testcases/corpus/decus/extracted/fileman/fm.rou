DQ	S X=$F(V,Q,X) I X>0 S V=$E(V,1,X-1)_Q_$E(V,X,999),X=X+2 G DQ
	S X="I "_DHI_">0 S DIK(0)=DA,",V="DIK="""_V_""",",DHI="DA="_DHI_" D ^DIK",DTAG="S DA=DIK(0)"
	F %=1:1:N S X=X_"DIK("_%_")=DA("_%_"),",DTAG=DTAG_",DA("_%_")=DIK("_%_")"
	F %=1:1:A#100 S DHI="DA("_%_")=DIV("_(A#100-%)_"),"_DHI
