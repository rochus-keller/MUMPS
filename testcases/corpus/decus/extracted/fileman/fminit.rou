	;;=one entry can be made in the Device File by leaving the 'Volume
	;;^DD(3.5,1.9,21,13,0)
	;;=Set(CPU)' Field null.  This shortcut will work only if the same $I

FMINI025
FMINI025	;
	;;Version 
	F I=1:2 S X=$T(Q+I) Q:X=""  S Y=$E($T(Q+I+1),4,999),X=$E(X,4,999) S:$A(Y)=126 I=I+1,Y=$E(Y,2,999)_$E($T(Q+I+1),5,99) S:$A(Y)=61 Y=$E(Y,2,999) X NO E  S @X=Y
Q	Q
	;;^DD(3.5,1.9,21,14,0)
	;;=has been associated with this device on every CPU.
	;;^DD(3.5,1.9,"DT")
	;;=2880622
	;;^DD(3.5,1.95,0)
	;;=SIGN-ON/SYSTEM DEVICE^SX^1:YES;0:NO;^0;11^K:X=1&$S($D(^%ZIS(1,D0,0)):$S($P(^(0),U,2)]"":$S($D(^%ZIS(1,"G","SYS."_$P(^(0),U,9)_"."_$P(^(0),U,2)))>9:1,1:0),1:1),1:0) X Q
	;;^DD(3.5,1.95,1,0)
	;;=^.1
	;;^DD(3.5,1.95,1,1,0)
	;;=3.5^G^MUMPS
	;;^DD(3.5,1.95,1,1,1)
	;;=S:$S($D(^%ZIS(1,DA,0)):$S($P(^(0),U,2)]"":$S(+$O(^%ZIS(1,"G","SYS."_$P(^(0),U,9)_"."_$P(^(0),U,2),0))'>0&(X=1):1,1:0),1:0),1:0) ^(DA)="" X ^DD(3.5,1.95,9.2)
	;;^DD(3.5,1.95,1,1,2)
	;;=K:$S($D(^%ZIS(1,DA,0)):$S($P(^(0),U,2)]"":1,1:0),1:0) ^%ZIS(1,"G","SYS."_$P(^(0),U,9)_"."_$P(^(0),U,2),DA)
	;;^DD(3.5,1.95,3)
	;;=YOU MAY ASSIGN ONLY ONE SIGN-ON/SYSTEM DEVICE PER $I PER CPU.
	;;^DD(3.5,1.95,4)
	;;=W !,"Answer 'yes' if this device is the primary device amoung those",!,"device entries that have the same $I and VOLUME SET(CPU)."
	;;^DD(3.5,1.95,9.2)
	;;=K:$S($D(^%ZIS(1,DA,0)):$S($P(^(0),U,2)]""&(X=0):1,1:0),1:0) ^%ZIS(1,"G","SYS."_$P(^(0),U,9)_"."_$P(^(0),U,2),DA)
	;;^DD(3.5,1.95,21,0)
	;;=^^10^10^2890124^^^
	;;^DD(3.5,1.95,21,1,0)
	;;=If answered 'YES', this field identifies that this entry is the primary
	;;^DD(3.5,1.95,21,2,0)
	;;=device among those device entries that have the same $I with the same
	;;^DD(3.5,1.95,21,3,0)
	;;=VOLUME SET(CPU).
	;;^DD(3.5,1.95,21,4,0)
	;;= 
	;;^DD(3.5,1.95,21,5,0)
	;;=Among those device entries that have a common $I and CPU,
	;;^DD(3.5,1.95,21,6,0)
	;;=only one of these entries can have this field set to 'YES'.
	;;^DD(3.5,1.95,21,7,0)
	;;=If none of the common device entries are set to 'YES', the
	;;^DD(3.5,1.95,21,8,0)
	;;=default device will be identified by the first device on
	;;^DD(3.5,1.95,21,9,0)
	;;=the CPU x-ref.  The default device is used when the device
	;;^DD(3.5,1.95,21,10,0)
	;;=handler is invoked with $I as the device to be selected.
	;;^DD(3.5,1.95,"DT")
	;;=2871013
	;;^DD(3.5,2,0)
	;;=TYPE^RS^TRM:TERMINAL;OTH:OTHER;MT:MAGTAPE;SDP:SDP;SPL:SPOOL;BAR:BARCODE READER;HFS:HOST FILE SERVER;VTRM:VIRTUAL TERMINAL;^TYPE;1^Q
	;;^DD(3.5,2,21,0)
	;;=^^2^2^2880309^^^
	;;^DD(3.5,2,21,1,0)
	;;=This field has the general type of device on the CPU.  'TRM' is the most
	;;^DD(3.5,2,21,2,0)
	;;=common entry.
	;;^DD(3.5,2,"DT")
	;;=2880309
	;;^DD(3.5,3,0)
	;;=SUBTYPE^RP3.2^%ZIS(2,^SUBTYPE;1^Q
	;;^DD(3.5,3,1,0)
	;;=^.1
	;;^DD(3.5,3,1,1,0)
	;;=3.5^D^MUMPS
	;;^DD(3.5,3,1,1,1)
	;;=S ^%ZIS(1,DA,91)=$P($S($D(^%ZIS(2,+X,1)):^(1),1:"")_"^^^",U,1,4)_U_$S($D(^(5)):$P(^(5),U,8,9),1:"")
	;;^DD(3.5,3,1,1,2)
	;;=Q
	;;^DD(3.5,3,21,0)
	;;=^^3^3^2850923^^
	;;^DD(3.5,3,21,1,0)
	;;=This field tells what type of terminal is on a terminal port.
	;;^DD(3.5,3,21,2,0)
	;;=It has a great impact on whether the proper terminal control codes
	;;^DD(3.5,3,21,3,0)
	;;=get sent to the terminal.
	;;^DD(3.5,4,0)
	;;=ASK DEVICE^S^1:YES;0:NO;^0;3^Q
	;;^DD(3.5,4,3)
	;;=IF '0', YOU WON'T BE ASKED TO SEND OUTPUT FROM THIS DEVICE TO ANOTHER
	;;^DD(3.5,4,21,0)
	;;=^^2^2^2851218^^
	;;^DD(3.5,4,21,1,0)
	;;=This field controls if the 'DEVICE' question is asked when a call
	;;^DD(3.5,4,21,2,0)
	;;=is made to ^%ZIS.
	;;^DD(3.5,5,0)
	;;=ASK PARAMETERS^S^1:YES;0:NO;^0;4^Q
	;;^DD(3.5,5,3)
	;;=Enter YES if OPEN parameters(RIGHT MARGIN on TRM & VTRM devices) should be asked when the device is selected.
	;;^DD(3.5,5,21,0)
	;;=^^4^4^2890525^^^
	;;^DD(3.5,5,21,1,0)
	;;=On devices of TYPE 'TRM' and 'VTRM', this field controls
	;;^DD(3.5,5,21,2,0)
	;;=if the 'RIGHT MARGIN' question is asked after selecting the device.
	;;^DD(3.5,5,21,3,0)
	;;=On devices of TYPE 'MT', 'SDP', 'BAR', and 'OTH', this field controls
	;;^DD(3.5,5,21,4,0)
	;;=if the 'ADDRESS/PARAMETERS' question is asked after selecting the device.
	;;^DD(3.5,5.1,0)
	;;=ASK HOST FILE^S^1:YES;0:NO;^1;5^Q
	;;^DD(3.5,5.1,3)
	;;=ANSWER YES IF HOST FILE NAME SHOULD BE ASKED
	;;^DD(3.5,5.1,21,0)
	;;=^^3^3^2890124^^
	;;^DD(3.5,5.1,21,1,0)
	;;=Answer 'yes' if 'HOST FILE NAME:' should be asked when the device
	;;^DD(3.5,5.1,21,2,0)
	;;=is selected.  TYPE must be 'HFS'.  Only applicable on layered systems
	;;^DD(3.5,5.1,21,3,0)
	;;=that support host files.
	;;^DD(3.5,5.1,"DT")
	;;=2880714
	;;^DD(3.5,5.2,0)
	;;=ASK HFS I/O OPERATION^S^1:YES;0:NO;^1;6^Q
	;;^DD(3.5,5.2,4)
	;;=W !,"If you wish to have INPUT/OUTPUT OPERATION asked, answer 'yes'",!,"to this field.  ASK PARAMETERS must be set to 'no'",!,"and the OPEN PARAMETERS must be null."
	;;^DD(3.5,5.2,21,0)
	;;=^^6^6^2890525^^^
	;;^DD(3.5,5.2,21,1,0)
	;;=For systems that support host files, this field may be used instead
	;;^DD(3.5,5.2,21,2,0)
	;;=of 'ADDRESS/PARAMETERS' to specify more general parameters.

