	W:$X ?40 W O Q
	Q
EN	;
	Q:'$D(DIC)!'$D(DA)!'$D(DR)  I $D(DIQ)#2 Q:DIQ["^"!($E(DIQ,1,2)="DI")  S:DIQ'["(" DIQ=DIQ_"("
	S DIQG=$S($D(DIQ)#2:DIQ,1:"^UTILITY(""DIQ1"""_","_$J_",")
	S DIQF=$S('$D(DIQ(0)):0,(DIQ(0)["E")&(DIQ(0)["I"):1,DIQ(0)["E":2,DIQ(0)["I":3,1:0)
	S DIQ2=0,DIQ5=DIC,DIFL=1 I 'DIC S DIQ1=DIC,DIC=$S($D(@(DIC_"0)")):+$P(^(0),U,2),1:"") G END:'DIC,CK
	S:DIC DIQ1=$S('$D(^DIC(DIC,0,"GL")):"",1:^("GL")) S D0=DA G END:DIQ1=""
CK	G:'$D(@(DIQ1_DA_",0)")) END
EN1	S DIQ2=DIQ2+1,DIQ3=$P(DR,";",DIQ2) G KIL:'DIQ3 G EN2:DIQ3[":" D EN3 G EN1
KIL	Q:DIFL>1  F J=0:0 S J=$O(DI1(J)) Q:J'>0  S DIFL=J+1 F I=0:1 S DIC=+$O(DI1(J,+DIC)) Q:DIC'>0  K DIF S DIQ1=DI2(J,DIC),@("D"_(J-1))=DI1(J,DIC) I $D(DA(DIC)) S DA=DA(DIC),@("D"_J)=DA(DIC) D:'$D(DR(DIC)) EN4 I '$D(DIF) S DR=DR(DIC),DIQ2=0 D EN1
END	K I,J,%,C,X,Y,%H,D0 S DIC=DIQ5
	K DIQ1,DIQ2,DIQ3,DIQ4,DIQ5,DIQ6,DIQ7,DIQ8,DIQ9,DIFL,DIF,DI1,DI2,DIQF,DIQW,DIQG Q
EN2	S DIQ4=$P(DIQ3,":",1,2) S DIQ3=$P(DIQ4,":",1),DIQ4=$P(DIQ4,":",2) D EN3
EN21	S DIQ3=$O(^DD(DIC,DIQ3)) G:DIQ3>DIQ4!(DIQ3'>0) EN1 D EN3 G EN21
EN3	Q:'$D(^DD(DIC,DIQ3,0))  S Y=^(0),DIQ6=$P(Y,U,4),DIQ7=$P(DIQ6,";",1),DIQ9=$P(DIQ6,";",2) S:+DIQ7'=DIQ7 DIQ7=""""_DIQ7_""""
	I DIQ9=0 S:$D(^DD(+$P(Y,U,2),.01,0)) DIQW=$P(^(0),U,2) G:DIQW["W" WD S DI1(DIFL,+$P(Y,U,2))=DA,DI2(DIFL,+$P(Y,U,2))=DIQ1_DA_","_DIQ7_"," Q
	I DIQ9["E"!(DIQ9) S DIQ8=DIQ1_DA_","_DIQ7_")" Q:'$D(@(DIQ8))  S Y=$S(DIQ9["E":$E(@DIQ8,+$E(DIQ9,2,9),$P(DIQ9,",",2)),1:$P(@DIQ8,U,DIQ9)) S:DIQF=3!(DIQF=1) @(DIQG_DIC_","_DA_","_DIQ3_","_"""I"""_")")=Y Q:DIQF=3  G EN31
	Q:DIQF=3  X $P(Y,U,5,999) K Y S Y=X
EN31	S C=$P(^DD(DIC,DIQ3,0),U,2) D:Y]"" Y^DIQ S:DIQF=0 @(DIQG_DIC_","_DA_","_DIQ3_")")=Y S:DIQF @(DIQG_DIC_","_DA_","_DIQ3_","_"""E"""_")")=Y Q
EN4	F DIQ3=0:0 S DIQ3=$O(^DD(DIC,DIQ3)) S:DIQ3'>0 DIF=1 Q:DIQ3'>0  D EN3
	Q
WD	F DIQJ=0:0 S DIQJ=$O(@(DIQ1_DA_","_DIQ7_","_DIQJ_")")) Q:DIQJ'>0  S @(DIQG_DIC_","_DA_","_DIQ3_","_DIQJ_")")=^(DIQJ,0)
	K DIQJ Q

DIQQ
DIQQ	; SF/GFT - VARIOUS HELPS ;05:01 PM  May 11, 1988
	;;17.7;VA FileMan; 6/9/89
DIP	;
	W !?9,"TYPE '-' IN FRONT OF NUMERIC-VALUED FIELD TO SORT FROM HI TO LO"
	W !?9,"TYPE '+' IN FRONT OF FIELD NAME TO GET SUBTOTALS BY THAT FIELD,"
	W !?12,"'#' TO PAGE-FEED ON EACH FIELD VALUE,  '!' TO GET RANKING NUMBER,"
	W !?12,"'@' TO SUPPRESS SUB-HEADER,   ']' TO FORCE SAVING SORT TEMPLATE"
	W:DJ=1 !?9,"TYPE [TEMPLATE NAME] IN BRACKETS TO SORT BY PREVIOUS SEARCH RESULTS" Q
	;
DIP3	W !,"SINCE YOU ARE CALLING FOR OUTPUT ON DEVICE '",IO,"', YOU MAY USE ",!,"THE TERMINAL YOU ARE NOW TYPING ON FOR SOMETHING ELSE, BY ANSWERING 'Y'",!!
	G FREE^DIP3
	;
DIP1F	W !,"TO ",DE," IN SEQUENCE, STARTING FROM" G 1
DIP1T	W !,"TO ",DE," ONLY UP TO"
1	W " A CERTAIN ",R,",",!?5,"TYPE THAT ",R W:$P(DC,U,1)'["R"&$L(DC) !?5,"'@' MEANS 'INCLUDE NULL ",R," FIELDS'" Q
	;
DICATT3	W "TYPE FIELD NAMES, OPERATORS(+-\/*), DIGITS, OR FUNCTIONS",!,"FOR FUNCTIONS,"
	S D="B",DZ="??",DIC("W")="W:$D(^(9)) ""  ("",^(9),"")""",DIC="^DD(""FUNC"",",DIC(0)="" D DQ^DICQ G 6^DICATT3
	;
DICATT31	W !,"ENTER THE NUMBER OF DIGITS THAT SHOULD NORMALLY APPEAR TO THE"
	W !,"RIGHT OF THE DECIMAL POINT WHEN '",F,"' IS DISPLAYED" G DEC^DICATT3
	;
DIP2	;
	W:$P(DU,U,4)>1 !?5,"TYPE 'ALL' TO PRINT EVERY ",$P(DU,U,1)
	W !?5,"TYPE '&' IN FRONT OF FIELD NAME TO GET TOTAL FOR THAT FIELD,",!?8,"'!' TO GET COUNT, '+' TO GET TOTAL & COUNT, '#' TO GET MAX & MIN,",!?8,"']' TO FORCE SAVING PRINT TEMPLATE"
	W:DE="" !?5,"TYPE '[TEMPLATE NAME]' IN BRACKETS TO USE AN EXISTING PRINT TEMPLATE"
	W !?5,"YOU CAN FOLLOW FIELD NAME WITH ';' AND FORMAT SPECIFICATION(S)"
	G F^DIP2
	;
DICE2	;
	W !!,"YOU MAY USE '@' TO INDICATE THAT '",DNEW,"' IS TO BE DELETED",!,"IF YOU SIMPLY WANT TO MOVE THE VALUE OF '",DOLD,"' OVER,",!,"   JUST ENTER '",DOLD,"'"
	G C^DICE2
DIARQ	;ARCHIVING ERROR MESSAGES
FER	W !,*7,"Less than 'FROM SELECT CRITERIA VALUE'.",$P(DIARS,U,2) Q
FER1	W !,*7,"Less than 'FROM' value." Q
TER	W !,*7,"Less than 'TO SELECT CRITERIA VALUE'.",$P(DIARE,U,2) Q
TER1	W !,*7,"Less than 'TO' value." Q
	;
ENTT	W !!,"_____________________________________________________________________________",!!,*7,"A field in the 'SELECT CRITERIA TEMPLATE being used does NOT MATCH."
	W !,"the field at the SAME LEVEL in the BASE SELECT CRITERIA SORT TEMPLATE"
	W !,"specified for this file.  There must be a one to one correspondence"
	W !,"between the fields in the template you want to use and the"
	W !,"BASIC SELECT CRITERIA SORT TEMPLATE, until all the fields in the"
	W !,"BASIC SELECT CRITERIA SORT TEMPLATE have been satisfied.  More"
	W !,"CRITERIA may exist after that.  See the development staff of the Package"
	W !,"or the ARCHIVING DOCUMENTATION where this process is explained further"
	W !,"for more information."
	W !,"_____________________________________________________________________________"
	Q

DIQQQ
DIQQQ	; SF/GFT,XAK - MORE HELP ;05:01 PM  May 11, 1988;
	;;17.7;VA FileMan; 6/9/89
	;
DICATT	W !,"IF YOU WANT THE SAME ANSWER ALLOWED FOR ",F,!,"AS FOR " Q
	;
DICATT1	W !,"ENTER GLOBAL SUBSCRIPT NAME AT WHICH ",F," WILL BE STORED"
	W !,"   ALREADY ASSIGNED: " S Y=-1 F T=0:0 S Y=$N(^DD(A,"GL",Y)) G SUB^DICATT1:Y<0 W $J(Y,9) W:$X>66 !
	;
DIS	;
	W !?8,"ENTER A VALUE WHICH '"_O(DC)_"'"
	W !?8,"MUST "_$P("NOT ",U,DN]"")_$P("^CONTAIN^MATCH^BE LESS THAN^EQUAL^EXCEED^FOLLOW",U,+DQ)_", IN ORDER FOR"
	W " TRUTH CONDITION -"_$C(DC+64)_"- TO BE TRUE",! W:+DQ=3 ?8,"(I.E., ENTER WHAT WOULD FOLLOW THE MUMPS '?' OPERATOR)",! W ! G F^DIS
	;
DISC	W !,"YOU CAN NEGATE ANY OF THESE CONDITIONS BY PRECEDING THEM WITH ""'"" OR ""-"""
	W !,"SO THAT ""'NULL'"" MEANS ""NOT NULL""",! G C^DIS
	;
DIP1	W *7,!,"YOU HAVE ASKED TO SORT ON THE SAME FIELD TWICE; THAT DOESN'T MAKE SENSE!" G Q^DIP
	;
DIP3	W !,"IF YOU WANT PAGE NUMBERING TO START AT A NUMBER HIGHER THAN 1, TYPE THAT NUMBER" G ^DIP3
	;
DIA	W "FOLLOW A FIELD NAME WITH ';""CAPTION""' TO HAVE THE FIELD ASKED AS 'CAPTION: '"
	W !?9,"OR WITH ';T' TO USE THE FIELD 'TITLE' AS CAPTION"
	G 2^DIA
	;
DIA3	W !,*7,"CAPTIONS CANNOT CONTAIN ':' OR ';', OR BEGIN WITH A PERIOD OR A DIGIT",! G 2^DIA
	;
DIP21	W !,"THIS TEMPLATE MAY EVENTUALLY BE USED WITH A DIFFERENT 'SORT-BY' SEQUENCE.",!
	W "ANSWERING 'Y' HERE INSURES THAT, IN THAT CASE, USER WON'T HAVE TO REMEMBER"
	W !,"TO TYPE THE '@' IN ORDER TO KEEP SUB-HEADERS FROM APPEARING.",! G SUB^DIP21
	;
DICOMPW	W !?4,"AT THE TIME THE LOOKUP OCCURS IN FILE "_Y_", THERE MAY"
	W !?4,"BE MORE THAN 1 ENTRY FOUND.  ANSWERING 'Y' HERE MEANS THAT THE"
	W !?4,"USER THEN WILL BE ALLOWED TO CHOOSE AMONG SEVERAL ENTRIES.",!! Q

DIR
DIR	; SF/XAK - READER-MAID (READ, HELP) ;5/23/89  17:41
	;;17.7;VA FileMan; 6/9/89
	Q:'$D(DIR(0))  D ^DIR2 G Q:%T="" N DIC
A	D W I $D(DTOUT) K Y S DIRUT=1,Y="" G Q
	I %T'="E",X?1."^".E K Y S DIRUT=1,Y=X S:X=U DUOUT=1 S:X="^^" DIROUT=1 S:%T="Y" %=-1 G Q
	I %T'="E",X="",%A["O" S Y="",DIRUT=1 G Q
	I %A'["O","@"[X,%T'="E" W *7,!!?5,"This is a required response.  Enter '^' to exit",! G A
	I $D(%G),$D(DIR("B")),X=DIR("B") S Y=%G G Q
	I X'?1."?" D ^DIR1 I '%E,$P(DIR(0),U,3)]"" S %X=X X $P(DIR(0),U,3,99) S:'$D(X) %E=1 S X=%X
	I X?1."?"!(X'?.ANP)!%E D QUES:%E'<0 W ! G A
	G Q
	;
W	;
	S %W=$S($D(DIR("?")):DIR("?"),1:$P($T(@%T),";",4)),%N=$E(%W)=U
	K DTOUT,DUOUT,DIRUT,DIROUT S %E=0 ;I $D(DIR0) G ^DIR0
	I %T="S",%A'["A",%A'["B" W !!?5,"Select one of the following:",! F %I=1:1 Q:'$L($P(%B,";",%I,99))  W !?10,$P($P(%B,";",%I),":"),?20,$P($P(%B,";",%I),":",2)
	I $D(DIR("A"))=11 F %=0:0 S %=$O(DIR("A",%)) Q:%'>0  W !,DIR("A",%)
	W ! W:$L(%P) %P
	I $D(DIR("B")) W DIR("B") I $L(DIR("B"))<20!(%T="D")!((%B["D"&%T)) W "//"
	I %T'="D",$D(DIR("B")),$L(DIR("B"))>19,(%B'["D"&%T)!'%T S Y=DIR("B") D RW^DIR2 S:X="" X=DIR("B") Q
	R X:$S($D(DIR("T")):DIR("T"),'$D(DTIME):300,1:DTIME) I '$T S DTOUT=1
	I X="",$D(DIR("B")) S X=DIR("B") I %T'="D",%B'["D"&%T W X
	Q
	;
QU	I %E!(X="?")!($O(^DD(%B1,%B2,21,0))'>0) K %Y W ! F %C=3,12 I $D(^DD(%B1,%B2,%C)) S X1=^(%C),%J=75,%Y=1 D W1
	I $D(^DD(%B1,%B2,4)) W ! X ^(4)
	I X?1"??".E W ! F %C=0:0 S %C=$O(^DD(%B1,%B2,21,%C)) Q:%C'>0  W !?5,^(%C,0)
	I %B["P" K DO S DIC=U_$P(%B3,U,3),DIC(0)="M"_$E("L",%B'["'") D AST:%B["*",DQ
	I %B["D" S %DT=$P($P($P(%B3,U,5,99),"%DT=""",2),"""",1) D HELP^%DTC
	I %B["S" X:$D(^DD(%B1,%B2,12.1)) ^(12.1) W !?5,"Choose from: " F %C=1:1 S Y=$P($P(%B3,U,3),";",%C) Q:Y=""  S %I=$P(Y,":",2),Y=$P(Y,":") X:$D(DIC("S")) DIC("S") I  W !?7,Y,?15," ",%I
	I %B["V" W ! S X1=X,DU=%B1,D=%B2,DZ=X D V^DIEQ S X=X1
	Q
DQ	N %W S D="B",DZ=X D DQ^DICQ K DD,DIC,%,DO S:$D(DZ) X=DZ
	Q
AST	S Y=$F(%B3," D ^DIC"),%=8 I 'Y S Y=$F(%B3," D IX^DIC"),%=10 Q:'Y
	X $P($E(%B3,1,Y-%),U,5,99) Q
QUES	;
	I %T D QU
	I X="??",$D(DIR("??")) D:$P(DIR("??"),U)]"" HF X:$P(DIR("??"),U,2)]"" $P(DIR("??"),U,2,99) Q
	I %T="P" S DIC=%B1,DIC(0)=%B2 D DQ
	W:'%N ! W:(X'["?") *7 X:%N $E(%W,2,999) D:'%N WRAP:%W]""
	Q
WRAP	I $D(DIR("?"))=11 F %I=1:1 Q:'$D(DIR("?",%I))  W !?5,DIR("?",%I)
	K %Y S %J=$S($D(IOM):IOM,1:80)-6,X1=%W,%Y=1
	I '%N,$D(DIR("?"))'=11,"FNDL"[%T S X1=X1_"."
W1	S:$L(X1)<%J %Y(%Y)=X1 I $L(X1)'<%J F %I=%J:-1:0 I $E(X1,%I)?1P S %Y(%Y)=$E(X1,1,%I),X1=$E(X1,%I+1,999),%Y=%Y+1 G W1
	F %I=1:1:%Y W !?5,%Y(%I)
	K %Y,%,X1
	Q
HF	N %A,%B S XQH=$P(DIR("??"),U) D EN1^XQH
	Q
F	;;;This response can be free text
S	;;;Enter a code from the list.
Y	;;;Enter either 'Y' or 'N'.
E	;;;Enter either RETURN or '^'
N	;;;This response must be a number
D	;;;This response must be a date
L	;;;This response must be a list or range, e.g., 1,3,5 or 2-4,8
Q	G ^DIRQ

DIR1
DIR1	; SF/XAK - READER-MAID (PROCESS DATATYPE) ;5/25/89  08:41
	;;17.7;VA FileMan; 6/9/89
	S %E=0 D @%T I %A["X"!'%E!(X?.UNP) Q
	F %Y=1:1:$L(X) I $E(X,%Y)?1L S X=$E(X,1,%Y-1)_$C($A(X,%Y)-32)_$E(X,%Y+1,999)
	G DIR1
Y	; YES/NO
S	; SET
	S %BA=$S($D(DIC("S")):DIC("S"),1:"I 1")
	S %J=0,Y(0)=$P($P(";"_%B,";"_X_":",2),";") I Y(0)]"" S Y=X X %BA I  S %J=1
	I '%J F %I=1:1 S %J=$P(%B,";",%I) Q:%J=""  S Y=$F(%J,":"_X) I Y S Y=$P(%J,":") X %BA I  S Y(0)=$P(%J,":",2) Q
	I %J="" S %E=1 Q
	W $S($P(Y(0),X)="":$E(Y(0),$L(X)+1,99),1:"  "_Y(0))
	I %T="Y" S (%,Y)=$S("Yy"[$E(X):1,"Nn"[$E(X):2,1:"") S:%=2 Y=0
	Q
	;
L	; LIST OR RANGE
	S Y(0)="",%C=0,%BA=$S($D(DIR("S")):DIR("S"),1:"I 1")
	F %I=1:1 S %X=$P(X,",",%I) Q:%E!'$L($P(X,",",%I,999))  S:%X'?.".".N."."."-".N."-".N.".".N %E=1 D L0:'%E
	I %E,'%N S %W="Response should be no less than "_+%B1_" and no greater than "_%B2
	S Y=Y(0) K %
	Q
L0	I $P(DIR(0),U,2)'="" S:+%X<%B1!(%X>%B2) %E=2 S %=$P(%X,"-",2) I %,%>%B2!(%<%X) S %E=3
	Q:%E  I %X?.N!(%X?1N.".".N) S %J=%X G L1
	I %X#1 S Y(%C)=Y(%C)_+%X_",",$P(%X,"-")=%X\1+1
	F %J=$P(%X,"-"):1:$P(%X,"-",2) D L1
	I $P(%X,"-",2)#1>0 S Y(%C)=Y(%C)_$P(%X,"-",2)_","
	Q
L1	I $L(Y(%C)_%J)>220 S %C=%C+1,Y(%C)=""
	F %=0:1:%C I Y(%)_","[(","_%J_",") S %=-1 Q
	I %'<0 S Y=%J X %BA I  S Y(%C)=Y(%C)_%J_","
	Q
D	; DATE
	D ^%DT I Y<0 S %E=1 Q
	I %B1,Y<%B1 S %E=1 S:'%N %W=$P(%W,"must be a date",1)_"must not be previous to "_+$E(%B1,4,5)_"/"_+$E(%B1,6,7)_"/"_$E(%B1,2,3)_$P(%W,"must be a date",2,99) Q
	I Y>%B2 S %E=1 S:'%N %W=$P(%W,"must be a date",1)_"must not be following "_+$E(%B2,4,5)_"/"_+$E(%B2,6,7)_"/"_$E(%B2,2,3)_$P(%W,"must be a date",2,99)
	Q
	;
N	; NUMERIC
	S Y=X I X'?.1"-".N.1".".N S %E=1 Q
	I X>%B2!(X<%B1) S %E=1 S:'%N %W=%W_" no "_$S(X>%B2:"greater",1:"less")_" than "_$S(X>%B2:%B2,1:%B1)
	I '%E,($L($P(X,".",2))>%B3) S %E=1 S:'%N %W=%W_" with no more than "_+%B3_" decimal digits"
	Q
	;
F	; FREETEXT
	S Y=X
	S %W="This response must have at least "_+%B1_" characters and no more than "_%B2_" characters"
	I $L(X)<%B1!($L(X)>%B2) S %E=1
	Q
	;
E	; END-OF-PAGE
	S Y=X="" S:X=U DUOUT=1 I $L(X),X'=U S %E=1
	Q
	;
P	; POINTER
	S %B2=$P(%B2,"L")_$P(%B2,"L",2)
	I %B2["A" S %B2=$P(%B2,"A")_$P(%B2,"A",2)
	S DIC=%B1,DIC(0)=%B2,%C=X D ^DIC S X=%C
	I Y<0,%A'["O" S %E=Y
	Q
	;
1	; DD
	S %C=X N %W
	I %B["S" S %B=$P(%B3,U,3) X:$D(^DD(%B1,%B2,12.1)) ^(12.1) D S S X=Y,%B=$P(%B3,U,2) G R
	I %B["P" S DIC=U_$P(%B3,U,3),DIE=DIC,DIC(0)="EM" I %B'["*" D ^DIC S X=+Y,%E=Y<0
	I %B["V" S (DIE,DP)=%B1,DIFLD=%B2,DQ=1 D ^DIE3 S %E=Y'>0 S:Y>0 Y(0)=$P(Y,U,2)
R	D IT:'%E S X=%C
	Q
IT	N %A,%C,%P,%T
	X $P(%B3,U,5,99) S %E='$D(X) I '%E,%B'["P" S Y=X
	Q

DIR2
DIR2	; SF/XAK - READER-MAID (SETUP VARIABLES/REPLACE...WITH) ;5/23/89  17:32
	;;17.7;VA FileMan; 6/9/89
	; Check that the inputs to the reader are there and setup variables
	K X,Y,% S U="^"
	S %T=$E(DIR(0)),%A=$P(DIR(0),U),%B=$P(DIR(0),U,2)
	K:$D(DIR("A"))=10 DIR("A") K:$D(DIR("?"))=10 DIR("?")
	I %A?.NP1",".ANP S %B1=$P(%A,","),%B2=+$P(%A,",",2) G:'$D(^DD(%B1,%B2,0)) EO S %B3=^(0),%B=$P(%B3,U,2) G:%B EO D:'$D(DIR("B")) DA^DIRQ:$D(DA)#2 S:'$D(DIR("A")) %P=$P(%B3,U)_": " S:$P(%B3,U,2)'["R" %A=%A_"O" S %T=1 G NN
	I "FSYENDLP"'[%T G EO
	S %B1=$P(%B,":"),%B2=$P(%B,":",2),%B3=$P(%B,":",3)
	S:'$L(%B2) %B2=9999999 I %T="F",%B2>245 S %B2=245
	I %T="Y" S %B="y:YES;n:NO"
	I %T="D" S %DT=$P(%B3,"A")_$P(%B3,"A",2)
	I %T="D",(%B["NOW"!(%B["DT")) D NOW^%DTC K %I,%H S DT=X S:%B1["NOW" %B1=% S:%B1["DT" %B1=X S:%B2["NOW" %B2=% S:%B2["DT" %B2=X K %
	I %T="P" S %B1=$S('%B1:U_%B1,'$D(^DIC(+%B1,0,"GL")):U,1:^("GL")) G EO:%B1=U,EO:'$D(@(%B1_"0)")) I '$D(DIR("A")) S %P="Select "_$O(^DD(+$P(^(0),U,2),0,"NM",0))_": " Q
NN	D:%T="S" S0:%A'["A" Q:$D(%P)
	S %P="" I %A["A" S:$D(DIR("A")) %P=DIR("A") Q
	I '$D(DIR("A")) S %P=$P($T(@%T),";",3) I %T="D" S %P=%P_$S(%B3["R":" and time",%B3["T":" and optional time",1:"")
	S:$D(DIR("A")) %P=$S(%T="Y":DIR("A")_"? ",%T="S":"Enter "_DIR("A")_": ",1:DIR("A")_": ") I "LND"'[%T Q
	I $L(%B1) S %P=%P_" ("_$S(%T="D":+$E(%B1,4,5)_"/"_+$E(%B1,6,7)_"/"_$E(%B1,2,3)_" - "_+$E(%B2,4,5)_"/"_+$E(%B2,6,7)_"/"_$E(%B2,2,3),1:%B1_"-"_%B2)_")"
	S %P=%P_$S("?: "[$E(%P,$L(%P)):"",1:":")_" "
	Q
S0	S %P=$S($D(DIR("A")):DIR("A"),1:"Select one of the following")_": "
	Q:%A'["B"  S %P=%P_" ("
	F %I=1:1 S %P=%P_$P($P(%B,";",%I),":") Q:'$L($P(%B,";",%I+1,99))  S %P=%P_"/"
	S %P=%P_"): "
	Q
EO	S %T="",Y=-1 Q
	;
RW	; Replace...With...
	S DG=Y I $D(DTIME)[0 S DTIME=999
A	W:$X>50 ! R "  Replace ",X:DTIME S:'$T DTOUT=1
	G B:X="",Q:X?1"^".E,Q:X?."?",Q:X="@",E1:X="END"!(X="end")
	I Y[X S D=X D H G B:'$T S Y=$P(Y,D,1)_X_$P(Y,D,2,999) G A
	S D=$P(X,"...",1),DH=$F(Y,D) I DH S X=$P(X,"...",2,99),X=$S(X="":999,1:$F(Y,X,DH)) I X S DH=DH-$L(D)-1,D=X D H I  S Y=$E(Y,1,DH)_X_$E(Y,D,999) G A
	W *7," ??" G A
H	R " With ",X:DTIME S:'$T DTOUT=1
	S %=$L(Y)+$L(X)>245 W:% *7," STRING TOO LONG!" G H:%
	Q:X?.ANP  W *7,"??" G H
E1	D H I  S Y=Y_X G A
B	W:'$T *7 I DG'=Y S X=Y W !?3 W X I X="" S X="@"
Q	Q
	;
F	;;Enter response: ;
S	;;Enter response: ;
Y	;;Enter Yes or No: ;
E	;;Press RETURN to continue or '^' to exit: ;
N	;;Enter a number;
D	;;Enter a date;
L	;;Enter a list or range of numbers;
P	;;Select: ;

DIRCR
DIRCR	; SF/GFT - DELETE THIS LINE AND SAVE AS '%RCR'*** ;05:02 PM  May 11, 1988
	;;17.7;VA FileMan; 6/9/89
%RCR	;GFT/SF
	;
STORLIST	D INIT
O	S %D=$N(%RCR(%D)) G CALL:%D<0
	I $D(@%D)#2 S @(%E_")="_%D) G O:$D(@%D)=1
	S %X=%D_"(" D %XY G O
	;
CALL	S %E=%RCR K %RCR,%X,%Y D @%E
	S %E="^UTILITY(""%RCR"",$J,"_^UTILITY("%RCR",$J)_",%D",^($J)=^($J)-1,%D=0,%X=%E_","
G	S %D=$N(@(%E_")")) I %D<0 K %D,%E,%X,%Y,^($J,^UTILITY("%RCR",$J)+1) Q
	I $D(^(%D))#2 S @%D=^(%D) G G:$D(^(%D))=1
	S %Y=%D_"(" D %XY G G
	;
%XY	;
	S %Z=1,%A="",%C(0)=0
S	S %B=-1
N	S %B=$N(@(%X_%A_"%B)")),%C(%Z)=%C(%Z-1)
	I %B["," F %C=0:0 S %C=$F(%B,",",%C) Q:'%C  S %C(%Z)=%C(%Z)+1
	I %B=-1 G Q:%Z=1 S %Z=%Z-1,@("%B="_$P(%A,",",%Z+%C(%Z-1),%Z+%C(%Z))),%A=$P(%A,",",1,%Z-1+%C(%Z-1))_$E(",",%Z>1) G N
	I $D(@(%X_%A_"%B)"))#10=1 S @(%Y_%A_"%B)="_%X_%A_"%B)")
