KL	K DIU,DIV,DIG,DIH,DLAYGO,DITF,DFN,DMRG,DTO,DTN,DDF,DTL,DFL,DDT,A,B,DKP,W,X,FLDS,Y,Z Q
	;
T	S Z=$P(^(0),U,4),V=$P($P(^(0),U,2),U,Z[";0"),^UTILITY("DITR",$J,L,Y)=$P(Z,";",2)_U_$P(Z,";",1) S:V ^(Y)=^(Y)_U_V,L(+$P(%,U,2))=+V I Z="0;1",DDF(1)=L S DITF=$P(%,U,4)
	Q:$D(A)  W:$X ", " W:$L(DIC)+$X>66 ! W "'"_DIC_"' FIELDS" Q
	;
PTS	;
	S DL=0 F X=0:0 S X=$N(^DD(+Y,0,"PT",X)) Q:X'>0  F Z=.001:0 S Z=$N(^DD(+Y,0,"PT",X,Z)) Q:Z'>0  I $D(^DD(X,Z,0))#2 S %=^(0) I (U_$P(%,U,3)=DTO!($P(%,U,2)="V")),$P(%,U,2)'["I" S DL=DL+1,^UTILITY("DIT",$J,0,DL)=X_U_Z_U_$P(%,U,2)
	Q
	;
F	W !?7,"(TYPE '^' TO FORGET THE WHOLE THING!)",!

DIT0
DIT0	; SF/XAK - PREPARE TO XFR ;09:21 AM  Jul 19, 1988;
	;;17.7;VA FileMan; 6/9/89
	K Y,DIC S DIT=DDF(1),DIC=L,DIC(0)="EQLAM",X="DATA INTO WHICH " D LK
	G Q:Y<0 S DFR=+Y,DTO(1)=DIC_+Y_",",DIC(0)="EQAM",X="FROM ",DIC("S")="I Y-"_+Y D LK G Q:Y<0
S	S %=2 W !,"   WANT TO DELETE THIS ENTRY AFTER IT'S TRANSFERRED" D YN^DICN G Q:%<0 S DH=2-% I '% D F^DIT G S
	S ^UTILITY("DIT",$J,+Y)=DFR_";"_$E(DIC,2,999)
	S DTO=0,(D0,DA)=+Y,DIK=DIC,DFR(1)=DIC_DA_"," K DIC D WAIT^DICD
GO	D GO^DITR
	S DIT=DH D KL^DIT,^DIK:DH S DA=DFR K DFR D IX1^DIK
	S DH=DIT D ASK^DITP,PTS^DITP:%=1
Q	G Q^DIT
	;
LK	S DIC("A")="TRANSFER "_X_DFL G ^DIC
	;
EN	; PROGRAMMER CALL
	; DIT("F") = GLOBAL ROOT OR FILE # OF FILE TO TRANSFER FROM
	; DIT("T") = GLOBAL ROOT OR FILE # OF FILE TO TRANSFER TO
	; DA("F")  = ENTRY # IN FILE TO TRANSFER FROM
	; DA("T")  = ENTRY # IN FILE TO TRANSFER TO
	;
	I '$D(DIT("F"))!'$D(DIT("T"))!'$D(DA("F"))!'$D(DA("T")) G FIN
	S DDF(1)=DIT("F"),DDT(0)=DIT("T")
	I 'DDF(1) S DDF(1)=$S($D(@(DDF(1)_"0)"))#2:+$P(^(0),U,2),1:0) G FIN:'DDF(1) S DFR(1)=DIT("F")
	I 'DDT(0) S DDT(0)=$S($D(@(DDT(0)_"0)"))#2:+$P(^(0),U,2),1:0) G FIN:'DDT(0) S DTO(1)=DIT("T") G C
	G FIN:'$D(^DIC(+DDF(1),0,"GL")) S DFR(1)=^("GL")
	G FIN:'$D(^DIC(+DDT(0),0,"GL")) S DTO(1)=^("GL")
C	S DB=DA("F"),(DB1,DFR)=DA("T"),DIK=DTO(1)
	I $D(DA(1)) F I=1:1 G:'$D(DA(I)) SET S DRF(I)=$P(DA(I),",",1)_",1,",DOT(I)=$P(DA(I),",",2)_",1,"
DON	K DRF,DOT S DFR(1)=DFR(1)_DB_",",DTO(1)=DTO(1)_DB1_",",DKP=1,DMRG=1,DTO=0,DH=0 G GO
SET	F I=I-1:-1 G:I'>0 DON S DFR(1)=DFR(1)_DRF(I),DTO(1)=DTO(1)_DOT(I)
FIN	;
	K DDF,DFR,DDT,DTO
	Q

DIT1
DIT1	; SF/GFT - TRANSFER DD'S ;3/1/89  19:55
	;;17.7;VA FileMan; 6/9/89
	K A W !! S A=+Y,E=A
CHK	F V=0:0 S V=$N(^DD(A,"SB",V)) Q:V'>0  S A(V)=0,L(V)=DLAYGO_$P(V,E,2,9)
	S A=$N(A(0)),B=A#1+DHIT I A+1 K A(A) G P:$P(DHIT,".",1)+1'>B,CHK:'$D(^DD(B)),P:DHIT["." S X=$P(^(B,0),U,1) S:$D(^DIC(B,0)) X=$P(^(0),U,1)_" FILE" W $P(^DD(A,0),U,1)_" WOULD COLLIDE WITH "_X,*7,! K L,A Q
	D WAIT^DICD F A="^DIE(","^DIPT(","^DIBT(" F V=0:0 S V=$N(@(A_"V)")) Q:V'>0  I $D(^(V,0)),$P(^(0),U,4)-Y=0 S ^UTILITY("DITR",$J,A,V)=$P(^(0),U,1)
	S A="F B=0:0 Q:F=DTO!'$F(W,DTO)  S W=$P(W,DTO)_F_$P(W,DTO,2,9)",C1="F B=0:0 S B=$F(W,""^DD("",B) Q:'B  S DTL=+$E(W,B,999),%=B+$L(DTL) S:$D(L(DTL)) W=$E(W,1,B-1)_(DTL#1+DHIT)_$E(W,%,999) S B=%"
	G GO:$N(^UTILITY("DITR",$J,-1))<0 W !,"DO YOU WANT TO COPY '",$P(Y,U,2),"'S TEMPLATES INTO YOUR NEW FILE" D YN^DICN W !
	I %=1 S E="I DIK=""^DIBT("",%Z=1,$D(L(+W)) S $P(W,U,1)=L(+W)" F DIK="^DIE(","^DIPT(","^DIBT(" S V=$P(@(DIK_"0)"),U,3),%X=DIK_"Z,",%Y=DIK_"V," D ^DIT2,IXALL^DIK
GO	S Y=DLAYGO K ^UTILITY("DITR",$J),^DD(Y,"B"),^(.01),^("IX"),^("RQ"),^(0,"IX"),E
	S @("V=$P("_DTO_"0),U,2)"),@("^(0)=$P("_DTO(0)_"0),U,1,2)_$P(V,DDF(1),2)_U_U")
DD	W ! S L=$N(L(L)),Y=L#1+DHIT Q:L<0  S B=0,V=$N(^DD(L,0,"NM",0)),^DD(Y,0)=^DD(L,0) I V+1,$N(^(0,"NM",0))<0 S ^(V)=""
	S V=-1 I $D(^DD(L,0,"UP")) S ^DD(Y,0,"UP")=^("UP")#1+DHIT
ID	S V=$N(^DD(L,0,"ID",V)) I V+1,$D(^(V))#2 S W=^(V) X A,C1 S ^DD(Y,0,"ID",V)=W G ID
	F V=0:0 S V=$N(^DD(L,V)) Q:V'>0  I $D(^(V,0)) W "." S W=^(0),D=$P(W,U,2),%Z=0,%A="" S:D L(+D)=D#1+DHIT,W=$P(W,U,1)_U_L(+D)_$P(D,+D,2,9)_U_$P(W,U,3,99) X A,C1 D Y S ^DD(Y,V,0)=W,%B=0 D N
	S DA(1)=Y,DIK="^DD("_Y_"," D IXALL^DIK K %A,%B,%C,%Z G DD
	;
P	W *7,"FILE #"_+Y_" SHOULD ONLY BE TRANSFERRED TO A FILE WHOSE NUMBER",!?8,"ALSO "_$S(Y#1:"ENDS WITH '"_(Y#1)_"'",1:"IS INTEGER") K L,A Q
	;
N	S %B=$O(@("^DD(L,V,"_%A_"%B)")) I %B="" Q:'%Z  S @("%B="_$P(%A,",",%Z)),%Z=%Z-1,%A=$P(%A,",",1,%Z)_$E(",",%Z>0) G N
	I @("$D(^DD(L,V,"_%A_"%B))#2") S W=^(%B) D D S @("^DD(Y,V,"_%A_"%B)=W")
	I @("$D(^DD(L,V,"_%A_"%B))<9") G N
	S:+%B'=%B %B=""""_%B_"""" S %A=%A_%B_",",%Z=%Z+1,%B=-1 G N
	;
D	X A,C1 G Y:%A-1!(%Z<2) I %B=0 S:W\1=(L\1) W=W#1+DHIT_U_$P(W,U,2,9) S %=$P(W,U,4) K %C I %,$D(L(%)) S W=$P(W,U,1,3)_U_(%#1+DHIT)_U_$P(W,U,5,9),%C=%
	I $D(%C) S B=$F(W,",DIH="_%C_",DIG=") I B S W=$E(W,1,B-$L(%C)-6)_(%C#1+DHIT)_$E(W,B-5,999)
Y	I '%Z S %="Y("_L_","_V_"," F B=0:0 S B=$F(W,%,B) Q:'B  S W=$E(W,1,B-$L(%)+1)_Y_","_V_","_$E(W,B,999),B=B+$L(Y)-$L(L)

DIT2
DIT2	; SF/GFT - TRANSFER TEMPLATES ;05:07 PM  May 11, 1988
	;;17.7;VA FileMan; 6/9/89
TEM	F Z=0:0 W "." S Z=$N(^UTILITY("DITR",$J,DIK,Z)) Q:Z<0  F V=V:1 I $N(@(%Y_"0)"))<0 D %XY S ^(0)=$P(@(%Y_"0)"),U,1,3)_U_DDT(0)_U_$P(^(0),U,5,99) K ^("ROU"),^("ROUOLD") K:DIK="^DIBT(" ^DIBT(V,1) Q
	Q
%XY	;
	S %Z=0,%A="",%C(-1)=0,%E=""
S	S %B=-1
N	S @("%B=$N("_%X_%A_"%B))"),%C(%Z)=%C(%Z-1),%D=$S($D(L(%B)):L(%B),1:%B)
	I %B=-1 Q:'%Z  S @("%B="_$P(%A,",",%Z+%C(%Z-2),%Z+%C(%Z-1))),%Z=%Z-1,%A=$P(%A,",",1,%Z+%C(%Z-1))_$E(",",%Z>0),%E=$P(%E,",",1,%Z+%C(%Z-1))_$E(",",%Z>0) G N
	I $D(@(%X_%A_"%B)"))#2 S W=^(%B) X A,C1,E S @(%Y_%E_"%D)=W") I %A="""DCL""," S ^(%B#1+DHIT_U_$P(%B,U,2))=^(%B) K ^(%B) G N
	I @("$D("_%X_%A_"%B))<9") G N
	S:+%B'=%B %B=""""_%B_"""" S:+%D'=%D %D=""""_%D_""""
	S %A=%A_%B_",",%Z=%Z+1,%E=%E_%D_"," G S
	;
DCL	;S ^(%B#1+DHIT_U_$P(%B,U,2))=^(%B) K ^(%B) G N
	;

DITC
DITC	; SF/XAK - MERGE OR COMPARE ENTRIES ;3/2/89  16:59
	;;17.7;VA FileMan; 6/9/89
	;
START	;
	K DFF,DIT,DIMERGE,DDSP,DDIF,DDEF
	D K2,K1,T^DICRW G:Y<0 END S (DSUB,DIT,L)=0,DSUB(L)=DIC
SUB	S L=L+1,DFL(L)=$N(^DD(+Y,0,"NM",-1)),(DFF,DFF(L))=+Y,DIC="^DD("_+Y_"," G ENTR:$N(^DD(+Y,"SB",0))'>0 S DIC(0)="AEQZ",DIC("A")="WHAT SUB-FILE: ",DIC("S")="I $P(^(0),U,2)"
	D ^DIC I Y>0 S Y=$P(Y(0),U,2),DSUB(L)=""""_$P($P(Y(0),U,4),";",1)_"""," G SUB
ENTR	G:X["^" END K DIC S DIC(0)="AEQMZ",DIC=DSUB(0),DFL=1,DIT=DIT+1,DIT(DIT)="" W:DIT=1 !
E1	S DIC("A")=$E("        ",1,DFL-1*3)_$S(DIT=2:"   WITH ",1:"COMPARE ")_DFL(DFL)_": " I (DIT=2),(DFL=L),($P(DIT(1),",",1,L-1)=$P(DIT(2),",",1,L-1)) S DIC("S")="I Y-"_$P(DIT(1),",",L)
	D ^DIC K DIC("S"),DIC("A") I Y>0,$D(DSUB(DFL)),$D(DFL(DFL+1)) S DIC=DIC_+Y_","_DSUB(DFL),DIT(DIT)=DIT(DIT)_+Y_",",DFL=DFL+1 S %=$N(@(DIC_"-1)")) G:'% E1 S:%>0 ^(0)=U_DFF_U I %<0 W !,"NO "_DFL(DFL) S Y=-1
	G:X=U END G:Y=-1 START S DTO(DIT)=DIC_+Y_",",DIT(DIT)=DIT(DIT)_+Y G:DIT=1 ENTR S DDSP=1
Q1	S %=2 W !!,"WILL YOU WANT TO MERGE THESE ENTRIES AFTER COMPARING THEM" D YN^DICN I '% W ! S DMSG=1 D HELP^DITC0 G Q1
	S:%=1 DIMERGE=1 G:%<0 END G:'$D(DIMERGE) Q2 W ! F I=1,2 W !?5,I,?10,$P(@(DTO(I)_"0)"),U)
Q15	R !!,"WHICH ENTRY SHOULD BE USED FOR DEFAULT VALUES (1 OR 2)? ",X:DTIME G:'$T!(X["^") END I X="?" S DMSG=3 D HELP^DITC0 G Q15
	I X'=1,X'=2 W *7,!,"Enter '1' or '2'" G Q15
	S DDEF=X
Q2	S %=2 W !!,"DO YOU WANT TO DISPLAY ONLY THE DISCREPANT FIELDS" D YN^DICN I '% S DMSG=2 D HELP^DITC0 G Q2
	S:%=1 DDIF=1 G:%<0 END G:$D(DIMERGE) PRNT^DITC1
EN	;
	D K2
EN2	;
	D K1 S DMSG=0 F I="DFF","DIT(1)","DIT(2)" Q:DMSG  I '$D(@I) S DMSG=1,DMSG(1)=I
	G:DMSG ERREND^DITC0 F I="DFF","DIT(1)","DIT(2)" Q:DMSG  I '$L(@I) S DMSG=2,DMSG(1)=I
	G:DMSG ERREND^DITC0 I '$D(^DD(DFF)) S DMSG=3,DMSG(1)=DFF G ERREND^DITC0
	S:'$D(DFL) N=$N(^DD(DFF,0,"NM",-1))_U,X1=1,M=DFF_U S K=DFF,DSUB=0
	F I=0:0 Q:'$D(^DD(K,0,"UP"))  S J=^("UP"),I=$N(^DD(J,"SB",K,-1)),DSUB=DSUB+1,DSUB(DSUB)=""""_$P($P(^DD(J,I,0),U,4),";",1)_""",",K=J S:'$D(DFL) N=N_$N(^DD(K,0,"NM",-1))_U,M=M_K_U,X1=X1+1
	S DSUB=DSUB+1,DSUB(DSUB)=^DIC(K,0,"GL") I '$D(DFL) F DFL=1:1:X1 S DFL(DFL)=$P(N,U,X1-DFL+1),DFF(DFL)=$P(M,U,X1-DFL+1)
	S DMSG="" F I=1:1:2 S DTO(I)="" I DIT(I)'=0 F K=DSUB:-1:1 S DTO(I)=DTO(I)_DSUB(K)_$P(DIT(I),",",DSUB-K+1)_"," I '$L($P(DIT(I),",",DSUB-K+1)) S DMSG=4,DMSG(1)="DIT("_I_")"
	F I=1,2 I $L($P(DIT(I),",",DSUB+1,99)) S DMSG=4,DMSG(1)="DIT("_I_")"
	G:$L(DMSG) ERREND^DITC0 G PRNT^DITC1
K1	;
	K %H,DSUB,DMSG,DTO,DFL,DNUM,DDON
	Q
K2	;
	K D001,DHD,^UTILITY($J,"DIT")
	Q
END	;
	D K1 K DIMERGE,DDSP,DDIF,DDEF,DIT,DFF,DDSH,DDSPC,DEQ,DIACT,X,X2,POP,DHD,D,Y,X1,^UTILITY($J,"DIT")
	Q

DITC0
DITC0	; SF/XAK - COMPARE FILE ENTRIES ; 5/12/88  10:34 ;
	;;17.7;VA FileMan; 6/9/89
	;
	; Mandatory INPUT VARIABLES using entry point EN:
	; DFF ...... File or subfile number
	; DIT(1) ... Internal number of first entry
	; DIT(2) ... Internal number of second entry
	;
	; Optional INPUT VARIABLES using entry point EN:
	; DIMERGE ..... If defined, allows for merge; if not, does compare only
	; DDSP ..... If defined, writes 'wait messages and dots' to the screen
	; DDIF ..... If undefined displays all fields
	; DDIF=1: displays discrepant only
	; DDIF=2: displays discrepant and missing as well
	; DDEF ..... Entry # (1 or 2) from which to take default values.
ERREND	;
	S DMSG=$P($T(ERRTXT+DMSG),";; ",2)_": "_DMSG(1) W !,DMSG
	G END^DITC
	Q
ERRTXT	;;
	;; Undefined INPUT VARIABLE
	;; Null INPUT VARIABLE
	;; Nonexistent FILE
	;; Incorrect INPUT VARIABLE specification
HELP	;;
	W ! F I=1:1 S J=$P($T(@("HTXT"_DMSG)+I),";; ",2) Q:'$L(J)  W !,J
	Q
HTXT1	;;
	;; Enter a 'N' if you wish only to compare and display the two
	;; entries.  Enter a 'Y' if you wish to choose valid fields from each
	;; entry and eventually do a merge.
HTXT2	;;
	;; Enter a 'N' if you wish to display all of the fields in each entry.
	;; Enter a 'Y' if you wish to display only those fields which differ.
HTXT3	;;
	;; On merging, the default field value can be taken from entry #1 or #2.
	;; You will later have the opportunity to modify this default selection
	;; on a field by field basis.
HTXT4	;;
	;; When the two entries are compared, all top level fields are displayed
	;; and a summary for multiple level fields are displayed. If you also wish to
	;; see a detailed comparison on the multiple level fields, enter 'Y'.
	;;
	;;

DITC1
DITC1	; SF/XAK - COMPARE FILE ENTRIES PRINT ;3/2/89  16:45 ;
	;;17.7;VA FileMan; 6/9/89
PRNT	S %ZIS("B")="",%ZIS="QM" D ^%ZIS Q:IO=""  I $D(IO("Q")) G QUE
COMP	W:$D(DDSP) !,"COMPARING THE TWO ENTRIES" F I=1:1:2 I $L(DTO(I)) S J=-1 F K=0:0 S @("J=$N("_DTO(I)_"J))") Q:J=-1  W:$D(DDSP) "." D EACH
	D DISP
	Q
EACH	;
	I @("$D("_DTO(I)_"J))'<10") D MUL Q
	S X=^(J) F N=1:1 D:$L($P(X,U,N)) SETU Q:'$L($P(X,U,N,999))
	Q
SETU	;
	I '$D(^UTILITY($J,"DIT",J,N,0)) S @("Y=$N(^DD("_DFF_",""GL"",J,"_N_",-1))") Q:Y=-1  S ^UTILITY($J,"DIT",J,N,0)=Y_U_$P(^DD(DFF,Y,0),U,1)_U
	S O=+^UTILITY($J,"DIT",J,N,0),C=^DD(DFF,O,0),O=$P(C,U,1),C=$P(C,U,2),D0=DIT(I),Y=$P(X,U,N) D Y^DIQ S ^UTILITY($J,"DIT",J,N,I)=Y
	Q
MUL	;
	I '$D(^UTILITY($J,"DIT",U,J,0)) S @("Y=$N(^DD("_DFF_",""GL"",J,0,-1))") Q:Y=-1  S ^UTILITY($J,"DIT",U,J,0)=Y_U_$P(^DD(DFF,Y,0),U,1)_U
	S N=0 F L=0:1 S @("N=$N("_DTO(I)_"J,N))") Q:N=-1!(N'=+N)
	S $P(^UTILITY($J,"DIT",U,J,0),U,I+3)=L
	Q
DISP	;
	U IO
	S DC=0,DDSH="",$P(DDSH,"-",IOM-1)="-",$P(DDSPC," ",30)=" ",DV=IOM\3
	K IOXY S I="" I $D(IOST(0)) S:$D(^%ZIS(2,IOST(0),1)) IOXY=$P(^(1),U,5)
	S DHD(0)="COMPARISON OF "_DFL(1)_" FILE ENTRIES"
	S R=$S(DSUB(DSUB)[",":1,1:0),%H=$H D YX^%DTC S DHD(9)=Y
	F I=1:1:2 I $L(DTO(I)) F J=1:2 S K=$P(DTO(I),",",1,J+R) Q:($E(K,$L(K))=",")  D D0
	D ^DITC2 I $D(ZTSK) K ^%ZTSK(ZTSK)
	I X'=U,$D(DIMERGE) W ! D @($P("ASK",U,$D(^UTILITY($J,"DIT",U)))_"^DITC3")
	X:$D(^%ZIS("C")) ^("C") G END^DITC
	Q
D0	;
	I '$D(^DD(DFF(J+1\2),.001,0)) S K=K_",0)" Q:'$D(@K)  S Y=^(0),Y=$P(Y,U,1) Q:'$L(Y)  S C=^DD(DFF(J+1\2),.01,0) G D01
	S Y=$P($P(DTO(I),DIC,2),",",1),C=^DD(DFF(J+1\2),.001,0)
D01	S O=$P(C,U,1),C=$P(C,U,2) D Y^DIQ S $P(DHD(J\2+1),U,I)=Y
	Q
QUE	;
	K Y,K,L,M,N,I,X,X1,C,DDSP,DMSG
	S DJ=0,DHD="COMPARE OF "_DFL(1)_" FILE" D ^DIP4 G END^DITC
	Q
DQ	;
	D NOW^%DTC S DT=X K %,%I G COMP

DITC2
DITC2	; SF/XAK - COMPARE FILE ENTRIES PRINT ;3/2/89  16:53 ;
	;;17.7;VA FileMan; 6/9/89
	S J=-1 D PG1 F K=0:0 S J=$O(^UTILITY($J,"DIT",J)) Q:X=U!(U[J)  S N=-1 F K=0:0 S N=$O(^UTILITY($J,"DIT",J,N)) Q:N=""!(X=U)  D D1 D:+X(0) D2
	I X'=U D PG,MUL:$D(^UTILITY($J,"DIT",U))
	Q
D1	;
	I $Y+6>IOSL,'$D(DREDO) S DIJ=J,DIN=N D PG,PG1:X'=U S J=DIJ,N=DIN K DIJ,DIN
	Q:X=U  F I=0:1:2 S X(I)=$S($D(^UTILITY($J,"DIT",J,N,I)):^(I),1:"") I X(I)["""" D D7
	S DEQ=X(1)=X(2) I $D(DDIF),DDIF=1,DEQ S X(0)=0 K ^UTILITY($J,"DIT",J,N) Q
	I $D(DDIF),DDIF=2,$L(X(1)),$L(X(2)),(X(1)=X(2)) S X(0)=0 K ^UTILITY($J,"DIT",J,N) Q
	Q:'$D(DIMERGE)  S X1=$P(X(0),U,3) I '$L(X1) S X1=$S(X(1)=X(2):0,'$L(X(DDEF)):'(DDEF-1)+1,1:DDEF),$P(^UTILITY($J,"DIT",J,N,0),U,3)=X1,$P(X(0),U,3)=X1
	Q
D2	;
	K D S X2=$P(X(0),U,3),X(0)=$P(X(0),U,2)
D20	F I=0:1:2 S X=X(I),X1="" F D=1:1 Q:'$L(X)  D:($L(X)>(DV-6)) D5 S $P(D(D),U,I+1)=$S(I=X2&I:"["_X_"]",1:X) S X=X1,X1=""
D21	F I=1:1 Q:'$D(D(I))  D D3
	Q
D3	;
	I $D(DREDO),I=1 X:$D(IOXY) IOXY W !,DREDO,".",?4 G D31
	W ! W:(I=1) ! I I=1,$D(DIMERGE) S DNUM=DNUM+1 W DNUM,"." S DNUM(DNUM)=J_U_N_U_$Y
	W:'DEQ&'$D(DIMERGE)&(I=1) "***" W ?4
D31	F X1=1:1:3 I $L($P(D(I),U,X1)) W ?(DV*(X1-1)) W $P(D(I),U,X1)
	I $D(DREDO) W $E(DDSPC,1,3)
	Q
D5	;
	F K=DV-6:-1:1 Q:$E(X,K)?1P
	I $E(X,K)?1P S X1=$E(X,K+1,999),X=$E(X,1,K) Q
	S X1=$E(X,DV-1,999),X=$E(X,DV-2)
	Q
D7	S X(I)=$P(X(I),"""",1)_"'"_$P(X(I),"""",2,99) I X(I)["""" G D7
	Q
MUL	;
	D PG1 S N=0,DIMUL=1
	F K=0:0 S N=$O(^UTILITY($J,"DIT",U,N)) Q:N=""!(X=U)  D EMUL
	K DIMUL Q
EMUL	;
	D:$Y+5>IOSL PG
	K D S X2="",J=^UTILITY($J,"DIT",U,N,0),X=$P(J,U,2),X1="",I=0 F D=1:1 Q:'$L(X)  D:($L(X)>(DV-6)) D5 S $P(D(D),U,I+1)=""""_X_"""" S X=X1,X1=""
	S X=J F I=1:1:2 S $P(D(1),U,I+1)=""""_$S('$P(X,U,I+3):"  ---",1:$J($P(X,U,I+3),2)_$S($P(X,U,I+3)>1:" entries",1:" entry"))_""""
	D D21
	Q
PG	;
	I '$D(DIMERGE)!$D(DIMUL) W:IOST?1"C".E *7 R:IOST?1"C".E X:DTIME S:'$T X=U Q
	Q:$D(ZTSK)  I $D(IOXY) S DX=0,DY=IOSL-3 X IOXY W !
	W:'$D(IOXY) !! W "Default is enclosed in brackets, e.g., [",$P(DHD(1),U,DDEF),"]",!,"Enter 1-",DNUM," to change a default value, '^' to halt, or RETURN to continue: " R X:DTIME S:'$T X=U Q:X=U
	I X=+X,X>0,X'>DNUM S J=$P(DNUM(X),U),N=$P(DNUM(X),U,2),X1=$P(^UTILITY($J,"DIT",J,N,0),U,3) G:'X1 PG S $P(^(0),U,3)='(X1-1)+1,DREDO=X,DX=5,DY=$P(DNUM(X),U,3)-1 D D1,D2 K DREDO G PG
	I $L(X) W *7 F I=1:1:$L(X) W $C(8)
	I $L(X) K:($L(X)>4) IOXY W $E(DDSPC,1,$L(X)) G PG
	Q
PG1	S DC=DC+1,DNUM=0 W @IOF,DHD(0),?(IOM-35),DHD(9),"    PAGE ",DC
	S I=$S($D(DIMERGE):DDEF,1:0) F X1=1:1:DFL W ! W $E(DFL(X1),1,DV-1) W ?DV W:(I=1) "[" W $E($P(DHD(X1),U,1),1,DV-1) W:(I=1) "]" W ?(DV*2) W:(I=2) "[" W $E($P(DHD(X1),U,2),1,DV-1) W:(I=2) "]"
	W !,DDSH
	Q

DITC3
DITC3	; SF/XAK - COMPARE FILE ENTRIES ;3/2/89  16:07
	;;17.7;VA FileMan; 6/9/89
	F I=1:1:(IOSL-$Y-1) W !
	W "Enter RETURN to continue: " R X:DTIME S:'$T X=U Q:X=U
ASK	W @IOF,!,"OK.  I'M READY TO DO THE MERGE."
	S DIR(0)="S^P:PROCEED to merge the data;S:SUMMARIZE the modifications before proceeding;E:EDIT the data again before proceeding;Q:QUIT this utility"
	S DIR("A")="ACTION" D ^DIR K DIR
	Q:X="Q"!$D(DIRUT)  I Y="E" D ^DITC2 G DITC3:$D(^UTILITY($J,"DIT",U)),ASK
	S DIACT=Y D ACT Q:DIACT="P"  G DITC3
ACT	;
	I DIACT="S" D SUMHD
	S DIT1="" F K=0:0 S DIT1=$O(^UTILITY($J,"DIT",DIT1)) Q:DIT1=""  S DIT2="" F K=0:0 S DIT2=$O(^UTILITY($J,"DIT",DIT1,DIT2)) Q:DIT2=""  S X(0)=^(DIT2,0),%=$P(X(0),U,3) I %,DDEF'=% D EACH
	K DIT1,DIT2 Q
EACH	;
	I DIACT="S" G SUMEACH
	S DIE=DFF(1),DA=$P(DIT(DDEF),","),X2=$S('$D(^UTILITY($J,"DIT",DIT1,DIT2,%)):"@",1:^(%))
	S DR=+X(0)_"///"_X2 D ^DIE W "."
	K DR,DIE Q
SUMHD	;
	W @IOF,!,"SUMMARY OF MODIFICATIONS TO ",$P(DHD(DFL),U,DDEF),!,"FIELD",?DV,$S(DDEF=1:"OLD",1:"NEW")," VALUE",?(DV*2),$S(DDEF=1:"NEW",1:"OLD")," VALUE",!,DDSH
	Q
SUMEACH	;
	I $Y+5>IOSL D SUMHD
	K D S X2="",X(0)=$P(X(0),U,2) F I=1:1:2 S X(I)=$S($D(^UTILITY($J,"DIT",DIT1,DIT2,I)):^(I),1:"")
	D D20^DITC2
	Q

DITP
DITP	; SF/GFT - TRANSFER POINTERS ;3/13/89  13:55 ;
	;;17.7;VA FileMan; 6/9/89
	D ASK Q:%-1  G PTS
	;
ASK	;
	I '$D(^UTILITY("DIT",$J,0,1)) S %=2 Q
	S %=$N(^(1)),%Y=+^(1)
U	I $D(^DD(%Y,0,"UP")) S %Y=^("UP") G U
	W !,"SINCE THE "_$P("TRANSFERRED^DELETED",U,DH+1)_" ENTRY MAY HAVE BEEN 'POINTED TO'"
	W !,"BY ENTRIES IN THE '"_$P(^DIC(+%Y,0),U,1)_"' FILE," W:%>1 " ETC.,"
Q	W !,"DO YOU WANT THOSE POINTERS UPDATED (WHICH COULD TAKE QUITE A WHILE)"
	S %=2 D YN^DICN Q:%  W !?4,"ANSWER 'YES' IF YOU THINK THAT THE ENTRY WHICH YOU HAVE JUST "_$P("MOVED^DELETED",U,DH+1),!?4,"MAY BE 'POINTED TO' BY SOME POINTER-TYPE FIELD VALUE SOMEWHERE",! G Q
	;
PTS	;
	D WAIT^DICD K IOP
P	K DR,D,DL,X S (BY,FR,TO)="",X=$O(^UTILITY("DIT",$J,0,0))
	I X="" K ^UTILITY("DIT",$J),DIA,DHD,DR,BY,TO,FR,FLDS,L Q
	S Y=^(X),L=$P(Y,U,2),DL=1
	S DL(1)=L_"////^S X=$S($D(DE(DQ))[0:"""",$D(^UTILITY(""DIT"",$J,DE(DQ)))-1:"""",^(DE(DQ)):"_$S($P(Y,U,3)'["V":"+",1:"")_"^(DE(DQ)),1:""@"")" K ^(X)
	S L=$P(^DD(+Y,L,0),U,4),%=$P(L,";",2),L=""""_$P(L,";",1)_"""",DHD=$P(^(0),U) I % S %="$P(^("_L_"),U,"_%
	E  S %="$E(^("_L_"),"_+$E(%,2,9)_","_$P(%,",",2)
	S L=L_")):"""","_%_")?."" "":"""",'$D(^UTILITY(""DIT"",$J,"_$S($P(Y,U,3)'["V":"+",1:"")_%_"))):"""",1:D"
UP	S (D(DL),%)=+Y I $D(^DD(%,0,"UP")) S DL=DL+1,Y=^("UP"),(DL(DL),%)=$N(^DD(Y,"SB",%,0))_"///",X(DL)=""""_$P($P(^DD(Y,+%,0),U,4),";")_"""",BY=+%_","_BY G UP
	S DHD=$N(^("NM",0))_" ENTRIES WHOSE '"_DHD_"' POINTERS HAVE BEEN CHANGED" G P:'$D(^DIC(%,0,"GL")) S DIC=^("GL"),Y="S X=$S('$D("_DIC_"D0,"
	F X=0:1:DL-1 S DR(X+1,D(DL-X))=DL(DL-X) S:X Y=Y_X(DL+1-X)_",D"_X_","
	S DIA("P")=%,%=$L(BY,",") I %>2 S BY=$P(BY,",",%-2)_",.01,"_BY
	S BY=BY_Y_L_X_")",L=0,FLDS="",DHIT="G LOOP^DIA2",%IS=""
	D EN1^DIP
	S IOP=IO G P

DITR
DITR	; SF/GFT - FIND FLDS TO XFR ;10:03 AM  Jul 21, 1988
	;;17.7;VA FileMan; 6/9/89
	S (DFL,DTL)=DFL-1 Q:'$D(DFN(DFL))
N	S @("DFN(DFL)=$N("_DFR(DFL)_"DFN(DFL)))")
	I $D(^(DFN(DFL)))#2 S Z=^(DFN(DFL)),A=-1 G NS
	G DITR:DFN(DFL)<0,1:DFL#2,DITR:$D(^(DFN(DFL),0))-1 S Z=^(0),X="D"_(DFL\2),@X=DFN(DFL) I DTO,$D(DSC(DDF(DFL+1))) X DSC(DDF(DFL+1)) E  G N
	D ^DITR1 G N:A D D
NS	S A=$N(^DD(DDF(DFL),"GL",DFN(DFL),A)) G N:A<0
	S W=$N(^(A,0)) I A S Y=$P(Z,U,A) G NS:Y=""
	E  S Y=$E(Z,+$E(A,2,9),$P(A,",",2)) F %=$L(Y):-1 Q:" "'[$E(Y,%)  G NS:'% S Y=$E(Y,1,%-1)
	I DTO G NS:'$D(^UTILITY("DITR",$J,DDF(DFL),W)) S B=^(W),DTN(DTL)=$P(B,U,2)
	E  S B=A,DTN(DTL)=DFN(DFL)
	S X="" I @("$D("_DTO(DTL)_"DTN(DTL)))#2") S X=^(DTN(DTL))
	I 'B S W=$E(B,2,9),B=$P(B,",",2) G NS:$E(X,+W,B)'?." "&DKP S %=$E(X,B+1,999),V=W-$L(X)-1,^(DTN(DTL))=$E(X,0,W-1)_$J("",$S(V>0:V,1:0))_Y S:%'?." " ^(DTN(DTL))=^(DTN(DTL))_$J("",B+1-W-$L(Y))_% G NS
	I DKP,$P(X,U,B)]"" G NS
P	S $P(^(DTN(DTL)),U,B)=Y G NS
	;
1	G N:$N(^(DFN(DFL),0))'>0 S Z=$N(^DD(DDF(DFL),"GL",DFN(DFL),0,0)) G N:Z'>0 I DTO G N:'$D(^UTILITY("DITR",$J,DDF(DFL),Z)) S B=^(Z)
	D D S Y=$P(^DD(DDF(DFL-1),Z,0),U,2),DDF(DFL+1)=+Y I DTO S Y=$P(B,U,3),X=""""_$P(B,U,2)_""","
	S DDT(DTL)=+Y,DTO(DTL)=DTO(DTL-1)_X I @("'$D("_DTO(DTL)_"0))") S ^(0)=U_Y
	G N
	;
D	S DTL=DFL+1
	S X=""""_DFN(DFL)_""",",DFR(DFL+1)=DFR(DFL)_X,DFL=DFL+1,DFN(DFL)=0 Q
	;
F	;
	S A=1,@("Z="_DIK_"D0,0)") W !,$P(^(0),U,1) G I:'DTO!'$D(DITF)
	S Z=$P(DITF,";",1) I Z=" " S Z=D0 G I
	Q:'$D(^(Z))  S X=$P(DITF,";",2) I X S Z=$P(^(Z),U,X) G I
	S Z=$E(^(Z),+$E(X,2,9),+$P(X,",",2))
I	;
	S DFL=0,DTL=0,DA=D0 D ^DITR1 Q:A
GO	;
	S DFL=1,DTL=1,DFN(1)=-1 D N

DITR1
DITR1	; SF/GFT - FIND ENTRY MATCHES ; 11/17/88  22:09 ;
	;;17.7;VA FileMan; 6/9/89
	S W=DMRG,X=$P(Z,U),%=DFL\2,Y=@("D"_%),A=1
	G WORD:$P(^DD(DDT(DTL),.01,0),U,2)["W",Q:X="",ON:'W
	I ^(0)["DINUM",$P(^(0),U,2)'["P" S V=X,DA=Y,Y=0 D DA X $P(^(0),U,5,99) S X=V,Y=DA I $D(DINUM) S Y=DINUM,W=1 K DINUM G ON
	S V=0 D:'$D(DISYS) OS^DII
B	I '$D(^DD(DDT(DTL),0,"IX","B",DDT(DTL),.01)) F A=1:1 S V=$N(@(DTO(DTL)_V_")")) G NEW:V'>0 I $D(^(V,0)),$P(^(0),U)=X D MATCH G OLD:'$D(A) S A=1
	S %=+$P(^DD("OS",DISYS,0),U,7) S:'% %=32
	S V=$S($N(@(DTO(DTL)_"""B"",$E(X,1,%),V)"))>0:$N(^(V)),1:$N(@(DTO(DTL)_"""B"",$E(X,1,30),V)"))) G NEW:V'>0
	I $D(@(DTO(DTL)_V_",0)")),$P(^(0),X)="" D MATCH G OLD:'$D(A)
	G B
	;
DA	Q:'%  S DA(%)=@("D"_Y),Y=Y+1,%=%-1 G DA
	;
NEW	S W=0
ON	I @("$D("_DTO(DTL)_"Y))") G OLD:W S Y=Y+1 G ON
	S @("V="_DTO(DTL)_"0)"),^(0)=$P(V,U,1,2)_U_Y_U_($P(V,U,4)+1),^(Y,0)=X
OLD	S DTO(DTL+1)=DTO(DTL)_Y_",",DTN(DTL+1)=0,A=0
Q	Q
	;
WORD	S @("V=$N("_DTO(DTL)_"0))") X:V'>0!'DKP "K "_$E(DTO(DTL),1,$L(DTO(DTL))-1)_") S:$D("_DFR(DFL)_"0)) "_DTO(DTL)_"0)=^(0)","F V=0:0 S V=$N("_DFR(DFL)_"V)) Q:V'>0  S:$D(^(V,0)) "_DTO(DTL)_"V,0)=^(0)" S (DFL,DTL)=DFL-1 Q
	;
MATCH	S A=1 I Y'=V,$D(^DD(DDT(DTL),.001,0)) Q
	S Y=V,I=.01
I	S I=$N(^DD(DDT(DTL),0,"ID",I)) I I'>0 K A Q
	G I:'$D(^DD(DDT(DTL),I,0)) K B D P G I:W="" S B=W
	I DTO S A=$P(A,";",2)_U_$P(A,";",1) F %=0:0 S %=$N(^UTILITY("DITR",$J,DDF(DFL+1),%)) G I:%'>0 Q:^(%)=A
	E  S %=I
	G I:'$D(^DD(DDF(DFL+1),%,0)) D P G I:W="",I:W=B
	S Y=@("D"_(DFL\2)) Q
	;
P	S A=$P(^(0),U,4),%=$P(A,";",2),W=$P(A,";",1) I @("'$D("_$S('$D(B):DTO(DTL)_"Y,",DFL:DFR(DFL)_"DFN(DFL),",1:DFR(1))_"W))") S W="" Q
	I % S W=$P(^(W),U,%)
	E  S W=$E(^(W),+$E(W,2,9),$P(W,",",2))
	I W'?.UNP F %=1:1:$L(W) I $E(W,%)?1L S W=$E(W,0,%-1)_$C($A(W,%)-32)_$E(W,%+1,999)

DIU
DIU	; SF/GFT - UTILITY FUNCTIONS ;3/30/89  16:18
	;;17.7;VA FileMan; 6/9/89
	K DIU
0	S DIC="^DOPT(""DIU"","
	G OPT:$D(^DOPT("DIU",10)) S ^(0)="UTILITY OPTION^1.01" K ^("B")
	F X=1:1:10 S ^DOPT("DIU",X,0)=$P($T(@X),";;",2)
	S DIK=DIC D IXALL^DIK S ^DOPT("DICR",0)="TYPE OF INDEXING^1.01"
	F X=1:1:7 S ^DOPT("DICR",X,0)=$P("REGULAR^KWIC^MNEMONIC^MUMPS^SOUNDEX^TRIGGER^BULLETIN",U,X)
	S DIK="^DOPT(""DICR""," D IXALL^DIK G 0
OPT	;
	S DIC(0)="AEQIZ" S:DUZ(0)'="@" DIC("S")="I Y-5"
	D ^DIC G Q:Y<0 S DI=Y D EN G 0
	;
EN	;
	D D^DICRW G Q:Y<0 I '$D(DIC) D DIE^DIB G Q:'$D(DG) S DIC=DG
	S DIU=DIC,DIU(0)="EDT" K DICS
	K DIC,I,J S Y=DI,N=0,DI=+$P(@(DIU_"0)"),U,2),J(0)=DI,I(0)=DIU
	D @+Y W !!
Q	K DI,DDD,DG,DGG,DIC,DIU,DJJ,DIK,DI,DA,I,J,X,Y,DICD,DICDF Q
	;
1	;;VERIFY FIELDS
	G ^DIV
	;
2	;;CROSS-REFERENCE A FIELD
	S X="CW" D DI Q:Y<.002  G ^DICD
	;
3	;;IDENTIFIER
	S X="CW.01" D DI Q:Y<0  G 3^DIU3
	;
4	;;RE-INDEX FILE
	G 4^DIU1
	;
5	;;INPUT TRANSFORM (SYNTAX)
	S X="W" D DI Q:Y<0  G 5^DIU3
	;
6	;;EDIT FILE
	G 6^DIU0
	;
7	;;OUTPUT TRANSFORM
	S X="CW" D DI Q:Y<0
O	S DIK=1,DJJ=+Y W !,$P(Y,U,2)_" OUTPUT TRANSFORM: "
	I '$D(^DD(DI,DJJ,2)) R X:DTIME I '$T S DTOUT=1 G Q
	I $D(^(2)) S (DIK,Y)=^(2) S:$D(^(2.1)) Y=^(2.1) W Y D RW^DIR2 I X="@" W !?9,"DELETED!" K ^(2),^(2.1) S Y=$P(^(0),U,2),$P(^(0),U,2)=$P(Y,"O")_$P(Y,"O",2),DA=DJJ D DIPZ^DIU0 G Q
	G Q:X="" I X?."?" S Y=DJJ_U_$P(^(0),U) W !?4,"Enter a computed-field expression using '"_$P(Y,U,2)_"'",! W:DUZ(0)="@" ?4,"or MUMPS code that takes Y and transforms it to a different Y.",! G O
	K ^(2) S DICOMPX(1,DI,DJJ)="Y(0)",DA=DIC_DJJ_",2,",DGG=X,DQI="Y("
	D ^DICOMP K DQI,DICOMPX F %=9.2:.1 Q:'$D(X(%))  S @(DA_"%)=X(%)")
	I $D(X) S ^DD(DI,DJJ,2)="S Y(0)=Y "_X_$P(" S Y=X",U,Y'["X"),^(2.1)=DGG,DA=DJJ S:$P(^(0),U,2)'["O" $P(^(0),U,2)=$P(^(0),U,2)_"O" D DIPZ^DIU0 G Q
	S:'DIK ^DD(DI,DJJ,2)=DIK
X	W *7,"??" Q
	;
8	;;TEMPLATE EDIT
	G 0^DIBT
	;
9	;;UNEDITABLE DATA
	S X="WC" D DI Q:Y<0  G 9^DIU3
	;
10	;;MANDATORY/REQUIRED FIELD CHECK
	G ^DIVRE
	;
DI	;
	S DIC(0)="ZQEAI"
D	;
	S DIC="^DD("_DI_",",DIC("W")="S %=$P(^(0),U,2) I % W $S($P(^DD(+%,.01,0),U,2)[""W"":""  (word-processing)"",1:""  (multiple)"")"
	S DIC("S")="S %=$P(^(0),U,2) I 1"_$P(",%'[""C""",U,X["C")_$P(",$P(^DD(+%,.01,0),U,2)'[""W""",9,X["W")_$P(",Y-.01",U,X[.01),DA=X
	D ^DIC K DIC("S") I Y>0,$P(Y(0),U,2) S N=N+1,X=$P($P(Y(0),U,4),";",1),DI=$E("""",+X'=X),I(N)=DI_X_DI,(DI,J(N))=+$P(Y(0),U,2),X=DA G DI

DIU0
DIU0	; SF/XAK - EDIT/DELETE A FILE ; 8/18/88  13:39 ;
	;;17.7;VA FileMan; 6/9/89
DIPZ	;
	S %=$N(^DIPT("AF",DI,DA,0)) I %>0 K ^(%),^DIPT(%,"ROU") W *7,!,"WARNING-'"_$P(^(0),U,1)_"' PRINT TEMPLATE NOW NEEDS TO BE RECOMPILED!" G DIPZ
DIEZ	;
	S %=$N(^DIE("AF",DI,DA,0)) I %>0 K ^(%),^DIE(%,"ROU") W *7,!,"WARNING-'"_$P(^(0),U,1)_"' INPUT TEMPLATE NOW NEEDS TO BE RECOMPILED!" G DIEZ
DT	S:$S($D(^DIC(J(0),"%A")):$P(^("%A"),U,2),1:0)-DT ^DD(DI,DA,"DT")=DT
	Q
EN	;
	I DIU,DIU(0)["S" G SUB
	I DIU,$D(^DIC(DIU,0,"GL")) S DIU=^("GL")
	G Q:DIU S DIK="^DIC(",DG=$S($D(@(DIU_"0)")):^(0),1:""),(A,DA)=+$P(DG,U,2)
	G Q:'A D ^DIK G 61
6	S DR=".01:10;"_$P(20,U,$S($D(^DIC(3,0)):^(0)["USER"!(^(0)["EMPLOY"),1:0))
	S DIE=1,(A,DA)=DI,DIER=1 D ^DIE K DIER G N^DIU2:$D(DA)
61	S DQ(A)=0 G:DIU(0)'["D" 63
	S Y=$L(DIU),Y=$E(DIU,1,Y-1)_$E(")",$E(DIU,Y)=","),%=0
	I DIU(0)["E" W !?3,"OK TO DELETE THE '"_Y_"' GLOBAL" D YN^DICN K:%=1 @Y G 63
	K @Y
63	W:DIU(0)["E" !?3,"Deleting the DATA DICTIONARY..." D KDD^DICATT4
	Q:DIU(0)["S"  G Q:DIU(0)'["T"
	F DIK="^DIE(","^DIPT(","^DIBT(" K @(DIK_"""F""_A)") W:DIU(0)["E" !?3,"Deleting the "_$P(^(0),U)_"S..." F DA=.9:0 S DA=$N(@(DIK_"DA)")) Q:DA'>0  I $D(^(DA,0)) S %=$P(^(0),U,4) I %=""!'$D(^DD(+%)) W:DIU(0)["E" "." D ^DIK
Q	K A,DA,DG,DIK,DQ Q
	;
SUB	G Q:'$D(^DD(DIU,0,"UP")) S DA(1)=^("UP"),DQ(DIU)=0
	I DIU(0)'["D" S A=DA(1) D 63 S A=DIU G SE
	S D0=DIU,S=";",Q=""""
	F I=1:1 Q:'$D(^DD(DIU,0,"UP"))  S A=^("UP"),%=$N(^DD(A,"SB",DIU,0)) Q:'$D(^DD(A,%,0))#2  S %(I)=$P($P(^(0),U,4),S),DIU=A S:+%(I)'=%(I) %(I)=Q_%(I)_Q I I=1 S (O,M)=^(0)
	S DICL=I-2 F I=1:1:DICL S I(I)=%(DICL-I+1)
	S I(0)=^DIC(DIU,0,"GL") K % D 63 S A=D0 D EN^DICATT4
SE	S DIK="^DD("_DA(1)_",",DA=$O(^DD(DA(1),"SB",A,0)) D ^DIK
	K D0,DICL,E,I,M,O,Q,S,T,X,Y G Q

DIU1
DIU1	; SF/GFT - REINDEX A FILE ; 5/12/88  10:35 ;
	;;17.7;VA FileMan; 6/9/89
4	;
	W !! K ^UTILITY("DIK",$J),X S DIK=DIU,X=0 D DD^DIK S DW=0,DDD=DI K DU,DV
DW	S DW=$N(^UTILITY("DIK",$J,DW)),DV=0 I DW>0 F DU=0:0 S DV=$N(^UTILITY("DIK",$J,DW,DV)),DH=0 G DW:DV<0 F Y=0:0 S DH=$N(^UTILITY("DIK",$J,DW,DV,DH)) Q:DH<0  S Y=^(DH),X=X+1,X(X)=Y,X(X,0)=DW_U_DV S:$P(Y,U,3)=""&'Y&$D(^(DH,0)) X(X)=^(0)
	K ^UTILITY("DIK",$J) G DD:'X,ONE:X>1
ALL	W "OK, ARE YOU SURE YOU WANT TO KILL OFF THE EXISTING "_$S(X=1:$P(^DD(+X(1,0),$P(X(1,0),U,2),0),U,1)_" INDEX",1:X_" INDICES") S %=2
	D YN^DICN G:%-1 NO:%,Q W !,"DO YOU THEN WANT TO 'RE-CROSS-REFERENCE'" D YN^DICN G NO:%<1 S N=%=1 D WAIT^DICD
	F X=X:-1:1 S %=$P(X(X),U,2) I %]"",+X(X)=DI K @(DIK_"%)"),X(X)
	S DIK(0)="B" I $N(X(0))>-1 S X=2,(DA,DCNT)=0 D DD^DIK,CNT^DIK1
	K X I N W !,*7,"FILE WILL NOW BE 'RE-CROSS-REFERENCED'..." H 5 D DD S DIK=^DIC(DDD,0,"GL") D IXALL^DIK
	K DIK,DIC Q
	;
DD	S DIK="^DD(DI,",DA(1)=DI K ^DD(DI,"B"),^("GL"),^("IX"),^("RQ"),^("GR"),^("SB")
	W "." D IXALL^DIK:$D(^(0))#2 S DI=$N(^DD(DI)) I DI>0,DI<$N(^DIC(DDD)) G DD
	Q
	;
ONE	S %=2 W "THERE ARE "_X_" INDICES WITHIN THIS FILE",!,"DO YOU WISH TO RE-CROSS-REFERENCE ONE PARTICULAR INDEX" D YN^DICN W ! I %-1 G ALL:%=2,NO:%,Q
	S X="CW" D DI^DIU G NO:Y<0 S (DA,DL)=+Y,DICD="RE-CROSS-REFERENCE" D CHIX^DICD G NO:'DICD
	S X=$P(I,U,2)
	W !,"ARE YOU SURE YOU WANT TO DELETE AND RE-CROSS-REFERENCE "_$S(X]"":"THE '"_X_"' INDEX",1:"THIS TRIGGER") S %=2 D YN^DICN G NO:%-1
	G IND:X="" F %=0:0 S %=$O(^DD(+I,0,"IX",X,%)) Q:%=""  F %Y=0:0 S %Y=$O(^DD(+I,0,"IX",X,%,%Y)) Q:%Y=""  I %Y-DA!(%-DI) G IND
	I +I=DDD,$P(I,U,3)="",X]"" K @(DIK_"X)") G REDO
IND	S X=^DD(J(N),DA,1,DICD,2) D DD^DICD:"Q"'[X S DIU=^DIC(DDD,0,"GL")
REDO	S X=^DD(J(N),DL,1,DICD,1) D DD^DICD:"Q"'[X W *7,"    ...DONE!" Q
	;
Q	F I=1:1:X W !,"FIELD " S %=X(I,0),J=$P(%,U,2) W J_" ('"_$P(^DD(+%,J,0),U,1)_"'" W:%-DI ", "_$O(^DD(+%,0,"NM",0))_" SUBFILE" W ") IS ",$S(X(I):"'"_$P(X(I),U,2)_"' INDEX",1:$P(X(I),U,3)) D UP
	G 4
UP	I X(I),X(I)-DI S %=$D(^DD(+X(I),0,"UP")) W " OF "_$O(^("NM",0))_" "_$P("SUB",U,%>0)_"FILE" Q
	S %=+$P(X(I),U,4),Y=+$P(X(I),U,5) I %,$D(^DD(%,Y,0)) W:$X>44 ! W " OF" D WR^DIDH
	Q
	;
NO	W !?7,*7,"<NO ACTION TAKEN>" K DICD,X,DH
	Q

DIU2
DIU2	; SF/XAK - EDIT FILE ;01:52 PM  Jul 21, 1988;
	;;17.7;VA FileMan; 6/9/89
	;
N	S X=$P(^DIC(DA,0),U,1),D=@(DIU_"0)"),^(0)=X_U_$P(D,U,2,9) K ^DD(+$P(D,U,2),0,"NM") S ^("NM",X)="" Q:$D(Y)
	I DUZ(0)]"" F DR=1:1:6 S D=$P("DD^RD^WR^DEL^LAYGO^AUDIT",U,DR),Y=$S($D(^DIC(DA,0,D)):^(D),1:"") D RW G Q:X=U
	G OK:DUZ(0)'="@"
ACT	W !,"POST-SELECTION ACTION: " W:$D(^DD(DA,0,"ACT")) ^("ACT")_"//"
	R X:DTIME S:'$T DTOUT=1 G OK:X="",Q:X=U!'$T
	I "@"'[X D ^DIM I $D(X) S ^DD(DA,0,"ACT")=X G OK
	I $D(X),X="@" K ^DD(DA,0,"ACT") W "   DELETED." G OK
	W *7,!?5,"Enter a line of standard MUMPS code which will be executed",!?5,"whenever an entry is selected from this file." G ACT
OK	S D=$P(@(DIU_"0)"),U,2),%=D'["O"+1
	W !,"ASK 'OK' WHEN LOOKING UP AN ENTRY" D YN^DICN
	I %>0 S $P(^(0),U,2)=$P(D,"O")_$E("O",%)_$P(D,"O",2)
	I '% W !?5,"Answer YES to cause a lookup into this file to verify the",!?5,"selection by prompting with '...OK? YES//'." G OK
	G Q:DUZ(0)'="@"!(%<0)
	D:'$D(DISYS) OS^DII Q:'$D(^DD("OS",DISYS,18))  S DR=^(18) G Q:DR=""
DIC	W !,"LOOK-UP PROGRAM: " W:$D(^DD(DA,0,"DIC")) ^("DIC")_"//" R X:DTIME
	S:'$T DTOUT=1 G DIK:X="",Q:X=U!'$T
	I "@"'[X K:$L(X)<1!($L(X)>8)!(X?1"DI".E) X I $D(X) X DR I  S ^DD(DA,0,"DIC")=X G DIK
	I $D(X),X="@" K ^DD(DA,0,"DIC") W "   DELETED." G DIK
	D H G DIC
DIK	W !,"CROSS-REFERENCE ROUTINE: " W:$D(^DD(DA,0,"DIK")) ^("DIK")_"//"
	R X:DTIME S:'$T DTOUT=1 G Q:U[X!'$T
	I "@"'[X,$L(X)<3!($L(X)>7)!(X?1"DI".E) D H G DIK
	I X="@" S X=DA D A W "   DELETED." G Q^DIU
	X DR I  W *7,!,"NOTE THAT '",X,"' IS ALREADY IN YOUR ROUTINE DIRECTORY!"
	W !,"READY TO COMPILE" S %=0 D YN^DICN G Q^DIU:%'=1
	S Y=DA,DMAX=^DD("ROU") G EN^DIKZ
A	N DA S DA=+X N X K ^DD(DA,0,"DIK")
	F X=0:0 S X=$O(^DD(DA,"SB",X)) Q:X'>0  D A
Q	Q
	;
K	S %=2,DG=@(DIU_"0)") I $P(DG,U,4)>1 W *7,!,"DO YOU WANT JUST TO DELETE THE ",$P(DG,U,4)," FILE ENTRIES,",!?9,"& KEEP THE FILE DEFINITION" D YN^DICN I %=1 G KL
	Q
KL	K % S %=$L(DIU),%=$E(DIU,1,%-1)_$E(")",$E(DIU,%)=","),%Y="%(",%X=DIU_"0," D %XY^%RCR K @% S @(DIU_"0)")=$P(DG,U,1,2)_U,^DIC(DA,0,"GL")=DIU,%X="%(",%Y=DIU_"0," D %XY^%RCR K % I 1 Q
	;
RW	W !,$P("DATA DICTIONARY^READ^WRITE^DELETE^LAYGO^AUDIT",U,DR)," ACCESS: " G R:Y="" W Y I DUZ(0)'="@" F X=1:1:$L(Y) G Q:DUZ(0)'[$E(Y,X)
	W "// "
R	R X:DTIME S:'$T X=U,DTOUT=1 Q:X=""  I X["@" G V:Y="" W *7,"   PROTECTION ERASED!" K ^(D) Q
	I X[U S DR=9 Q
	I X["?" W !,"ENTER CODE(S) TO RESTRICT USER'S ACCESS TO THIS FILE" G RW
V	I DUZ(0)'="@" F Z=1:1:$L(X) I DUZ(0)'[$E(X,Z) W *7,"??" G RW
	S ^(D)=X Q
H	;
	W *7,!?5,"Enter the name of a routine (without the '^') which exists"
	W !?5,"on this computer.  It must be from 1 to 7 characters in"
	W !?5,"length and CANNOT be a DI routine." Q
EN	;
	Q:'$D(DIU)  G EN^DIU0

DIU3
DIU3	; SF/GFT - IDENTIFIERS, UNEDITABLE, INPUT TRANS. ;4/11/89  16:42
	;;17.7;VA FileMan; 6/9/89
	;
3	;
	S %=2,X="W """""
	I $D(^DD(DI,0,"ID",+Y)) W !,"'",$P(Y,U,2),"' is already and Identifier; Want to delete it" D YN^DICN K:%=1 ^DD(DI,0,"ID",+Y) Q
	W !,"Want to make '",$P(Y,U,2),"' an Identifier" D YN^DICN Q:%-1
	S %=$N(^DD(DI,0,"NM",0))
	W !,"Want to display "_$P(Y,U,2)_" whenever a lookup is done",!,"  on an entry in the '"_%_"' File" S %=1 D YN^DICN
	I %-1 G S:%=2&(Y-.001) W *7,"??" Q
	S V=$P(Y(0),U,2),X=$P(Y(0),U,4),D="W",%="(^(0)",%Y=$P(X,";")
	I %Y'=0 S D=$S(+%Y=%Y:"",V["S":"""""",1:""""),%="(^("_D_%Y_D_")",D="W"_$S(+Y'=.001:":$D(^("_$E(D)_%Y_$E(D)_"))",1:"")
	S %Y=$P(X,";",2),X=$S(+Y=.001:"Y",%Y:"$P"_%_",U,"_%Y_")",1:"$E"_%_","_+$E(%Y,2,9)_","_$P(%Y,",",2)_")")
	I V["D" S X="$E("_X_",4,5)_""-""_$E("_X_",6,7)_""-""_$E("_X_",2,3)"
	I V["P" S X="S %I=Y,Y=$S('$D"_%_"):"""",$D(^"_$P(Y(0),U,3)_"+"_X_",0))#2:$P(^(0),U,1),1:""""),C=$P(^DD("_+$P(V,"P",2)_",.01,0),U,2) D Y^DIQ:Y]"""" W ""   "",Y,@(""$E(""_DIC_""%I,0),0)"") S Y=%I K %I" G S
	I V["V" S X=$P(Y(0),U,4),X="S DIY=$S($D(@(DIC_(+Y)_"","""""_$P(X,";",1)_""""")"")):$P(^("""_$P(X,";",1)_"""),U,"_$P(X,";",2)_"),1:"""") D NAME^DICM2 W ""   "",DINAME,@(""$E(""_DIC_""Y,0),0)"")" G S
	I V["S" S X="@(""$P($P($C(59)_$S($D(^DD("_DI_","_+Y_",0)):$P(^(0),U,3),1:0)_$E(""_DIC_""Y,0),0),$C(59)_"_X_"_"""":"""",2),$C(59),1)"")"
	S X=D_" ""   "","_X
S	S ^DD(DI,0,"ID",+Y)=X,X=DIU I N S V=N,P=$N(^DD(J(N-1),"SB",DI,0)),X="^DD(J(N-1),P,"
	S @("X="_X_"0)"),%=$P(X,U,2) I %'["I" S ^(0)=$P(X,U)_U_%_"I"_U_$P(X,U,3,99)
	I N S DIFLD=+Y D WAIT^DICD,0^DIVR S:DE?.E1"  " DE=$E(DE,1,$L(DE)-2) X DE K DE,DA,X,W,DIFLD
	Q
	;
9	;
	S %=2,DA=+Y
	I $P(Y(0),U,2)["I" W !,*7,"FIELD IS ALREADY UNEDITABLE",!,"DO YOU WANT TO ALLOW EDITING AGAIN" D YN^DICN Q:%-1  S X=$P(^(0),U,2),^(0)=$P(^(0),U,1)_U_$P(X,"I",1)_$P(X,"I",2)_$P(X,"I",3)_U_$P(^(0),U,3,99) W "  ..OK" G 2
	W !,"WANT TO PREVENT ALL USERS FROM CHANGING OR DELETING DATA VALUES",!
	W "THAT ARE ENTERED FOR THE '"_$P(Y,U,2)_"' FIELD" D YN^DICN Q:%-1  S ^(0)=$P(^(0),U,1,2)_"I^"_$P(^(0),U,3,99) W *7,!?9,"...FIELD IS NOW UNEDITABLE!"
2	G DIEZ^DIU0
	;
5	W !,$P(Y,U,2) S DA=+Y,Y=$P(Y(0),U,5,99)
	W " INPUT TRANSFORM: ",Y D RW^DIR2 Q:X=""  S %=$L($P(Y(0),U,1,4))+$L(X) I %>244 W !!?5,*7,"Input Transform is TOO LONG by ",%-244," characters.",! K X S Y=DA_U_$P(Y(0),U) G 5
	I $P(Y(0),U,2)["K",X'["D ^DIM" K X S Y=DA_U_$P(Y(0),U) W *7,!?5,"Input Transform must contain D ^DIM",! G 5
	I $P(Y(0),U,2)["F",X["DINUM" W *7,!?5,"DINUM on a Freetext field can cause database",!?5,"problems unless you are sure DINUM is numeric."
	D ^DIM I '$D(X) W *7,"??" S Y=DA_U_$P(Y(0),U) G 5
	S ^(0)=$P(Y(0),U,1,2)_$E("X",$P(Y(0),U,2)'["X")_U_$P(Y(0),U,3,4)_U_X,DR="3:4"
	I $P(Y(0),U,2)["P" S %=$F(X," D ^DIC") I % S X=$E(X,1,%-8),%=$F(X,"DIC(""S"")=") I % S X=$E(X,%-9,$L(X)),^(12.1)="S "_X,DR=DR_";12EXPLANATION OF SCREEN"
	S DIE=DIC D DIPZ^DIU0 Q:$P(Y(0),U,2)["C"  G ^DIE

DIV
DIV	; SF/GFT - VERIFY FLDS ;3/29/89  16:36
	;;17.7;VA FileMan; 6/9/89
	K J
	S Q="""",S=";",V=0,P=0,I(0)=DIU,@("(A,J(0))=+$P("_DIU_"0),U,2)")
	I $N(^(0))'>0 W *7,"  NO ENTRIES ON FILE!" Q
DIC	S DIC="^DD(A,",DIC(0)="EZ",DIC("W")="W:$P(^(0),U,2) ""  (multiple)"""
	S DIC("S")="S %=$P(^(0),U,2) I %'[""C"",$S('%:1,1:$P(^DD(+%,.01,0),U,2)'[""W"")"
	W !,"VERIFY WHICH "_$P(^DD(A,0),U)_": " R X:DTIME Q:U[X
	I X="ALL" D ALL G Q:$D(DIRUT) I Y F DQI=0:0 S DQI=$O(^DD(A,DQI)) G Q^DIVR:DQI'>0 S Y=DQI,Y(0)=^(Y,0),DR=$P(Y(0),U,2) I 'DR,DR'["C" W !!!,"--",$P(Y(0),U),"--" D 1
	D ^DIC K DQI,^UTILITY("DIVR",$J)
	I Y<0 W:X?1."?" !?3,"You may enter ALL to verify every field at this level of the file.",! G DIC
	S DR=$P(Y(0),U,2) I DR S J(V)=A,P=+Y,V=V+1,A=+DR,I(V)=$P($P(Y(0),U,4),S,1) S:+I(V)'=I(V) I(V)=Q_I(V)_Q G DIC
1	F T="N","D","P","S","V","F" Q:DR[T
	F W="FREE TEXT","SET OF CODES","DATE","NUMERIC","POINTER","VARIABLE POINTER","K" I T[$E(W) S:W="K" W="MUMPS" W "   ",W
	K DA S Z=$P(Y(0),U,3),DDC=$P(Y(0),U,5,99),(DIFLD,DA)=+Y
	G ^DIVR
	;
Q	K DIR,DIRUT,N,P,Q,S,V,C
	Q
	;
ALL	S DIR(0)="Y",DIR("??")="^D H^DIV"
	S DIR("A")="DO YOU MEAN ALL THE FIELDS IN THE FILE"
	D ^DIR K DIR S X="ALL"
	Q
	;
H	W !!?5,"YES means that every field at this level in the file will"
	W !?5,"be checked to see if it conforms to the input transform."
	W !!?5,"NO means that ALL will be used to lookup a field in the"
	W !?5,"file which begins with the letters ALL, e.g., ALLERGIES."
	Q

DIVR
DIVR	; SF/GFT - VERIFY FLDS ;2/17/89  14:24
	;;17.7;VA FileMan; 6/9/89
	S W="W !,""ENTRY#"_$S(V:"'S",1:"")_""",?10,"""_$P(^DD(A,.01,0),U)_""",?40,""ERROR"""
	W ! S T=$E(T) G E:'$D(^($N(^DD(A,DA,1,0)),1))
	I $P(^(0),U,2,9)?1.A,^(2)?1"K ^".E1")",^(1)?1"S ^".E W "(CHECKING" S DG="I $D("_$E(^(2),3,99)_"),"_$E(^(1),3,99),E=T,T="IX"
	E  W *7,"(CANNOT CHECK"
	W " CROSS-REFERENCE)",!
E	S Y=$F(DDC,"%DT=""E") S:Y DDC=$E(DDC,1,Y-2)_$E(DDC,Y,999)
	I DR["*" S DDC="Q" I $D(^DD(A,DA,12.1)) X ^(12.1) I $D(DIC("S")) S DDC(1)=DIC("S"),DDC="X DDC(1) E  K X"
	D 0 S X=$P(Y(0),U,4),Y=$P(X,S,2),X=$P(X,S)
	I +X'=X S X=Q_X_Q I Y="" S DE=DE_"S X=DA D R" G XEC
	S M="S X=$S($D(^(DA,"_X_")):$"_$S(Y:"P(^("_X_"),U,"_Y,1:"E(^("_X_"),"_$E(Y,2,9))_"),1:"""") D R"
	I $L(M)+$L(DE)>250 S DE=DE_"X DE(1)",DE(1)=M
	E  S DE=DE_M
XEC	K DIC,M,Y X DE Q:$D(DQI)
	W:'$D(M) *7,!,"NO PROBLEMS"
Q	S M=$N(^UTILITY("DIVR",$J,0)),E=$N(^(M)),DK=J(0)
	I E>0 K DIBT,DISV R !,"STORE THESE ENTRY ID'S IN TEMPLATE: ",X:DTIME I U'[X D MRG^DIBT G Q:Y<0 F DDC=0:0 S DDC=$N(^UTILITY("DIVR",$J,DDC)) Q:DDC<0  S ^DIBT(+Y,1,DDC)=""
	K ^UTILITY("DIVR",$J),DQI,DK,DA,DG,DQ,DE,T,P,E,M,DR,W,DDC,DIFLD Q
	;
R	I X?." " Q:DR'["R"  S M="Missing" G X
	G @T
	;
P	I @("$D(^"_Z_"X,0))") S Y=X G F
	S M="No '"_X_"' in pointed-to File" G X
	;
S	S Y=X X DDC I '$D(X) S M=Q_Y_Q_" fails screen" G X
	Q:S_Z[(S_X_":")  S M=Q_X_Q_" not in Set" G X
	;
D	S Y=X,X=$E(Y,1,3)+1700,%=$E(Y,6,7) S:% X=%_"-"_X S:$E(Y,4,5) X=+$E(Y,4,5)_"-"_X S:Y["." X=X_"@"_$E(Y_"000",9,12)
N	;
F	S DQ=X I X'?.ANP S M="Non-printing character" G X
	X DDC Q:$D(X)  S M=Q_DQ_Q_" fails Input Transform"
X	I $O(^UTILITY("DIVR",$J,0))="" X W
	S X=$S(V:DA(V),1:DA),^UTILITY("DIVR",$J,X)=""
	S X=V I @(I(0)_"0)")
DA	I 'X W !,DA,?10,$S($D(^(DA,0)):$P(^(0),U),1:DA),?40,$E(M,1,40) W:V ! Q
	W !,DA(X),?10,$P(^(DA(X),0),U) S X=X-1,@("Y=$D(^("_I(V-X)_",0))") G DA
	;
0	;
	S Y=I(0),DE="",X=V
L	S DA="DA" S:X DA=DA_"("_X_")" S Y=Y_DA,DE=DE_"F "_DA_"=0:0 ",%="S "_DA_"=$O("_Y_"))" I V>2 S DE(X+X)=%,DE=DE_"X DE("_(X+X)_")"
	E  S DE=DE_%
	S DE=DE_" Q:"_DA_"'>0  S D"_(V-X)_"="_DA_" "
	I X=1,DIFLD=.01 S DE=DE_"X P:$D(^(DA(1),"_I(V)_",0)) ",P="S $P(^(0),U,2)="""_$P(^DD(J(V-1),P,0),U,2)_Q
	S X=X-1 Q:X<0  S Y=Y_","_I(V-X)_"," G L
	;
IX	X DG I  G @E
	S M=Q_X_Q_" not properly Cross-referenced" G X
	Q
V	I $P(X,S,2)'?1A.AN1"(".ANP,$P(X,S,2)'?1"%".AN1"(".ANP S M=Q_X_Q_" has the wrong format" G X
	S M=$S($D(@(U_$P(X,S,2)_"0)")):^(0),1:"")
	I '$D(^DD(A,DIFLD,"V","B",+$P(M,U,2))) S M=$P(M,U)_" FILE not in the DD" G X
	I '$D(@(U_$P(X,S,2)_+X_",0)")) S M=U_$P(X,S,2)_+X_",0) does not exist" G X
	G F

DIVRE
DIVRE	; SF/MWE - REQ FLD(S) CHK ;5/25/89  09:54 ;
	;;17.7;VA FileMan; 6/9/89
B	K ^UTILITY($J),DIBT S (DK,DIC)=DI,DIC(0)="EQM",DIK=0
	W !,"CHECK WHICH ENTRY: " R X:DTIME G Q:U[X!'$T
	I X="ALL" D ALL G Q:$D(DIRUT) I Y S DIROOT=DIU G D
	D ^DIC I Y<0 W:X?1."?" !?3,"You may type 'ALL' to select every entry in the file.",! G B
R	S DIK=DIK+1,^UTILITY($J,"DIN",+Y)=""
	S DIC(0)="AEQM",DIC("A")="ANOTHER ONE: " D ^DIC I Y>0 G R
	Q:'DIK!(X=U)
D	;
	R !,"STORE THE RESULTING ENTRIES ID'S IN TEMPLATE: ",X:DTIME G Q:X=U!'$T I X]"" D MRG^DIBT G D:Y<0,D:"??"[X,Q:X=U S:Y>0 DIBT=+Y
	S DIC=DI
	S:$D(^%ZTSK) %IS="Q" D ^%ZIS
	G:IO']"" Q I $D(IO("Q")) G:IO("Q")=1 TSK
L	S (DC,DA,N)=0 S:'$D(DIROOT) DIROOT="^UTILITY($J,""DIN""," F I=0:0 S DA=$O(@(DIROOT_DA_")")) Q:'DA  W:IOST?1"C".E "." D START
	I N U IO S DC=0 D PH F N=1:1 Q:'$D(^UTILITY($J,"DIVRE",N))  S X=^(N) D P I IOST?1"C".E,$Y>(IOSL-4) W *7 R X:DTIME Q:X=U!'$T
	I 'N U IO D PH W !!,"NO REQUIRED FIELD IS MISSING"
Q	K DIRUT,DK,C,D,I,J,N,F,S,G,P,L,X,Y,DI,DIK,DIC,DISD,DIREF,DIFLD,DC,DIROOT,^UTILITY($J)
	X:$D(^%ZIS("C")) ^("C")
	Q
P	;
	D:$Y>(IOSL-3) PH
	S %=$P(X,U),Y=$P(@(^DIC($P(%,";",2),0,"GL")_+%_",0)"),U,1),C=$P(^DD($P(%,";",2),.01,0),U,2) D Y^DIQ
	W !,+$P(X,U),?10,$E(Y,1,20),?35,$P(X,U,2),?50,$P(^DD($P(X,U,2),$P(X,U,3),0),U)
	Q:DUZ(0)'="@"
	I IOM>80 W ?85,$P(X,U,4) Q
	W !?35,$P(X,U,4) Q
PH	;
	S DC=DC+1 W @IOF,"Required-Field-Check  File: ",I(1)_" "_$O(^DD(I(1),0,"NM","")),?(IOM-25) S Y=DT D DD^%DT W ?(IOM-10),"PAGE ",DC
	W !,"Entry",?35,"DD-Number",$S((DUZ(0)="@")+(IOM'>80)=2:"/Path",1:""),?50,"Field" I DUZ(0)="@",IOM>80 W ?85,"Path"
	W ! F L=1:1:(IOM-2) W "-"
	Q
CHECK	;
	Q:$P(^DD(DIC,DIFLD,0),U,2)'["R"
	S G=$P(^(0),U,4),P=$P(G,";",2),G=$P(G,";") S:'P P=1
	I $D(@(DIREF_","""_G_""")")),$P(^(G),U,P)]"" Q
	S N=N+1,^UTILITY($J,"DIVRE",N)=D(1)_";"_I(1)_U_DIC_U_DIFLD_DIREF S:$D(DIBT) ^DIBT(DIBT,1,D(1))=""
	Q
START	;
	S L=1,DIC=$S('DIC:+$P(@(DIC_"0)"),U,2),1:DIC),DIREF=^DIC(DIC,0,"GL"),X="",U="^",DIREF=DIREF_DA
M	S J(L)=DIREF,I(L)=DIC,D(L)=DA
	S DIFLD=0 F I=0:0 S DIFLD=$O(^DD(DIC,"RQ",DIFLD)),F(L)=DIFLD Q:'DIFLD  D CHECK
	S DISD=0 F I=0:0 S DISD=$O(^DD(DIC,"SB",DISD)) Q:'DISD  S S(L)=DISD D NEW
	Q
NEW	;
	S L=L+1
	S DIC=DISD,DIREF=DIREF_","_+$P(^DD(I(L-1),$O(^DD(I(L-1),"SB",DISD,"")),0),U,4)_","
	S DA=0 F I=0:0 S DA=$O(@(DIREF_DA_")")) Q:'DA  S DIREF=DIREF_DA D M
	S L=L-1,DIC=I(L),DIREF=J(L),DA=D(L),DIFLD=F(L),DISD=S(L)
	Q
TSK	;
	S ZTRTN="L^DIVRE",ZTDESC="REQUIRED FIELD CHECK",ZTIO=ION_";"_IOST_";"_IOM
	F N="DIC","^UTILITY($J,","DIROOT" S ZTSAVE(N)=""
	D ^%ZTLOAD G Q
	;
ALL	S DIR(0)="Y",DIR("??")="^D H^DIVRE"
	S DIR("A")="DO YOU MEAN ALL THE ENTRIES IN THE FILE"
	D ^DIR K DIR S X="ALL"
	Q
	;
H	W !!?5,"YES means that every entry in the file will be checked to see"
	W !?5,"that all the required fields have data."
	W !!?5,"NO means that ALL will be used to lookup an entry in the"
	W !?5,"file which begins with the letters ALL."
	Q

DIWE
DIWE	; SF/GFT,XAK - START OF WP ;5/30/89  09:13
	;;17.7;VA FileMan; 6/9/89
EN	K DTOUT ;G Q:'$D(@(DIC_"0)")) D A
	D A L @(DIC_"0)"):1 E  W !,"FILE IS IN USE BY ANOTHER TERMINAL" G Q
GO	S:$D(DTIME)[0 DTIME=600 I $D(DT)[0 D NOW^%DTC S DT=X K %I
	S @(DIC_"0)")=DWLC G ^DIWE1:DWLC D ^DIWE2 S (DWL,DWLC)=DWI G GO:DWL,X
	;
DIEN	;
	S DH=$P(Y,U,1),DV=DG,DWPK="FM",(DIC,Y)=DIE_DA_",DV",DWO="ABCDE IJLM"_$E("P ",$D(I)+$D(J)>19+1)_"RSTU"_$E("Y",DUZ(0)="@") D A G W:'$D(DE(1,0))
	S X=DE(1,0),DWI=X?1"/".E S:DWI X=$E(X,2,999) I X?1"+".E S X=$E(X,2,999)
	E  G W:'DWI&DWLC K:DWLC @(Y_")") S DWLC=0 Q:X="@"
	I X?1"^".E S DIW=DIC,DICMX="S DWLC=DWLC+1,"_DIC_",DWLC,0)=X",DIWL=DWLC X $E(X,2,999) S DIC=DIW S:DIWL-DWLC X="" K DICMX,DIWL,DIW
	S:X]"" DWLC=DWLC+1,@(DIC_"DWLC,0)=X") G X:DWI
W	W !?DL+DL-2,DH_":" G GO
	;
A	S:$E(DIC,$L(DIC))'="," DIC=DIC_"," S:'$D(DWO) DWO="ABCDE IJLMPRSTU"_$E(" Y",$S($D(DUZ(0)):DUZ(0)="@"+1,1:1))_"T"
	S @("J=$N("_DIC_"0))>0") I '$D(^(0))!'J S ^(0)=""
	K DWL S U="^",DWHD=^(0)_U,DWLC=+$P(DWHD,U,3),DWLW=$S($D(DWLW):DWLW,1:245) I J D REPACK:DWLC-$P(DWHD,U,4)!'DWLC!'$D(^(DWLC))
	S DWPK=$S($D(DWPK):DWPK,1:2),DWLR=245,DWLC=$S('DWLC:+DWHD,1:DWLC)
	S DIWPT=$S('$D(^DIC(3,0)):"",^(0)'["USER":"",'$D(^DIC(3,+DUZ,1)):"",1:$P(^(1),U,2)) Q
	;
REPACK	K ^UTILITY($J,"W") S J=0 F I=0:0 S @("J=$N("_DIC_"J))") Q:J'>0  S:$D(^(J,0)) I=I+1,^UTILITY($J,"W",I)=^(0) W "."
	K @($E(DIC,1,$L(DIC)-1)_")") F J=1:1:I S @(DIC_"J,0)=^UTILITY($J,""W"",J)") W "."
	K ^UTILITY($J,"W") S DWLC=I Q
	;
X	;
	I @("$N("_DIC_"0))'>0") K @($E(DIC,1,$L(DIC)-1)_")") G Q
	S ^(0)=$P(DWHD,U,1,2)_U_DWLC_U_DWLC_U_DT_U_$P(DWHD,U,6,9)
Q	K DW2,DW3,DIWPT,DWO,DWLR,DWHD,DWL,DWPK,DWI,DWJ,DWLC
	K Y,Z,DWAFT,DWLW,DIW,D Q

DIWE1
DIWE1	; SF/GFT - WORD PROCESSING FUNCTION ;1/31/89  15:27 ;
	;;17.7;VA FileMan; 6/9/89
	G Q^DIWE:$D(DTOUT) I '$D(DWL) S I=DWLC,J=$S(I<11:1,1:I-8) W:J>1 ?7,". . .",!?7,". . ." D LL
1	G Q^DIWE:$D(DTOUT) R !,"EDIT Option: ",X:DTIME S:'$T DTOUT=1 G X:U[X!(X=".")
LC	I X?1L S X=$C($A(X)-32)
	S J="^DOPT(""DIWE1""," I X?1U S I=$F(DWO,X)-1 I I>0 S ^DISV(DUZ,J)=I S I=I*2-1 G OPT
	I X=" ",$D(^DISV(DUZ,J)) S I=^(J),X=$E(DWO,I) I X]"" W X S I=I*2-1 G OPT
	I X?1N.N S I=9 D LN G E2:X W "OR"
	W !?5,"Choose, by first letter, a Word Processing Command"
	I X?2"?".E W " from the following:" F I=1:2 S Y=$T(OPT+I),J=$E(Y,1) Q:J=" "  I DWO[J W !?10,$P(Y,";",4)
	W !?5,"or type a Line Number to edit that line." G 1
	;
OPT	Q:$D(DTOUT)  S X1=$T(OPT+I),X=$P(X1,";",3) W $E(X,'$X)_$E(X,2,99) G @$E(X1,1)
A	;;Add lines;Add Lines to End of Text
	D ^DIWE2 S (DWL,DWLC)=DWI,@(DIC_"0)=DWLC") G 1:DWLC,X
B	;;Break line: ;Break a Line into Two;
	D RD G B^DIWE4
C	;;Change every: ;Change Every String to Another in a Range of Lines;
	G C^DIWE2
D	;;Delete from line: ;Delete Line(s);
	D RD G D^DIWE3
E	;;Edit line: ;Edit a Line (Replace __  With __);
	D RD G OPT:X="",1:X=U,LC:X?1A,E2
G	;;Get Data from Another Source ;Get Data from Another Source
	G X^DIWE5
I	;;Insert after line: ;Insert Line(s) after an Existing Line;
	D RD G I^DIWE2
J	;;Join line: ;Join Line to the One Following;
	D RD G J^DIWE4
L	;;List line: 1//;List a Range of Lines;
	R X:DTIME S:'$T X=U,DTOUT=1 S:X="" X=1 D LN G LIST:X,1:X=U W !,$P(X1,";",3) G L
M	;;Move line: ;Move Lines to New Location within Text;
	D RD G M^DIWE3
P	;;Print from Line: 1//;Print Lines as Formatted Output;
	R X:DTIME S:'$T X=U,DTOUT=1 S:X="" X=1 D LN,^DIWE4:X G 1
R	;;Repeat line: ;Repeat Lines at a New Location
	D RD G R^DIWE3
S	;;Search for: ;Search for a String
	G S^DIWE2
T	;;Transfer incoming text after line: ;Transfer Lines From Another Document
	D RD,Z^DIWE3 G DIWE1
U	;;Utilities in Word-Processing;Utility Sub-Menu
	D ^DIWE11 G 1
Y	;;Y;Y-Programmer Edit;
	G Y^DIWE4
	;;
E2	S Y=^(0) S:Y="" Y=" " W !,$J(DWL,3)_">"_Y,! D RW^DIR2 G E2:X?1."?",X:X?1."^"
TAB	I X[$C(9) S X=$P(X,$C(9),1)_$C(124)_"TAB"_$C(124)_$P(X,$C(9),2,999) G TAB
	S:X]"" ^(0)=X I X="@" S (DW1,DW2)=DWL W "DELETED..." D DEL^DIWE3
	W ! S I=9 G OPT
	;
RD	R X:DTIME S:'$T DTOUT=1 I X?1."?" W !?5,"Enter a line number from 1 through "_DWLC,!!,$P(X1,";",3) G RD
LN	I U[X!(X=".") S X=U Q
	Q:I=9&(X?1A)  I 'DWLC,I<27,I-13 S X=U W "  THERE ARE NO LINES!",*7,! Q
	I "+- "[$E(X,1),X?1P.N,$D(DWL) S:X?1P X=X_1 S X=X+DWL W "  "_X
	E  S X=+X
	I (I=13!(I=27)&(X=0))!$D(@(DIC_"X,0)")) S DWL=X Q
	S X="" G LNQ^DIWE5
	;
X	Q:$D(DTOUT)  G X^DIWE
	;
LIST	W "  to: "_DWLC_"// " R I:DTIME S I=$S('$T:U,I="":DWLC,1:I) I I,I>DWLC!(I<1) S I=DWLC
	S J=X D LL S:I=U DTOUT=1 G 1
LL	X "F J=J:1:I W !,$J(J,3)_"">""_"_DIC_"J,0)"

DIWE11
DIWE11	; SF/GT,SF/MWE - WORD PROCESSING UTILITY FUNCTION ; 10/13/88  11:21 ;
	;;17.7;VA FileMan; 6/9/89
	S DWOU="EFT"
1	R !,"UTILITY Option: ",X:DTIME S:'$T DTOUT=1 G QQ:U[X!(X=".")
LC	I X?1L S X=$C($A(X)-32)
	S J="^DOPT(""DIWE11""," I X?1U S I=$F(DWOU,X)-1 I I>0 S ^DISV(DUZ,J)=I S I=I*2-1 G OPT
	I X=" ",$D(^DISV(DUZ,J)) S I=^(J),X=$E(DWOU,I) I X]"" W X S I=I*2-1 G OPT
	W !?5,"Choose, by first letter, a Utility Command"
	I X?2"?".E W " from the following:" F I=1:2 S Y=$T(OPT+I),J=$E(Y,1) Q:J=" "  I DWOU[J W !?10,$P(Y,";",4)
	G 1
	;
OPT	Q:$D(DTOUT)  S X1=$T(OPT+I),X=$P(X1,";",3) W $E(X,'$X)_$E(X,2,99) G @$E(X1,1)
E	;;Editor;Editor Change
	W !,"Reserved for future use !" G QQ
F	;;File transfer;File Transfer from Foreign CPU
	G NA:'$D(^%ZOSF("EON"))!'$D(^("EOFF")) D X^DIWE5 G QQ
T	;;Text-Terminator;Text-Terminator-String Change
	D TT G QQ
	;;
TT	;
	W !,"Text-Terminator: ",$S(DIWPT="":"<NULL-STRING>",1:DIWPT),"//"
	R X:DTIME S:'$T DTOUT=1 Q:U[X
	K:$L(X)>5!(X'?.ANP)!(X["?")!(X["^") X
	I '$D(X) W !?5,"Answer must be 1 to 5 Characters, no question marks or up-arrows,",!?5,"to go back to the Null-String just type ""@"" !",*7 G TT
	I X="@" W !?5,"Text-Terminator is now Null-String !" S X=""
	S DIWPT=X Q
QQ	K DWOU Q
ASK	W ! S DIR("A")="MAXIMUM string length? "
	S DIR("B")=75,DIR(0)="N^3:245:0" D ^DIR K DIR G XQ1:$D(DTOUT)!$D(DUOUT)
	W !!,"You have 30 seconds to start sending text."
	W !,"An End Of File is assumed on 30 second time-out."
	W !!,"TABs are converted to 1 thru 9 spaces to start the next character"
	W !,"at a column evenly divisable by 9 plus 1. (10,19,28,37...)"
	W !!,"End of Line = Carriage Return/$C(13) or Escape/$C(27)."
	W !,"All other control characters will be stripped.",!!
	Q
XQ	X ^%ZOSF("EON") W !!,"File Transfer Complete",*7,!
XQ1	K %,%1,%2,%B,%0,DIWL,DIR,DTOUT,DUOUT
	Q
NA	W !!,"This option is not available without the rest of the KERNEL"
	G QQ

DIWE2
DIWE2	; SF/GFT - WP SEARCH, CHANGE, INSERT ;2/8/89  09:05
	;;17.7;VA FileMan; 6/9/89
	S DWI=DWLC,DWJ=0,DWLR=DWLW
NEWL	W !,$J(DWJ+DWI+1,3),">" R X#245:DTIME I '$T,X="" S DTOUT=1 Q
	I X="",DIWPT'="" S X=" "
	Q:U[X!(DIWPT=X)
	I X?."?" D IQ^DIWE5 G NEWL
TAB	I X[$C(9) S X=$P(X,$C(9),1)_$C(124)_"TAB"_$C(124)_$P(X,$C(9),2,999) G TAB
	I X'?.ANP W *7,!?9,"CONTROL CHARACTERS REMOVED!!",! F Y=1:1 I $E(X,Y)?.C G:Y>$L(X) NEWL:X="",G S X=$E(X,1,Y-1)_$E(X,Y+1,999),Y=Y-1
G	G NW:'DWPK,NW:X?." "!(X[($C(124)_"TAB"_$C(124)))!($A(X)=124),NL:DWPK=1 S:DWI Y=@(DIC_DWI_",0)") S J=$L(X) I J+DWLR<DWLW S @(DIC_"DWI,0)")=Y_$E(" ",$A(Y,DWLR)'=32)_X,DWLR=$L(@(DIC_"DWI,0)")) G NEWL
	I DWLR+7<DWLW F J=DWLW-DWLR:-1:1 IF $E(X,J)=" " S @(DIC_"DWI,0)")=Y_$E(" ",$A(Y,DWLR)'=32)_$E(X,1,J-1),X=$E(X,J+1,256),DWLR=$L(X) Q
NL	I $L(X)>DWLW S J=$F(X," ",DWLW-7),J=$S(J<1!(J>DWLW):DWLW,1:J),DWI=DWI+1,@(DIC_"DWI,0)")=$E(X,1,J-1),X=$E(X,J,256),DWLR=J G NL
	S:$L(X) DWI=DWI+1,@(DIC_"DWI,0)")=X,DWLR=$L(X) G NEWL
NW	S:$L(X) DWI=DWI+1,@(DIC_"DWI,0)")=X,DWLR=DWLW G NEWL
	;
I	;INSERT
	G 1:X=U,OPT^DIWE1:X=DIWPT S DWJ=X W:X !,$J(DWJ,3),">",^(0) K ^UTILITY($J,"W") S DWI=0,DIC(1)=DIC,DIC="^UTILITY($J,""W"",",@(DIC_"0)")="",DWLR=DWLW D NEWL G D:'DWI
	W !,DWI_" line"_$E("s",DWI'=1)_" inserted.."
	X "F DWL=DWI+DWLC:-1:DWJ+DWI+1 S "_DIC(1)_"DWL,0)="_DIC(1)_"DWL-DWI,0) W ""."""
	X "F DWL=DWI:-1:1 S "_DIC(1)_"DWJ+DWL,0)="_DIC_"DWL,0) W ""."""
D	S DWLC=DWLC+DWI,DIC=DIC(1) K ^UTILITY($J,"W"),DIC(1)
1	G ^DIWE1
	;
S	;SEARCH
	R X:DTIME S:'$T DTOUT=1 I X]"" W " ...",! X "F I=1:1:DWLC I "_DIC_"I,0)[X W $J(I,3)_"">""_^(0),! S DWL=I"
	G 1^DIWE1
	;
C	;CHANGE
	R DWI:DTIME S:'$T DTOUT=1 G 1:DWI="" R " to: ",DWJ:DTIME S:'$T DTOUT=1 G 1:'$T
	W !,"Ask 'OK' for each line found" S %=2 D YN^DICN G 1:%<1
FR	R !,"From line: 1// ",X:DTIME S:'$T DTOUT=1 G 1:X=U!'$T I X="" S J=1 G TO
	D LN^DIWE1 G FR:X="",1:X=U S J=X
TO	W "   to line: "_DWLC_"// " R I:DTIME S:'$T DTOUT=1 G 1:X=U!'$T I I="" S I=DWLC
	I I<J!'I W *7,"??" G FR
	I I>DWLC S I=DWLC W "  ("_I_")"
	W " ...",! X "F J=J\1:1:I I "_DIC_"J,0)[DWI D C1"
	G 1
C1	S Y=0,DWL=^(0) I %=1 W $J(J,3)_">"_DWL R !,"OK to change? YES// ",X:DTIME,! S:X=U!'$T J=I,DTOUT=1 Q:"YESyes"'[X!'$T
C2	S Y=$F(DWL,DWI,Y) I Y S DWL=$E(DWL,1,Y-$L(DWI)-1)_DWJ_$E(DWL,Y,999),Y=Y-$L(DWI)+$L(DWJ) G C2
	W $J(J,3)_">"_DWL,! S ^(0)=DWL,DWL=J

DIWE3
DIWE3	; SF/GFT - WP - MOVE, DELETE, REPEAT, TRANSFER ;09:09 AM  Nov 15, 1988;
	;;17.7;VA FileMan; 6/9/89
M	;MOVE
	S DWAFT=1 G 1:X=U,OPT:'X D MOVE Q:$D(DTOUT)  S:DW1>DW3 DW1=DW1+I,DW2=DW2+I D DEL:DW1
1	G ^DIWE1
	;
OPT	W ! G OPT^DIWE1
	;
R	;REPEAT
	S DWAFT=1 G 1:X=U,OPT:'X D MOVE
	G 1
	;
D	;DELETE
	S DW1=X G 1:X=U,OPT:'X W "  thru: "_DW1_"// " R DW2:DTIME S:'$T DTOUT=1
	G 1:DW2=U!'$T S:DW2="" DW2=DW1 I DW1>DW2 W *7,"??" G OPT
	I DW2>DWLC S DW2=DWLC W "  ("_DW2_")"
	S X=DW2-DW1+1,%=2 W !,"OK TO REMOVE "_X_" LINE"_$E("S",X>1)
	D YN^DICN I %-1 W "  <NOTHING DELETED>" G 1
	S %=2 I DW1=1,DW2=DWLC W !,*7,"ARE YOU SURE YOU WANT TO DELETE THIS ENTIRE TEXT" D YN^DICN G 1:%-1
	D DEL K DWL G 1
	;
F	R !,"From line: ",DWL:DTIME S:'$T DTOUT=1 G 1:DWL=U!'$T
	I DWL?."?" D H^DIWE5 G F
	I +DWL'=DWL W *7," ??    Please enter a number." G F
MOVE	R "  thru: ",DW2:DTIME S:'$T DTOUT=1 G 1:DW2=U!'$T S DW1=DWL
	I $E(DW2)="E"!($E(DW2)="e") S DW2=9999999
	I 'DW2 S DW2=DW1 W " (",DW1,")"
	S %=2 G YN:'DWAFT R " after line: ",DW3:DTIME S:'$T DTOUT=1 G 1:DW3=U!'$T
	I DW1-1<DW3,DW2>DW3 G Q
	I DW1<1!(DW2>DWLC)!(DW1>DW2)!(DW3<0)!(DW3>DWLC)!(+DW3'=DW3) G Q
YN	W !,"ARE YOU SURE" D YN^DICN
	G Q:%-1 K ^UTILITY($J,"W") S I=0
	I DWAFT?.N X "F J=DW1-.1:0 S J=$N("_DIC_"J)) Q:J>DW2!(J'>0)  I $D(^(J,0)) S X=^(0) D O" G DN
	S DICMX=DWAFT X X S DIC=DWI
DN	G Q:'I X "F J=DWLC:-1:DW3+1 S "_DIC_"J+I,0)="_DIC_"J,0)","F J=1:1:I S "_DIC_"DW3+J,0)=^UTILITY($J,""W"",J,0) W ""."""
	K ^UTILITY($J,"W"),DWL,X,DICMX S DWLC=DWLC+I,@(DIC_"0)")=DWLC Q
	;
DEL	S I=+DW1
	X "F J=DW2+1:1:DWLC S "_DIC_"I,0)="_DIC_"J,0),I=I+1 W ""."""
	S I=DW2-DW1
	X "F J=DWLC-I:1:DWLC K "_DIC_"J) W ""."""
	S DWLC=DWLC-I-1 Q
	;
Z	;
	Q:X=""  S DWAFT=0,DW3=X Q:X[U!(X>DWLC)  I '$D(DIA("P")) G Q
	R !,"From what text: ",X:DTIME S:'$T DTOUT=1 G Q:U[X
	I DIA("P")=3.9,'$D(DC) S DC="1^3.92A",DIE="^XMB(3.9,"
	K I,J S DWI=DIC,DWAFT=$S($D(DA)#2:DA,1:0)
	S DICMX="D O:D'<DW1&(D'>DW2) K:D>DW2 D",DQI="Y(",DA="X(",I(0)=DIA
	S J(0)=DIA("P"),DICOMP="?"
	I X?.ANP,$L(X)<31 S @("I=$N("_DIE_"""B"",X))") I $P(I,X)=""!$D(^(X))!(X?1."?") S X=""""_X_""":"_$N(^DD(J(0),0,"NM",0))_":"_$N(^DD(+$P(DC,U,2),0,"NM",0))
	D ^DICOMP
	S DIC=DWI,DA=DWAFT,DWAFT=U I '$D(X)!(Y'["w") G Q
	S %=$F(X,"D ^DIC"),DWAFT=$E(X,1,$F(X,"S X=")-6),DWAFT(1)=$E(X,%,999)
	X $E(X,1,%-8) S DIC(0)="QEM" D ^DIC I Y<0 K DWAFT S DIC=DWI G Z:X?1."?",Q
	I DIC["^XMB(3.9,",$D(XMZ) S DIXM=XMZ X "N X D XM" K DIXM
	S DIC=DWI I X'[U S X=DWAFT_" S Y="_+Y_DWAFT(1) K DWAFT S DWAFT=U G F
Q	W "  <NO CHANGE>",*7 S DW1=0 K DWL,X,DICMX Q
O	S I=I+1,^UTILITY($J,"W",I,0)=X Q
	;
XM	W !,"Transfer from Response: Original Message// " R X:DTIME Q:X[U
	I X?1."?" S XMZ=+Y D ENT8^XMAH S Y=XMZ,XMZ=DIXM G XM
	I X,$D(^XMB(3.9,+Y,3,X,0)) S Y=+^(0) Q
	I X=""!(X=0)!(X="O") Q
	G XM

DIWE4
DIWE4	; SF/GFT - WP - ROUGH DRAFT, BREAK, JOIN ;05:20 PM  May 11, 1988;
	;;17.7;VA FileMan; 6/9/89
	W " to Line: "_DWLC_"// " R DW2:DTIME S:'$T DW2=U,DTOUT=1 S:DW2="" DW2=DWLC Q:DW2>DWLC!(DW2<X)  S DW2=+DW2
	S:$D(DV)[0 DV=0 S %=2 W !,"WANT LINE NUMBERS" D YN^DICN Q:%<1  S I=%,J=0
RD	I I=1 S %=2 W !,"ROUGH DRAFT" D YN^DICN Q:%<0  S:%=1 J=124 I %=0 W !,"A Rough Draft is printed line-for-line, showing windows.",! G RD
	S DIWF="W"_$S(J:"N",DWPK="FM"&$D(DQ(1)):$E("N",$P(DQ(1),U,2)["L"),1:"")_$E("L",I)_$C(J)
	K DW1,IOP,I,J D ^%ZIS G K:IO="" S DIWR=IOM-(DIWF["L"*4),DIWL=1,DWI="F D=DWL:1:"_DW2_" S X="_DIC_"D,0) D ^DIWP",DWJ=0
	I DWPK'="FM" S DWH="" G HEAD
	S:'$D(DIEL) DIEL=DL-1 S DW1=DIE,DW2=DA,%=DIEL,I(%)=DIE,J(%)=DP,I(%,0)=DA,DWH=$S($D(DQ)<11:"",1:$E($P(DQ(DQ),U,1),8,99))
DWH	S DWH=$N(^DD(J(%),0,"NM",0))_$P(" FILE",1,'%)_":"_DWH I @("$D("_I(%)_I(%,0)_",0))") S DWH=""""_$P(^(0),U,1)_""" IN "_DWH
	S %=%-1 I %+1 S J(%)=DP(DIEL-%),I(%)=DIE(DIEL-%),I(%+1)=$P($P(I(%+1),I(%),2,99),",",2),I(%,0)=DA(DIEL-%) G DWH
HEAD	S ^UTILITY($J,1)="S DWJ=DWJ+1 W @IOF,?3,DWH,?IOM-22 S Y=DT D DT^DIO2 W ""   PAGE "",DWJ,!!"
	U IO X ^(1),DWI D ^DIWW S:$D(DW1) DIE=DW1,DA=DW2 D CLOSE^DIO4
K	K I,J,DIWF,DIWL,DIWR,DIWT,DIWLL,DW1,DW2,DWJ,DWH Q
	;
Y	;
	Q:DUZ(0)'["@"
	R !!,"The text is in X and returned in Y",!,"Enter MUMPS xecute string to do transformation: ",X:DTIME S:'$T DTOUT=1 G 1:X'?1U.E D ^DIM G 1:'$D(X) S DW=X
	R !,"Edit from line: 1// ",DW1:DTIME S:'$T DTOUT=1 G 1:DW1=U!'$T S:DW1="" DW1=1 G 1:+DW1'=DW1 W "  thru: ",DWLC,"// " R DW2:DTIME S:'$T DTOUT=1 G 1:DW2=U!'$T S:DW2="" DW2=DWLC
	IF (DW1>DW2)!(DW2>DWLC)!(DW1<1) G 1
	F I=DW1:1:DW2 S X=@(DIC_"I,0)") K Y X DW I $D(Y)=1 S @(DIC_"I,0)")=Y W !,$J(I,3)_">"_Y S DWL=I
	G 1
	;
B	;BREAK
	G 1:X=U,OPT:'X
BA	R !," after character(s): ",X:DTIME S:'$T DTOUT=1 G 1:U[X S DW=^(0) I DW'[X W *7,"??" G BA
	S DWLC=DWLC+1 X "F I=DWLC:-1:DWL+1 S "_DIC_"I,0)="_DIC_"I-1,0) W ""."""
	S @(DIC_"0)")=DWLC,Y=$F(DW,X)-1,@(DIC_"DWL,0)")=$E(DW,1,Y),@(DIC_"DWL+1,0)")=$E(DW,Y+1,999)
	W !,$J(DWL,3)_">",@(DIC_"DWL,0)"),!,$J(DWL+1,3)_">",@(DIC_"DWL+1,0)")
1	G ^DIWE1
	;
OPT	W ! G OPT^DIWE1
	;
J	;JOIN
	G 1:X=U,OPT:'X I X=DWLC W *7,"??" G OPT
	S @("Y="_DIC_"X+1,0)"),@("J="_DIC_"X,0)") I $L(Y)+$L(J)>250 W *7,"  TOO LONG" G 1
	S ^(0)=J_" "_Y W !,$J(X,3)_">"_^(0),! F I=X+1:1:DWLC-1 S @(DIC_"I,0)="_DIC_"I+1,0)") W "."
	K @(DIC_"DWLC)") S DWLC=DWLC-1 G 1

DIWE5
DIWE5	; SF/GFT - WP, AUX FUNCTIONS ;1/30/89  11:56 ;
	;;17.7;VA FileMan; 6/9/89
	;
LNQ	;
	W !,"ANSWER WITH A LINE NUMBER ("_(I'=6)_$P("-"_DWLC,U,DWLC>1)_")"
	I $D(DWL) W !?9,"OR A SPACE TO MEAN THE CURRENT LINE ("_DWL_")" W:DWL>2 !?9,"OR '-' TO MEAN LINE ",DWL-1,", '-2' TO MEAN ",DWL-2,", ",$P("'+' TO MEAN "_(DWL+1)_", ",U,DWL<DWLC)_"ETC."
	W ! Q
	;
WL	W !,"INITIALS:",! S X=$P(DIC,"(",1) Q:$D(@X)<9  S X=$N(@(X_"(0)"))-1 F I=0:0 S X=$N(^(X)) Q:X=-1  W X,!
	Q
NL	W !,"TEXT NAMES:",! S %T2="" F I=0:0 S %T2=$N(@(DW_")")) Q:%T2=-1  W %T2,?20,^(%T2,0),!
	K %T2 Q
	;
F	;
	W !!,"Line WIDTH: "_DWLW_"//" R X:DTIME S DWLW=$S(X<10:DWLW,X>255:DWLW,1:X\1)
	W !,"PACK "_$S(DWPK:"ON",1:"OFF")_"//" R X:DTIME S DWPK=$S(X="ON":1,1:0)
	Q
X	D ASK^DIWE11 S DIWL=X,(%,%B)="" X ^%ZOSF("EOFF")
ENT	I '$D(DIWL) S DIWL=245
A	R X#245:30 E  I '$L(X) D S:$L(%B) G XQ^DIWE11
	S:X="" X=" " I X?.ANP S Y=X G D
	S I=0,Y=""
C	S I=I+1 I $E(X,I,999)?.ANP S Y=Y_$E(X,I,999) G D
	S %=$E(X,I),%0=$A(%)
	I %?1C S %="" I %0=9 S %=$E("         ",1,9-($L(Y)-($L(Y)\9*9)))
	S Y=Y_% D S:$L(Y)>DIWL I ":27:13:"[(":"_%0_":") D S
	G C
D	D S G D:$L(Y)'<DIWL S %B=Y,Y="" G A
S	S:$L(%B) %B=%B_$S($E(Y)=" ":"",1:" ") S %=%B_Y,%2=$L(%) Q:'%2  S Y=""
	I %2>DIWL F %1=DIWL:-1 I %1<$S(DIWL-12>0:DIWL-12,1:4)!(" -"[$E(%,%1)) S Y=$E(%,%1+1+$S($E(%,%1+1)=" ":1,1:0),999),%=$E(%,1,%1-$S($E(%,%1)=" ":1,1:0)) Q
	S %B="",DWLC=DWLC+1,@(DIC_"DWLC,0)")=%
	Q
TQ	;
	W !?4,"IF YOU WANT TO USE TEXT FROM THE '"_J_"' FIELD",!?4,"OF ANOTHER '"
	W I,"' ENTRY, TYPE THE NAME OF THAT ENTRY",!?4,"OTHERWISE, "
	W "USE A COMPUTED-FIELD EXPRESSION TO DESIGNATE SOME W-P TEXT",!
	G Z^DIWE3
	;
H	;
	S DIR(0)="E",I(0,0)=$S($D(D0):D0,1:""),%=$F(X(9.2),"D O"),D0=+Y,DTOUT=0
	S %="N X "_$E(X(9.2),1,%-4) X %_"W !,$J(D,3),"">"",X I D#15=0 D ^DIR Q:X=U!$D(DTOUT)"
	S D0=I(0,0) K %,DIR,DIRUT,DUOUT
	Q
	;
IQ	;
	I $D(DC) W:$D(^DD(+$P(DC,U,2),.01,3)) !?4,^(3),! X:$D(^(4)) ^(4) F %=0:0 S %=$O(^DD(+$P(DC,U,2),.01,21,%)) Q:%'>0  W !,^(%,0)
	W !!,"You are ready to enter a line of text.",!,"If you have no text to enter,just ",$S(DIWPT="":"press the return key.",1:"type in """_DIWPT_"""."),!
	W "Type 'CONTROL-I' (or TAB key) to insert tabs.",!
	W "When text is output, these formatting rules will apply:"
	W !," A)  Lines containing only punctuation characters, or lines containing tabs",!?5,"will stand by themselves, i.e., no wrap-around."
	W !," B)  Lines beginning with spaces will start on a new line."
	W !," C)  Expressions between '|' characters will be evaluated as"
	W !?5,"'computed-field expressions and then be printed as evaluated"
	W !?5,"thus '|NAME|' would cause the current name to be inserted in the text."
	W !!,*7,"Want to see a list of allowable formatting 'WINDOWS'" S %=2 D YN^DICN Q:%-1
	W !?5,"SPECIAL FORMATTING INCLUDES: "
FN	F %=15:0 S %=$N(^DD("FUNC",%)) Q:%>97  I $D(^(%,10)) W !," |"_$P(^(0),U,1)_$P("(ARGUMENT)",U,$S('$D(^(3)):1,1:^(3)'=0))_"|",?25 W:$D(^(9)) ^(9)

DIWF
DIWF	; SF/GFT - FORMS PRINT ;2/6/89  16:29
	;;17.7;VA FileMan; 6/9/89
	D DT^DICRW,DICS,L S DIC("S")=DIC("S")_" I  "_L
	S DIC="^DIC(",DIC(0)="AEQMZ",DIC("A")="Select Document File: "
	D ^DIC K DIC Q:Y<0
FINDWORD	X L I '$T S Y=-1 G Q
	S DJ=%,DIC=DIWF,D=$N(^DD(DIWFN,"SB",%,0)) Q:'$D(^DD(DIWFN,D,0))  S D=$P($P(^(0),U,4),";") S:+D'=D D=""""_D_"""" S DIWF=DIWF_"DIWFN,"_D_","
	F D=0:0 S D=$N(^DD(DIWFN,D)) Q:D'>0  I $D(^(D,0)),$P(^(0),U,3)="DIC(" S DIWF(0)=D Q
DOC	S DIC(0)="AEQM" D ^DIC G Q:Y<0
	I $D(DIWF(0)) S D=$P(^DD(DIWFN,DIWF(0),0),U,4),%=$P(D,";",1) I @("$D("_DIC_+Y_",%))") S D=$P(D,";",2),X=$S(D:$P(^(%),U,D),1:$E(^(%),+$E(D,2,9),+$P(D,",",2))) S:X DIWF(1)=X
	S DIWFN=+Y I @("$N("_DIWF_"0))'>0") W *7,!?7,"'"_$P(Y,U,2),"' HAS NO '"_$P(^DD(DJ,.01,0),U,1)_"' TEXT!",! G DOC
EN2	;
	I $O(@(DIWF_"0)"))'>0 S Y=-1 G Q
	S DIC(0)="AIQEMZ",DIC="^DIC(",DIC("A")="Print from what FILE: "
	I $D(DIWF(1)) S DIC(0)="ZIF",X=DIWF(1)
	D DICS:'$D(DIWF(1)),^DIC K DIC G Q:Y<0,Q:'$D(^DIC(+Y,0,"GL")) S DIC=^("GL")
	S %=1 I $D(BY)[0 W !,"WANT EACH ENTRY ON A SEPARATE PAGE" D YN^DICN G Q:%<1
	S L=0,DHD="@",FLDS="",DHIT="X "_$P("^UTILITY($J,1):$Y,",9,%)_"DIWFX D ^DIWW",DIWFX="S DIWF=""?W"",DIWL=1,DIWR=IOM F D=0:0 S D=$N("_DIWF_"D)) Q:D'>0  I $D(^(D,0)) S X=^(0) D ^DIWP" K DIWF D EN1^DIP
Q	K L,DIWF,DIWFN,DIWFX Q
	;
EN1	;
	I DIC Q:'$D(^DIC(+DIC,0))  S Y=DIC D L G FINDWORD
	I @("$D("_DIC_"0))") S DIC=+$P(^(0),U,2) G EN1
	Q
	;
DICS	I DUZ(0)="@" S DIC("S")="I 1" Q
	I $D(^DIC(3,"AFOF")) S DIC("S")="I $D(^DIC(3,DUZ,""FOF"",+Y,0)),$P(^(0),U,5)" Q
	S DIC("S")="I 1 X:$D(^(0,""RD"")) ""F %=1:1:$L(^(""""RD"""")) I DUZ(0)[$E(^(""""RD""""),%) Q"""
	Q
	;
L	S L="I $D(^DIC(+Y,0,""GL"")) S DIWF=^(""GL"") I $D(@(DIWF_""0)"")) S DIWFN=+$P(^(0),U,2) I $D(^DD(DIWFN,""SB"")) F %=0:0 S %=$N(^DD(DIWFN,""SB"",%)) Q:%<0  I $P(^DD(%,.01,0),U,2)[""W"" Q"

DIWP
DIWP	; SF/GFT - ASSEMBLE WP LINE ;05:24 PM  May 11, 1988
	;;17.7;VA FileMan; 6/9/89
	S DIWTC=X[($C(124)_"TAB") S:'$D(DN) DN=1
LN	S:'$D(DIWF) DIWF="" S:'DIWTC DIWTC=DIWF["N" S DIWX=X,DIW=$C(124),I=$P(DIWF,"C",2) I I S DIWR=DIWL+I-1
	I '$D(^UTILITY($J,"W",DIWL)) S ^(DIWL)=1 K DIWFU,DIWFWU,DIWLL D DIWI S:'$D(DIWT) DIWT="5,10,15,20,25" G DIW
	S I=^(DIWL),DIWI=^(DIWL,I,0) I DIWI="" D DIWI G Z
	D NEW:DIWTC
Z	S Z=X?.P!DIWTC I X?1" ".E!Z S DIWTC=1 D NEW:DIWI]"" S DIWTC=Z
DIW	;
	S X=$P(DIWX,DIW,1) D C:X]"" S X=$P(DIWX,DIW,1),DIWX=$P(DIWX,DIW,2,999) G D:DIWX="" I $D(DIWP),X'?.E1" " D ST
	S X=$P(DIWX,DIW,1) I $P(X,"TAB",1)="" D TAB G N
	I X="TOP" D PUT S ^("X")="X:$D(^UTILITY($J,1)) ^(1)" D NEW G N
	I DIWF'[DIW G U:X="_" D PUT,RCR^DIWW G N:$D(X)
	S X=DIW_$P(DIWX,DIW,1)_DIW D C
N	K X S DIWX=$P(DIWX,DIW,2,99) I DIWX]"" D ST:$D(DIWP) G DIW
D	K DIWP D PUT,PRE:DIWTC Q
	;
ST	S DIWI=$E(DIWI,1,$L(DIWI)-1) K DIWP Q
	;
DIWI	S DIWI=$J("",+$P(DIWF,"I",2)) I DIWF["L",$D(D)#2 S DIWLL=D
	Q
PUT	S I=^UTILITY($J,"W",DIWL),^(DIWL,I,0)=DIWI I DIWF["L",$D(DIWLL) S ^("L")=DIWLL
	Q
L	;
	S DIWTC=1 G LN
	;
TAB	I X="" S X=DIW G C
	S J=$P(DIWT,",",DIWTC),DIWTC=DIWTC+1 I X?3A1P.P1N.E S J=+$E(X,5,9)
	I J'>0 S %=$P(DIWX,DIW,2) Q:%=""  S J=$S(J<0:1-$L(%)-J,J="C":DIWR-DIWL-$L(%)\2,1:0)
	S J=J-1-$L(DIWI) Q:J<1  S X=$J("",J)
C	K DIWP I DIWTC S DIWI=DIWI_X Q
B	S Z=DIWR-DIWL+1-$L(DIWI) G FULL:$F(X," ")-1>Z F %=Z:-1 I " "[$E(X,%) S:$E(X,%+1)=" " %=%+1 Q
	S Z=$E(X,1,%-1),X=$E(X,%+1,999) I Z]"" S DIWI=DIWI_Z G S:X]"" S %=$E(Z,$L(Z)) S:%'=" " DIWI=DIWI_$J("",%="."+1),DIWP=1 Q
FULL	I $P(DIWF,"I",2)'<$L(DIWI) S DIWI=DIWI_$P(X," ",1),X=$P(X," ",2,999)
S	D PUT,NEW G B:X]"" Q
	;
U	S I=^UTILITY($J,"W",DIWL) I $D(DIWFU) S ^(DIWL,I,"U",$L(DIWI)+1)="" K DIWFU G N
	S ^(DIWL,I,"U",$L(DIWI)+1)=X,DIWFU=1 G N
	;
NEW	D DIWI
PRE	S I=^UTILITY($J,"W",DIWL),^(DIWL)=I+1,^(DIWL,I+1,0)="" I DIWF["D" S ^(0)=" ",^UTILITY($J,"W",DIWL)=I+2,^(DIWL,I+2,0)=""
	I $D(DIWFU) S ^("U",1+$P(DIWF,"I",2))="_"
	G P:DIWF'["R"!DIWTC K % Q:'$D(^UTILITY($J,"W",DIWL,I,0))
	S Y=^(0),%=$L(Y) F %=%:-1 Q:$A(Y,%)-32
	S Y=$E(Y,1,%),J=DIWR-DIWL-%+1,%X=0 G P:J<1
	F %=1:1 S %(%)=$P(Y," ",1),Y=$P(Y," ",2,999) G:Y="" PAD:%-1,P I $E(%(%),$L(%(%)))?.P S:%=1&(%(%)="") %=0,%X=%X+1 S:%&J J=J-1,%(%)=%(%)_" "
PAD	I J F Y=%\2+1:1:%-1,%\2:-1 S %(Y)=%(Y)_" ",J=J-1 G PAD:Y=1!'J
	S Y=%(%) F %=%-1:-1:1 S Y=%(%)_" "_Y
	S ^(0)=$J("",%X)_Y K %
P	I DIWF["W" G NX^DIWW

DIWW
DIWW	; SF/GFT - OUTPUT WP LINE ;10:02 AM  Oct 24, 1988;
	;;17.7;VA FileMan; 6/9/89
	F I=0:1 G:$D(DN) Q:'DN Q:'$D(^UTILITY($J,"W"))  D T,0
T	W:$X !
B	I '$D(DIWF) S DIWF=""
	I '$D(DIOT(2)),$D(IOSL),$Y+$S($P(DIWF,"B",2):$P(DIWF,"B",2),1:2)'<IOSL,$D(^UTILITY($J,1))#2,^(1)?1U1P1E.E X ^(1) I $D(DN),'DN S D0="zzzzzz",W=9999999 Q
	F I=$Y+2:1:+$P(DIWF,"T",2) W !
	Q
	;
A	;
	D 0 G DIWW
	;
NX	;
	W:$X+1>DIWL ! D B G:$D(DN) Q:'DN
0	;
	S I=999999 F %=0:0 S %=$N(^UTILITY($J,"W",%)) Q:%'>0  S:$N(^(%,-1))<I I=$N(^(-1))
1	F %=0:0 S %=$N(^UTILITY($J,"W",%)) G Q:%'>0 I $D(^(%,I)) D W I $D(^UTILITY($J,"W",%))<9 K ^(%) I $N(^(-1))=-1 K DIWI,DIWX,DIWTC
	;
W	G X:^(I,0)="",O:'$D(DIWF) I DIWF[" " S DIWF=$P(DIWF," ",1)_$P(DIWF," ",2) G X:^(0)?." "
	W:$X+1>% ! I DIWF["L",$D(^("L")) W $E(^("L")_"   ",1,4)
O	W ?%-1,^(0)
X	D U:$D(^("U")) I $D(^("X")) S Y=^("X") D K X Y Q
K	K ^UTILITY($J,"W",%,I) Q
	;
U	Q:'$D(IOST)  Q:IOST'?1"P".E  W $C(13) F DE=1:1:$S($D(^("L")):%+3,1:%-1) W " "
	S DE=1
UU	S %Y=$N(^UTILITY($J,"W",%,I,"U",-1)) I %Y<0 S %Y=$L(^UTILITY($J,"W",%,I,0))+1 S:'$D(DIWFWU) DIWFWU=" " D UUU K DIWFWU Q
	S Y=^(%Y) K ^(%Y) I Y="" D UUU K DIWFWU G UU
	S DIWFWU=Y F DE=DE:1 G UU:DE'<%Y W " "
UUU	I $D(DIWFWU) F DE=DE:1 Q:DE'<%Y  W DIWFWU
Q	Q
	;
RCR	;
	F DQI=1:1 I '$D(DIWF(DQI)) S DIWF(DQI)="" Q
	F M="DIWX","DICMX","DIC","D","D0","D1","D2","D3","D4","D5","D6","D7","Y" I $D(@M)#2 S DIWF(DQI,M)=@M
	S DQI="Y(",DA="X(",DICMX="X DICMX",DICOMP="T" D EN1^DICOMP
	I '$D(X) G RESTORE:DIWF'["?"!(IO(0)=IO)!$D(IO("C")) S IOP=IO(0) D ^%ZIS G RESTORE:POP U IO(0) W *7,!,$P(@(I(0)_"D0,0)"),U,1),"---",!?4,$P(DIWX,DIW,1)_": " R X:DTIME,! U IO G BACK
	I Y["m" S DICMX=$S(Y["w":"D ^DIWP",1:"S DIWX=X,DIWTC=1 D DIW^DIWP S DIWI=$J("""","_$L(DIWI)_")") X X S X="" G BACK
	I Y["X" S X=DIW_X_DIW G BACK
	I $P(DIWX,"SETPAGE(",1)="" S ^(DIWL,^UTILITY($J,"W",DIWL),"X")=X,X="" G BACK
	S DICMX=Y["D" X X I DICMX S Y=X X ^DD("DD") S X=Y
	I $P(DIWX,"INDENT(",1)="" S X=$J(X,$P(DIWF,"I",2)-$L(DIWI)-1)
BACK	D C^DIWP:X]"" S X="" K DICMX
RESTORE	F DQI=1:1 I '$D(DIWF(DQI)) S DQI=DQI-1,M="" Q
R	S M=$O(DIWF(DQI,M)) I M]"" S @M=DIWF(DQI,M) G R
	K DIWF(DQI) Q
	;
DIQ	;
	S DIWF=$E("N",C["L")_"W|",DIWL=2,DIWR=IOM,X=O_":   " K ^UTILITY($J,"W")
	X "F W=0:0 D ^DIWP S W=$N("_D(DL-1)_"W)) Q:W'>0  S X=^(W,0)"
	G DIWW
	;
H	G H^DIO2
DT	G DT^DIO2
	;
N	W ! G B

