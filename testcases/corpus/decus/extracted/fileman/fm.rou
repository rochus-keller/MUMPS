DIC1
DIC1	; SF/GFT - READ X, SHOW CHOICES ;5/26/89  09:19 ;
	;;17.7;VA FileMan; 6/9/89
	K DUOUT I $D(DIC("A")) S DD=DIC("A") G B
	D DO S Y=$P(DO,U) I D="B",DO(2)>1.9 S X=$P(^DD(+DO(2),.01,0),U) I X'[Y,Y'[X S Y=Y_" "_X
	S DD="Select "_Y_": "
B	I $D(DIC("B")),DIC("B")]"" S Y=DIC("B"),X=$N(@(DIC_"D,Y)")),DIY=$S($D(^(Y)):Y,$F(X,Y)-1=$L(Y):X,$D(@(DIC_"Y,0)")):$P(^(0),U),1:Y) W DD D WR R "// ",X:$S($D(DTIME):DTIME,1:999) G DO:X]"",T:'$T S X=DIY S:DIC(0)'["O" DIC(0)=DIC(0)_"O" G DO
	W DD R X:$S($D(DTIME):DTIME,1:999) E  G T:X=""
DO	; GET FILE ATTR
	Q:$D(DO)  I $D(@(DIC_"0)")) S DO=^(0)
	E  S DO="0^-1" I $D(DIC("P")) S DO=U_DIC("P"),^(0)=DO
DO2	S DO(2)=$P(DO,U,2) I DO?1"^".E S DO=$N(^DD(+DO(2),0,"NM",0))_DO
	I DO(2)["s",$D(^DD(+DO(2),0,"SCR")) S DO("SCR")=^("SCR")
	Q:DO(2)'["I"!$D(DIC("W"))  Q:'$D(^DD(+DO(2),0,"ID"))  S %=0,DIC("W")="" I DO(2)["P" D WOV S %=+DO(2),%Y=DIC G P
W	;
	S %=$N(^DD(+DO(2),0,"ID",%)) I %+1 G WOV:$L(DIC("W"))+$L(^(%))>244 S:^(%)'="W """"" DIC("W")=DIC("W")_" W ""   "" "_^(%) G W
	S DIC("W")=$E(DIC("W"),2,999) Q
P	I %,$D(^DD(%,.01,0)) S %=+$P($P(^(0),U,2),"P",2) I $D(^DIC(%,0,"GL")) S %W=^("GL") D Q:%W]"" G P
	Q
Q	S %W1=%W
	I %W[$C(34) S %W1=$P(%W,$C(34))_$C(34,34)_$P(%W,$C(34),2)_$C(34,34)_$P(%W,$C(34),3,9)
	I $L(DIC("W"))<200 S DIC("W")=DIC("W")_" I '$D(DICR) S %Y=+"_%Y_"%Y,0) I $D("_%W_"%Y,0)) S %W="_%_",%Z="""_%W1_""" D WOV^DICQ1",%Y=%W
	K %W1 Q
WOV	S DIC("W")="S %W=+DO(2),%Y=Y,%Z=DIC D WOV^DICQ1" Q
	;
RENUM	;
	D DO I '$D(DF),X?.NP,^DD(+DO(2),.01,0)["DINUM",$D(@(DIC_"X)")) S Y=X G 1^DIC
	G F^DIC
	;
WO	W "  " D WR I $D(DIC("W")),$D(@(DIC_"Y,0)")) W "  " X DIC("W")
	Q
	;
WR	D DO Q:DIC(0)["S"&(X'=" ")
	I DO(2)["V" S %X=Y,DIYS=DIY D NAME^DICM2 W DINAME S Y=%X,DIY=DIYS K DINAME,%X Q
	I DIY'?1.N.1".".N W DIY Q
	I DO(2)["D" W:$E(DIY,4,5) +$E(DIY,4,5),"-" W:$E(DIY,6,7) +$E(DIY,6,7),"-" W DIY\10000+1700 W:DIY["." "@"_$E(DIY_0,9,10)_":"_$E(DIY_"000",11,12)_":"_$E(DIY_"00000",13,14) Q
	I DO(2)["P",$D(@("^"_$P(^DD(+DO(2),.01,0),"^",3)_+DIY_",0)")) S %X=Y,Y=DIY,C=$P(^DD(+DO(2),.01,0),U,2) D Y^DIQ W Y S Y=%X Q
	W DIY Q
Y	;
	S DZ=Y,DD=$N(DS(DD)),Y=+DS(DD) 
	I DIC(0)["E" W !?5,DD,?9 S %=$P(X,U,'$D(DICRS))_$P(DS(DD),U,2,9) S DIY=$S(DO(2)["D"&(D="B"):%,1:"")_DIY(DD) W:DO(2)'["D"&'$D(DIDA) % D DT^DICQ1:D'="B"&$D(DIDA),WO
	S Y=DZ I DIC(0)["Y" G Y:DD<DS F Y=DS:-1 G Q^DIC:'Y S Y(+DS(Y))=""
	G N:DIC(0)'["E" I DS>DD G Y:DD#5 W !,"TYPE '^' TO STOP, OR"
	W !,"CHOOSE "_$N(DS(0))_"-"_DD R ": ",DIY:$S($D(DTIME):DTIME,1:999) E  D T G N
	I U[DIY S:DIY=U DUOUT=1 G:DD=DS L^DICM:DO(2)["O"&(DO(2)'["A"),A^DIC G Y^DIC:DIY="" S X=U G A^DIC
	I +DIY'=DIY S D=$S($D(DF):DF,1:"B"),X=DIY K DIY,DS G X^DIC
	G BAD:'$D(DS(DIY)) S Y=+DS(DIY),DIY(+X)="" K DIC("W"),DIVP1 G C^DIC
	;
T	W *7 S DTOUT=1 Q
	;
OK	;
	S %=1 I $D(DS),DS=1 W !?9,"...OK" D YN^DICN
	I %>0 G R^DIC:%=1 S X=DIX G L^DICM
O	;
BAD	W:DIC(0)["Q" *7," ??" I $D(Y),Y[U S Y=-1
	Q:$D(DTOUT)  G A^DIC
N	G NO^DIC
MIX	;
	S DID=D_"^-1",DID(1)=2,D=$P(DID,U) G IX^DIC

DICATT
DICATT	; SF/GFT,XAK - MODIFY FILE ATTR ;5/9/89  14:41 ;
	;;17.7;VA FileMan; 6/9/89
	S DLAYGO=1 D D^DICRW Q:Y<0  I '$D(DIC) D DIE^DIB Q:'$D(DG)  S DIC=DG
EN	;
	K I S Q="""",I(0)=DIC,B=+$P(@(DIC_"0)"),U,2),S=";"
B	;
	K DA,J S A=B,DICL=0,J(0)=B
N	;
	W !!! K DQ,DIC,DIE,DG,M G Q^DIB:$D(DTOUT)
	S O=1,E=0,DIC(0)="ALEQIZ",DIC="^DD("_A_"," S:$D(DICS) DIC("S")=DICS
	S DIC("W")="S %=$P(^(0),U,2) I % W $P(""  (multiple)^  (word-processing)"",U,$P(^DD(+%,.01,0),U,2)[""W""+1)"
	I $P(^DD(A,.01,0),U,2)["W" S DIC(0)="AEQZ",DIC("B")=.01
	E  I $D(DA),$D(^DD(A,DA,0)),'$P(^(0),U,2),$P(^(0),U,4)'?.P S E=DA
	D ^DIC I Y<0 G B:A-B,Q^DICATT2
	G SKP:DUZ(0)="@"
	I $D(^DIC(3,DUZ,"FOF",A,0)) S O=+$P(^(0),U,7) G SKP
	I $D(^DIC(A,0,"AUDIT")) S O=0 F I=1:1:$L(^("AUDIT")) I DUZ(0)[$E(^("AUDIT"),I) S O=1 Q
SKP	S DA=+Y,DA(1)=A,DIE=DIC,M=Y(0),T=$P(M,U,2) S:T["C" O=0
	S DR=$P(".01:.1;",U,DUZ(0)="@"!'$F(T,"X"))_$P("1.1;",U,O)_$S(DUZ(0)="@"&(T'["C"):"1.2;",1:"")_$S(T["C":"8;",1:"8:9;10:")_"11;20:29"
	S O=$S($P(Y,U,3):0,1:1_U_$P(M,U,2,99)),F=$P(M,U) K DIC,DQI
	F X=0:0 S X=$N(^DD(A,DA,1,X)) Q:X'>0  I +^(X,0)=B,$P(^(0),B,2)?1"^"1.A S DQI=$P(^(0),U,2)
	I 'T D ^DIE:O Q:$D(DTOUT)  G TYPE:$D(DA),N:$P(O,U,4)?.P,^DICATT4
	S DR=".01;8;9;10:11;20:29" D ^DIE I '$D(DA) S DQ(+T)=0 G NEW^DICATT4
	S X=$P($P(M,U,4),S,1),M=^DD(A,DA,0),E=$P(M,U,1),A=+T,DICL=DICL+1,J(DICL)=A,Y=$E(Q,+X'=X),I(DICL)=Y_X_Y I E'=F S ^(0)=E_" SUB-FIELD^"_$P(^DD(A,0),U,2,9) K ^(0,"NM") S ^("NM",E)=""
	G 5:$P(M,U,2)["W",N
	;
NO	;
	W !,*7,"  <DATA DEFINITION UNCHANGED>" I $P(Z,U)["K"&(DUZ(0)'="@") G N
TYPE	K Y,M,DE,DIE,DQ,DG G Q^DIB:$D(DTOUT) S N=0,DQI=DICL+9,Y=^DD(A,DA,0),F=$P(Y,U,1),Z="" W !!,"DATA TYPE OF ",F,": " I 'O R X:DTIME S:'$T DTOUT=1 G X:X[U!'$T S:DUZ(0)'="@" DIC("S")="I Y-9" S:DA=.001 DIC("S")="I Y<4!(Y=7)" G NEW
	F N=9:-1:5,1:1:4 Q:$P(Y,U,2)[$E("DNSFWCPVK",N)
	W $P(^DOPT("DICATT",N,0),U,1) G X^DICATT2:$P(Y,U,2)["K"&(DUZ(0)'="@")
	G X^DICATT2:$P(Y,U,2)["X",6:N=6 R "// ",X:DTIME S:'$T DTOUT=1 G N:X[U!'$T,0:X="" S DIC("S")="I Y-6,Y-9"_$P(",Y-5",U,N\2-2!(A=B)!(DA-.01)!$N(^DD(A,DA))>0)
NEW	I 'O,X=" ",E W " <",*7 D E W " DUPLICATED>" G E^DICATT1
	S DIC(0)="QEI",DIC="^DOPT(""DICATT""," D ^DIC I Y>0 S:N-Y&O M="",O=$P(O,U,1,2)_U_U_$P(O,U,4) S N=+Y G 0
