	I %["D RCR" S ^UTILITY($J,DIKR)=DIK0_" "_^UTILITY("DIK",$J,DH,DIKQ,DIKC,0) Q
	I %["S XMB=" S ^UTILITY($J,DIKR)=DIK0_",$D(DIK(0)),DIK(0)[""B"" S DIKZR="_DIKC_",DIKZZ="_DIKQ_" D BUL^"_DNM,DIKR=DIKR+1,^UTILITY($J,DIKR)=DIK0_",'$D(DIKOZ) "_% Q
	S ^UTILITY($J,DIKR)=DIK0_" "_$S(%["D AUDIT":"S DH="_DH_",DV="_DIKQ_",DU="_A_" ",1:"")_%_$S(%["D AUDIT":"^DIK1",1:"")
	Q

DIKZ1
DIKZ1	; SF/XAK - XREF COMPILER ; 10/12/88  18:19 ;
	;;17.7;VA FileMan; 6/9/89
NEWR	;
	K ^UTILITY($J) S DRN=""
	S ^UTILITY($J,0,1)=DNM_" ; DRIVER FOR COMPILED XREFS FOR FILE #"_DH(1)_" ; "_$E(DT,4,5)_"/"_$E(DT,6,7)_"/"_$E(DT,2,3),^(2)=" ; "
	S ^UTILITY($J,0,4)=" L @(DIK_DA_"")"") D DI L  G Q"
	S ^(5)="DI S DIKM1=0,DIKUM=0,DA(0)="""" F DV=0:0 S DV=$N(DA(DV)) Q:DV'>0  S DIKUM=DIKUM+1,DIKUP(DV)=DA(DV)"
	S ^(6)=" S DH(1)="_DH(1)_",DIKUP=DA"
	S ^(7)=" I $D(DIKKS) D:DIKZ1=DH(1) "_$P(DIKGO,",")_" S DA=DIKUP D:DIKZ1=DH(1) "_$P(DIKGO,",",2)_" D:DIKZ1'=DH(1) KILL D:DIKZ1'=DH(1) DA D:DIKZ1'=DH(1) SET D DA Q"
	S ^(8)=" I $D(DIKIL) D:DIKZ1=DH(1) "_$P(DIKGO,",")_" S:DIKZ1=DH(1) DIKM1=1 D:DIKZ1'=DH(1) KILL S DA=DIKUP D:DIKM1>0 KIL1 D DA Q"
	S ^(9)=" I $D(DIKST) D:DIKZ1=DH(1) "_$P(DIKGO,",",2)_" D:DIKZ1'=DH(1) SET D DA Q"
	S ^(10)=" I $D(DIKSAT) D SET1 D DA Q"
	S ^(11)=" Q"
	S ^(12)="DA K DA F DV=1:1 Q:'$D(DIKUP(DV))  S DA(DV)=DIKUP(DV)"
	S ^(13)=" S DA=DIKUP Q"
	S ^(14)="SET1 S (DA,DCNT)=0"
	S ^(15)=" S DU=$E(DIK,1,$L(DIK)-1) L @($S(DIK["","":DU_"")"",1:DU))"
	S ^(16)="C I @(""$N(""_DIK_""DA))'>0"") S ^(0)=$P(^(0),U,1,2)_U_DA_U_DCNT K DCNT L  Q"
	S ^(17)=" S (DIKY,DA)=$N(^(DA)),DU=1,DCNT=DCNT+1 D:DIKZ1=DH(1) "_$P(DIKGO,",",2)_" D:DIKZ1'=DH(1) SET D:DIKZ1'=DH(1) DA K DB(0) S DA=DIKY G C"
	S ^(18)=" Q"
	S ^(19)="KILL S DIKILL=1,DIKZK=2",DIKR=19,X=2 D SUB
	S DIKR=DIKR+1,^(DIKR)=" Q"
	S DIKR=DIKR+1,^(DIKR)="SET S DISET=1,DIKZK=1",X=1 D SUB
	F DIK8=1:1 S DIKRT=$T(TEXT+DIK8) Q:DIKRT=""  S ^(DIKR+DIK8)=$E(DIKRT,4,999)
	S DRN="" G SAVE^DIKZ
	;
SUB	F DIK8=0:0 S DIK8=$O(DIK(X,DIK8)) Q:DIK8'>0  S DIKR=DIKR+1,^(DIKR)=" I DIKZ1="_DIK8_","_$P(DIK2(DIK8),",",4)_" S "_$P(DIK2(DIK8),",",3)_" D "_DIK(X,DIK8)_" Q"
	Q
TEXT	;;
	;; Q
	;;KIL1 K @(DIK_"DA)") Q:'$D(^(0))
	;; S Y=^(0),DH=$S($N(^(0))'>0:0,1:$P(Y,U,4)-1),X=$P($P(Y,U,3),U,DH>0) D 3:X=DA
	;; S ^(0)=$P(Y,U,1,2)_U_X_U_DH
