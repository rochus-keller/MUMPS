STU1    ;31-Dec-81 ;UTILITY ;STARTUP ;SETS UP MEMORY CONFIGURATION ;JBH
        Q
START   S $ZE="",GVEC2MM=64,DDPVECMM=128
        B 0 S ^SYS(0,"RUNNING")=ID,^%Q(0,"RUNNING")=ID S ST=$V(44) V ST+34::$V(ST+34)#256
        D WAIT^SYSWAIT I %FAIL U 0 W !,"Important system processes running, unable to startup.",! Q
WRTWT   H 1 I $V(ST+364)+$V(ST+84)+$V(ST+380)'=0 H 0 G WRTWT
        W !,"Re-configuring memory...",!
        S LST="CONFIG;TTY;MAGTAPE;SPOOL;SDP;DMC;JOBCOM;DDP;USRDRV",SUM=0
        F I=1:1:$L(LST,";") S $P(LST,";",I)=^SYS(ID,"OPTIONS",$P(LST,";",I))
        C 1,2,3,47,59,60,61,62,63
        V $V(ST+8)+46::255*256
        S CLKCSR=65382 V CLKCSR::0
        V ST+130::$V(ST+130)-8192+63\64+$V(ST+28)
        S SYSEND=$V(ST+130),DDBBEG=$V(ST+128),MAP=ST+130
        F I=1:1:$L(LST,";") D  S MAP=MAP+2
        .S BYTES=$V(MAP+2)-$V(MAP)*64
        .I $P(LST,";",I)="N" S SUM=SUM+BYTES V MAP::0 Q
        .I SUM V 0:SYSEND:0:$V(MAP):BYTES V MAP::$V(MAP)-(SUM\64)
        .S SYSEND=BYTES\64+SYSEND
        I ^SYS(ID,"OPTIONS","USRDRV")="Y" S SYSEND=^SYS(ID,"MEM.ALLOC","USRDRV")+63\64+SYSEND
        V MAP::SYSEND
DDBINI  O 1 U 1 V ST+20::$V(ST+68)*(^SYS(ID,"CONTROLLER","SINGLE")+2)+$V(ST+10)
        S MTOLD=$V(ST+22)
        V ST+22::$V(ST+68)*((^("DH11")*16)+(^("DHU11")*16)+(^("DHV11")*8)+(^("DZ11")*8)+(^("DZV11")*4))+$V(ST+20)
        V ST+358::$V(ST+298)*^SYS(ID,"MT")+$V(ST+22),ST+402::$V(ST+358)
        I ^SYS(ID,"OPTIONS","JOBCOM")="Y" V ST+402::^SYS(ID,"JOBCOM","CHANNELS")*$V(ST+300)+$V(ST+358),ST+262::256*$V(ST+263)+^("RBS
IZE")
        V ST+414::^SYS(ID,"MEM.ALLOC","JOURNAL BUFFERS"),ST+408::$V(ST+414)*$V(ST+302)+$V(ST+402)
        S END=^SYS(ID,"OPTIONS","SDP")="Y"*4*$V(ST+232)+$V(ST+408)
        S DDPLNS=0 I ^SYS(ID,"OPTIONS","DDP")="Y" S DDPLNS=^SYS(ID,"DDP","LINES"),END=$V(ST+384)*DDPLNS+END
SYSINI  S MAPSTR=END-8192+63\64+$V(ST+28)
        I MAPSTR<$V(ST+132) S MAPSTR=$V(ST+132)
        S SYSEND=SYSEND-$V(ST+132)+MAPSTR
DMAINI  S DDPBF=^SYS(ID,"MEM.ALLOC","DDP BUFFERS"),DDPBAS=^("DDP BASE TABLES")
        V ST+16::SYSEND
        V ST+400::^SYS(ID,"MEM.ALLOC","RING BUFFERS","DEFAULT SIZE"),ST+18::^("POOL")+63\64
        V ST+446::$V(ST+16)+$V(ST+18)
        V ST+396::DDPBAS+63\64+(DDPBF+63\64)+$V(ST+446)
        S CACHE=36*^SYS(ID,"DMC","LINES")+$V(ST+396)
        S GBFNUM=^SYS(ID,"MEM.ALLOC","DISK-TAPE BUFFER POOL")\1024
        S UCIS=^("UCITAB")\1024
BBINI   S BBSIZ=^("BBTAB")+63\64
        S GBFBLK=16*GBFNUM+CACHE
        S BDBTAB=GBFNUM+1*4+63\64
        S MAP=ST+502 F I=0:1:3 S MAP=MAP+2 V MAP::BDBTAB*I+GBFBLK
        S BBTAB=$V(MAP)+BDBTAB
        V 0:BBTAB:0:$V(ST+86):192
        V ST+86::BBTAB
        S UCIMM=BBTAB+BBSIZ,OLDUCI=$V($V(ST+12)+2)
        F I=0:2:18 V I:UCIMM:$V(I,OLDUCI)
        F I=0:1:UCIS-1 V $V(ST+34)#256*I+$V(ST+12)+2::I*16+UCIMM
        V $V(ST+12)+4::UCIS*16+UCIMM
        V ST+356::UCIS*16+UCIMM
        F I=0:2:62 V I:$V(ST+356):65535
        V ST+62::$V(ST+16),0:$V(ST+62):$V(ST+18),2:$V(ST+62):0
BDBINI  V ST+32::GBFNUM,ST+398::CACHE S N=GBFNUM-1\64,HASH=1 F I=1:1 Q:'N  S HASH=HASH*2,N=N\2
        S BDBHD=$V(ST+14) V BDBHD::65536-(2*HASH)+1 F I=1:1:HASH V 2*I+BDBHD::0
        F I=0:2:GBFNUM+1*4-2 V I:$V(ST+504):0
        V 0:$V(ST+506):0:$V(ST+504):GBFNUM+1*4
        V 0:$V(ST+508):0:$V(ST+506):GBFNUM+1*4
        V 0:$V(ST+510):0:$V(ST+508):GBFNUM+1*4
        S BDB=0 F I=1:1:GBFNUM S BDB=BDB+4,PTR=I-1#HASH+1*2+BDBHD V BDB:$V(ST+508):$V(PTR),PTR::BDB
        S VWMAX=GBFNUM S:GBFBLK>3968 VWMAX=3968-CACHE\16
        I GBFNUM-VWMAX<(HASH*2) S VWMAX=GBFNUM-(HASH*2)
        V ST+352::VWMAX
MMSPC   S UCISPC=^SYS(ID,"MEM.ALLOC","UCITAB")\64
        V ST+394::^("SATMAP")
        V ST+64::^("SATMAP")+63\64+UCIMM+UCISPC
        V ST+66::^("LOCK TABLE SIZE")
        F I=0:2:$V(ST+66)-2 V I:$V(ST+64):0
        V ST+444::^("LOCK TABLE SIZE")+63\64+$V(ST+64)
        V ST+448::^("RV TABLE")+63\64+$V(ST+444)
        V ST+450::DDPBF\512+63\64+$V(ST+448)
        V ST+38::DDPLNS'=0*DDPVECMM+$V(ST+450),ST+216::^("ROUTINE MAP")+63\64
        I '$V(ST+144) F I=ST+444:2:ST+450 V I::0
        E  V 0:$V(ST+444):0
        E  F I=0:1:DDPVECMM-1 V 0:$V(ST+450)+I:0,32:$V(ST+450)+I:0
        V ST+468::$V(ST+38)+$V(ST+216)
        F I=0:1:GVEC2MM-1 V 0:$V(ST+468)+I:0,32:$V(ST+468)+I:0
        V ST+260::^("TRANSLATION TABLE")
        I $V(ST+260)=0 V ST+276::0
        E  V ST+276::$V(ST+468)+GVEC2MM F I=0:2:256 V I:$V(ST+276):0
        S PARNXT=$V(ST+468)+GVEC2MM+($V(ST+260)+63\64)+15\16*16,PARTAB=$V(ST+6)
        I '^("ROUTINE MAP") V ST+38::0
        E  V 0:$V(ST+38):0,4:$V(ST+38):8+$V(ST+38)
        S BASKIOD=$V(ST+132) V 0:MAPSTR:0:BASKIOD:$V(ST+148)-BASKIOD*64
        F MAP=ST+132:2:ST+148 V:$V(MAP) MAP::MAPSTR-BASKIOD+$V(MAP)
        V 148::$V(ST+22) F I=1:1:^SYS(ID,"MT") S MTNEW=$V(ST+22)+(I-1*$V(ST+298)) F J=0:2:$V(ST+298)-2 V MTNEW+J::$V(MTOLD+J)
        I ^SYS(ID,"OPTIONS","JRNL")="Y" V PARTAB-4::PARNXT S PARNXT=PARNXT+16
        S PAR1=PARNXT+(^SYS(ID,"PARTITION","1")\1024-1),PARNUM=1,JT=$V(ST+4),PAVL=-$V(ST+416),PREV=PAVL,SIZE1=^(PARNUM),MM=PARNXT
PAR     S PARNXT=PARNXT+(^(PARNUM)\64),PARNUM=PARNUM+1 I $D(^(PARNUM))#2'=1 G POOL
        S PAROFF=PARNUM>63*-128+PARNUM*2
        V PARTAB+PAROFF::PARNXT+(^(PARNUM)\1024-1),JT+PREV::PAVL*256+PAROFF+(PAROFF<0*256) S PREV=PAROFF G PAR
POOL    V PARTAB-2::PARNXT S PARNXT=PARNXT+16
        V PARTAB::$V(PARTAB+1)*256+(^("DEFAULT")\1024),JT::(PARNUM-1)*256+PARNUM-2 I PREV'=PAVL V JT+PAVL::256*PREV+4,PREV+JT::PAVL*
256
        S POOL=^("POOL")\1024*1024 I POOL=0 G SIZE
        V ST+374::PARNXT,ST+376::PARNXT,ST+378::POOL\64
        S PARNXT=PARNXT+(POOL\64)
SIZE    I PARNXT>(^SYS(ID,"MEMORY SIZE","K BYTES")*16) O 1 U 1 W !,"Memory size exceeded by ",PARNXT-(^("K BYTES")*16)*64," bytes.",
!,"Please re-boot and run SYSGEN in baseline mode." B 1 F I=0:0 H 1
        S UCI=1,DEV=1,RTN="START^STU2" D START^STUSETPV V 2:MM:5
        V CLKCSR::64,PARTAB+2::PAR1 H 0
