SD	F DH=DH(1):0 S DH=$O(DU(DH)) Q:DH'>0  S:$D(^DD(DH,"SB")) DK1(DH)="" D DD1^DIK,0 S:$D(^DD(DH,"IX")) DIK(X,DH)="A1^"_DNM_DRN K:'$D(^("IX")) DIK(X,DH) K DU(DH)
	Q
0	;
	D SV^DIKZ S DIK1=""
