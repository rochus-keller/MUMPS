DIT	; SF/GFT - GET XFR ANSWERS ;2/6/89  11:43 ;
	;;17.7;VA FileMan; 6/9/89
0	S DIC="^DOPT(""DIT""," G OPT:$D(^DOPT("DIT",2)) S ^(0)="TRANSFER OPTION^1.01" K ^("B")
	F X=1,2 S ^DOPT("DIT",X,0)=$P("TRANSFER^COMPARE/MERGE",U,X)_" FILE ENTRIES"
