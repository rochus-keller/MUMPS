MINIMUM	S %X="'<"
MM	D L S W=W_"&("_DICN_%X_"Y!'$L("_DICN_")) "_DICN_"=Y" Q
TOTAL	S W="S "_DICN_"="_DICN_"+"_W Q
COUNT	S W=$S($P(Y(0),U,2)["W":"S ",1:"S:"_W_"'?."""" """" ")_DICN_"="_DICN_"+1" Q
LAST	D L S W=W_" "_DICN_"=Y" Q
