SAVE	I $D(DIKLW),'DIKR S ^UTILITY($J,0,997)=" G:'$D(DIKLM) "_$C(64+DIKCT)_$S(DNM_DRN'=DNM(1):"^"_DNM(1),1:"")_" Q:$D("_DIKVR_")"
	I $D(DIKLW),DIKR S ^UTILITY($J,0,998)=" G ^"_DNM_(DRN+1)
	S ^UTILITY($J,0,999)="END "_$S($D(DIKRT):"Q",1:"G "_$S(DIKR:"END",1:"")_U_DNM_(DRN+1))
