	D ST,STP:'$T S:%IS["U" USIO=IOM_"^"_IOF_"^"_IOSL_"^"_IOBS
	G TRY:$P(^%ZIS(1,%E,0),"^",9)="" S %A=$P(^(0),"^",9) I %IS'["Q" G N:$D(IOP) W *7,"  DEVICE IS ON ANOTHER CPU ('",%A,"')",! G I
	S IO("Q")=1,%B=0
