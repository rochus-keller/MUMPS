PUT	I '$D(DIK6(%)) S ^UTILITY($J,DIKR)=" S DIKZ("_%_")=$S($D("_DIK_"DA,"_%_"))#2:^("_%_"),1:"""")",DIK6(%)=""
	S DIKR=DIKR+1,(DIK6,^UTILITY($J,DIKR))=" "_$P(^UTILITY("DIK",$J,DH,DIKQ,0),"^(X)")_"DIKZ("_%_")"_$P(^(0),"^(X)",2,9)
	F DIKC=0:0 S DIKC=$O(^UTILITY("DIK",$J,DH,DIKQ,DIKC)) Q:DIKC'>0  S %=^(DIKC) S:$O(^(0))'=DIKC DIKR=DIKR+1,^UTILITY($J,DIKR)=DIK6 D CRF
	S DIKR=DIKR+1 Q
