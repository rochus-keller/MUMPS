1	S DK(0)=DK,Z="D0," F DQ=0:1:DL K R,M S X=0,DQ(0)=DQ,R=-1 D MAKE F %=0:0 S R=$N(R(R)) Q:R<0  I R(R)<2 S DIS(R)=DIS(R)_" K D"
