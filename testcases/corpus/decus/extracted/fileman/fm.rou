	S W="(#"_DF_") "_$P(N,U,1)_" ["_DP
	S:X["K" X="M" F Y="F","S","D","N","P","W","V","M" I X[Y S W=W_Y
	S W=W_"] ^ " D WL Q:M=U  G B
	;
PUSH	S N=$N(^DD(F(Z),"GL",DN(Z),DP,0)),Y=^DD(F(Z),N,0),DID(Z)=DID(Z)_","
	W !,DID(Z)_"0)=^"_$P(Y,U,2)_"^^  (#",N,") "_$P(Y,U,1) S Z=Z+1,F(Z)=+$P(Y,U,2)
	D L G A
