	;;^DD(3.5,2008,21,1,0)
	;;=This is the name of the last user who signed on to this device. It
	;;^DD(3.5,2008,21,2,0)
	;;=is controlled internally by the KERNEL.
	;;^DD(3.5,2008,"DT")
	;;=2831208
	;;^DD(3.5,2009,0)
	;;=PROHIBITED TIMES FOR SIGN-ON^FX^^TIME;1^K:$E(X,1,2)>23!($E(X,3,4)>59)!'(X?4N1"-"4N)!($E(X,6,7)>23)!($E(X,8,9)>59) X
	;;^DD(3.5,2009,3)
	;;=RANGE OF MILITARY TIMES (HHMM-HHMM) DURING WHICH SIGN-ONS WON'T BE ALLOWED
	;;^DD(3.5,2009,4)
	;;=W !?7,"FOR EXAMPLE, TO SHUT OFF DEVICE OVERNIGHT, TYPE '1630-0800'"
	;;^DD(3.5,2009,21,0)
	;;=^^6^6^2851010^^^^
	;;^DD(3.5,2009,21,1,0)
	;;=This field allows a device to be locked out for certain periods of the
	;;^DD(3.5,2009,21,2,0)
	;;=day. The time period for which logons will be prohibited is specified
	;;^DD(3.5,2009,21,3,0)
	;;=in the form HHMM-HHMM. For example, 1630-0800 would lock out the device
	;;^DD(3.5,2009,21,4,0)
	;;=from 4:30 PM to 8:00 AM.
	;;^DD(3.5,2009,21,5,0)
	;;= 
	;;^DD(3.5,2009,21,6,0)
	;;=If device checking is bypassed for this device, these times are ignored.
	;;^DD(3.5,2009,"DT")
	;;=2831203
	;;^DD(3.5,2010,0)
	;;=OPEN TIMEOUT^NJ2,0^^TIME;2^K:+X'=X!(X>10)!(X<0)!(X?.E1"."1N.N) X

FMINI030
FMINI030	;
	;;Version 
	F I=1:2 S X=$T(Q+I) Q:X=""  S Y=$E($T(Q+I+1),4,999),X=$E(X,4,999) S:$A(Y)=126 I=I+1,Y=$E(Y,2,999)_$E($T(Q+I+1),5,99) S:$A(Y)=61 Y=$E(Y,2,999) X NO E  S @X=Y
Q	Q
	;;^DD(3.5,2010,3)
	;;=Type a Number between 0 and 10, 0 Decimal Digits
	;;^DD(3.5,2010,21,0)
	;;=^^4^4^2890124^^
	;;^DD(3.5,2010,21,1,0)
	;;=If a specific timeout is needed when an open is performed,
	;;^DD(3.5,2010,21,2,0)
	;;=enter the value of the timeout into this field.  This will enable %ZIS
	;;^DD(3.5,2010,21,3,0)
	;;=to "hang" for the number of seconds specified in this field to achieve
	;;^DD(3.5,2010,21,4,0)
	;;=a connection rather than using the default of zero.
	;;^DD(3.5,2010,"DT")
	;;=2880505
	;;^DD(3.501,0)
	;;=MNEMONIC SUB-FIELD^NL^.01^1
	;;^DD(3.501,0,"NM","MNEMONIC")
	;;=
	;;^DD(3.501,0,"UP")
	;;=3.5
	;;^DD(3.501,.01,0)
	;;=MNEMONIC^MFX^^0;1^K:X[""""!(X'?.ANP)!(X<0) X I $D(X) K:$L(X)>35!($L(X)<1)!($D(^%ZIS(1,"C",$E(X,1,30)))) X
	;;^DD(3.501,.01,1,0)
	;;=^.1
	;;^DD(3.501,.01,1,1,0)
	;;=3.5^B^MNEMONIC
	;;^DD(3.501,.01,1,1,1)
	;;=S ^%ZIS(1,"B",$E(X,1,30),DA(1),DA)=1
	;;^DD(3.501,.01,1,1,2)
	;;=K ^%ZIS(1,"B",$E(X,1,30),DA(1),DA)
	;;^DD(3.501,.01,3)
	;;=ANSWER MUST BE 1-35 CHARACTERS IN LENGTH and not equal to a $I.
	;;^DD(3.501,.01,21,0)
	;;=^^2^2^2851010^
	;;^DD(3.501,.01,21,1,0)
	;;=This is an alternate name which may be used to select the
	;;^DD(3.501,.01,21,2,0)
	;;=device.
	;;^DD(3.501,.01,"DT")
	;;=2890602

FMINIT
FMINIT	;;MAY 31,1990
	;
	K DIF,DIK,DDF,DDT,DTO,D0,DLAYGO,DIC,DIDUZ,DIR,DA,DIFROM,DFR,DTN,DIX,DZ
	S DIFQ=0,DIFROM=0 W !,"This version of 'FMINIT' was created on MAY 31,1990"
	W !?9,"(at PRx VAX Development, by VA FileMan V.17.7)",!
	I $D(^DD("VERSION")),^("VERSION")'<17 G GO:$N(^("VERSION",17))<0 W !,"BUT I'M OBSOLETE!!" G Q
	W !,"FIRST, I'LL FRESHEN UP YOUR VA FILEMAN...." D N^DINIT
	I ^DD("VERSION")<17 W !,"BUT I NEED VERSION 17 OF THE VA FILEMAN!" G Q
GO	;
EN	; ENTER HERE TO BYPASS THE PRE-INIT PROGRAM
	S DIFQ=0 W !,"I AM GOING TO SET UP THE FOLLOWING FILES:",! F I=1:1:4 D 1 Q:DIFQ
	G Q:DIFQ D ^FMINIT1 G Q:'$D(DIFQ) S DIK(0)="B"
	F DIF=1:1:4 S %=$T(IXF+DIF),DIK=$P(%,";",6),N=$P(%,";",3),D=$P(%,";",4)_U_N D D
	D ^FMINIT2,^FMINIT3
	L  S DUZ=DIDUZ W !,*7,"OK, I'M DONE.",!,"NO"_$P("TE THAT FILE",U,DSEC)_" SECURITY-CODE PROTECTION HAS BEEN MADE"
	S:$D(DIFROM(0))&($D(DIFQ)) ^DIC(9.4,DIFROM(0),"VERSION")=DIFROM G Q^DIFROM0
D	S:$D(^DIC(+N,0))[0 ^(0)=D S X=$D(@(DIK_"0)")),^(0)=D_U_$S(X#2:$P(^(0),U,3,9),1:U)
	I '$D(DIFQ(+N)),$P(%,";",5)!'X D IXALL^DIK:$N(^(0))>0 W "."
	I ^DD("VERSION")>17.5,$D(^DD(+N,0,"DIK"))#2 S X=^("DIK"),Y=+N,DMAX=^DD("ROU") D EN^DIKZ
	Q
	;
1	S X=$T(IXF+I),N=+$P(X,";",3),N(N)=$P(X,";",4),D=$P(X,";",5),S=$P(X,";",6),U="^" W !?3,N,?13,N(N),$P("  (PARTIAL DEFINITION)",U,$P(X,";",7)),$P("  (INCLUDING DATA)",I,D) S Z=$S($D(^DIC(N,0))#2:^(0),1:"")
	I $L($P(Z,N(N),1)) W *7,!,"*BUT YOU'VE ALREADY GOT '",$P(Z,"^",1),"' AS FILE #",N,"!*" G REP
	S %=$P(S,"(",1),DW=0 S:$D(@%)#2 DW=@% S @%=DW
	I $L(Z) W *7,!,"NOTE -- YOU ALREADY HAVE '",$P(Z,"^",1),"' FILE" S DIFQ(0)=1
SKP	I D,$N(@(S_"0)"))>0 W " WITH DATA",!?9,"WANT MY DATA ADDED IN TO YOURS" S %=1 D YN^DICN S:%=2 DIFQ(N)=1 D OV:D-1&(%=1) I '% W !?3,"Answer YES to add incoming data if it does not match exactly",!?3,"on Name and Identifiers.",! G 1
MCK	I %<0 S DIFQ=1
	W ! Q
OV	W !?9,*7,"I WILL **REPLACE** YOUR DATA WITH MINE, OK" D YN^DICN S:%=1 DIFQR(N)=1 Q
Q	W *7,!!,"NO UPDATING HAS OCCURRED!" Q
REP	S %=2 W !,"I'm Changing the NAME of your File to the Name of My File  OK " D YN^DICN G:%<0 MCK S:%=1 DIE=1,DIFQ=0,DA=N,DR=".01///"_N(N) D:%=1 ^DIE G 1:%=1 I '% D REP^DIFROMH1 G REP
AG	S %=2 W !," OK! Then I am Replacing Your File with My File OK " D YN^DICN S:%=2 %=-1 G:%<0 MCK I '% D AG^DIFROMH1 G AG
CHG	S %=2,DIU(0)="E" W !,"Would you like to Keep the Data  " D YN^DICN G MCK:%<0 S:%=2 DIU(0)=DIU(0)_"D" I '% D CHG^DIFROMH1 G CHG
TEMP	S %=2 W !,"Would you like to keep the Templates " D YN^DICN G MCK:%<0 S:%=2 DIU(0)=DIU(0)_"T" I '% D TEMP^DIFROMH1 G TEMP
	S DIFKEP(N)=DIU(0) W !,?15," (",N(N),") " G SKP
	;
IXF	;;FM
	;;1.1I;AUDIT;0;^DIA(;0
	;;3I;USER;0;^DIC(3,;0
	;;3.2I;TERMINAL TYPE;1;^%ZIS(2,;0
	;;3.5Is;DEVICE;0;^%ZIS(1,;0

FMINIT1
FMINIT1	;
	;;Version 
	; LOADS AND INDEXES DD'S
	;
	K DIF,DIK,D,DDF,DDT,DTO,D0,DLAYGO,DIC,DIDUZ,DIR,DA,DFR,DTN,DIX,DZ D DT^DICRW S %=1,U="^",DSEC=1
1	I $D(DIFQ(0)) W !,"SHALL I WRITE OVER EXISTING DATA DEFINITIONS" S %=1 D YN^DICN S:%=2 DSEC=0
	I '% W !?3,"Answer YES to replace current field definitions with the ones in these",!?3,"programs, or NO to leave the current ones in place.  In either case",!?3,"new fields will be added." G 1
	S NO=$P("I 0^I $D(@X)#2,X[U",U,%) I %<1 K DIFQ Q
ASK	I %=1,$D(DIFQ(0)) W !,"SHALL I WRITE OVER FILE SECURITY CODES" S %=2 D YN^DICN S DSEC=%=1 I %<1 K DIFQ Q
	Q:'$D(DIFQ)  S %=0 W !!,"ARE YOU SURE EVERYTHING'S OK" D YN^DICN I %-1 K DIFQ Q
	I $D(DIFKEP) F DIDIU=0:0 S DIDIU=$N(DIFKEP(DIDIU)) Q:DIDIU'>0  S DIU=DIDIU,DIU(0)=DIFKEP(DIDIU) D EN^DIU2
	D DT^DICRW K ^UTILITY(U,$J),^UTILITY("DIK",$J) D WAIT^DICD F R=1001:1:1030 D @("^FMINI"_$E(R,2,4)) W "."
	F D=1.1,3,3.01,3.02,3.03,3.04,3.19,3.196,3.2,3.5,3.501 D IX
DATA	W "." S (D,DDF(1),DDT(0))=$N(^UTILITY(U,$J,0)) Q:D'>0
	I '$D(DIFQ(D)) S DTO=0,DMRG=1,DTO(0)=^(D),Z=^(D)_"0)",D0=^(D,0),@Z=D0,DFR(1)="^UTILITY(U,$J,DDF(1),D0,",DKP='$D(DIFQR(D)) F D0=0:0 S D0=$N(^UTILITY(U,$J,DDF(1),D0)) Q:'$D(^(D0,0))  S Z=^(0) D I^DITR
	K ^UTILITY(U,$J,DDF(1)),DDF,DDT,DTO,DFR,DFN,DTN G DATA
	;
W	S Y=$P($T(@X),";",2) W !,"NOTE: This package also contains "_Y_"S",! Q:'$D(DIFQ(0))
	S %=1 W ?6,"SHALL I WRITE OVER EXISTING "_Y_"S OF THE SAME NAME" D YN^DICN I '% W !?6,"Answer YES to replace the current "_Y_"S with the incoming ones." G W
	S:%=2 DIFQ(X)=0 K:%<0 DIFQ
	Q
	;
OPT	;OPTION
RTN	;ROUTINE DOCUMENTATION NOTE
FUN	;FUNCTION
BUL	;BULLETIN
KEY	;SECURITY KEY
HEL	;HELP FRAME
DIP	;PRINT TEMPLATE
DIE	;INPUT TEMPLATE
DIB	;SORT TEMPLATE
	;
IX	W "." S DIK="A" F %=0:0 S DIK=$N(^DD(D,DIK)) Q:DIK<0  K ^(DIK)
	S DA(1)=D,DIK="^DD("_D_"," D IXALL^DIK
	I $D(^DIC(D,"%",0)) S DIK="^DIC(D,""%""," G IXALL^DIK
	Q

FMINIT2
FMINIT2	;
	;;Version 
	;
	;
	K ^UTILITY("DIFROM",$J),DIC S DIDUZ=0 S:$D(DUZ)#2 DIDUZ=DUZ S DUZ=.5
	I $D(^DIC(9.2,0))#2,^(0)?1"HEL".E S (DIC,DLAYGO)=9.2,N="HEL",DIC(0)="LX" G ADD
	Q
	;
ADD	F R=0:0 S R=$N(^UTILITY(U,$J,N,R)) Q:R<0  S X=$P(^(R,0),U,1) W "." D ^DIC I Y>0,'$D(DIFQ(N))!$P(Y,U,3) S ^UTILITY("DIFROM",$J,N,X)=+Y K ^DIC(9.2,+Y,1),^(2),^(3) S %X="^UTILITY(U,$J,N,R,",%Y=DIC_"+Y,",DA=+Y D %XY^%RCR
	S DIK=DIC
HELP	S R=$N(^UTILITY("DIFROM",$J,N,R)) Q:R<0  W !,"'"_R_"' Help Frame filed." S DA=^(R) G IX:$N(^DIC(9.2,DA,2,0))'>0
	F X=0:0 S X=$N(^DIC(9.2,DA,2,X)) Q:X'>0  S I=$S($D(^(X,0)):^(0),1:0),Y=$P(I,U,2) S:Y]"" Y=$N(^DIC(9.2,"B",Y,0)) S ^(0)=$P(^DIC(9.2,DA,2,X,0),U,1)_U_$S(Y>0:Y,1:"")_U_$P(^(0),U,3,99)
IX	D IX1^DIK G HELP

FMINIT3
FMINIT3	;
	;;Version 
	;
	;
	K ^UTILITY("DIFROM",$J) S DIC(0)="LX",(DIC,DLAYGO)=3.6,N="BUL" D ADD:$D(^XMB(3.6,0))
	S X=0 F R=0:0 S X=$N(^UTILITY("DIFROM",$J,N,X)) Q:X<0  W !,"'",X,"' BULLETIN FILED -- Remember to add its user groups."
	I $D(^DIC(9.4,0))#2,^(0)?1"PACK".E S N="PKG",(DIC,DLAYGO)=9.4 D ADD
	G NP:'$D(DA) S:$D(^DIC(9.4,DA,22,DIFROM,0)) $P(^(0),U,3)=DT
	I $D(^DIC(9.4,DA,0))#2 S %=$P(^(0),U,4) I %]"" S %=$N(^DIC(9.2,"B",%,0)) S:%]"" $P(^DIC(9.4,DA,0),U,4)=%
	G NP:'$D(^ORD(100.99))!'$O(^UTILITY(U,$J,"OR",""))
	S %X="^UTILITY(U,$J,""OR"","_$O(^(""))_",",DIK="^ORD(100.99,1,5,",%Y=DIK_DA_","
	S:'$D(^ORD(100.99,1,5,0)) ^(0)="^100.995P^^"
	D %XY^%RCR S $P(^ORD(100.99,1,5,DA,0),U)=DA,%=$P(^(0),U,4)
	I %]"" S %=$N(^ORD(100.98,"B",%,0)) I %>0 S $P(^ORD(100.99,1,5,DA,0),U,4)=%
	S DA(1)=1 D IX1^DIK
NP	K ^UTILITY("DIFROM",$J) I $D(^DIC(19,0))#2,^(0)?1"OPTION".E S (DIC,DLAYGO)=19,N="OPT" D ADD,OP
	I $D(^DIC(19.1,0))#2,^(0)?1"SECUR".E S (DIC,DLAYGO)=19.1,N="KEY" D ADD K ^UTILITY("DIFROM",$J)
	I $D(^DIC(9.8,0))#2,^(0)?1"ROUTINE^".E S (DIC,DLAYGO)=9.8,N="RTN" D ADD
	S DIC=.5,DLAYGO=0,N="FUN" D ADD
	S DIC("S")="I $P(^(0),U,4)=I" F N="DIPT","DIBT","DIE" S DIC=U_N_"(" D ADD
	K ^UTILITY(U,$J),DIC,DLAYGO F DIR="DIE","DIPT" D DIEZ
	Q
DIEZ	I ^DD("VERSION")>17.4,'$D(DISYS) D OS^DII
	E  S DISYS=^DD("OS")
	Q:'$D(^DD("OS",DISYS,"ZS"))
	S N=$N(^UTILITY("DIFROM",$J,DIR,0)) Q:N<0  S Y=+^(N) K ^(N)
	I $D(@("^"_DIR_"(Y,""ROU"")")) K ^("ROU") I $D(^("ROUOLD")) S X=^("ROUOLD"),DMAX=^DD("ROU") D:X]"" @("EN^DI"_$E(DIR,3)_"Z")
	G DIEZ
	;
OP	S R=$N(^UTILITY("DIFROM",$J,N,R)) I R<0 K ^UTILITY("DIFROM",$J) G Q
	W !,"'"_R_"' Menu Option Filed" S DA=+^UTILITY("DIFROM",$J,N,R) G:$P(^(R),U,2,3)="XUCORE^"!($P(^(R),U,2,3)="XUCOMMAND^") OP
	S %=$P(^DIC(19,DA,0),U,12) S:%]"" %=$O(^DIC(9.4,"B",%,0))
	S $P(^DIC(19,DA,0),U,12)=%,%=$P(^(0),U,7),(DZ,DIX)=0
	S:%]"" %=$O(^DIC(9.2,"B",%,0)) S $P(^DIC(19,DA,0),U,7)=%,%=$P(^(0),U,4),%="MOQ"[% K ^(10,"B"),^("C")
	F X=0:0 S X=$N(^DIC(19,DA,10,X)) Q:X'>0  S I=$S($D(^(X,0)):^(0),1:0),Y=$S($D(^(U)):^(U),1:"") K ^DIC(19,DA,10,X) I Y]"",% S D=$N(^DIC(19,"B",Y,0)) I D>0 S ^DIC(19,DA,10,X,0)=D_U_$P(I,U,2,9),DZ=DZ+1,DIX=X
	S:% ^DIC(19,DA,10,0)="^19.01PI^"_DZ_U_DIX D IX1^DIK G OP
	;
ADD	F R=0:0 S R=$N(^UTILITY(U,$J,N,R)) Q:R<0  S X=$P(^(R,0),U),I=$P(^(0),U,4) W "." D ^DIC I Y>0,'$D(DIFQ(N))!$P(Y,U,3) S Y=Y_U D A
Q	Q
A	K:N'="KEY"&(N'="OPT") @(DIC_"+Y)") S ^UTILITY("DIFROM",$J,N,X)=Y S:N="PKG" DIFROM(0)=+Y Q:$P(Y,U,2,3)="XUCORE^"!($P(Y,U,2,3)="XUCOMMAND^")
	I N="OPT" S:$P(^DIC(19,+Y,0),U,6)]"" DIOPT=$P(^(0),U,6) I $N(^UTILITY(U,$J,N,R,1,0))>0 K ^DIC(19,+Y,1)
	S %X="^UTILITY(U,$J,N,R,",%Y=DIC_"+Y,",DA=+Y,DIK=DIC D %XY^%RCR,IX1^DIK:N'="OPT" I N="OPT",$D(DIOPT) S $P(^DIC(19,DA,0),U,6)=DIOPT K DIOPT


