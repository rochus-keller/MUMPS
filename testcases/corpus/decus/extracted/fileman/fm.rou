	;
S	;SETS
	S DICR(DICR,1)=1,Y=$P(DS,U,3),DD=$P(";"_Y,";"_X_":",2) I DD]"" W:DIC(0)["E" "  (",$P(DD,";",1),")" Q
SS	S DD=$P(Y,";",1),Y=$P(Y,";",2,99) I DD]"" G SS:DD'[(":"_X) W:DIC(0)["E" $P(DD,X,2,9) S X=$P(DD,":",1) Q
	K X S Y=-1 Q
	;
V	;VARIABLE POINTER
	I X["?BAD" K X Q
	D ^DICM2,DO^DIC1
	Q
	;
LC	;
	Q:DIC(0)["X"  S DIC(0)=$P(DIC(0),"L",1)_$P(DIC(0),"L",2)
	F %=1:1 S Y=$E(X,%) I Y?.L Q:Y=""  S X=$E(X,1,%-1)_$C($A(Y)-32)_$E(X,%+1,999)
	G DIC^DICM
	;
SOU	;
	S DSOU="01230129022455012623019202",DSOV=X,X=$C($A(X)-(X?1L.E*32)),DIX=$E(DSOU,$A(X)-64) F DIY=2:1 S Y=$E(DSOV,DIY) Q:","[Y  I Y?1A S %=$E(DSOU,$A(Y)-$S(Y?1U:64,1:96)) I %-DIX,%-9 S DIX=% I % S X=X_% Q:$L(X)=4
	S X=$E(X_"000",1,4) K DSOU,DSOV Q
	;
ACT	;
	S DIY=Y,DIY(1)=DIC,DIC("W")="",DIX=X
A	X:$D(^DD(+DO(2),0,"ACT")) ^("ACT") I Y<0 S DIC=DIY(1),X=DIX K DIC("W"),DO Q
	I DO(2)["P" S DIC=U_$P(^DD(+DO(2),.01,0),U,3) K DO D DO^DIC1 I $D(@(DIC_+$P(Y,U,2)_",0)")) S Y=+$P(Y,U,2)_U_$P(^(0),U) G A
	S Y=DIY,DIC=DIY(1),X=DIX K DIC("W"),DO D DO^DIC1 Q

DICM2
DICM2	; SF/XAK - LOOKUP FOR VAR PTR ; 6/22/88  11:03 ;
	;;17.7;VA FileMan; 6/9/89
	;
	S DIVDO=+DO(2),DIVDS=DS,DIVDIC=DIC,DIVY=%Y N DIADD
	F %="DR","S","A","V" I $D(DIC(%)) S DIV(%)=DIC(%)
	K DIC("W"),DIC("S"),DIC("DR"),DO,DUOUT S DIEX=X G ALL:X'["."
	I $P(X,".",2)="" S Y=-1 G Q
V	S DIVP=$P(DIEX,"."),X=$P(DIEX,".",2)
	I DIVP]"",$D(^DD(DIVDO,DIVY,"V","P",DIVP)) S (DIVP,DIVPDIC)=+$O(^(DIVP,0)),DIVPDIC=$S($D(^DD(DIVDO,DIVY,"V",DIVP,0)):^(0),1:"") G Q:'DIVPDIC D ^DICM3 G Q
	S X="",DIVP=$P(DIEX,".",1)
	F %=0:0 S X=$O(^DD(DIVDO,DIVY,"V","M",X)) Q:X=""  I $P(X,DIVP)="" S (DIVP,DIVPDIC)=+$O(^(X,0)),DIVPDIC=$S($D(^DD(DIVDO,DIVY,"V",DIVP,0)):^(0),1:""),X=$P(DIEX,".",2) G Q:'DIVPDIC D ^DICM3 G Q:Y>0 S X=DIEX
	F DIVP=0:0 S DIVP=$N(^DD(DIVDO,DIVY,"V",DIVP)) Q:DIVP'>0  I $D(^(DIVP,0)) S DIVPDIC=^(0) I $D(^DIC(+DIVPDIC,0)) S %=$P(^(0),U) I $P(%,$P(DIEX,"."))="" S X=$P(DIEX,".",2) D ^DICM3 G Q:Y>0 S X=DIEX
	K X G Q
ALL	F DIVP1=0:0 S DIVP1=$N(^DD(DIVDO,DIVY,"V","O",DIVP1)) Q:DIVP1'>0  S DIVP=$N(^(DIVP1,0)) I $D(^DD(DIVDO,DIVY,"V",DIVP,0)) S DIVPDIC=^(0) D ^DICM3 G Q:Y>0!(%<0)!$D(DUOUT) S X=DIEX
	G Q:DICR>1!$D(DICR(DICR,"V")) S DICR(DICR,"V")=1 K DIVP G ALL
	;
	;
Q	I '$D(DUOUT),Y<0,DICR<2,'$D(DICR(DICR,"V")) S DICR(DICR,"V")=1 K DIVP G V
	K:Y<0 X S DS=DIVDS,DICR(DICR,"V")=1
	F %="DR","S","A","V" I $D(DIV(%)) S DIC(%)=DIV(%)
QQ	K:Y DICR(DICR,6)
	K DUOUT,DIVP,DIVDIC,DIVY,DO,DIVDO,DIVDS,DIVPDIC,DIEX,DIVP1,DIV Q
	;
NAME	;DETERMINE EXTERNAL FORM FROM INTERNAL FOR VP
	S DINAME=DIY Q:'DIY  S %=$P(DIY,";",2),DINAME="^"_%_+DIY_",0)",DINAME=$S($D(@DINAME)#2:$P(^(0),U,1),1:DIY),%=$S($D(@("^"_%_"0)")):$P(^(0),U,2),1:"") Q:%=""
	I %["P"!(%["S")!(%["D") S C=$P(^DD(+%,.01,0),U,2),%YYY=DIY,%YY=Y,Y=DINAME D Y^DIQ S DINAME=Y,DIY=%YYY,Y=%YY,C="," K %YY,%YYY
	Q

DICM3
DICM3	; SF/XAK - PROCESS INDIVIDUAL FILE FOR VAR PTR ;4/26/89  14:21 ;
	;;17.7;VA FileMan; 6/9/89
DIC	;
	Q:$D(DIVP(+DIVPDIC))
	I $D(DIC("V")) S Y=DIVP,Y(0)=DIVPDIC X DIC("V") I '$T K Y S Y=-1 G DQ
	I '$D(^DIC(+DIVPDIC,0,"GL")) S Y=-1 G DQ
	S DIC=^("GL"),%="DIC"_DICR
	S:DIC(0)'["L"!'$D(DICR(DICR,"V")) DIC("S")="X ""I 0"" F "_%_"=0:0 S "_%_"=$N("_DIVDIC_""""_D_""""_",(+Y_"";"_$E(DIC,2,99)_"""),"_%_")) Q:"_%_"'>0  I $D("_DIVDIC_%_",0))"_$S($D(DIV("S")):" S %YV=Y,Y="_%_" X DIV(""S"") S Y=%YV I ",1:"")_" Q"
	S %=DIC(0),DIC(0)="DM"_$E("E",%["E")_$E("O",%["O") I $P(DIVPDIC,U,6)="y",$D(DICR(DICR,"V")),%["L" S DIC(0)=DIC(0)_"L"
	I $D(DICR(DICR,"V")),$P(DIVPDIC,U,5)="y",$D(^DD(DIVDO,DIVY,"V",DIVP,1)),^(1)]"" S %=$S($D(DIC("S")):DIC("S"),1:"") X ^(1) S DIC("S")=DIC("S")_" "_%
	I DIC(0)["E",$D(DIVP1),$D(DICR(DICR,"V")) W !!?5,"Searching for a "_$P(DIVPDIC,U,2)
	I X?."?" S DZ=X_$E("?",'$D(DICR(DICR,"V"))) D DQ^DICQ S X=$S($D(DZ):DZ,1:"?"),Y=-1 G DQ
	D DO^DIC1
	S D="B" D X^DIC G DQ:$D(DUOUT) S X=+Y_";"_$E(DIC,2,99),%=1 K:Y<0 X
	I '$D(DICR(DICR,"V")) K DICR("^",+DIVPDIC) S DIVP(+DIVPDIC)=0
	I Y>0,$D(DIVP1),DIC(0)["E",'$P(Y,U,3),$P(^DIC(+DIVPDIC,0),U,2)'["O" W !?9,"...OK" D YN^DICN S:%=2!(%<0) Y=-1
DQ	K DIC,DO S DIC=DIVDIC,D=$S($D(DICR(DICR,4)):DICR(DICR,4),1:"B"),DIC(0)=DICR(DICR,0) I $D(DIV("V")) S DIC("V")=DIV("V")
	Q

DICN
DICN	; SF/GFT,XAK - ADD A NEW ENTRY ;5/26/89  16:32
	;;17.7;VA FileMan; 6/9/89
	D:'$D(DO) DO^DIC1 S DO(1)=1
	I $S($D(DLAYGO):DO(2)\1-(DLAYGO\1),1:1),DUZ(0)'="@" G:+DO(2) B1:$D(^DIC(3,"AFOF")) I $D(^DIC(+DO(2),0,"LAYGO")) F %=1:1 I DUZ(0)[$E(^("LAYGO"),%) G B:%>$L(^("LAYGO")) Q
USR	I $D(DD) S X=DD D N^DICN1 G I:$D(X),B
	D DS S DIX=X I X?.NP,X,DIC(0)["E",'$D(DICR),DS'["DINUM",$P(DS,U,2)'["N",DIC(0)["N"!$D(^DD(+DO(2),.001,0)) D N^DICN1 I $D(X) S DD=X G I
	S X=DIX D VAL G I:$D(X)
	S X=DIX
B	G BAD^DIC1
B1	G USR:$D(^DD(+DO(2),0,"UP")),B:'$D(^DIC(3,DUZ,"FOF",+DO(2),0)),B:'$P(^(0),U,4),USR
	;
1	I '$D(DIC("S")) W " (THE ",Y,$S(Y#10=1&(Y#100-11):"ST",Y#10=2&(Y#100-12):"ND",Y#10=3&(Y#100-13):"RD",1:"TH"),$S('$D(^DD(+DO(2),0,"UP")):"",1:" FOR THIS "_$N(^DD(^("UP"),0,"NM",0))),")"
YN	;
	W "? ",$P("YES// ^NO// ",U,%)
RX	R %Y:$S($D(DTIME):DTIME,1:999) E  S DTOUT=1,%Y=U W *7
	S:%Y]""!'% %=$A(%Y),%=$S(%=89:1,%=121:1,%=78:2,%=110:2,%=94:-1,1:0)
	I '%,%Y'?."?" W *7,"??",!?4,"ANSWER 'YES' OR 'NO': " G RX
	W:$X>73 ! W $P("  (YES)^  (NO)",U,%) Q
	;
DS	S DS=^DD(+DO(2),.01,0) Q
	;
VAL	I X'?.ANP K X Q
	I X["""" K X Q
	I $P(DS,U,2)'["N",$A(X)=45 K X Q
	I $P(DS,U,2)["*" S:DS["DINUM" DINUM=X Q
	S %=$F(DS,"%DT=""E"),DS=$E(DS,1,%-2)_$E(DS,%,999) X $P(DS,U,5,99) Q
	;
I	I DIC(0)["E",DO(2)'["A",DIC(0)'["W" S C=$P(^DD(+DO(2),.01,0),U,2),(DIX,Y)=X D Y^DIQ W *7,!?3,"ARE YOU ADDING " W:'$D(DD) "'"_Y_"' AS " S %=$P(DO,U,1) W:$X+$L(%)>55 !?7 W "A NEW "_% S %=0,Y=$P(DO,U,4)+1,X=DIX D 1 G OUT:$D(DTOUT),B:%-1
	G FILE:'$D(DD)
R	D DS W !?3,$P(DS,U,1),": " R X:DTIME S:'$T X=U,DTOUT=1,Y=-1
	G B:X[U,R:X="" D VAL I '$D(X) W *7,"??" W:$D(^DD(+DO(2),.01,3)) !?5,^(3) G R
FILE	D:'$D(DO) DO^DIC1 I DO="0^-1" G OUT
	F DIX=0:0 S DIX=$O(^DD(+DO(2),.01,"LAYGO",DIX)) Q:DIX'>0  I $D(^(DIX,0)) X ^(0) I '$T G OUT
	S DIX=X
F1	S X=$P(DO,U,3) D INCR S X=X\DIY*DIY+DIY
	I $D(DINUM) S X=DINUM D INCR
F2	I $D(@(DIC_"X)")) S X=X\DIY*DIY+DIY G B:$D(DINUM),F2
	S Y=$P(DO,"^",2) I $D(DD) S X=DD
	E  I 'Y,DUZ(0)'="@" G LOCK
	I DIC(0)["E",'$D(DINUM),$D(^DD(+Y,.001,0)) G NUM^DICN1
LOCK	L @(DIC_"X):1") I $D(@(DIC_"X)"))!'$T L  G F1
	S ^(X,0)=DIX,DD=0 L  K D S:$D(DA)#2 D=DA S DA=X,X=DIX
	I $D(@(DIC_"0)")) S ^(0)=$P(^(0),"^",1,2)_"^"_DA_"^"_($P(^(0),"^",4)+1)
IX	S DS=X,DD=$N(^DD(+DO(2),.01,1,DD))
	I DD>0 G RIX^DICN1:^(DD,0)["TRIGGER"!(^(0)["BULL") X ^(1) S X=DS G IX
	I DIC(0)["E"&($N(^DD(+DO(2),0,"ID",0))>0)!$D(DIC("DR")) G ^DICN1
D	I $P(^DD(+DO(2),.01,0),U,2)["a",^("AUDIT")'="e" D A
	S Y=DA_"^"_X_"^"_1 S:$D(D)#2 DA=D G R^DIC
	;
INCR	S DIY=1 I $P(DO,U,2)>1 F %=1:1:$L($P(X,".",2)) S DIY=DIY/10
	Q
OUT	S Y=-1 G A^DIC:$D(DO(1))&'$D(DTOUT),Q^DIC
	;
A	N DP
	S DIIX="3^.01",DP=+DO(2) D AUDIT^DIET:DP>0 K DIANUM
	Q

DICN1
DICN1	; SF/GFT - PROCESS DIC("DR") ;5/8/89  07:55
	;;17.7;VA FileMan; 6/9/89
	K DICRS,Y,%RCR
	F Y="I","J","X","DO","DIADD","DC","DA","DE","DG","DIE","DR","DIC","D","D0","D1","D2","D3","D4","D5","D6","DI","DH","DIA","DICR","DK","DIK","DL","DLAYGO","DM","DP","DQ","DU","DW","DIEL","DOV","DIOV","DIEC","DB","DV","DIFLD" S %RCR(Y)=""
	S DZ="W !?3,$S("""_$P(DO,U)_"""'=$P(DQ(DQ),U):"""_$P(DO,U)_""",1:"""")_"" ""_$P(DQ(DQ),U)_"": """
	I $D(DIC("DR")) S DD=DIC("DR")
	E  S DD="",%=0 F Y=0:0 S Y=$N(^DD(+DO(2),0,"ID",Y)) Q:Y'>0  D CKID I '$D(%) W !,"SORRY!  A VALUE FOR '"_$P(^(0),U,1)_"' MUST BE ENTERED,",!?6,"BUT YOU DON'T HAVE 'WRITE ACCESS' FOR THIS FIELD" S %RCR="D^DICN1" D STORLIST^%RCR G BAD
	S %RCR="RCR^DICN1" D STORLIST^%RCR G D^DICN:$D(Y)<9
BAD	S:$D(D)#2 DA=D K Y I '$D(DO(1)) S Y=-1 G Q^DIC
	K DO G A^DIC
	;
CKID	I $D(DUZ(0)),DUZ(0)'="@",$D(^DD(+DO(2),Y,9)),^(9)]"" F %=1:1 I DUZ(0)[$E(^(9),%) Q:$L(^(9))'<%  K:$P(^(0),U,2)["R" % G Q
	S DD=DD_Y_";"
Q	Q
	;
RCR	;
	K DR,DQ,DG,DE,DO,DIADD S DIE=DIC,DR=DD,DIE("W")=DZ K DIC I $D(DIE("NO^")) S %RCR("DIE(""NO^"")")=DIE("NO^")
	S DIE("NO^")="OUTOK" D ^DIE K DIE("W"),DIE("NO^") I '$D(DA) S Y(0)=0 Q
	Q:$D(Y)<9
ZAP	S DIK=DIE W !?6,"<'",*7,$P(@(DIK_"DA,0)"),U,1),"' DELETED>" D ^DIK S Y(0)=0 Q
D	S DIE=DIC G ZAP
	;
RIX	;
	K %RCR F %="D0","Y","DIC","DIU","DIV","DO","D","DD","DICR","X" S %RCR(%)=""
	S %RCR="RR^DICN1",DZ=^(1) D STORLIST^%RCR G IX^DICN
	;
RR	X DZ Q
	;
NUM	;
	I '$D(DD),DIC="^DIC(",'$D(DO(3)) D DIC G F2^DICN
	S %=$P(^DD(+Y,.001,0),U,2),X=$S(%'["N"!(%["O"):0,1:X),%Y=X I X F %=1:1 D N Q:$D(X)  S X=0 Q:%>50  S X=%Y+DIY,%Y=X
	W !?3,$P(DO,U)_" "_$P(^DD(+Y,.001,0),U),": " W:X X,"// " R Y:$S($D(DTIME):DTIME,1:999) E  S DTOUT=1,Y=U W *7
	I Y="?" W:$D(^(3)) !?5,^(3) X:$D(^(4)) ^(4) G F1^DICN
	G BAD^DIC1:Y[U S:Y]"" X=Y D N I '$D(X) W *7,"??" W:$D(^DD(+DO(2),.001,3)) !?5,^(3) X:$D(^(4)) ^(4) G F1^DICN
	G LOCK^DICN
	;
N	X:$D(^DD(+$P(DO,U,2),.001,0)) $P(^(0),U,5,99) I $D(X),$L(X)<15,+X=X,X>0,X>1!(DIC'="^DIC(") Q
	K X Q
	;
DS	I '$D(DISMN) S DISMN=1000 D OS^DII:'$D(DISYS) S DISMN=$S(+$P(^DD("OS",DISYS,0),U,2):$P(^(0),U,2),1:DISMN)
	Q
DIC	;
	S DO(3)=1
	I $D(^DIC(3,DUZ,1))#2,$P(^(1),U) S DIY=.1,X=+$P(^(1),U) Q
	I $D(^DD("SITE",1)),X\1000'=^(1) S X=^(1)*1000,%=0
	Q

DICOMP
DICOMP	; SF/GFT - EVALUATE COMPUTED FLD EXPR ; 7/1/88  10:55 ;
	;;17.7;VA FileMan; 6/9/89
	S:$D(DICOMP)[0 DICOMP="" K K S K=0 F DLV=0:1 G A:'$D(J(DLV+1))
EN1	;
	F K=0:0 S DLV=K,K=$N(I(K)) G K:I'>0!'$D(J(K))!'$D(I(K\100*100))
EN	;
	S DLV=+DICOMP
K	K K S K=0 I DLV F I=0:100 Q:I>DLV  S K=K+1,K(K)="",K(K,1)=I
A	K DICO F I=DLV:0 S I=$N(J(I)),DICO(1)=DLV Q:I<0  K:DLV I(I),J(I)
	S DPUNC=",'+-():[]!&\/*_=<>",DLV0=DLV\100*100,I=X,DIM=9.1,DIMW="" K X,DG,DIC,DATE,DPS,M,Y,W
	S DIC(0)="ZFO",Q="""",(M,DPS,DBOOL)=0,DICO=I,DICO(1)=DLV,DICO(0)=DLV\100*100 F %=0:100 Q:'$D(J(%))  S DG(%)=%
	G 0:" "[I!(+I=I)!(I'?.ANP)!(I?."?")!($E(I,$L(I))=":") I DPUNC[$E(I,1),$A(I)-40,$A(I)-39 G 0
G	D I I X?.NP G:X="" N:I]"",^DICOMP1 I +X=X,X<1700!'$D(DATE(K-1))!'DBOOL G N:W'=":",N:$D(DPS(DPS,"$S"))
	G E:$L(X)>30,FUNC:W="(",N:X?1"$"1U
V	I $D(DICOMPX(X))#2 D DATE^DICOMP0:$D(DICOMPX(X,"DATE")) S T=X,X=DICOMPX(X) G N:'$D(DICOMPX(T,U)) S T=DICOMPX(T,U),DICN=$P(T,U,2),T=+T,Y(0)=^DD(T,DICN,0),D=$P(Y(0),U,2) D S^DICOMP0 G N
E	K Y D ^DICOMP0 G 0:+X'=X&'$D(Y)
N	;
	I X]"" S K=K+1,K(K)=X
	S I=$E(I,M,999),M=0 G G:$F(DPUNC,W)<2
	I W=":",'$D(DPS(DPS,"$S")) S I=$E(I,2,999) D I,M^DICOMPX,M^DICOMPW:$D(X) S W="" G N:$D(X),0
	S X=W,W="",M=2 G N:X=""
	G DPS:X=")",C:",:"[X,0:"+-'"[X&'$L($E(I,M,999)) I X="(" D ST G N
	S DBOOL="><]['=!&"[X,Y="[]!&/\_><*=" G N:Y'[X I $E(I,M,999)_W]"",$D(K(K)),")'"[K(K)!'$F(DPUNC,K(K)),$F(Y,W)<2 G N:K(K)'="'" S K(K)="'"_X,X="" G N:DBOOL
0	G 0^DICOMP1
	;
I	I $A(I,M+1)=34 S M=$F(I,Q,M+2)-1 G I:M>0 S W=0,M=999,X=U Q
MR	F M=M+1:1 S W=$E(I,M) Q:DPUNC[W
	S X=$E(I,1,M-1) Q
	;
C	I DICO["SETDATA(" D SD^DICOMPZ G Q^DICOMP1:'$D(X)
	S DICF=X D DG S K(K+1,2)=0
	I $N(DPS(DPS,"$"))["$" S DPS(DPS)=DPS(DPS)_Y_DICF G N
	G 0:'$D(W(DPS)) S (W,W(DPS))=W(DPS)-1 K:W<2 W(DPS) S DPS(DPS)=" S X"_W_"="_Y_DPS(DPS) G N
	;
DPS	I DPS D DPS^DICOMPW G N:'$D(W(DPS+1))
	G 0
	;
FUNC	S Y=$N(^DD("FUNC","B",X,0)) I '$D(^DD("FUNC",Y,0)),X'?1N.N2A,X'?1"$"1U G V
	S DICF=X D ST I $D(^(1)) D 1 G B
	I DICF'?1"$"1U.U D ^DICOMPX S W="" G DPS:DPS,0
	S DPS(DPS,DICF)=DPS(DPS),DPS(DPS)=" S X="_DICF_W
B	S M=M+1,W="" G 0:$E(I,M)=")",N
	;
2	;
	D ST
1	G ARG^DICOMPZ
	;
ST	;
	S DPS=DPS+1,%="",Y=K
S	I 'Y S X="",DPS(DPS)=$P(" S X="_%_"X",U,%]"") Q
	I K(Y)="" S Y=Y-1 G S
	I "'"[K(Y)!(K(Y)="+"),$S(Y=1:1,1:K(Y-1)?1P!(K(Y-1)="")) S %=K(Y)_%,K=K-1,Y=Y-1 G S
	D DG S DPS(DPS)="" I K(K)?1P!(K(K)?2P) S DPS(DPS)=" S Y="_%_"X,X="_Y_",X=X",DPS(DPS,U)=K(K)_"Y",K=K-1
	S:$D(DATE(K)) DPS(DPS,"DATE")=1 S:DBOOL DBOOL=0,DPS(DPS,"BOOL")=1
	S K(K+1,2)=0 Q
	;
DG	S (Y,DG(DLV0))=DG(DLV0)+1,Y=DQI_Y_")",X=" S "_Y_"=X"

DICOMP0
DICOMP0	; SF/GFT - EVALUATE COMPUTED FLD EXPR ; 8/15/88  08:50 ;
	;;17.7;VA FileMan; 6/9/89
	I DPS,$D(DPS(DPS,"SET")),'$D(W(DPS)) S T="""",D=$P(X,T,1)_$P(X,T,2) G BAD:$L(D)+2\5-1!(D'?.UN)!(D?1"D".E)!(DUZ(0)'="@") S X=T_D_T,DICOMPX(D)=D,Y=0 Q
	I X?1"""".E1"""" S Y=0,%=$E(X,2,$L(X)-1) K:%[""" X "!(%[""" D @") Y Q
L	S T=DLV,DICN=X G M:'$D(J(T))
TRY	S DIC="^DD("_J(T)_",",DG=$N(^DD(J(T),0,"NM",0))_" ",DIC("S")=$S(W="["!($E(I,M,M+1)="'[")!$D(DICMX):"I 1",1:"S %=$P(^(0),U,2) I '%,%'[""m""")_$P(",Y-DA",U,DICO(1)=T&DA) D DICS^DICOMPY:DUZ(0)'="@"
R	I X?1"#"1NP.NP S X=$E(X,2,99) D ^DIC G:Y>0 A:DLV,X S X="#"_X
