DPS	;
	S X=DPS(DPS),%=$N(DPS(DPS,"$")) S:M'>$L(I)!(DICO'?1"(".E) DBOOL=$D(DPS(DPS,"BOOL")) I %["$" S X=X_"X)"_DPS(DPS,%)
