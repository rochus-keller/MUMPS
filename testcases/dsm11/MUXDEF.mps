MUXDEF  Q  ;RLW,DMW; DEFINE VARS USED IN ^MUX (CALLED BY ^MUX)
DEFINE  S ^SYS(ID,"TTY",DEV,"PARITY")=PAR,^("ROUTINE")=RTN,^("CRT")=CRT,^("MODEM CONTROL")=DATA,^("OUTPUT ONLY")=OP,^("LOGIN")=LOGIN,^("STALL COUNT")=STALL,^("TAB CONTROL")=TAB,^("OUTPUT MARGIN")=MAR,^("LOWER CASE")=LOWER
        S ^("AUTOBAUD")=AUT,^("ZUSE")=ZUSE
        I CMNT="Y" S ^("COMMENT")=COM
        G:CNTLER["DH" @(CNTLER) I CNTLER'["DZ" Q
        S LPR=DEV#(8-(CNTLER["V"*4))+24 S:(PAR="EVEN")!(PAR="ODD") LPR=LPR+64-8 I PAR="ODD" S LPR=LPR+128
        S B=$P($T(B),";;",2) F I=1:1:16 Q:RCVR=$P(B,",",I)
        I I'=1 S LPR=LPR+(16+(I-1)*256)
        S ^SYS(ID,"TTY",DEV,"LPR")=LPR
        Q
DH11    S LPR=3 S:(PAR?1"E".E)!(PAR?1"O".E) LPR=18 I PAR="ODD" S LPR=34
        I XMIT<300 S LPR=LPR+4
        S C=$P($T(C),";;0,",2),R(0)=0,X(0)=0
        F I=1:1 Q:$P(C,",",I)=""  S R($P(C,",",I))=64*I,X($P(C,",",I))=1024*I
        G DHEND
DHV11   ;
DHU11   S LPR=24 S:(PAR?1"E".E)!(PAR?1"O".E) LPR=LPR+32 S:PAR="EVEN" LPR=LPR+64
        S C=$P($T(D),";;",2) F I=1:1 Q:$P(C,",",I)=""  S R($P(C,",",I))=256*I,X($P(C,",",I))=4096*I
DHEND   S LPR=LPR+R(RCVR)+X(XMIT) S ^SYS(ID,"TTY",DEV,"LPR")=LPR
        Q
DEF     S LPR=0,CNTLER=^SYS(ID,"TTY",DEV,"CONTROLLER")
        S PARDF=^("PARITY"),RTNDF=^("ROUTINE"),CRTDF=^("CRT"),DATADF=^("MODEM CONTROL"),OPDF=^("OUTPUT ONLY"),LOGDF=^("LOGIN")
        S STALDF=^("STALL COUNT"),TABDF=^("TAB CONTROL"),MARDF=^("OUTPUT MARGIN"),LOWDF=^("LOWER CASE"),AUTDF=^("AUTOBAUD"),ZUSEDF=^("ZUSE")
        S LP=(CNTLER="LP11")
        I CNTLER="DHV11"!(CNTLER="DHU11") S LPR=^("LPR"),D=$P($T(D),";;",2),RCVRDF=$P(D,",",LPR\256#16),XMITDF=$P(D,",",LPR\4096)
        I CNTLER="DH11" S LPR=^("LPR"),C=$P($T(C),";;",2),RCVRDF=$P(C,",",LPR\64#16+1),XMITDF=$P(C,",",LPR\1024#16+1)
        I CNTLER["DZ" S LPR=^("LPR"),B=$P($T(B),";;",2),RCVRDF=$P(B,",",LPR\256#16+1),XMITDF=RCVRDF
        W:DEV>63 ?7,$E(PARDF,1) W:'LP ?10,CRTDF W:DEV>63 ?13,AUTDF,?15,RCVRDF,?20,XMITDF W:'LP ?25,DATADF,?28,ZUSEDF,?32,OPDF,?36,LOGDF,?40,STALDF,?43,TABDF W ?46,LOWDF,?50,MARDF W:'LP ?56,RTNDF W ?62,"N",!
        W:RANGE="Y" RAN W:RANGE="N" DEV Q
B       ;;50,75,110,134.5,150,300,600,1200,1800,2000,2400,3600,4800,7200,9600
C       ;;0,50,75,110,134.5,150,200,300,600,1200,1800,2400,4800,9600
D       ;;75,110,134.5,150,300,600,1200,1800,2000,2400,4800,7200,9600,19200
