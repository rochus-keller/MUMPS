L	S L=L+1,^UTILITY($J,0,L)=X,T=T+$L(X) Q
	;
O	;
	S F=0,Q=^(2) D QFF S %=" S DQ("_DQ_",2)="_Q_"," Q
	;
PR	;
	F %=1,2,3 Q:$E(DPR,%)'="/"
	S X=$E(DPR,%,999),Q=X,F=0 D QFF I $A(X)-94 S X=" S Y="_Q
	E  S X=" "_$E(X,2,999) D L S X=" S Y=X"
	D L S X=" G Y" I %>1 S DPP=0,X=" S X=Y,DB(DQ)=1 G:X="""" N^DIE17:DV,A I $D(DE(DQ)),DV[""I""!(DV[""#"") D E^DIE0 G A:'$D(X)" D L S X=" G "_$P("Z:X,",U,%=3)_"RD"
	Q
QF	;
	S F=0,Q=DIE
QFF	;
	S F=$F(Q,"""",F) I F S Q=$E(Q,1,F-1)_$E(Q,F-1,999),F=F+1 G QFF
	S Q=""""_Q_""""

DIFROM
DIFROM	; SF/XAK - GENERATE INITS ;3/14/89  16:10 ;1/27/89  3:39 PM
	;;17.7;VA FileMan; 6/9/89
	I $S('$D(DUZ(0)):1,DUZ(0)'="@":1,1:0) W !,"PROGRAMMER ACCESS REQUIRED",! Q
	I '$D(^DIC(3,+DUZ,0)) W !,"YOU ARE NOT A KNOWN USER AND CANNOT SEND THESE ROUTINES DIRECTLY AS A MESSAGE."
R	D:'$D(DISYS) OS^DII
	R !!,"Enter the Name of the Package (2-4 characters): ",X:$S($D(DTIME):DTIME,1:60)
	Q:"^"[X  I X'?1U1.NU!($L(X)>4) D R^DIFROMH G R
	S DIC="^DIC(9.4,",DIC(0)="E",D="C" D IX^DIC,Q^DIFROM0 S DPK=+Y
R1	W !!,"I am going to create a routine called '",X,"INIT'."
	S U="^",%=0,%B="",DL=0,DIH="",DTL=X,DN=X_$E("INI",1,5-$L(X))
	S ^UTILITY($J)=DN,X=X_"INIT"
	I $D(^DD("OS",DISYS,18)) X ^(18) I  W *7,!,"but '"_X_"' is ALREADY ON FILE!" S Q=1
	W !,"Is that OK" D YN^DICN G Q:%<0!(%=2) I '% D R1^DIFROMH G R1
R3	S %=1,Q=DPK,DPK(1)=""
	W !,"Would you like to include Data Dictionaries" D YN^DICN S:%=2 F(-1)=0
	G DD:%=2,Q:%<0 I '% D R3^DIFROMH G R3
	F DH=0:0 S DH=$N(^DIC(9.4,Q,4,DH)) G:'$D(^(DH,0)) DD:$D(F),L S Y=+^(0) I $D(^DIC(Y,0))#2 S F(Y)=$P(^(0),U) W !!,F(Y) D SF G Q^DIFROM0:%<0
L	W !!,"THEN PLEASE LIST THE FILES THAT YOU WISH TO TRANSPORT:"
	F F=1:1 G Q:$D(DTOUT) K DIC S DIC("S")="I Y>0&'$D(F(+Y))",DIC(0)="AIQEZ",DIC="^DIC(" D ^DIC G:Y<0 Q:X[U,DD S F(+Y)=$P(Y,U,2) D F
DD	W ! F Y=1,2,3 S D=$P("DIE^DIPT^DIBT",U,Y),DIC=$P("INPUT^PRINT^SORT",U,Y)_" TEMPLATE(S):" F %=0:0 S %=$N(^DIC(9.4,Q,D,%)) Q:'$D(^(%,0))  S DH=$P(^(0),U),X=$P(^(0),U,2) D T
D1	K ^UTILITY(U,$J),DR S DRN=DL,F=0,%=2 G Q:$D(F)+$D(Q)=2,S:Q<1
	S DIE=9.4,DA=Q,DR=22,DR(2,9.49)=1 D ^DIE G Q^DIFROM0:$D(Y) S:$D(D1) DPK(1)=D1
	S %Y="^UTILITY(U,$J,""PKG"",DPK,",%X=DIE_DPK_","
	W !,"Moving "_$P(^DIC(9.4,DPK,0),U)_" Entry into Init's."
	S D=%X_"""22""," D %XY^%RCR K DR S:$D(^DISV(DUZ,D)) DR=^(D)
	I $P(^DIC(9.4,DPK,0),U,4) S DL=$S($D(^DIC(9.2,+$P(^(0),U,4),0))#2:$P(^(0),U),1:""),$P(^UTILITY(U,$J,"PKG",DPK,0),U,4)=DL
	K ^UTILITY(U,$J,"PKG",DPK,"VERSION") D OR^DIFROM11:$D(^ORD(100.99,1,5,DPK,0))
S	G ^DIFROM0
	;
T	W !,DIC,?24,DH F F=0:0 S @("F=$N(^"_D_"(""B"",DH,F))"),DIC="" Q:F'>0  I @("$D(^"_D_"(F,0))"),$P(^(0),U,4)=X!'X S Q(D,F)="" G TQ
	W *7," **NOT FOUND** "
TQ	Q
	;
SF	G F:$O(^DIC(9.4,Q,4,DH,1,0))'>0
	F %=0:0 S %=$O(^DIC(9.4,Q,4,DH,1,%)) Q:%'>0  I $D(^(%,0)) S E=$P(^(0),U),D=$O(^DD(+Y,"B",E,0)) I $D(^DD(+Y,D,0)) S F(+Y,+Y,D)="",%C=+$P(^(0),U,2) I %C W "  (",E,")" S F(+Y,%C)=0
	S F(+Y,+Y)=1,F(+Y,+Y,.01)=0,E=+Y G E
F	S F(+Y,+Y)=0,%=1,E=0 K %A
E	F E=E:0 S E=$N(F(+Y,E)) Q:E<0  F D=0:0 S D=$N(^DD(E,"SB",D)) Q:D<0  I Y-E!'$D(%A)!$D(%A(D)) S F(+Y,D)="" S:$D(%A) %A(D)=0
	S F(+Y,0)=^DIC(+Y,0,"GL"),@("D=$P("_F(+Y,0)_"0),U,4)") S:D<2 D=""
E1	S %=$S($D(^DIC(9.4,Q,4,DH,222.7)):2-(^(222.7)="Y"),1:2),%A=$S($D(^(222.9)):^(222.9)="Y",1:0)
	W !?9,"Transfer ",D," '",F(+Y),"' entries" W:$X>40 !?8 W " as well as the Data Dictionary" D YN^DICN I %=1 S DTL(+Y)=%A W:%A *7,"  (OVERWRITE)" K %A Q
	K:%<0 F(+Y) Q:%<0  I '% D E1^DIFROMH G E1
	Q
	;
Q	G Q^DIFROM0

DIFROM0
DIFROM0	; SF/XAK - GATHERS PARTS TO SEND ;3/27/89  11:19 ;
	;;17.7;VA FileMan; 6/9/89
	S %=2,DIT=0
	I DPK<0,$N(F(0))>0 W !,"Do you want to include all the templates" D YN^DICN G Q:%<0 S DIT=%=1 I %=0 D NOPKG^DIFROMH G DIFROM0
	S DL=DRN,DRN=1001,DH=$S(DTL="XU":"DI",1:DTL)
	F Y=19,3.6,19.1,.5,9.8,9.2 I $D(^DIC(Y,0)) S %=1 W !,"Would you Like to Include the "_$P(^(0),U)_"S" D YN^DICN G Q:%<0 I %=1 S Y(Y)=Y,DIFC=1 G:$D(F(-1))&('$D(DIFC)) Q
S	S %=2 W !!,"WANT SECURITY CODES SENT ALONG" D YN^DICN
	G Q:%<0 S DSEC=%=1 K ^UTILITY("DI",$J) I '% D S^DIFROMH G S
I	I '$D(^DIC(3,DUZ,0)) G M
	S %=2 W !!,"WOULD YOU LIKE THIS SENT IN A MESSAGE" D YN^DICN
	G M:%=2,Q:%<0 I '% D MSG^DIFROMH G I
	S DIFROM=1,DIMA="W !,""Installation Cannot Be Stopped! Please Proceed"""
	D QUES^XMASEC G Q:Y=-1
	W !,"Message Will Be Sent To: "_$P(^DIC(3,DUZ,0),U) D MSG^DIFROM3
	I $D(Y(9.8)) S XCNP=1 D LOAD^XMPH D:$O(^UTILITY($J,""))]"" INTEG^DIFROM6 K ^UTILITY($J)
	G GO
M	S DIRS="K ^UTILITY(U,$J),^UTILITY(""DIK"",$J) "
	W !,"MAXIMUM ROUTINE SIZE(BYTES): ",^DD("ROU"),"// "
	R %:$S($D(DTIME):DTIME,1:60) E  S DTOUT=1 G Q
	S DIFRM=^DD("ROU")
	I %]"" G Q:%[U S DIFRM=% I %\1'=%!(%<2000)!(%>9999) D M^DIFROMH G M
GO	W ! D WAIT^DICD F Y=19,3.6,19.1,.5,9.8,9.2 I $D(Y(Y)) S X=$S(Y=19:"OPT",Y=3.6:"BUL",Y=19.1:"SE",Y=.5:"FUN",Y=9.8:"RTN",Y=9.2:"HEL") D ADD
	K Y G ^DIFROM1
	;
ADD	;
	Q:$D(^DIC(Y,0))[0!$D(DTL(Y))  Q:$P(^(0),X,1)]""!'$D(^(0,"GL"))
	S Y=^("GL") S:X="SE" X="KEY" D A S DH=$S(DTL="XU":"DI",1:DTL) Q
A	F D=0:0 S D=$N(^DIC(9.4,DPK,"EX",D)) Q:D'>0  I $P(DH,$P(^(D,0),U))="" G DH
	S D=$N(@(Y_"""B"",DH,0)")),%X=Y_"D,",%Y="^UTILITY(U,$J,X,D,"
	G DH:D<0,DH:D<100&(X="FUN") S Q(X)=0 D %XY^%RCR G H:X'="OPT"
	S %=^UTILITY(U,$J,X,D,0),%1=+$P(%,U,12),%1=$S($D(^DIC(9.4,%1,0)):$P(^(0),U),1:""),$P(%,U,12)=%1,$P(%,U,5)=""
	S %1=+$P(%,U,7),%1=$S($D(^DIC(9.2,%1,0)):$P(^(0),U),1:""),$P(%,U,7)=%1,^UTILITY(U,$J,X,D,0)=% K ^(10,"B"),^("C")
	F %=0:0 S %=$N(^DIC(19,D,10,%)) Q:%'>0  I $D(^(%,0)),$D(^DIC(19,+^(0),0)) S ^UTILITY(U,$J,X,D,10,%,U)=$P(^(0),U)
H	K:"BULKEY"[X ^UTILITY(U,$J,X,D,2) G:X'="HEL" DH
	K ^UTILITY(U,$J,X,D,4) S $P(^(0),U,4)="" K ^(2,"B")
	F %2=0:0 S %2=$N(^UTILITY(U,$J,X,D,2,%2)) G DH:%2'>0 I $D(^(%2,0))#2,$P(^(0),U,2) S %1=^(0),%=1 D HP1 Q:%<0
	K %1,%2 Q
HP1	I $D(^DIC(9.2,+$P(%1,U,2),0)) S ^UTILITY(U,$J,X,D,2,%2,0)=$P(%1,U)_U_$P(^(0),U) Q
	W !,*7,"The Help Frame, "_$P(^DIC(9.2,D,0),U)_" has the keyword "_$P(%1,U)
	W !,"whose Related Frame does not exist.  Shall I exclude it" D YN^DICN
	K:%=1 ^UTILITY(U,$J,X,D,2,%2) Q
	;
DH	S DH=$N(@(Y_"""B"",DH)")) G A:$S(DTL="XU":DH+1,1:$P(DH,DTL,1)="") Q
	;
Q	;
	K ^UTILITY($J),^(U,$J),DIFROM,DR,DD,DLAYGO,DIRS,DIMA,DWLW,DREF,D1
	K DIX,DIY,DO,DZ,DIK,DIDUZ,DIFQ,DDF,DDT,NO,DIF,DIG,DIH,DIU,DIV,DIW
	K %A,%B,%C,%V,%X,%Y,%Z,DG,D0,DA,DIFRM,DL,D,E,F,DIC,DIE,DN,DPK,DQ,DRN
	K DIFQR,DNAME,DSEC,DTL,DIFC,Q,DIDIU,DIFKEP,DIT Q
	;

DIFROM1
DIFROM1	; SF/XAK - CREATES RTNS CONTAINING DD'S ;12:22 PM  May 18, 1988
	;;17.7;VA FileMan; 6/9/89
L	S DH=" F I=1:2 S X=$T(Q+I) Q:X=""""  S Y=$E($T(Q+I+1),4,999),X=$E(X,4,999) S:$A(Y)=126 I=I+1,Y=$E(Y,2,999)_$E($T(Q+I+1),5,99) S:$A(Y)=61 Y=$E(Y,2,999) X NO E  S @X=Y",F=$N(F(F))
	S:F>0&($D(XMKEY)) ^UTILITY($J,DL+1,0)="$DDD "_F(F),DL=DL+1
	I F<0 D FILE^DIFROM3:DL S:DSEC DH=" I DSEC"_DH,%X="^UTILITY(""DI"",$J,",%Y="^UTILITY($J," D:DSEC %XY^%RCR,FILE^DIFROM3:$N(^UTILITY($J,0))>0 K ^UTILITY("DI",$J) S:DSEC DH=$E(DH,8,999) G ^DIFROM11
	S ^UTILITY($J,DL+1,0)="^DIC("_F_",0,""GL"")",^UTILITY($J,DL+2,0)="="_F(F,0),^UTILITY($J,DL+3,0)="^DIC(""B"","""_F(F)_""","_F_")",^UTILITY($J,DL+4,0)="=",DL=DL+4
	F E="%","%D" S %X="^DIC("_F_","""_E_""",",E=0 D %XY
	I DSEC S E="" F DSEC=DSEC:1 S E=$O(^DIC(F,0,E)) Q:E=""  I E'="GL" S ^UTILITY("DI",$J,DSEC,0)="^DIC("_F_",0,"""_E_""")" S DSEC=DSEC+1 S ^UTILITY("DI",$J,DSEC,0)="="_^DIC(F,0,E)
	F D=0:0 S D=$N(F(F,D)),E=0,%X="^DD("_D_",0" Q:D<0  S DL=DL+1,^UTILITY($J,DL,0)=%X_")",DL=DL+1,^UTILITY($J,DL,0)="="_^DD(D,0),%X=%X_"," D %XY F X=0:0 S X=$N(^DD(D,X)) Q:X'>0  S %X="^DD("_D_","_X_",",E="%Z#2" D SAVE:$D(F(F,D))<9!$D(F(F,D,X))
	I $D(DTL(F)) S:$D(XMKEY) DL=DL+1,^UTILITY($J,DL,0)="$END DDD "_F(F) D FILE^DIFROM3
	I $D(DTL(F)) S DL=DL+1 S:$D(XMKEY) ^UTILITY($J,DL,0)="$DTA "_F(F) S E="%Z#2=0",%X=F(F,0),@("D="_%X_"0)")
	I  S ^UTILITY($J,DL+1,0)="^UTILITY(U,$J,"_F_")",^UTILITY($J,DL+2,0)="="_%X,^UTILITY($J,DL+3,0)="^UTILITY(U,$J,"_F_",0)",^UTILITY($J,DL+4,0)="="_D,%Y="^UTILITY(U,$J,"_F_",",%Z=0,%C(-1)=0,%B=0,%A="",DL=DL+5
	I  D N S:$D(XMKEY) ^UTILITY($J,DL+1,0)="$END DTA "_F(F) D FILE^DIFROM3
	I '$D(DTL(F)),$D(XMKEY) S DL=DL+1,^UTILITY($J,DL,0)="$END DDD "_F(F)
	G L
	;
SAVE	K DSV I $D(^(X,8)) S DSV(8)=^(8) K ^(8)
	I $D(^(8.5)) S DSV(8.5)=^(8.5) K ^(8.5)
	I $D(^(9)),^(9)'=U S DSV(9)=^(9) K ^(9)
	D %XY
	F %Z=8,8.5,9 I $D(DSV(%Z)),DSV(%Z)]"" S ^DD(D,X,%Z)=DSV(%Z) I DSEC S ^UTILITY("DI",$J,DSEC,0)="^DD("_D_","_X_","_%Z_")",DSEC=DSEC+1,^UTILITY("DI",$J,DSEC,0)="="_DSV(%Z),DSEC=DSEC+1
	Q
	;
%XY	;
	W "." S %Z=0,%A="",%C(-1)=0,%Y=%X
S	S %B=-1
N	S @("%B=$N("_%X_%A_"%B))"),%C(%Z)=%C(%Z-1) I '%B,%B'?1"0".E,@E S %B=-1
	I %B["," F %C=0:0 S %C=$F(%B,",",%C) Q:'%C  S %C(%Z)=%C(%Z)+1
	I %B=-1 G Q:'%Z S @("%B="_$P(%A,",",%Z+%C(%Z-2),%Z+%C(%Z-1))),%Z=%Z-1,%A=$P(%A,",",1,%Z+%C(%Z-1))_$E(",",%Z>0) G N
	I @("$D("_%X_%A_"%B))#2=1") S %V=^(%B) D W:%V'?.ANP S %=$P("""",U,+%B'=%B),%=%Y_%A_%_%B_%_")" D B:$L(%V)>240 S DL=DL+1,^UTILITY($J,DL,0)=%,DL=DL+1,^UTILITY($J,DL,0)="="_%V
	I @("$D("_%X_%A_"%B))<9") G N
	G D:+%B=%B F %C=0:0 S %C=$F(%B,"""",%C) Q:'%C  S %B=$E(%B,1,%C-1)_""""_$E(%B,%C,999),%C=%C+1
	S %B=""""_%B_""""
D	S %A=%A_%B_",",%Z=%Z+1 G S
	;
B	I $L(%V)>255 W !,"WARNING--DATA TOO LONG:  " D X
	S DL=DL+1,^UTILITY($J,DL,0)=%,%=$C(126)_$E(%V,1,160),%V=$E(%V,161,999) Q
	;
W	W !,"WARNING--CONTROL CHARACTER IN DATA:  "
X	W *7,%X,%A,%B,")--",!?3,%V
Q	Q

DIFROM11
DIFROM11	; SF/XAK - CREATES RTN ENDING IN INIT1 ;11:18 AM  Oct 18, 1988;
	;;17.7;VA FileMan; 6/9/89
	S %Y="^UTILITY(U,$J,D,Y,",E=0
	F D="DIE","DIPT","DIBT" S %X=U_D_"(Y," F Y=0:0 S @("Y=$N(^"_D_"(Y))") Q:Y'>0  I $D(^(Y,0))#2 S DSV=^(0),F=$P(DSV,U,4) I F,$D(F(F))!$D(Q(D,Y)) D 1
	S X="" F D=0:0 S X=$O(^UTILITY(U,$J,X)) Q:X=""  S %X="^UTILITY(U,$J,"_""""_X_"""," S:$D(XMKEY)&'X DL=DL+1,^UTILITY($J,DL,0)="$"_$E(X,1,3) D %XY^DIFROM1 I $D(XMKEY)&'X S DL=DL+1,^UTILITY($J,DL,0)="$END "_$E(X,1,3)
	I DPK=-1,$D(XMKEY),'$D(^UTILITY("INTEG",$J)),'$D(^UTILITY(U,$J)),'$D(^XMB(3.9,XMZ,2,2,0)) K ^XMB(3.9,XMZ) G Q^DIFROM0
	K ^UTILITY(U,$J) D FILE^DIFROM3:DL K ^UTILITY($J)
	I '$D(XMKEY) S ^UTILITY($J,.6,0)="1 I $D(DIFQ(0)) W !,""SHALL I WRITE OVER EXISTING DATA DEFINITIONS"" S %=1 D YN^DICN S:%=2 DSEC=0"
	I  S ^UTILITY($J,1,0)=" I '% W !?3,""Answer YES to replace current field definitions with the ones in these"",!?3,""programs, or NO to leave the current ones in place.  In either case"",!?3,""new fields will be added."" G 1"
	G Q^DIFROM0:DRN=1001&'$D(XMKEY),^DIFROM2
1	;
	I 'DIT F %=0:0 S %=$N(^DIC(9.4,DPK,"EX",%)) Q:%'>0  I $P($P(DSV,U),$P(^(%,0),U))="" G Q
	I DIT!($P($P(DSV,U),DTL)="")!$D(Q(D,Y)) S Q(D)=0 D %XY^%RCR K ^UTILITY(U,$J,D,Y,"RD"),^("AB") K:'$D(DTL(F)) ^(1) S:'DSEC ^(0)=$P(DSV,U,1,2)_U_U_F W "."
Q	Q
	;
OR	;
	S %X="^ORD(100.99,1,5,DPK,",%Y="^UTILITY(U,$J,""OR"",DPK," D %XY^%RCR
	S %=$P(^ORD(100.99,1,5,DPK,0),U,4)
	I %]"" S %=$N(^ORD(100.98,"B",%,0)),%=$S($D(^ORD(100.98,%,0)):$P(^(0),U),1:"") I %]"" S $P(^UTILITY(U,$J,"OR",DPK,0),U,4)=%
	K ^UTILITY(U,$J,"OR",DPK,"B")
	Q

DIFROM2
DIFROM2	; SF/XAK - CREATES RTN ENDING IN 'INIT1' ;6/7/89  20:25
	;;17.7;VA FileMan; 6/9/89
	S DIFROM=5,Y=DRN-1,S=""
	S DH=" ; LOADS AND INDEXES DD'S",^UTILITY($J,.3,0)=" K DIF,DIK,D,DDF,DDT,DTO,D0,DLAYGO,DIC,DIDUZ,DIR,DA,DFR,DTN,DIX,DZ D DT^DICRW S %=1,U=""^"",DSEC=1"
	S X="",DD="A" F E=1:1 S DD=$N(Q(DD)) Q:DD  S DL=$S(DD="DIPT":"DIP",DD="DIBT":"DIB",1:DD) S X=X_","""_DL_""""
	S DL=0,^UTILITY($J,1.4,0)=" S NO=$P(""I 0^I $D(@X)#2,X[U"",U,%) I %<1 K DIFQ Q"
	S DIRS(1)=$S($D(XMKEY):" I %<1 "_DIMA_" S %=1 G ASK",1:" I %<1 K DIFQ Q")
	S:E>1 ^UTILITY($J,2,0)=" F X="_$E(X,2,99)_" D W Q:'$D(DIFQ)"
	S:'$D(XMKEY) ^UTILITY($J,2.5,0)=" Q:'$D(DIFQ)  S %=0 W !!,""ARE YOU SURE EVERYTHING'S OK"" D YN^DICN I %-1 K DIFQ Q"
	S ^UTILITY($J,2.6,0)=" I $D(DIFKEP) F DIDIU=0:0 S DIDIU=$N(DIFKEP(DIDIU)) Q:DIDIU'>0  S DIU=DIDIU,DIU(0)=DIFKEP(DIDIU) D EN^DIU2"
	S ^UTILITY($J,3,0)=" D DT^DICRW "_$S($D(DIRS)#2:DIRS,1:"")_"D WAIT^DICD F R=1001:1:"_Y_" D @(""^"_DN_"""_$E(R,2,4)) W "".""" K Q S X=4,E="",Q=" ;"
	F L=0:0 S L=$O(F(L)) Q:L'>0  F DD=0:0 S DD=$O(F(L,DD)) Q:DD'>0  S E=E_","_DD I $L(E)>200 D LDD
	D:E]"" LDD S DIRS=$S($D(XMKEY):" I %<1 "_DIMA_" G W",1:" K:%<0 DIFQ")
	S E=$E(DTL_"INIT",1,7),DNAME=E_1,D=-9999 F DD=1:1 S X=$T(TEXT+DD) Q:X=""  S ^UTILITY($J,DD+4,0)=X S:DD=7 ^UTILITY($J,DD+4,0)=X_DIRS
	S ^UTILITY($J,1.5,0)="ASK I %=1,$D(DIFQ(0)) W !,""SHALL I WRITE OVER FILE SECURITY CODES"" S %=2 D YN^DICN S DSEC=%=1"_DIRS(1)
	D ZI^DIFROM3 G ^DIFROM3
	Q
LDD	S ^UTILITY($J,X,0)=" F D="_$E(E,2,999)_" D IX",X=X+.01,E="" Q
TEXT	;
DATA	W "." S (D,DDF(1),DDT(0))=$N(^UTILITY(U,$J,0)) Q:D'>0
	I '$D(DIFQ(D)) S DTO=0,DMRG=1,DTO(0)=^(D),Z=^(D)_"0)",D0=^(D,0),@Z=D0,DFR(1)="^UTILITY(U,$J,DDF(1),D0,",DKP='$D(DIFQR(D)) F D0=0:0 S D0=$N(^UTILITY(U,$J,DDF(1),D0)) Q:'$D(^(D0,0))  S Z=^(0) D I^DITR
	K ^UTILITY(U,$J,DDF(1)),DDF,DDT,DTO,DFR,DFN,DTN G DATA
	;
W	S Y=$P($T(@X),";",2) W !,"NOTE: This package also contains "_Y_"S",! Q:'$D(DIFQ(0))
	S %=1 W ?6,"SHALL I WRITE OVER EXISTING "_Y_"S OF THE SAME NAME" D YN^DICN I '% W !?6,"Answer YES to replace the current "_Y_"S with the incoming ones." G W
	S:%=2 DIFQ(X)=0
	Q
	;
OPT	;OPTION
RTN	;ROUTINE DOCUMENTATION NOTE
FUN	;FUNCTION
BUL	;BULLETIN
KEY	;SECURITY KEY
HEL	;HELP FRAME
DIP	;PRINT TEMPLATE
DIE	;INPUT TEMPLATE
DIB	;SORT TEMPLATE
	;
IX	W "." S DIK="A" F %=0:0 S DIK=$N(^DD(D,DIK)) Q:DIK<0  K ^(DIK)
	S DA(1)=D,DIK="^DD("_D_"," D IXALL^DIK
	I $D(^DIC(D,"%",0)) S DIK="^DIC(D,""%""," G IXALL^DIK
	Q

DIFROM3
DIFROM3	; SF/XAK - CREATES RTN ENDING IN 'INIT2' (HELP FRAMES) ;1/31/89  10:57
	;;17.7;VA FileMan; 6/9/89
	S DNAME=E_2,DL=0,(DH,Q)=" ;" K ^UTILITY($J) F DD=1:1 S X=$T(TEXT+DD) Q:X=""  S ^UTILITY($J,DD,0)=X,DIFROM=2
	D ZI G ^DIFROM4
	;
FILE	;
	S DL=0,Q="Q Q",S=" ;;"
NAME	S D=$L(DH)+10,DNAME=DN_$E(DRN,2,4)
ZI	;
	K ^UTILITY($J,0) S ^(0,1)=DNAME_" ;",^(1.1)=" ;;Version "_DPK(1)
2	G MSG:$D(XMKEY) S ^UTILITY($J,0,2)=DH,^UTILITY($J,0,3)=Q F L=4:1 S DL=$N(^UTILITY($J,DL)) Q:DL<0  S ^UTILITY($J,0,L)=S_^(DL,0),D=$L(^(L))+D I D+380>DIFRM,$E(^(L),4)'="^",$E(^(L),4)'=$C(126) Q
	S DRN=DRN+1,X=DNAME X ^DD("OS",DISYS,"ZS") W !,X_" HAS BEEN FILED..." G NAME:DL>0
K	K %A,%B,%C,%Z,^UTILITY($J) S DL=0 Q
	;
MSG	I DIFROM>1 S ^UTILITY($J,.1,0)="$ROU "_DNAME,^UTILITY($J,.2,0)=DNAME_" ;"_DIH,^UTILITY($J,DD+DIFROM,0)="$END ROU "_DNAME
	I '$D(XMZ) S XMSUB=DTL_"INIT - "_$S(DPK>0:$P(^DIC(9.4,DPK,0),U,1),1:""),XMTEXT="^UTILITY($J,",XMY(DUZ)="",XMDUZ=DUZ D INIT^XMD G K
	S X=XCNP D EN2^XMD G K
	;
TEXT	;
	K ^UTILITY("DIFROM",$J),DIC S DIDUZ=0 S:$D(DUZ)#2 DIDUZ=DUZ S DUZ=.5
	I $D(^DIC(9.2,0))#2,^(0)?1"HEL".E S (DIC,DLAYGO)=9.2,N="HEL",DIC(0)="LX" G ADD
	Q
	;
ADD	F R=0:0 S R=$N(^UTILITY(U,$J,N,R)) Q:R<0  S X=$P(^(R,0),U,1) W "." D ^DIC I Y>0,'$D(DIFQ(N))!$P(Y,U,3) S ^UTILITY("DIFROM",$J,N,X)=+Y K ^DIC(9.2,+Y,1),^(2),^(3) S %X="^UTILITY(U,$J,N,R,",%Y=DIC_"+Y,",DA=+Y D %XY^%RCR
	S DIK=DIC
HELP	S R=$N(^UTILITY("DIFROM",$J,N,R)) Q:R<0  W !,"'"_R_"' Help Frame filed." S DA=^(R) G IX:$N(^DIC(9.2,DA,2,0))'>0
	F X=0:0 S X=$N(^DIC(9.2,DA,2,X)) Q:X'>0  S I=$S($D(^(X,0)):^(0),1:0),Y=$P(I,U,2) S:Y]"" Y=$N(^DIC(9.2,"B",Y,0)) S ^(0)=$P(^DIC(9.2,DA,2,X,0),U,1)_U_$S(Y>0:Y,1:"")_U_$P(^(0),U,3,99)
IX	D IX1^DIK G HELP

DIFROM4
DIFROM4	; SF/XAK - CREATES 'INIT3' (PARTS BESIDES DD'S) ; 7/29/88  11:57 ;
	;;17.7;VA FileMan; 6/9/89
	S DNAME=E_3,DL=0,(DH,Q)=" ;"
	K ^UTILITY($J) F DD=1:1 S X=$T(TXT+DD) Q:X=""  S ^UTILITY($J,DD,0)=X
	S DIFROM=2 D ZI^DIFROM3 G ^DIFROM5
TXT	;
	K ^UTILITY("DIFROM",$J) S DIC(0)="LX",(DIC,DLAYGO)=3.6,N="BUL" D ADD:$D(^XMB(3.6,0))
	S X=0 F R=0:0 S X=$N(^UTILITY("DIFROM",$J,N,X)) Q:X<0  W !,"'",X,"' BULLETIN FILED -- Remember to add its user groups."
	I $D(^DIC(9.4,0))#2,^(0)?1"PACK".E S N="PKG",(DIC,DLAYGO)=9.4 D ADD
	G NP:'$D(DA) S:$D(^DIC(9.4,DA,22,DIFROM,0)) $P(^(0),U,3)=DT
	I $D(^DIC(9.4,DA,0))#2 S %=$P(^(0),U,4) I %]"" S %=$N(^DIC(9.2,"B",%,0)) S:%]"" $P(^DIC(9.4,DA,0),U,4)=%
	G NP:'$D(^ORD(100.99))!'$O(^UTILITY(U,$J,"OR",""))
	S %X="^UTILITY(U,$J,""OR"","_$O(^(""))_",",DIK="^ORD(100.99,1,5,",%Y=DIK_DA_","
	S:'$D(^ORD(100.99,1,5,0)) ^(0)="^100.995P^^"
	D %XY^%RCR S $P(^ORD(100.99,1,5,DA,0),U)=DA,%=$P(^(0),U,4)
	I %]"" S %=$N(^ORD(100.98,"B",%,0)) I %>0 S $P(^ORD(100.99,1,5,DA,0),U,4)=%
	S DA(1)=1 D IX1^DIK
NP	K ^UTILITY("DIFROM",$J) I $D(^DIC(19,0))#2,^(0)?1"OPTION".E S (DIC,DLAYGO)=19,N="OPT" D ADD,OP
	I $D(^DIC(19.1,0))#2,^(0)?1"SECUR".E S (DIC,DLAYGO)=19.1,N="KEY" D ADD K ^UTILITY("DIFROM",$J)
	I $D(^DIC(9.8,0))#2,^(0)?1"ROUTINE^".E S (DIC,DLAYGO)=9.8,N="RTN" D ADD
	S DIC=.5,DLAYGO=0,N="FUN" D ADD
	S DIC("S")="I $P(^(0),U,4)=I" F N="DIPT","DIBT","DIE" S DIC=U_N_"(" D ADD
	K ^UTILITY(U,$J),DIC,DLAYGO F DIR="DIE","DIPT" D DIEZ
	Q
DIEZ	I ^DD("VERSION")>17.4,'$D(DISYS) D OS^DII
	E  S DISYS=^DD("OS")
	Q:'$D(^DD("OS",DISYS,"ZS"))
	S N=$N(^UTILITY("DIFROM",$J,DIR,0)) Q:N<0  S Y=+^(N) K ^(N)
	I $D(@("^"_DIR_"(Y,""ROU"")")) K ^("ROU") I $D(^("ROUOLD")) S X=^("ROUOLD"),DMAX=^DD("ROU") D:X]"" @("EN^DI"_$E(DIR,3)_"Z")
	G DIEZ
	;
OP	S R=$N(^UTILITY("DIFROM",$J,N,R)) I R<0 K ^UTILITY("DIFROM",$J) G Q
	W !,"'"_R_"' Menu Option Filed" S DA=+^UTILITY("DIFROM",$J,N,R) G:$P(^(R),U,2,3)="XUCORE^"!($P(^(R),U,2,3)="XUCOMMAND^") OP
	S %=$P(^DIC(19,DA,0),U,12) S:%]"" %=$O(^DIC(9.4,"B",%,0))
	S $P(^DIC(19,DA,0),U,12)=%,%=$P(^(0),U,7),(DZ,DIX)=0
	S:%]"" %=$O(^DIC(9.2,"B",%,0)) S $P(^DIC(19,DA,0),U,7)=%,%=$P(^(0),U,4),%="MOQ"[% K ^(10,"B"),^("C")
	F X=0:0 S X=$N(^DIC(19,DA,10,X)) Q:X'>0  S I=$S($D(^(X,0)):^(0),1:0),Y=$S($D(^(U)):^(U),1:"") K ^DIC(19,DA,10,X) I Y]"",% S D=$N(^DIC(19,"B",Y,0)) I D>0 S ^DIC(19,DA,10,X,0)=D_U_$P(I,U,2,9),DZ=DZ+1,DIX=X
	S:% ^DIC(19,DA,10,0)="^19.01PI^"_DZ_U_DIX D IX1^DIK G OP
	;
ADD	F R=0:0 S R=$N(^UTILITY(U,$J,N,R)) Q:R<0  S X=$P(^(R,0),U),I=$P(^(0),U,4) W "." D ^DIC I Y>0,'$D(DIFQ(N))!$P(Y,U,3) S Y=Y_U D A
Q	Q
A	K:N'="KEY"&(N'="OPT") @(DIC_"+Y)") S ^UTILITY("DIFROM",$J,N,X)=Y S:N="PKG" DIFROM(0)=+Y Q:$P(Y,U,2,3)="XUCORE^"!($P(Y,U,2,3)="XUCOMMAND^")
	I N="OPT" S:$P(^DIC(19,+Y,0),U,6)]"" DIOPT=$P(^(0),U,6) I $N(^UTILITY(U,$J,N,R,1,0))>0 K ^DIC(19,+Y,1)
	S %X="^UTILITY(U,$J,N,R,",%Y=DIC_"+Y,",DA=+Y,DIK=DIC D %XY^%RCR,IX1^DIK:N'="OPT" I N="OPT",$D(DIOPT) S $P(^DIC(19,DA,0),U,6)=DIOPT K DIOPT

DIFROM5
DIFROM5	; SF/XAK - CREATES RTN ENDING IN 'INIT' ;3/14/89  16:19 ;
	;;17.7;VA FileMan; 6/9/89
	S Q=$S('$D(^DIC(9.4,DPK,"INIT")):1,^("INIT")?1PA.E:^("INIT"),1:1) K ^UTILITY($J)
	S X="T",%DT="" D ^%DT,D^DIO3 S DRN=17,DIRS=$S($D(XMKEY):" "_DIMA_" G 1",1:" S DIFQ=1")
	S X=0
	F F=0:0 S F=$N(F(F)) Q:F<0  S X=X+1,DH=$P(@(F(F,0)_"0)"),U,2),^UTILITY($J,27+X,0)=" ;;"_DH_";"_F(F)_";"_$S($D(DTL(F)):DTL(F)+1,1:0)_";"_F(F,0)_";"_$S($D(F(F,F)):F(F,F),1:"")
	S ^UTILITY($J,5,0)=" F DIF=1:1:"_X_" S %=$T(IXF+DIF),DIK=$P(%,"";"",6),N=$P(%,"";"",3),D=$P(%,"";"",4)_U_N D D"
	S ^UTILITY($J,9,0)=" L  S DUZ=DIDUZ W !"_$S(Q:",*7,""OK, I'M DONE."",!",1:"")_",""NO""_$P(""TE THAT FILE"",U,DSEC)_"" SECURITY-CODE PROTECTION HAS BEEN MADE"""_$S(Q:"",1:" D ^"_Q)
	S ^UTILITY($J,9.1,0)=" S:$D(DIFROM(0))&($D(DIFQ)) ^DIC(9.4,DIFROM(0),""VERSION"")=DIFROM G Q^DIFROM0"
	S ^UTILITY($J,9.2,0)="D S:$D(^DIC(+N,0))[0 ^(0)=D S X=$D(@(DIK_""0)"")),^(0)=D_U_$S(X#2:$P(^(0),U,3,9),1:U)"
	S ^UTILITY($J,9.3,0)=" I '$D(DIFQ(+N)),$P(%,"";"",5)!'X D IXALL^DIK:$N(^(0))>0 W ""."""
	S ^UTILITY($J,9.4,0)=" I ^DD(""VERSION"")>17.5,$D(^DD(+N,0,""DIK""))#2 S X=^(""DIK""),Y=+N,DMAX=^DD(""ROU"") D EN^DIKZ"
	S ^UTILITY($J,9.5,0)=" Q"
	F D=1:1 S E=$T(T+D) Q:E=""  S:E="IXF ;;" E=E_DTL S ^UTILITY($J,9+D,0)=E,DIFROM=X+3 S:D=7 ^UTILITY($J,9+D,0)=E_DIRS
	G ^DIFROM6
T	;
	;
1	S X=$T(IXF+I),N=+$P(X,";",3),N(N)=$P(X,";",4),D=$P(X,";",5),S=$P(X,";",6),U="^" W !?3,N,?13,N(N),$P("  (PARTIAL DEFINITION)",U,$P(X,";",7)),$P("  (INCLUDING DATA)",I,D) S Z=$S($D(^DIC(N,0))#2:^(0),1:"")
	I $L($P(Z,N(N),1)) W *7,!,"*BUT YOU'VE ALREADY GOT '",$P(Z,"^",1),"' AS FILE #",N,"!*" G REP
	S %=$P(S,"(",1),DW=0 S:$D(@%)#2 DW=@% S @%=DW
	I $L(Z) W *7,!,"NOTE -- YOU ALREADY HAVE '",$P(Z,"^",1),"' FILE" S DIFQ(0)=1
SKP	I D,$N(@(S_"0)"))>0 W " WITH DATA",!?9,"WANT MY DATA ADDED IN TO YOURS" S %=1 D YN^DICN S:%=2 DIFQ(N)=1 D OV:D-1&(%=1) I '% W !?3,"Answer YES to add incoming data if it does not match exactly",!?3,"on Name and Identifiers.",! G 1
MCK	I %<0
	W ! Q
OV	W !?9,*7,"I WILL **REPLACE** YOUR DATA WITH MINE, OK" D YN^DICN S:%=1 DIFQR(N)=1 Q
Q	W *7,!!,"NO UPDATING HAS OCCURRED!" Q
REP	S %=2 W !,"I'm Changing the NAME of your File to the Name of My File  OK " D YN^DICN G:%<0 MCK S:%=1 DIE=1,DIFQ=0,DA=N,DR=".01///"_N(N) D:%=1 ^DIE G 1:%=1 I '% D REP^DIFROMH1 G REP
AG	S %=2 W !," OK! Then I am Replacing Your File with My File OK " D YN^DICN S:%=2 %=-1 G:%<0 MCK I '% D AG^DIFROMH1 G AG
CHG	S %=2,DIU(0)="E" W !,"Would you like to Keep the Data  " D YN^DICN G MCK:%<0 S:%=2 DIU(0)=DIU(0)_"D" I '% D CHG^DIFROMH1 G CHG
TEMP	S %=2 W !,"Would you like to keep the Templates " D YN^DICN G MCK:%<0 S:%=2 DIU(0)=DIU(0)_"T" I '% D TEMP^DIFROMH1 G TEMP
	S DIFKEP(N)=DIU(0) W !,?15," (",N(N),") " G SKP
	;
IXF	;;

DIFROM6
DIFROM6	; SF/XAK - CREATES RTN ENDING IN 'INIT' ;6/7/89  20:24 ;
	;;17.7;VA FileMan; 6/9/89
	S DH=" ;",Q=" K DIF,DIK,DDF,DDT,DTO,D0,DLAYGO,DIC,DIDUZ,DIR,DA,DIFROM,DFR,DTN,DIX,DZ"
	S ^UTILITY($J,.3,0)=" S DIFQ=0,DIFROM="_$S($D(DR):DR,1:0)_" W !,""This version"_$S($D(DR):" (#"_DR_")",1:"")_" of '"_DTL_"INIT' was created on "_Y_""""
	S ^UTILITY($J,1,0)=" I $D(^DD(""VERSION"")),^(""VERSION"")'<"_DRN_" G GO:$N(^(""VERSION"","_DRN_"))<0 W !,""BUT I'M OBSOLETE!!"" G Q"
	S ^UTILITY($J,2,0)=" W !,""FIRST, I'LL FRESHEN UP YOUR VA FILEMAN...."" D N^DINIT"
	S ^UTILITY($J,2.9,0)=" I ^DD(""VERSION"")<"_DRN_" W !,""BUT I NEED VERSION "_DRN_" OF THE VA FILEMAN!"" G Q"
	S ^UTILITY($J,3,0)="GO ;"
	S ^UTILITY($J,3.5,0)="EN ; ENTER HERE TO BYPASS THE PRE-INIT PROGRAM"
	S ^UTILITY($J,3.6,0)=" S DIFQ=0 W !,""I AM GOING TO SET UP THE FOLLOWING FILE"_$E("S",X>1)_":"",! F I=1:1:"_X_" D 1 Q:DIFQ"
	S X=$E(DTL_"INIT",1,7)
	S ^UTILITY($J,4,0)=" G Q:DIFQ D ^"_X_"1 G Q:'$D(DIFQ) S DIK(0)=""B"""
	S ^UTILITY($J,6,0)=" D ^"_X_"2,^"_X_3,X=0
	D VERSION^DI
	S ^UTILITY($J,.6,0)=" W !?9,""("_$S($D(^DD("SITE")):"at "_^("SITE")_",",1:"")_" by "_X_")"",!"
	I DPK>0,$D(^DIC(9.4,DPK,"PRE")),^("PRE")]"" S ^UTILITY($J,3.1,0)=" W !,""I HAVE TO RUN A PRE-INITIALIZATION ROUTINE."" D ^"_^("PRE")_" Q:'$D(DIFQ)"
	K ^UTILITY(U,$J),^UTILITY($J,0),E,F S D=-9999,DNAME=DTL_"INIT",DL=0,^(0,1)=DNAME_" ;;"_Y D 2^DIFROM3
	I $D(XMKEY) S F=XMKEY D SKEY^XME,INTEG1 S XMKEY=F D EN3^XMD
	G Q^DIFROM0
	;
INTEG	W !,"..." S X=0,%X="F %Y=1:1:DD S D=$A(DNAME,%Y)*%Y+D"
	F XCNP=XCNP:0 S X=$O(^UTILITY($J,X)) Q:X=""  W "." X "ZL @X S D=0 F Y=1:1 S DNAME=$T(+Y),DD=$L(DNAME) X %X I 'DD S ^UTILITY(""INTEG"",$J,X)=D ZL DIFROM6 Q"
	Q
INTEG1	Q:'$D(^UTILITY("INTEG",$J))  S DIFROM=2,DNAME=DTL_"NTEG",DIH=" Integrity Checker",DIRS=" I U'=T W "" ROUTINE FAILS INTEGRITY CHECK."" S %E=1"
	S ^UTILITY($J,.5,0)=" I '$D(XMKEY) S %E=$T(KEY) W:$P(%E,"";"",4)]"""" !,""Your Hint is: "",$P(%E,"";"",4) D KEY^XME Q:XMKEY=""^""!(XMKEY'=$P(%E,"";"",5,99))"
	S ^UTILITY($J,1,0)=" K %E D CC F %=1:1 S X=$T(ROU+%),T=$P(X,"" ""),U=$P(X,"";"",3) Q:X=""""  W !,T X ""ZL @T F J=1:1 S L=$T(+J),LN=$L(L) X CC I 'LN X CD Q"""_DIRS
	S ^UTILITY($J,1.5,0)=" W:'$D(%E) !,""ALL PROGRAMS PASS."""
	S ^UTILITY($J,1.6,0)=" K CC,CD,XMSJ,XMRW,XMCL,%E,XMKEY,XMKEYTRY Q"
	S ^UTILITY($J,2,0)="CC S CC=""F C=1:1:LN S T=$A(L,C)*C+T"""
	S ^UTILITY($J,2.1,0)="CD S CD=""S X=T+XMRW,T="""""""" F XMSJ=1:1:$L(X) S T=T_$C($F(^UTILITY(""""XMS"""",$J,""""S"""",XMSJ#XMCL+1),$E(X,XMSJ))+30)"""
	S ^UTILITY($J,2.4,0)="KEY ;;;"_XMHINT_";"_XMKEY
	S ^UTILITY($J,2.5,0)="ROU ;",^UTILITY($J,2.3,0)=" Q",X=0
	F DD=3:1 S X=$O(^UTILITY("INTEG",$J,X)) Q:X=""  S ^UTILITY($J,DD,0)=X_" ;;"_^UTILITY("INTEG",$J,X)
	D MSG^DIFROM3 K ^UTILITY("INTEG",$J) Q

DIFROMH
DIFROMH	; SF/XAK - HELP FOR DIFROM ; 7/13/88  16:51 ;
	;;17.7;VA FileMan; 6/9/89
R	; HELP FOR PREFIX
	W !?5,"Enter a unique 2 to 4 character prefix beginning with an uppercase",!?5,"letter and followed only by uppercase letters or numbers." Q:X'?1"??".E
	W !?5,"If this is an established package, you may enter one of the prefixes",!?5,"listed in the right column below."
	S DIC=9.4,DIC(0)="QE",DIC("W")="W ?35,$P(^(0),U,2)",DIZ=15 D ^DIC K DIC,DIZ Q
	;
R1	; HELP FOR RTN NAME
	W !?5,"Answer YES if you want to create a program called "_X W:$D(Q) !?5,"even though there already is one on file.  (It will be overwritten.)" W !?5,"Answer NO if you don't want to do this." S X=$P(X,"INIT",1) Q
	;
E1	; HELP FOR BRINGING DATA
	W !!?5,"Answer YES if you want to include the data currently in the file",!?5,"in the initialization programs to be created.  A recipient of this",!?5,"package will be able to add this data to his/her system."
	W !?5,"Answer NO if you only want to include the dictionaries.",! Q
	;
S	; HELP FOR SECURITY CODES
	W !?5,"Answer YES if you want to include the security protection currently on",!?5,"the files in this package in the initialization programs.  A recipient of",!?5,"this package will be able to decide whether or not to accept these codes."
	W !?5,"Answer NO if you do not want to include security codes." Q
	;
M	; HELP FOR MAX RTN SIZE
	W !?5,"Enter the maximum number of characters you would like each routine",!?5,"contain.  This number must be between 2000 and 10000." Q
	;
MSG	; HELP FOR MAILMAN MESSAGE
	W !?5,"Answer with Yes if you are going to send this Package over"
	W !?5,"the Network as a message.  If not, Answer NO and the DIFROM"
	W !?5,"will act the same" Q
	;
Q1	; HELP FOR SCRAMBLE PASSWORD
	W !?5,"The scramble password is a private code, which must be "
	W !?5,"exactly correct for a reader to to see the message legibly"
	W !?5,"It may be from 3 to 20 characters long.  Upper and lower"
	W !?5,"case characters are treated as the same.",! Q
	;
Q3	; HELP FOR SCRAMBLE HINT
	W !?5,"A scramble hint is used to suggest to the reader what"
	W !?5,"the scramble password is.  Since the password is not"
	W !?5,"recorverable after it is entered, the hint can be a "
	W !?5,"helpful reminder to the reader of the message.  The"
	W !?5,"hint will be shown to the recipient just before he "
	W !?5,"is asked to enter the password.",! Q
R3	;DATA DICTIONARIES
	W !?5,"Enter Yes if you wish to transport dictionaries"
	W !?5,"or NO if you just want to Transport Options,Keys"
	W !?5,"Help Frames etc. in the Difrom.",! Q
NOPKG	; TEMPLATES WITH NON-PACKAGE FILE PREFIX
	W !!?5,"If YES, then ALL of the templates belonging to the files"
	W !?5,"selected will be included in the initialization routines."
	W !?5,"If NO, only NAMESPACED templates will be included.",!
	Q

DIFROMH1
DIFROMH1	; SF/XAK - HELP FOR ANSWERING DIFROM PROMPTS ;01:21 PM  May 11, 1988
	;;17.7;VA FileMan; 6/9/89
REP	;CHANGING YOUR FILE NAME
	W !!?5,"If YES, this will change the existing file name"
	W !?5,"to the incoming file name."
	W !?5,"If NO, it then will go on to the next Question.",!
	Q
CHG	;KEEPING YOUR OLD DATA
	W !!?5,"This allows you to keep your old data if you wish."
	W !?5,"I suggest if you get to this"
	W !?5,"question Just Default to the Question.",!
	Q
TEMP	;DELETING THE TEMPLATES
	W !!,"This will allow you to Delete or Keep the"
	W !,"(Sort,Print,Input) Templates if you wish.",!
	Q
AG	;DELETING FILES THAT ARE THE SAME
	W !!?5,"Enter Yes if you wish to Delete your file"
	W !?5,"This will overwrite your file with my file"
	W !?5,"If you wish to save your file please say"
	W !?5,"NO.  It will then Quit the INIT Process.",!
	Q

DIG
DIG	; SF/GFT - SCATTERGRAM ;3/31/89  15:06
	;;17.7;VA FileMan; 6/9/89
	I '$D(^DOSV(0,IO(0),2)) W !,"NO SUB-SUB TOTALS WERE RUN" Q
	K ZTSK S:$D(^%ZTSK) %ZIS="QM" D ^%ZIS G END:IO="",QUE:$D(IO("Q"))
DQ	S C(1)=^DOSV(0,IO,"BY",1),C(2)=^(2),X=$O(^DOSV(0,IO(0),2,"")),(DXMIN,DXMAX)=X,(DYMIN,DYMAX)=$O(^(X,"")),X=""
	F C=1,2 S C(C,0)=$S($D(^DD(+C(C),+$P(C(C),U,2),0)):$P(^(0),U,2),1:$P(C(C),U,7))
	F C=0:0 S X=$O(^DOSV(0,IO(0),2,X)) Q:X=""  S:X>DXMAX DXMAX=X S Y=$O(^(X,"")),DY=Y S:Y<DYMIN DYMIN=Y D A S:DYMAX<DY DYMAX=DY
	I DXMAX-DXMIN*(DYMAX-DYMIN)=0 W *7,!,"NO RANGE OF VARIABLES" Q
	S H=DYMAX,L=DYMIN,DYS=IOSL-9,N=DYS/6,C=2 D S S DYMIN=B,DYSC=I/6,DYMAX=T,DYI=X
DYI	I T-B/DYI*6'>DYS S DYI=DYI\2 G DYI
	S H=DXMAX,L=DXMIN,DXS=IOM-28,N=DXS/6,C=1 D S S DXMIN=B,DXSC=I/6,DXI=X,DXMAX=T,T=X*DXS/(T-B),H=-1
LOOP	K ^UTILITY($J) S H=$O(^DOSV(0,IO(0),"F",H)) I H S X=^(H) U IO W @IOF,?22,$N(^DD(+X,0,"NM",0))," ",$P(X,U,$P(X,U,2)'=.01*3)," COUNT   " S (B,DX,DY)="" D I2 G LOOP:X'=U
END	K:$D(ZTSK) ^DOSV(0,IO) D CLOSE^DIO4
	K %H,%T,%Y,%D,B,I,L,H,T,C,X,Y,POP,IOP,DX,DY,DXS,DYS,DXSC,DYSC,DXMIN,DYMIN,DXMAX,DYMAX,DXI,N,DYI Q
	;
I2	S (DX,X)=$O(^DOSV(0,IO(0),2,DX)) I X="" W "(TOTAL = "_B_")",! G O
	I C(1,0)["D" D H^%DTC S X=%H
	S X=$J(X-DXMIN/DXSC,0,0)
I3	S (Y,DY)=$O(^DOSV(0,IO(0),2,DX,DY)) G I2:Y="" I C(2,0)["D" S C=X,X=Y D H^%DTC S Y=%H,X=C
	G I3:'$D(^(DY,H,"N")) S C=^("N"),Y=$J(Y-DYMIN/DYSC,0,0),B=B+C,^(X)=C+$S($D(^UTILITY($J,Y,X)):^(X),1:0) G I3
	;
A	F C=0:0 S Y=$O(^(DY)) Q:Y=""  S DY=Y
	Q
	;
O	S X=0 D X W !?12,"." D P K Y S L=0 F B=DYMIN:DYI:DYMAX S C=2,Y=B D Y S Y($J(L,0,0))=Y,L=DYI*DYS/(DYMAX-DYMIN)+L
	W ".",! F Y=DYS:-1:0 D LINE W !
	W ?13 D P W ! S X=DXI D X W !?22,"X-AXIS: ",$P(C(1),U,3),"    Y-AXIS: ",$P(C(2),U,3) I IOST?1"C".E W *7 R X:DTIME S:'$T X=U
	Q
	;
P	S L=-1,X=0
PP	I L<X W "+" S L=L+T
	E  W "-"
	S X=X+1 G PP:X'>DXS Q
	;
X	F B=DXMIN+X:DXI*2:DXMAX S Y=B,C=1 D Y W ?B-DXMIN\DXSC-($L(Y)\2)+13,Y
	Q
Y	S C=C(C,0) I C["D" S %H=Y D 7^%DTC S Y=X
	G S^DIQ
	;
LINE	I $D(Y(Y)) W ?12-$L(Y(Y)),Y(Y),"+"
	E  W ?12,"|"
	F X=-1:0 S X=$N(^UTILITY($J,Y,X)) Q:X<0  S I=^(X) W ?X+13,$S(I>9:"*",I:I,1:"")
	W ?DXS+14 I  W "+",Y(Y) Q
	W "|" Q
	;
S	I C(C,0)["D" F B="H","L" S X=@B D H^%DTC S @B=%H
	S B=H-L,X=1 I B>1 F C=1:1 S X=X*10 Q:B'>X
	E  S I=1 Q:'B  F C=0:-1 Q:X/10'>B  S X=X/10
	S B=L-X\X*X F I=B:X/10 Q:I'<L  S B=I
	S T=H+X\X*X F I=T:-X/10 Q:I'>H  S T=I
I	S I=T-B/X*10 I I>N S X=X*2 G I
	S X=X/10,I=T-B/N
	Q
QUE	;
	S ZTSAVE("^DOSV(0,$I,")=""
	S ZTIO=ION_";"_IOST_";"_IOM_";"_IOSL,ZTRTN="DQ^DIG"
	D ^%ZTLOAD K ZTSK G END

DIH
DIH	; SF/GFT - HISTOGRAM ;3/31/89  14:26 ;
	;;17.7;VA FileMan; 6/9/89
	I $O(^DOSV(0,IO(0),0))'>0 W !,*7,"NO SUB-COUNTS WERE RUN" Q
	K ZTSK S:$D(^%ZTSK) %ZIS="QM" D ^%ZIS G END:IO="",QUE:$D(IO("Q"))
DQ	S (IO(0),J)=$I,DN="=$O(^DOSV(0,J," F X=0:1 Q:'$D(^DOSV(0,J,"BY",X+1))
	G END:'X S A=^(1),DD=$P(A,U,3) I $D(^DD(+A,+$P(A,U,2),0)) S DD=^(0)
	S T=$P(DD,U,2),DP=$P(DD,U,3),DF=$S(T["S":1,T["P":2,T["D"!($P(A,U,7)["D"):3,1:0)
	S DMX=DN_X,DX="",F=X
F	S DMX=DMX_",D"_F,DX=DX_"S D"_F_"="""" F X=X:0 S D"_F_DMX_")) Q:D"_F_"=""""  "_$P("S X=X+1,DS(X)=0,DD(X)=0,DV(X)=D"_X_" ",U,F=X),F=F-1 G F:F
	S DX=DX_"S:$D(^(D1,F,""N"")) DD(X)=DD(X)+^(""N"") S:$D(^(""S"")) DS(X)=DS(X)+^(""S"")"
	S F=-1,C="*",IOM=IOM-23,IOSL=IOSL-8 U IO W @IOF
I	S @("F"_DN_"""F"",F))") I 'F G END
	S X=0,T=^(F),DS=1 X DX S DIH=X
	D MAX G I
	;
MAX	S DMX=0 F N=1:1:DIH S:DD(N)>DMX DMX=DD(N) D LBL:DS=1&DF S DV(N)=$E(DV(N),1,14)
	S X=1 F S=1:1 S X=X*2 Q:DMX'>X
	S D1=DMX+X\X*X F S=D1:-X/2 Q:S'>DMX  S D1=S
	S D2=IOM*X/D1
XX	S X=X\2,D2=D2\2 I X>4,$L(X)+7<D2 G XX
	I DMX S S=D1/IOM,D1=D2 F X=1:1:DIH D HD:X=1!'(X-1#IOSL),LN,TR:X=N!'(X#IOSL) I Y=U Q
SUM	Q:$P(T,U,4)["D"!(Y=U)  I DS=1 S DS=2 F N=1:1 G:N>DIH MAX S S=DD(N),DD(N)=DS(N),DS(N)=S
MEAN	I DS=2 S DS=3 F N=1:1 S DD(N)=$S(DS(N):DD(N)/DS(N),1:0) G MAX:N=DIH
	Q
	;
END	K:$D(ZTSK) ^DOSV(0,IO) D CLOSE^DIO4
	K ZTSK,DIH,S,A,C,DD,DS,D1,D2,DN,T,DP,F,N,J,POP,DF,X,Y,DX,DMX,DV Q
	;
LBL	I DF=1 S D1=$F(DP,DV(N)_":") S:D1 DV(N)=$P($E(DP,D1,999),";",1) Q
	I DF=2 S DV(N)=$P(@(U_DP_DV(N)_",0)"),U,1) Q
	S D1=$E(DV(N),6,7),D2=$E(DV(N),4,5),DV(N)=$P(+D2_"-",U,D2>0)_$P(+D1_"-",U,D1>0)_(DV(N)\10000+$S(D2:-200,1:1700)) Q
	;
HD	U IO W:$Y+N+1>IOSL @IOF W !!?27,$P("COUNT^SUM^MEAN",U,DS),", " I $D(^DD(+T,0)) S Y=+$P(T,U,2) I Y>.01,$D(^(Y,0)) W $P(^(0),U,1),", "
	W "BY ",$P(DD,U,1),!! Q
LN	W ?15-$L(DV(X))-1,DV(X)," |" F Y=1:1:DD(X)/S W C
	W ! Q
TR	W ?15 F Y=0:1:IOM W $E("-+",Y#D1=0+1)
	W ! F Y=1:1:IOM I Y#D1=0 S D2=$J(Y*S,0,0) W ?Y+15-($L(D2)\2),D2
	I IOST?1"C".E W *7 R Y:DTIME
	Q
QUE	;
	S ZTSAVE("^DOSV(0,$I,")=""
	S ZTIO=ION_";"_IOST_";"_IOM_";"_IOSL,ZTRTN="DQ^DIH"
	D ^%ZTLOAD K ZTSK G END
	;

DII
DII	; SF/GFT,XAK - OPTION RDR, INQUIRY ;4/17/89  12:18
V	;;17.7;VA FileMan; 6/9/89
	W !!,"VA FileMan "_$P($T(V),";",3),!
NOKL	D DT^DICRW,OS S DIK="^DOPT(""DII""," G F:$D(^DOPT("DII",9)) S ^(0)="OPTION^1.01^" F I=1:1 S X=$E($T(F+I),4,99) Q:X=""  S ^DOPT("DII",I,0)=X
	D IXALL^DIK
F	S DIC=DIK,DIC(0)="AEQZ" D ^DIC K DIC,DIK G Q:Y<0 S X=$P(Y(0),U,2,99) K Y D @X W !!! D Q G NOKL
	;;ENTER OR EDIT FILE ENTRIES^^DIB
	;;PRINT FILE ENTRIES^^DIP
	;;SEARCH FILE ENTRIES^^DIS
	;;MODIFY FILE ATTRIBUTES^^DICATT
	;;INQUIRE TO FILE ENTRIES^INQ^DII
	;;UTILITY FUNCTIONS^^DIU
	;;STATISTICS^^DIX
	;;LIST FILE ATTRIBUTES^^DID
	;;TRANSFER ENTRIES^^DIT
	;
Q	D Q^DIB,Q^DICATT2 K DK,DIACD,DIQ,DX,DQI,DISYS,DHIT,%X,%Y,%,DXS,Q,DNP,DCC,DIJ,DP,DM,DQ,DICATT,DIFLD,D0,DIEL,DL,DC,DU,DIP,DH,DIYS,DINS,DIPT,DHD,DCL,DPP,DPQ,DALL Q
INQ	;
	W !! D ^DICRW Q:'$D(DIC)  S DI=DIC,DPP(1)=+Y_"^^^@",DK=+Y I $D(DICS) S DICSS=DICS
B	K ^UTILITY($J),^(U,$J),DIC,DIQ,DISV,DIBT,DICS S DIC=DI,DIC(0)="AEQM",DIK=0
R	D ^DIC I Y>0 S DIK=DIK+1,^UTILITY(U,$J,DIK,+Y)="",DIC("A")="ANOTHER ONE: " G R
S	G Q^DIP:'DIK!(X=U) I DIK>3 R !,"STORE THESE ENTRY ID'S IN TEMPLATE: ",X:DTIME G Q^DIP:X=U!'$T I X]"" D MRG^DIBT G:Y<0 Q^DIP:X=U,S F X=1:1:DIK S ^DIBT(+Y,1,$N(^UTILITY(U,$J,X,0)))=""
O	K DIC Q:$D(DTOUT)  S DIC=DI,%=1
	W !,"STANDARD CAPTIONED OUTPUT" D YN^DICN G Q^DIP:%<0
	I '% W !?5,"Answer 'N' to create a formatted dislay as in the Print Option." G O
	I %=2 S L=1,Q="""",DPP=1,DPP(1,"IX")="^UTILITY(U,$J,"_DI_"^2" S:$D(DICSS) DICS=DICSS G N^DIP1
C	S %=2 W !,"DISPLAY COMPUTED FIELDS" D YN^DICN G Q:%<0
	I '% W !?5,"Answer 'Y' to have computed fields evaluated and displayed." G C
	S DIQ(0)=$S(%=1:"C",1:"")
AD	I $D(^DIA(DK)) S %=2 W !,"DISPLAY AUDIT TRAIL" D YN^DICN G Q:%<0 S:%=1 DIQ(0)=DIQ(0)_"A" I '% W !?5,"Answer 'Y' to display the audit trail for each Entry." G AD
	S IOP="HOME" D ^%ZIS I $D(DICSS) S DICS=DICSS
	S S=1 F DIK=1:1:DIK S DA=$N(^UTILITY(U,$J,DIK,0)),DIC=DI,E="N<0",N=-1,DD=DK W ! X:DIK>1 DX(0) Q:'S  D GUY^DIQ Q:'S  I DIQ(0)["A",$D(^DIA(DK,"B",DA)) D AUD
	W !! Q:$D(DTOUT)  G B
	;
P	G Q^DI
	;
OS	I $D(^%ZOSF("OS"))#2 S DISYS=+$P(^("OS"),"^",2) Q:DISYS>0
	S DISYS=$S($D(^DD("OS"))#2:^("OS"),1:100)
	Q
AUD	S DIACD=DIQ(0),DIQ(0)="C",DIQ=DA
	F DA=0:0 S DA=$N(^DIA(DK,"B",DIQ,DA)) Q:DA'>0  S DIC="^DIA("_DK_",",E="N<0",N=-1,DD=1.1,DIA=DK D GUY^DIQ Q:'S  W !
	S DIQ(0)=DIACD Q

DIIS
DIIS	; SF/GFT - DELETE THIS LINE AND SAVE AS '%ZIS' IF YOU DON'T HAVE A '%ZIS' ROUTINE ;3/27/89  17:21 ;
	;;17.7;VA FileMan; 6/9/89
%ZIS	;
	I $D(IOP)#2 S IO=$I G PARAMS
	S IO=$I ;READ "DEVICE: ",IO ;INSERT DEVICE SELECTION HERE
PARAMS	S IOM=80,IOSL=24,IOF="#",IOST="C",IOPAR="",POP=0,ION=$P(IO,";")

DIK
DIK	; SF/GFT,XAK - GATHER A FILE'S XREFS TO EXECUTE ;5/25/89  16:16 ;
	;;17.7;VA FileMan; 6/9/89
	I '$D(@(DIK_"DA)")) Q
	D CHKS I $D(DIKZ1) S DIKIL=1 G @DIKGP
	S X=2 D DD G ^DIK1
	;
DD1	D D,A Q
DD	K DIKS,DIN,DH,DU,DV,DW S U="^",DH=+$P(@(DIK_"0)"),U,2),DH(1)=DH,DV=0 D D,A
E	S DV=$N(^DD(DH,"SB",DV))
	I DV>0 S DU=$N(^(DV,0)),DW=$P($P(^DD(DH,DU,0),U,4),";") S:+DW'=DW DW=""""_DW_"""" S DV(DH,DU)=DW,DV(DH,DU,0)=DV,DU(DV)="" D:$D(DIK0) CRT^DIKZ2 G E
	Q:$D(DIK0)
DH	S DH=$N(DU(DH)) G:DH>0 DH:$D(DV(DH)),E
	F DH=DH(1):0 S DH=$N(DU(DH)) Q:DH<0  D D,A
	S DH=DH(1),DU=1
DV	I $N(^UTILITY("DIK",$J,DH))>DH S DH=$N(DV(DH)) G DV:DH>0 Q
K	K DV(DH) S DH=$N(DV(DH)) G K:DH>0 Q
	;
DW	I $N(^UTILITY("DIK",$J,DH,DV,0))<0 K ^UTILITY("DIK",$J,DH,DV)
D	S DV=$N(^DD(DH,"IX",DV)) Q:DV<0  I '$D(^DD(DH,DV,0)) K ^DD(DH,"IX",DV) G D
	D 0
I	S DW=$N(^DD(DH,DV,1,DW)) G DW:DW<0,I:'$D(^(DW,X)),I:"Q"[^(X)!'$D(^(0)) S %=^(0)
	I %["TRIGGER" S %=^(X),^UTILITY("DIK",$J,DH,DV,DW)="D RCR",^(DW,0)=% G I
	I %["BULLETIN MESSAGE",$D(DIK(0)),DIK(0)["B" S %=$P("CREA^DELE",U,X)_"TE VALUE" W:$D(^(%)) !,"...('"_^(%)_"' BULLETIN WILL NOT BE TRIGGERED)..." G I
	S ^UTILITY("DIK",$J,DH,DV,DW)=^(X) G I
A	F DV=0:0 S DV=$N(^DD(DH,"AUDIT",DV)) Q:DV<0  D 0 S ^UTILITY("DIK",$J,DH,DV,99)="S DIIX="_(4-X)_" D AUDIT"
	Q
0	;
	S DW=$P(^DD(DH,DV,0),U,4),^UTILITY("DIK",$J,DH,DV)=$P(DW,";",1),DW=$P(DW,";",2)
	S ^UTILITY("DIK",$J,DH,DV,0)=$S(DW:"S X=$P(^(X),U,"_DW_")",1:"S X=$E(^(X),"_+$E(DW,2,9)_","_$P(DW,",",2)_")"),DW=0 Q
	;
IX	;
	D CHKS I $D(DIKZ1) S DIKKS=1 G @DIKGP
	S X=2,DIKNM=1 D DD,1^DIK1
IX1	;
	I '$D(DIKNM) D CHKS I $D(DIKZ1) S DIKST=1 G @DIKGP
	S X=1 D DD G 1^DIK1
	;
IXALL	;
	D CHKS I $D(DIKZ1) S DIKSAT=1,DA=0 G @DIKGP
	S (DA,DCNT)=0,X=1 D DD
	G CNT^DIK1
CHKS	;
	I '$D(@(DIK_"0)"))#2 S DIKZ1=1,DIKGP="Q^DIK1" Q
	S DIKZ1=+$P(^(0),"^",2) I DIKZ1,$D(^DD(DIKZ1,0,"DIK")) S DIKGP="^"_^("DIK") Q
	K DIKZ1 Q

DIK1
DIK1	; SF/GFT - ACTUAL INDEXER ;5/25/89  16:25 ;
	;;17.7;VA FileMan; 6/9/89
	D DI K @(DIK_"DA)") G Q:'$D(^(0))
	S Y=^(0),DH=$S($N(^(0))'>0:0,1:$P(Y,U,4)-1),X=$P($P(Y,U,3),U,DH>0) D 3:X=DA
	S ^(0)=$P(Y,U,1,2)_U_X_U_DH
Q	K ^UTILITY("DIK",$J),DB(0),DIKJ,DIKYR,DIKNM,DIKS,DIN,DH,DU,DV,DW,DIAU,DIKDA,DIKF,DIIX,DIKIL,DIKZ1,DIKGP,DIKKS,DIKSAT Q
	;
3	I X>1,$D(^(X-1)) S X=X-1 Q
	S DV=1 F X=X:1 S X=X+DV,DV=DV+1 I $N(^(X))'>0 S DU=X-2,DV=1 Q
L	S X=$N(^(DU)) Q:X>0  S DU=DU-DV,DV=DV+1 S:DU<0 DU=0 G L
	;
DI	S (DIC,DIN)=DIK,DH=DH(DU) F DV=1:0 S DV=$N(DA(DV)) Q:DV'>0  S DU=DU+1
DIN	F DV=0:0 S DV=$N(^UTILITY("DIK",$J,DH,DV)) Q:DV<0  D R:DV-.01
DVA	S DV=$N(DV(DH,DV)) I DV<0 S DV=.01 D R:$D(^UTILITY("DIK",$J,DH,DV)) Q
	S X=DIN_DA_","_DV(DH,DV) I @("'$D("_X_"))") G DVA
	S DU(DU)=DIN,DIN=X_",",DH(DU)=DH,DH=DV(DH,DV,0),DV(DU)=DV,DU=DU+1 F X=DU:-1:1 I $D(DA(X)) S DA(X+1)=DA(X)
	S DA(1)=DA,DA=0
DA	S @("DA=$N("_DIN_"DA))") I DA>0 D DIN G DA
	S DU=DU-1,DIN=DU(DU),DH=DH(DU),DV=DV(DU),DA=DA(1) K DA(1) F X=2:1 G DVA:'$D(DA(X)) S DA(X-1)=DA(X) K DA(X)
	;
R	S X=^UTILITY("DIK",$J,DH,DV),%=^(DV,0) I @("$D("_DIN_DA_",X))[0") Q
	X % Q:X?." "  S DIKS=X,DW=0
XEC	S DW=$N(^UTILITY("DIK",$J,DH,DV,DW)) Q:DW<0  X ^(DW) S X=DIKS G XEC
	;
RCR	K Y,%RCR F %="DIKS","DIK","DW","DH","DIN","DU","DV","X" S %RCR(%)=""
	S %RCR="RR^DIK1",Y=^UTILITY("DIK",$J,DH,DV,DW,0) G STORLIST^%RCR
	;
RR	X Y Q
	;
AUDIT	G SET:$D(DIAU(DH,DV)) S %F=DH,%=DU I $D(^DD(%F,0,"UP")) F %=1:1 Q:'$D(^DD(%F,0,"UP"))  S %D=%F,%F=^("UP"),DV(%)=$N(^DD(%F,"SB",%D,0))
	S DIKDA="",DIKF="" F %=%-1:-1:1 S DIKDA=DIKDA_DA(%)_",",DIKF=DIKF_DV(%)_","
	D ADD^DIET S DIAU(DH,DV)="^DIA("_%F_","_+Y_",",^DIA(%F,%D,0)=DIKDA_DA_U_%T_U_DIKF_DV_U_DUZ,^DIA(%F,"B",DIKDA_DA,%D)=""
SET	S (%F,C)=$P(^DD(DH,DV,0),U,2),Y=X D Y^DIQ S @(DIAU(DH,DV)_"DIIX)")=Y
	I %F["P"!(%F["V")!(%F["S") S ^(DIIX+.1)=X_U_%F
	K %F,%T,%D Q
	;
1	;
	L @(DIK_DA_")") D DI L  G Q
	;
CNT	;
	S DU=$E(DIK,1,$L(DIK)-1) L @($S(DIK[",":DU_")",1:DU))
C	I @("$N("_DIK_"DA))'>0") S ^(0)=$P(^(0),U,1,2)_U_DA_U_DCNT K DCNT L  G Q
	S DA=$N(^(DA)),DU=1,DCNT=DCNT+1 W:(DCNT#100=0) "." D DI K DB(0) G C

DIKZ
DIKZ	; SF/XAK - XREF COMPILER ; 12/1/88  09:30 ;
	;;17.7;VA FileMan; 6/9/89
	I $S($D(DUZ(0)):DUZ(0)'="@",1:1) W *7,"FOR PROGRAMMERS ONLY." Q
EN1	D:'$D(DISYS) OS^DII
	I '$D(^DD("OS",DISYS,"ZS")) W "YOUR MUMPS SYSTEM HAS NO WAY TO SAVE ROUTINES",*7 Q
	S T=^DD("ROU"),U="^"
	W !!,"MAXIMUM ROUTINE SIZE ON THIS COMPUTER (IN BYTES): "_T_"// "
	R X:$S($D(DTIME):DTIME,1:300) G Q:X["^"!'$T S:X="" X=T
	I +X=X,X>2400 S ^("ROU")=X G FILE
	W *7,!,"Your answer must be a number larger than 2400." G EN1
FILE	K DIC S DMAX=X,DIC="^DIC(",DIC(0)="AEQ" D ^DIC G Q:Y'>0
DNM	S %="" W !,"NAME OF ROUTINE TO BE CREATED: "
	I $D(^DD(+Y,0,"DIK")) S %=^("DIK") W %_"// "
	R X:$S($D(DTIME):DTIME,1:300) S:X="" X=% G Q:U[X!'$T
	I X'?1U.NU!($L(X)>7)!($L(X)<3)!(X?1"DI".E) W *7,!?3,"USE A VALID MUMPS ROUTINE NAME OF FROM 3 TO 7 CHARACTERS" G DNM
	I $D(^DD("OS",DISYS,18)) X ^(18) I  W *7,!,"NOTE THAT '",X,"' IS ALREADY IN YOUR ROUTINE DIRECTORY!"
	W !,"READY TO COMPILE" S %=0 D YN^DICN G Q:%-1
EN	;
	W ! K ^UTILITY($J),DIK,^UTILITY("DIK",$J)
	S DNM=X,DH=+Y I $D(^DIC(+Y,0,"GL")) S DIK2=^("GL")
	I '$D(DIK2)!(DMAX<2400) G Q
	D WAIT^DICD,DT^DICRW,OS^DII:'$D(DISYS) S (DIKA,A)=1,DRN=0
	S DIKGO="^"_DNM_1,DMAX=DMAX-100,DIK=DIK2,X=2,DIKVR="DIKILL"
	D NEWR S ^UTILITY($J,0,3)=" S DIKZK=2" D ^DIKZ0,RTE
