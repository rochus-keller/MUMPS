	G TYPE
	;
E	S DE=^DD(A,E,0) W $P(DE,U,1) Q
	;
X	W *7,"    '",F,"' DELETED!" S DIK="^DD(A,",DA(1)=A D ^DIK G N
	;
CHECK	G X:$P(^DD(A,DA,0),U,2)']"",NO
	;
0	S C=$P(O,U,5,99) G @N
