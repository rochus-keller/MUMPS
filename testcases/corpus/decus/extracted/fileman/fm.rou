GOT	S X=DN_$E(" [?<=>",DQ)_Y X:E["D" ^DD("DD") S O(DC)=O(DC)_" "_O_" "_Y
OK	S DC(DC)=DV_DU_U_X,%=DL-1_U_(N#100) I DL>1,O(DC)'[R S O(DC)=R_" "_O(DC)
