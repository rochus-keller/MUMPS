	S D=$S($D(^(DG,0)):$P(^(0),U,3,4),1:$N(^(0)))
DE	I D>0 S Y=Y_U_D I DP(0)-Y,$D(^(+D,0)) S DE(DQ)=$P(^(0),U,1)
DC	S DC=$P(^DD(+Y,0),U,4)_U_Y,%=DQ(DQ),Y=^(.01,0),DQ(DQ)="Select "_$P(Y,U,1)_U_1_$P(Y,U,2,99) G D:$P(Y,U,2)'["W"
