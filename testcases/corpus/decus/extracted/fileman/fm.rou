DICRW	; SF/XAK - SELECT A FILE ;2/6/89  11:0 ;
	;;17.7;VA FileMan; 6/9/89
R	D DT G DIAR:$D(DIAR) S D="OUTPUT FROM",DIC(0)="QEI",DIA=$S($D(^DISV(DUZ,"^DIC(")):^("^DIC("),1:"")
