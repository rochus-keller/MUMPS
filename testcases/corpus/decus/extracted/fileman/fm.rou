TRIG	S W1="W:$Y ! W !,""A FIELD IS"",!,""TRIGGERED BY :"",?15",DDPT=1
	K X F X=-1:0 S X=$N(^DD(DA,"TRB",X)) Q:X<0  I X-DA,'$D(^DD(DA,"SB",X)) F %=0:0 S %=$N(^DD(DA,"TRB",X,%)) Q:%<0  F %X=0:0 S %X=$N(^DD(DA,"TRB",X,%,%X)) Q:%X<0  F %Y=0:0 S %Y=$N(^DD(DA,"TRB",X,%,%X,%Y)) Q:%Y'>0  D TT
	I $D(X)>9 F %X=0:0 S %X=$N(X(%X)) Q:%X<0  F X=0:0 S X=$N(X(%X,X)) Q:X<0  S %F=X,%=%X D WR:$D(^DD(%,X,0)) W !?15 D:'$D(DIU) H I 1
	K X,%X,%Y,W1,DDPT Q
