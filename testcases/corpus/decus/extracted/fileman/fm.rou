FILE	;
	K DQ Q:$D(DG)<9  S DQ=-1,DU=-2,DG="$D("_DIE_DA_",DU))"
Y	S DQ=$N(DG(DQ)),DW=$P(DQ,";",2) G DE:$P(DQ,";",1)=DU
	I DU'<0 S ^(DU)=DV,DU=-2
	G E1:DQ<0 S DU=$P(DQ,";",1),DV="" I @DG S DV=^(DU)
DE	I 'DW S DW=$E(DW,2,99),DE=DW-$L(DV)-1,%=$P(DW,",",2)+1,X=$E(DV,%,999),DV=$E(DV,0,DW-1)_$J("",$S(DE>0:DE,1:0))_DG(DQ) S:X'?." " DV=DV_$J("",%-DW-$L(DG(DQ)))_X G Y
PC	S $P(DV,U,DW)=DG(DQ) G Y
	;
IX	D @DE(DQ)
K	K DE(DQ)
E1	S DQ=$N(DE(" ")) I DQ+1 G IX:$D(DG(DQ)),K
	K DG,DE,DIFLD S DQ=0 Q
	;
1	;
	D FILE
R	D UP G @("R"_DQ_U_DNM)
	;
UP	S DNM=DNM(DL),DQ=DNM(DL,0) K DTOUT,DNM(DL) I $D(DIEC(DL)) D DIEC^DIE1 G U
	S DIEL=DIEL-1,%=2,DA=DA(1) K DA(1)
DA	I $D(DA(%)) S DA(%-1)=DA(%) K DA(%) S %=%+1 G DA
U	S DL=DL-1 Q
	;
X	W *7,"??" G Z:$D(DB(DQ))
B	G @(DQ_U_DNM)
	;
N	;
	D DOWN S DA=$P(DC,U,4),D=0 S ^DISV(DUZ,$E(DIC,1,28))=$E(DIC,29,999)_DA
D1	S @("D"_DIEL)=DA G @(DGO)
	;
M	;
	S DD=X D DOWN S DO(2)=$P(DC,"^",2),DO=DOW_"^"_DO(2)_"^"_$P(DC,"^",4,5),DIC(0)=$P("QE",U,'$D(DB(DNM(DL,0))))_"LM" I @("'$D("_DIC_"0))") S ^(0)="^"_DO(2)
	E  I DO(2)["I" S %=0,DIC("W")="" D W^DIC1
	K DICR S D="B",DLAYGO=DP\1,X=DD D X^DIC
	I Y>0 S DA=+Y,X=$P(Y,U,2),D=$P(Y,U,3) G D1
	D UP G @(DQ_U_DNM)
	;
DOWN	S DL=DL+1,DNM(DL)=DNM,DNM(DL,0)=DQ D FILE
	F %=DL+1:-1:1 I $D(DA(%)) S DA(%+1)=DA(%)
	S DA(1)=DA,DIC=DIE_DA_","""_$P(DC,U,3)_""",",DIEL=DIEL+1 Q
	;
ABORT	D E S Y(DM)="" Q
	;
0	;
	D FILE
E	K DIP,Y,DE,DOW,DB,DP,DW,DU,DC,DV,DH,DIL,DNM,DIEZ,DLB,DIEL,DGO
	Q

DIE2
DIE2	; SF/GFT,XAK - DELETE AND ENTRY ;5/11/89  07:59 ;
	;;17.7;VA FileMan; 6/9/89
	D F,DL Q:$D(DTOUT)  G B^DIED:Y=2,A^DIED:Y,UP^DIE1:DL>1,Q^DIE1
	;
F	S D=$P(DQ(DQ),U,4) S:DP+1 D=DIFLD Q
	;
Z	D DL S DU="" I Y=2 G @(DQ_U_DNM)
	I Y G @("A^"_DNM)
	G R^DIE9:DL>1,E^DIE9
DL	;
	S %=DP,X=D,Y=$P(DQ(DQ),U,4)="0;1"
	G X:$D(DE(DQ))[0,X:DV["R"&'Y,S:DP<0,DD:DUZ(0)="@" I DV S %=+$P(DC,U,2),X=.01
	G DD:DP<2 I $D(DIDEL),DIDEL\1=(DP\1) G DD
	I Y,$D(^DIC(3,"AFOF")) G DD:$D(^DD(DP,0,"UP"))!DV,DAR:'$D(^DIC(3,DUZ,"FOF",DP)),DAR:'$P(^(DP,0),U,3),DD
	I Y,$D(^DIC(%,0,"DEL")) S X=^("DEL")
	E  G DD:'$D(^DD(%,X,8.5)) S X=^(8.5)
	G DD:X="" F %=1:1:$L(X) G DD:DUZ(0)[$E(X,%)
DAR	W !,"'DELETE ACCESS' REQUIRED!!"
X	I $D(DB(DQ)) D N G A
	W:'$D(DIER) *7,"??" W:DV["R"&'$D(DIER) "  Required" G R
DD	G MD:DV S DH=0 F DU=0:0 S DH=$N(^DD(DP,D,"DEL",DH)) Q:DH<0  I $D(^(DH,0)) X ^(0) Q:$D(DTOUT)  G X:$T
	S X=DQ(DQ) I Y,$E(@(DIE_"0)"))'=U S X=^(0)
	D D G R:X I Y S X=DE(DQ) D DEL:$D(DIU(0)) K DE,DG,DQ,DB S DIK=DIE D ^DIK S Y=0 K:DL<2 DA Q
S	S X="",DG($P(DQ(DQ),U,4))=""
A	S Y=1 Q
	;
D	I $D(DB(DQ)) S X=0 Q
	W *7,!?3,"SURE YOU WANT TO DELETE"
	I Y W " THE ENTIRE " W:DV'["D"&(DV'["P")&(DV'["V") "'"_DE(DQ)_"' " W $P(X,U,1)
	S %=0,X=0 D YN^DICN Q:%=1  S X=1 W:$X>55 !?9
N	I $D(DE(DQ))#2 W *7,"  <NOTHING DELETED>"
	Q
	;
MD	G X:DV["R"&($P(DC,U,5)=1) S DH=0 F DU=0:0 S DH=$N(^DD(+$P(DC,U,2),.01,"DEL",DH)) Q:DH<0  I $D(^(DH,0)) D DDA X ^(0) D UDA G X:$T
	S Y=DC>1,X=$E(DQ(DQ),8,99) D D
	I 'X D DDA S DIK=DIC D ^DIK,UDA K DE(DQ) S X=$P(@(DIK_"0)"),U,3,4),DC=$P(DC,U,1,3)_U_X,DIC=DIE S:$D(^(+X,0)) DE(DQ)=$P(^(0),U,1)
R	S Y=2 Q
	;
DDA	F X=DL+1:-1:1 I $D(DA(X)) S DA(X+1)=DA(X)
	K DA(DL+2) S DA(1)=DA,DIC=DIE_DA_","""_$P(DC,U,3)_""",",DA=$P(DC,U,4) Q
	;
UDA	S DA=DA(1) F X=2:1 Q:'$D(DA(X))  S DA(X-1)=DA(X) K DA(X)
	Q
QS	;
	G ^DIEQ
QQ	;
	G QQ^DIEQ
	Q
DEL	I '$D(^DIC(3,"AFOF",DA)) Q
	S DA(1)=0,DIFOF=DA F P=0:0 S DA(1)=$N(^DIC(3,"AFOF",DA,DA(1))) Q:DA(1)'>0  I $D(^DIC(3,DA(1),"FOF",DA)) S DIK="^DIC(3,"_DA(1)_",""FOF""," D ^DIK
	K DA S DA=DIFOF K DIFOF
	Q
V	;
	G ^DIE3

DIE3
DIE3	; SF/XAK - PROCESS SINGLE-VALUED VARIABLE PNTR ;4/20/89  10:54 ;
	;;17.7;VA FileMan; 6/9/89
V	;
	S DIEX=X I $D(DNM) S DIDS=D
	G ALL:X'["." S DIVP=$P(X,"."),X=$P(X,".",2),Y=-1 I X="" G Q
	I DIVP]"",$D(^DD(DP,DIFLD,"V","P",DIVP)) S (DIVP,DIVPDIC)=+$O(^(DIVP,0)),DIVPDIC=$S($D(^DD(DP,DIFLD,"V",DIVP,0)):^(0),1:"") G Q:'DIVPDIC D DIC G Q
	S X="",DIVP=$P(DIEX,".",1) F %=0:0 S X=$O(^DD(DP,DIFLD,"V","M",X)) Q:X=""  I $P(X,DIVP,1)="" S (DIVP,DIVPDIC)=+$O(^(X,0)),DIVPDIC=$S($D(^DD(DP,DIFLD,"V",DIVP,0)):^(0),1:""),X=$P(DIEX,".",2) G Q:'DIVPDIC D DIC G Q:Y>0 S X=DIEX
	F DIVP=0:0 S DIVP=$N(^DD(DP,DIFLD,"V",DIVP)) Q:DIVP'>0  I $D(^(DIVP,0)) S DIVPDIC=^(0) I $D(^DIC(+DIVPDIC,0)) S %=$P(^(0),U,1) I $P(%,$P(DIEX,".",1),1)="" S X=$P(DIEX,".",2) D DIC G Q:Y>0 S X=DIEX
	G Q
ALL	F DIVP1=0:0 S DIVP1=$N(^DD(DP,DIFLD,"V","O",DIVP1)) G Q:DIVP1'>0 S DIVP=$N(^(DIVP1,0)) I $D(^DD(DP,DIFLD,"V",DIVP,0)) S DIVPDIC=^(0) D DIC G Q:Y>0 S X=DIEX
	;
DIC	I '$D(^DIC(+DIVPDIC,0,"GL")) S Y=-1 Q
	I $D(DIC("V")) S Y=DIVP,Y(0)=DIVPDIC X DIC("V") I '$T K Y S Y=-1 Q
	I $D(DIVP1),'$D(DB(DQ)) W !!?5,"Searching for a "_$P(DIVPDIC,U,2)
	S DIC=^DIC(+DIVPDIC,0,"GL"),DIC(0)="MD"_$E("E",'$D(DB(DQ)))_$E("L",$P(DIVPDIC,U,6)="y") I $P(DIVPDIC,U,5)="y",$D(^DD(DP,DIFLD,"V",DIVP,1)),^(1)]"" X ^(1)
	D ^DIC S X=+Y_";"_$E(DIC,2,99) K:Y<0 X S %=1
	I Y>0,$D(DIVP1),'$D(DB(DQ)),'$P(Y,U,3),$P(^DIC(+DIVPDIC,0),U,2)'["O" W !?9,"...OK" D YN^DICN S:%=2 Y=-1
	K DIC S DIC=DIE Q
	;
Q	K DIEX,DIVP1,DIVP,DIVPDIC I $D(DNM) S D=DIDS K DIDS G:Y>0 @("V^"_DNM) G X^DIE17:'$D(DB(DQ)),B^DIE17
	Q:$D(DIR)  G V^DIED:Y>0,X^DIED:'$D(DB(DQ)),B^DIE1

DIE9
DIE9	; SF/GFT - JUMPING, FILING, MULTIPLES ;3/27/89  17:19
	;;17.7;VA FileMan; 6/9/89
	G:$A(X)-94 X:'$P(DW,";E",2),@("T^"_DNM)
	I $D(DIE("NO^")),DIE("NO^")="OUTOK"'&(X=U) W *7,!?3,"Sorry, ""^"" is not allowed!" G B
	S X=$P(X,U,2),DIC(0)="E"
OUT	I 0[X S DM=DW D FILE G ABORT:DL=1,R
	I X?1"@".N,$D(^DIE("AF",X,DIEZ)) S DNM=^(DIEZ)
	E  S DIC="^DD("_DP_",",DIC("S")="I $D(^DIE(""AF"","_DP_",Y,DIEZ))" D ^DIC K DIC S DIC=DIE G X:Y<0 S DNM=^DIE("AF",DP,+Y,DIEZ)
	D FILE S Y=DNM,DNM=$P(Y,U,2),DQ=+Y,D=0 D @("DE^"_DNM) G @Y
	;
F	;
	S DC=$S($D(X)#2:X,1:0) D FILE S X=DC Q
FILE	;
	K DQ Q:$D(DG)<9  S DQ=-1,DU=-2,DG="$D("_DIE_DA_",DU))"
Y	S DQ=$N(DG(DQ)),DW=$P(DQ,";",2) G DE:$P(DQ,";",1)=DU
	I DU'<0 S ^(DU)=DV,DU=-2
	G E1:DQ<0 S DU=$P(DQ,";",1),DV="" I @DG S DV=^(DU)
DE	I 'DW S DW=$E(DW,2,99),DE=DW-$L(DV)-1,%=$P(DW,",",2)+1,X=$E(DV,%,999),DV=$E(DV,0,DW-1)_$J("",$S(DE>0:DE,1:0))_DG(DQ) S:X'?." " DV=DV_$J("",%-DW-$L(DG(DQ)))_X G Y
PC	S $P(DV,U,DW)=DG(DQ) G Y
	;
IX	I $D(DE(DE(DQ)))#2 F DG=1:1 Q:'$D(DE(DQ,DG))  S DIC=DIE,X=DE(DE(DQ)) X DE(DQ,DG,2)
	S X="" I DG(DQ)]"" F DG=1:1 Q:'$D(DE(DQ,DG))  S DIC=DIE,X=DG(DQ) X DE(DQ,DG,1)
K	K DE(DQ)
E1	S DQ=$N(DE(" ")) I DQ+1 G IX:$D(DG(DQ)),K
	K DG,DE,DIFLD S DQ=0 Q
	;
AST	S E=DQ(DQ),Y=$F(E," D ^DIC"),%=8
	I 'Y S Y=$F(E," D IX^DIC"),%=10 G V^DIED:'Y
	S %DD=Y+1 X $P($E(E,1,Y-%),U,5,99) G V^DIED:'$D(DIC("S"))
	S DICSS=DIC("S") D ^DIC S X=+Y
	I $P(Y,U,3) S Y=+Y X:$D(@(DIC_Y_",0)")) DICSS I '$T S D=DA,DA=Y,DIK=DIC D ^DIK K DICSS S DA=D,DV=$P(E,U,2),DU=$P(E,U,3) G X^DIED
	K DICSS X:Y>0 $E(E,%DD,999) K %DD G X^DIED:'$D(X),X^DIED:X<0,Z^DIED
1	;
	D FILE
R	D UP G @("R"_DQ_U_DNM)
	;
UP	S DNM=DNM(DL),DQ=DNM(DL,0),%=2 I $D(DIEC(DL)) D DIEC^DIE1 G U
	S DA=DA(1) K DA(1)
DA	I $D(DA(%)) S DA(%-1)=DA(%) K DA(%) S %=%+1 G DA
U	K DTOUT,DNM(DL) S DL=DL-1 Q
	;
X	W *7,"??"
B	G @(DQ_U_DNM)
	;
N	D DOWN S DA=$P(DC,U,4),D=0,^DISV(DUZ,$E(DIC,1,28))=$E(DIC,29,999)_DA
D1	S @("D"_(DL-1))=DA G @(DGO)
	;
M	S DD=X D DOWN S DO(2)=$P(DC,"^",2),DO=DOW_"^"_DO(2)_"^"_$P(DC,"^",4,5),DIC(0)=$P("QE",U,'$D(DB(DNM(DL,0))))_"LM" I @("'$D("_DIC_"0))") S ^(0)="^"_DO(2)
	E  I DO(2)["I" S %=0,DIC("W")="" D W^DIC1
	K DICR S D="B",DLAYGO=DP\1,X=DD D X^DIC I Y'>0 D UP G @(DQ_U_DNM)
	S DA=+Y,X=$P(Y,U,2),D=$P(Y,U,3) G D1
	;
DOWN	S DL=DL+1,DNM(DL)=DNM,DNM(DL,0)=DQ D FILE
DDA	F %=DL+1:-1:1 I $D(DA(%)) S DA(%+1)=DA(%)
	S DA(1)=DA,DIC=DIE_DA_","""_$P(DC,U,3)_"""," Q
	;
ABORT	D E S Y(DM)="" Q
	;
0	;
	D FILE
E	K DIP,Y,DE,DB,DP,DW,DU,DC,DV,DH,DIL,DNM,DIEZ,DLB

DIED
DIED	; SF/GFT,XAK - MAJOR INPUT PROCESSOR ;5/8/89  09:45
	;;17.7;VA FileMan; 6/9/89
O	D W W Y W:$X>48 !?9
	I $L(Y)>19,'DV,(DV["F"!(DV["K")) G RW^DIR2
	I Y]"" W "// " I 'DV,DV["I",$D(DE(DQ))#2 S X="" W "  (No Editing)" Q
TR	Q:$P(DQ(DQ),U,2)["K"&(DUZ(0)'="@")  R X:DTIME E  S (DTOUT,X)=U W *7
	Q
W	I $P(DQ(DQ),U,2)["K"&(DUZ(0)'="@") Q
	I $D(DIE("W")) X DIE("W") Q
	W !?DL+DL-2,$P(DQ(DQ),U,1)_": " Q
	;
DQ	;
	S:$D(DTIME)[0 DTIME=999 S DQ=1 G B
A	K DQ(DQ) S DQ=DQ+1
B	S DIFLD=$S($D(DIFLD(DQ)):DIFLD(DQ),1:-1)
	I '$D(DQ(DQ)) G E^DIE1:'$D(DQ(0,DQ)),BR^DIE0
RE	;
	S DIP=$P(DQ(DQ),U,1),DV=$P(DQ(DQ),U,2),DU=$P(DQ(DQ),U,3) G:DV["K"&(DUZ(0)'="@") A G PR:$D(DE(DQ)) D W,TR I $D(DTOUT) K DQ G QY^DIE1
N	I X="" G A:DV'["R",X:'DV,X:$P(DC,U,2)-DP(0),A
RD	G ^DIE0:X[U,^DIE2:X="@",^DIEQ:X?."?"
	I X=" ",DV["d",DV'["P",$D(^DISV(DUZ,"DIE",DIP)) S X=^(DIP) I DV'["D",DV'["S" W "  "_X
T	G M^DIE1:DV,^DIE3:DV["V",P:DV'["S" X:$D(^DD(DP,DIFLD,12.1)) ^(12.1) S %=$P($P(";"_DU,";"_X_":",2),";",1),Y=X I %]"" X:$D(DIC("S")) DIC("S") I  W:'$D(DB(DQ)) "  "_% G V
	F %=1:1 S Y=$P(DU,";",%),DG=$F(Y,":"_X) G X:Y="" S YS=Y,Y=$P(Y,":",1) I DG X:$D(DIC("S")) DIC("S") I  Q:DG
	W:'$D(DB(DQ)) $E(YS,DG,999) S X=$P(YS,":",1)
P	I DV["P" S DIC=U_DU,DIC(0)=$E("EN",$D(DB(DQ))+1)_"M"_$E("L",DV'["'") S:DIC(0)["L" DLAYGO=+$P(DV,"P",2) G AST:DV["*" D ^DIC S X=+Y,DIC=DIE G X:X<0
	G V:DV'["N" I $L($P(X,"."))>24 K X G Z
	I +$P(DV,",",2),X[".",$P(DQ(DQ),U,5,99)'["$" S X=$S($P(X,"00",1)="":"",$E(X,1)[0:$E(X,2,$L(X)),1:X) S:$E($P(X,".",2),$L($P(X,".",2)))[0 X=$E(X,1,$L(X)-1) I $P(X,".",2)=""&(X[".") S X=+X
V	S DIER=1 X $P(DQ(DQ),U,5,99) K DIER,YS
Z	K DIC("S"),DLAYGO I $D(X),X?.ANP,X'=U S DG($P(DQ(DQ),U,4))=X S:DV["d" ^DISV(DUZ,"DIE",DIP)=X G A
X	W *7,"??" I '$D(DB(DQ)),$D(^DD(DP,DIFLD,3)),^(3)]"" W !?5,^(3)
	G B^DIE1
	;
PR	I $D(DE(DQ,0)) S Y=DE(DQ,0) G F:Y?1"/".E I $D(DE(DQ))=10 D Y:$E(Y,1)=U,O G RD:"@"'[X,A:DV'["R"&(X="@"),X:X="@" S X=Y G N
	S DG=DV,Y=DE(DQ),X=DU I DG["O",$D(^DD(DP,DIFLD,2)) X ^(2) G S
R	I DG["P",@("$D(^"_X_"0))") S X=+$P(^(0),U,2) G S:'$D(^(Y,0)) S Y=$P(^(0),U,1),X=$P(^DD(X,.01,0),U,3),DG=$P(^(0),U,2) G R
	I DG["V",+Y,$D(@(U_$P(Y,";",2)_"0)")) S X=+$P(^(0),U,2) G S:'$D(^(+Y,0)) S Y=$P(^(0),U,1) I $D(^DD(+X,.01,0)) S DG=$P(^(0),U,2),X=$P(^(0),U,3) G R
	X:DG["D" ^DD("DD") I DG["S" S %=$P($P(";"_X,";"_Y_":",2),";",1) S:%]"" Y=%
S	D O I $D(DTOUT) K DQ G QY^DIE1
	I X="" S X=DE(DQ) G A:'DV,A:DC<2 G N^DIE1
	G RD:DQ(DQ)'["DINUM" D E^DIE0 G RD:$D(X),PR
	;
F	S DB(DQ)=1,X=$E(Y,2,999),DH=$F(DQ(DQ),"%DT=""E") I DH S DQ(DQ)=$E(DQ(DQ),1,DH-2)_$E(DQ(DQ),DH,999)
	I X?1"/".E S X=$E(X,2,999),DH=""
	X:$E(X,1)=U $E(X,2,999) G:X="" A:'DV,A:'$P(DC,U,4),N^DIE1 I $D(DE(DQ))#2,DV["I"!(DQ(DQ)["DINUM") D E^DIE0
	G X:'$D(X),RD:DH]"",RD:X="@",Z
	;
Y	X $E(Y,2,999) S Y=X I DV["D",Y?7N.NP X ^DD("DD")
Q	Q
	;
AST	G V:DV["'",AST^DIE9
RW	G RW^DIR2

DIEQ
DIEQ	; SF/XAK - HELP DURING INPUT ;4/20/89  11:36
	;;17.7;VA FileMan; 6/9/89
F	S D=$P(DQ(DQ),U,4) S:DP+1 D=DIFLD
	S DZ=X D Q G B^DIED
QQ	;
	I DV,DV["*",$D(^DD(+DV,.01,0)) S DQ(DQ)=$P(DQ(DQ),U,1,4)_U_$P(^(0),U,5,99)
Q	S XQH=-1 G M:DV I DP<0 W:$D(DQ(DQ,3)) !?5,DQ(DQ,3) X:$D(DQ(DQ,4)) DQ(DQ,4) G P
	I X="?" F DG=3,12 I $D(^DD(DP,D,DG)) S X=^(DG) F %=$L(X," "):-1:1 I $L($P(X," ",1,%))<75 W !?5,$P(X," ",1,%) W:%'=$L(X," ") !?5,$P(X," ",%+1,99) S X="?" Q
	I $D(^DD(DP,D,4)) W ! X ^(4) G I:'$D(DZ)
	I $D(X),X'["BAD",X?1"??".E S DIG=D S:$D(^DD(DP,D,22)) XQH=^(22) D:$D(^(22)) EN1^XQH S D=DIG K DIG I XQH=-1 F DG=1:1 Q:'$D(^DD(DP,D,21,DG,0))  W !?5,^(0)
P	I DV["P" K DO S DIC=U_DU,D="B",DIC(0)="M"_$E("L",DV'["'") G AST:DV["*" D DQ^DICQ D %
VP	I DV["V" S DU=DP S:DV DU=+DO(2),D=.01 D V G I
	I DV["D" S %(0)=0,%DT=$P($P($P(DQ(DQ),U,5,9),"%DT=""",2),"""",1) D HELP^%DTC
	I DV["S" X:$D(^DD(DP,D,12.1))#2 ^(12.1) W !?5,"CHOOSE FROM: " F DG=1:1 S Y=$P($P(DQ(DQ),U,3),";",DG) Q:Y=""  S D=$P(Y,":",2),Y=$P(Y,":",1) X:$D(DIC("S")) DIC("S") I  W !?7,Y,?15," ",D
I	S:$D(DIE) DIC=DIE S D=0 K XQH Q
%	K % S:$D(DIC("V")) %=DIC("V") K DIC S:$D(%) DIC("V")=% Q
	;
AST	S:$D(X)[0 X="?" X $P(DQ(DQ),U,5,99) K DIC G I
	D ^DIC K DIC,DICS,DICW G I
	;
M	K DO S DZ=X,DIC=DIE_DA_","_$S(+$P(DC,U,3):$P(DC,U,3),1:$C(34)_$P(DC,U,3)_$C(34))_",",D="B",DIC(0)="LM",DZ(1)=0
	I '$D(@(DIC_"0)")) S DO=U_$P(DC,U,2) D DO2^DIC1
	D DQ^DICQ D % G I:'$D(DZ)!(DV["S") S X=DZ G P
	;
V	W:$X ! W ?5,"Enter one of the following:",!?7
	F Y=0:0 S Y=$N(^DD(DU,D,"V",Y)) Q:Y'>0  I $D(^(Y,0)) S Y(0)=^(0) X:$D(DIC("V")) DIC("V") I  W:$D(^DIC(+Y(0),0)) $P(Y(0),U,4)_".EntryName to select a "_$P(Y(0),U,2),!?7
	W !?5,"To see the entries in any particular file, type <Prefix.?>",! S DU="" I DZ'?1"??".E K X,DZ Q
T	F DG=2:1 S X=$T(T+DG) Q:X=""  W !?5,$E(X,4,99)
	K X,DZ Q
	;;If you simply enter a name then the system will search each of
	;;the above files for the name you have entered. If a match is
	;;found the system will ask you if it is the entry that you desire.
	;;
	;;However, if you know the file the entry should be in, then you can
	;;speed processing by using the following syntax to select and entry:
	;;      <Prefix>.<entry name>
	;;                or
	;;      <Message>.<entry name>
	;;                or
	;;      <File Name>.<entry name>
	;;
	;;Also, you do NOT need to enter the entire file name or message
	;;to direct the look up. Using the first few characters will suffice.

DIET
DIET	; SF/XAK - DISPLAY INPUT TEMPLATE ;2/15/89  09:36
	;;17.7;VA FileMan; 6/9/89
	I '$D(^DIE(D0,0)) S X="" Q
	S X=^(0),DL=1,DIFILE(DL)=$P(X,U,4),W="FIRST" G Q:'$D(^DD(DIFILE(DL),0))
A	S DIPP(DL)=$S($D(^DIE(D0,"DR",DL,DIFILE(DL))):^(DIFILE(DL)),1:"ALL") F %A(DL)=1:1 S X=$P(DIPP(DL),";",%A(DL)) Q:X=""  D DJ
	F %(DL)=0:0 S %(DL)=$N(^DIE(D0,"DR",DL,DIFILE(DL),%(DL))) G UP:%(DL)'>0 S DIPP(DL)=^(%(DL)) F %A(DL)=1:1 S X=$P(DIPP(DL),";",%A(DL)) Q:X=""  D DJ
EXIT	K DIFILE,DIPP,%A,% S X="" Q
	;
DJ	S Y=+$P(X,":",1),Z=+$P(X,":",2) I Y,Z F X=Y-.00000001:0 S X=$N(^DD(DIFILE(DL),X)) Q:X=Z  G Q:X<0 S %B=X,X=$P(^(X,0),U,1),Y="" D W S X=%B
	I $L(X)<30 S Y=$S($D(^DD(DIFILE(DL),X,0)):^(0),1:""),X=$S(Y]"":$P(Y,U,1),1:X)
W	W !?DL*2-2,W," EDIT FIELD: ",X,"//" S W="THEN" Q:'$P(Y,U,2)  S DL=DL+1,DIFILE(DL)=+$P(Y,U,2),%(DL)=0 D A Q
Q	Q
	;
UP	S DL=DL-1 G EXIT:'DL Q
	;
AUDIT	;
	I $D(^DD(DP,+$P(DIIX,U,2),"AX")) X ^("AX") Q:'$T
	K % S DIEX=X D @+DIIX
	K DPS,DIEX,DIEDA,DIEF,%T,DIIX,%F,%D,%
	Q
3	;
	I $D(DG),DG]"",$D(DIANUM(DG)) S Y=X,(DIEX(1),C)=$P(^DD(DP,+$P(DIIX,U,2),0),U,2) D Y^DIQ S @(DIANUM(DG)_"+DIIX)")=Y K DIANUM(DG) G I
2	;
	S:$D(DP(1)) DPS=DP(1) S DIEDA="",DIEF="",%=1,DP(1)=DP,%F=+DP,X=DA
	F C=1:1 Q:'$D(^DD(DP(1),0,"UP"))  S %F=^("UP"),%=$N(^DD(%F,"SB",DP(1),0)),DIEDA=DA(C)_","_DIEDA,DIEF=%_","_DIEF,DP(1)=%F
	D ADD I $D(DG),DG]"" S DIANUM(DG)="^DIA("_%F_","_+Y_","
	S (DIEX(1),C)=$P(^DD(DP,+$P(DIIX,U,2),0),U,2),Y=DIEX D Y^DIQ
	S ^DIA(%F,"B",DIEDA_DA,%D)="",X=DIEX S:$D(DPS) DP(1)=DPS
	S ^DIA(%F,%D,0)=DIEDA_DA_U_%T_U_DIEF_+$P(DIIX,U,2)_U_DUZ,^(+DIIX)=Y
I	I DIEX(1)["P"!(DIEX(1)["V")!(DIEX(1)["S") S ^(DIIX+.1)=X_U_DIEX(1)
	Q
ADD	I '$D(^DIA(%F,0)) S ^DIA(%F,0)=$P(^DIC(%F,0),U,1)_" AUDIT^1.1I"
	F Y=$P(^(0),U,3):1 I '$D(^(Y)) L ^DIA(%F,Y):0 Q:$T
	S $P(^(0),U,3,4)=Y_U_($P(^(0),U,4)+1),^(Y,0)=X L
	S %D=Y,%T=$P($H,",",2),%T=%T#60/100+(%T#3600\60)/100+(%T\3600)/100,%T=DT_%T
	S ^DIA(%F,"C",%T,Y)="",^DIA(%F,"D",DUZ,Y)=""
	Q

DIEZ
DIEZ	; SF/GFT - COMPILE INPUT TEMPLATE ;4/14/89  16:10 ;
	;;17.7;VA FileMan; 6/9/89
	I $S($D(DUZ(0)):DUZ(0)'="@",1:1) W *7,"FOR PROGRAMMERS ONLY!!" K DIX Q
EN1	D:'$D(DISYS) OS^DII I '$D(^DD("OS",DISYS,"ZS")) W "YOUR MUMPS SYSTEM HAS NO WAY TO SAVE ROUTINES",*7 K DIX Q
	S T=^DD("ROU"),U="^"
	W !!,"MAXIMUM ROUTINE SIZE ON THIS COMPUTER (IN BYTES): "_T_"// " R X:$S($D(DTIME):DTIME,1:300) Q:X["^"!'$T  S:X="" X=T
	I +X=X,X>2400 S ^("ROU")=X G TEM:'$D(DIX) Q
	W *7,!,"Your answer must be a number larger than 2400 (the larger the better)" G DIEZ
TEM	K DIC S DMAX=X,DIC="^DIE(",DIC(0)="AEQ",DIC("W")="W ?40,""FILE #"",$P(^(0),U,4) W:$D(^(""ROU"")) ?60,^(""ROU"")" D ^DIC Q:'$D(^DIE(+Y,"DR"))
DNM	S %="" W !,"NAME OF ROUTINE TO BE CREATED: " I $D(^("ROUOLD")) S %=^("ROUOLD") W %_"// "
	R X:$S($D(DTIME):DTIME,1:300) S:X="" X=% Q:U[X!'$T
	I X'?1U.NU&(X'?1"%"1U.NU)!($L(X)>7)!($L(X)<3)!(X?1"DI".E) W *7,!?3,"USE A VALID MUMPS ROUTINE NAME OF FROM 3 TO 7 CHARACTERS" G DNM
	I $D(^DD("OS",DISYS,18)) X ^(18) I  W *7,!,"NOTE THAT '",X,"' IS ALREADY IN YOUR ROUTINE DIRECTORY!"
	W !,"READY TO COMPILE" S %=0 D YN^DICN Q:%-1
EN	;
	W ! K ^UTILITY($J),DRN S DMAX=DMAX-2000,DNM=X,DIEZ=+Y,DRN="",DRD=0
	S DP=$P(^DIE(DIEZ,0),U,4),DIE=^DIC(DP,0,"GL")
	I '$D(^DIE(DIEZ,"DR",1,DP)) S ^DIE(DIEZ,"DR",1,DP)=^DIE(DIEZ,"DR")
	D DT^DICRW S X=-1
	W !,"Compiling "_$P(^DIE(DIEZ,0),U)_" input template of File "_DP
	F T=0:0 S X=$N(^DIE("AF",X)) Q:X<0  K:'X ^(X,DIEZ) F %=0:0 S %=$N(^DIE("AF",X,%)) Q:%'>0  K:$D(^(%,DIEZ)) ^(DIEZ)
	K DOV,^DIE(DIEZ,"RD"),DR S DR=^("DR",1,DP),DL=1,DIEZL=0,DIEZAB=U
	D NEWROU F %=0:0 S %=$N(^DIE(DIEZ,"DR",99,%)) Q:%<0  F %Y=0:0 S %Y=$N(^DIE(DIEZ,"DR",99,%,%Y)) Q:%Y<0  S F=0,Q=^DIE(DIEZ,"DR",99,%,%Y) D QFF^DIEZ2 S X=" S DR(99,"_%_","_%Y_")="_Q D L^DIEZ2
	S X=" S:$D(DTIME)[0 DTIME=999 S D0=DA,DIEZ="_DIEZ_",U=""^""" G ^DIEZ0
	;
NEWROU	;
	K ^UTILITY($J,0) S DQ=0,T=99,L=3
	S ^UTILITY($J,0,1)=DNM_DRN_" ; "_$P("GENERATED FROM '"_$P(^DIE(DIEZ,0),U,1)_"' INPUT TEMPLATE(#"_DIEZ_"), FILE "_DP,U,DRN="")_";"_$E(DT,4,5)_"/"_$E(DT,6,7)_"/"_$E(DT,2,3),^(2)=" D DE G BEGIN",^(3)="BEGIN S DNM="""_DNM_DRN_""",DQ=1"
	Q
RECOMP	S DIX=1 D DIEZ Q:'$D(DIX)
	F DIX=0:0 S DIX=$O(^DIE(DIX)) Q:DIX'>0  I $D(^(DIX,0)),$D(^("ROU")) S %=$P(^(0),"^",1),X=$E(^("ROU"),2,99) I X]"" S Y=DIX,DMAX=^DD("ROU") D EN
	K DIX Q

