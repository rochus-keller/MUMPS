DQ	W ! D:'$D(DO) DO^DIC1 K DS,%Y I DO="0^-1" K DO W "  Pointed-to File does not exist!" Q
	S DD="",Y=$P(DO,U,4),DIY=DO,DIX=D D DIY
	S X=$S($D(^DD(+DO(2),.001,0)):$P(^(0),U,1),DIC(0)["N":"NUMBER",1:""),DIZ=X]"",DIW=^DD(+DO(2),.01,0)
	S DIW=$P(DIW,U,2,3) G:$D(^DD(+DO(2),0,"QUES")) @^("QUES") I DIZ S DS=.001 D DS
IX	S X=$N(^DD(+DO(2),0,"IX",DIX,-1)) S:X<0 %=DO(2) I X'<0 S DS=$N(^(X,0)) I $D(^DD(X,DS,0)) S %=$P(^(0),U,2,3),X=$P(^(0),U,1) D DS
	I @("$D("_DIC_"DIX))>9!$D(DF)"),DD="" S DD=DIX,DIW=% S:'Y Y=2 S:'$D(^(DD)) Y=0,DIZ=0
	S DIX=$N(^(DIX)) G IX:DIC(0)["M"&'DIX
	I DD="" S DIZ=1 S:'$N(^("AZ")) Y=0
	I $D(DZ)#2 G C:DZ["??" S:DZ["BAD" Y=0
	W " ANSWER WITH ",$P(DO,U,1) S DS=0
	F X=1:1 S DS=$N(DS(DS)) Q:DS<0  W $P(", OR",U,X>1) W:$X+$L(DS(DS))>70 !?4 W " ",DS(DS)
	K DS W $E(":",Y) G 0:'Y
20	G C:Y<21 W !," DO YOU WANT THE ENTIRE " W:DO(2)'["s"&'$D(DIC("S"))&'$D(DF) Y,"-ENTRY " W $P(DO,U,1)," LIST" S %=0 D YN^DICN S:%=1 %Y=1 I %Y'="??" S %Y=$E(%Y,2,99) S:%=2&(DIC(0)["L") DZ=""
	G 0:%#2=0!(%<0&(%Y="")),C:%Y=""
	S DIZ=$S(+%Y=%Y:1,DD]"":0,1:DIZ) I +%Y'=%Y G 20:DD="" I $P(DIW,U,1)["D" S DS=Y,X=%Y,%DT="T" D ^%DT K %DT S %Y=Y,Y=DS,DIZ=0 I %Y<0 W *7 G 20
C	W:Y>1&$D(DZ) !,"CHOOSE FROM:" S X=$P(" D S I ",U,$D(DIC("S"))!$D(DO("SCR")))
	I DIZ S DS="I $D(^(Y,0))#2 S X=$P(^(0),""^"",1)"_X_" W"_$S(DO(2)'["D":"",1:":$L(Y)<8")_" Y,?$X+11-$L(Y),"" """,DIX="S Y=$N("_DIC_"Y)) I Y'>0" G A
	S DIX="S X=$O("_DIC_""""_DD_""",X)) I X=""""",DS=$S(X]""!$D(DIC("W")):"F Y=0:0 S Y=$N("_DIC_""""_DD_""",X,Y)) Q:Y<0 "_$P(" I $D(^(Y))#2,'^(Y)",1,DD="B")_" I $D("_DIC_"Y,0)),'$D(^(-9))"_X,1:"I 1")_" W:$X>5 !?3"
A	S X="X"
D	S Y=$P(DIW,U,1) I Y["D" S DIY=27,X=" S %="_X_" D DT" G ^DICQ1
	I Y["P" S DIY=U_$P(DIW,U,2),X="$S($D("_DIY_X_",0))#2:$P(^(0),""^"",1),1:"_X_")" I @("$D("_DIY_"0))") S DIY=^(0) D DIY S DIW=$P(^(0),U,2,3) G D
	I Y["S" S DS(95)=";"_$P(DIW,U,2),X="$P($P(DS(95),"";""_"_X_"_"":"",2),"";"")"
	I Y["V" S X=" S %Y=Y,Y=X,C=$P(^DD(+DO(2),.01,0),U,2) D Y^DIQ W Y S Y=%Y" G ^DICQ1
	S X=" W "_X
M	G ^DICQ1
	;
0	K DIW,DIZ,DS Q:$D(DTOUT)  G 0^DICQ1:DIC(0)["L" Q
	;
DIY	S DIY=$P(^DD(+$P(DIY,U,2),.01,0),"$L(X)>",2),DIY=$S(DIY:DIY,1:30)+7 Q
	;
SOUNDEX	S Y=0 G IX
	;
DS	S:DO'[X DS(DS)=X

DICQ1
DICQ1	; SF/GFT - HELP FOR LOOKUPS ;5/25/89  10:27
	;;17.7;VA FileMan; 6/9/89
	S Y=$S('$D(%Y):0,%Y:%Y-.00000001,1:%Y),DS=DS_X,X="" I DIZ S DIY=$L($P(DO,U,3))+DIY+5 S:Y="" Y=0
	E  S X=$S(Y=0:"",1:Y),Y=0
	D Y I $D(DIC("W")) S DIY=" I $D("_DIC_"Y,0)) X:$D(DIC(""W"")) DIC(""W"")" S:$L(DS)+$L(DIY)<254 DS=DS_DIY S DIY=99
LST	W !?3 S DD=DIY+3 I $Y>DIZ!'$Y R "'^' TO STOP: ",%Y:$S($D(DTIME)[0:9999,1:DTIME) S:'$T DTOUT=1 W $C(13),$J("",15),$C(13),?3 Q:$D(DTOUT)  G 0:%Y?1P D Y
L	X DIX I  G 0
	S DIW=$X X DS I DIW-$X G LST:DD+DIY>79 W ?DD S DD=DD+DIY
	G L
	;
WOV	S %DIC=DIC,%WW=Y,DIC=%Z,Y=%Y,%X=0
W1	S %X=$O(^DD(%W,0,"ID",%X)) I %X]"" S %=^(%X) X "W ""  "",$E("_%Z_%Y_",0),0)",% G W1
	S DIC=%DIC,Y=%WW K %DIC,%W,%X,%YY,%Z,%WW Q
	;
Y	D:'$D(DISYS) OS^DII I $D(^DD("OS",DISYS,"XY")) S DIZ=^("XY") I DIZ?1U.E S (IOX,IOY)=0 X DIZ K IOX,IOY
	S DIZ=$Y+21 I $D(DIR0) S DIZ=21
	Q
