F	;
	W ! K X,DIC,P D W S C=",",DIC(0)="EZ",DIC="^DD("_DK_C,DIC("W")="S %=$P(^(0),U,2) W:% $S($P(^DD(+%,.01,0),U,2)[""W"":""   (word-processing)"",1:""   (multiple)"")",DIC("S")="I $P(^(0),U,2)'[""m"""_$S($D(DICS):" "_DICS,1:""),DU=""
	W "SEARCH FOR "_R_" "_$P(^DD(DK,0),U,1)_": "
	R X:DTIME S:'$T DTOUT=1 G Q:X=U!'$T,TEM^DIS2:X?1"[".E D ^DIC I Y>0 K P S DE=Y(0),O(DC)=$P(DE,U,1),DU=+Y,Z=$P(DE,U,3),E=$P(DE,U,2) G G
HARD	G UP:X="",F:X?."?",Q:X=U!($D(DTOUT)),COMP^DIS2
	;
G	;
	K X,DIC S DIC="^DOPT(""DIS"",",DIC(0)="QEZ" I E["B" S X="" G OK
	I E S N(DL)=N,N=N+1,DV(DL)=DV,DL(DL)=DK,DK=+E,J(N)=DK,X=$P($P(DE,U,4),";",1),I(N)=$S(+X=X:X,1:Q_X_Q),Y(0)=^DD(DK,.01,0),DL=DL+1 G WP:$P(Y(0),U,2)["W" S DV=DV_+Y_C G F
	I E["P" S P=+Y_U_Y(0),X=$P(Y(0),U,1)_":.01" G HARD
C	D W R "CONDITION: ",X:DTIME S:'$T DTOUT=1 G Q:X[U!'$T S DN=$S("'-"[$E(X,1):"'",1:""),X=$E(X,DN]""+1,99) D ^DIC G:Y<0 Q:X[U,B:X="",DISC^DIQQQ:X["?",C S O=$P("NOT ",U,DN]"")_$P(Y,U,2) I +Y=1 S X=DN_"?."" """,O(DC)=O(DC)_" "_O G OK
	S DQ=Y D W W O I E["D",Y-3 R " DATE: ",X:DTIME S:'$T DTOUT=1 G Q:X=U!'$T S %DT="TE" D ^%DT G GOT:Y>1,X
PT	I $D(P),+DQ=5 K DIC,DIS($C(DC+64)_DL) S DIC=U_$P(P,U,4),DIC(0)="EMQ",DU=+P W " "_$P(@(DIC_"0)"),U,1)_": " R X:DTIME S:'$T DTOUT=1 G Q:U[X!'$T D ^DIC G GOT:Y>0,PT
	R ": ",Y:DTIME S:'$T DTOUT=1 G Q:'$T,X:Y[U!'$L(Y) I +DQ=3 S X="I X?"_Y D ^DIM G GOT:$D(X) S Y="?"
	G DIS^DIQQQ:Y?."?",T:E'["S" I +DQ=5 S Y=":"_Y F X=1:1 S D=$P(Z,";",X) G X:D="" I D[Y W $P(D,Y,2) S Y=$P(D,":",1) G T
